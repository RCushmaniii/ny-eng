{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "titan-core",
  "type": "module",
  "version": "2.1.0",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "prebuild": "node scripts/prebuild.js",
    "build": "npm run prebuild && cross-env NODE_OPTIONS=--max-old-space-size=7168 astro build && node scripts/pre-deploy/audits/sitemap-validator.js",
    "build:hostinger": "npm run prebuild && powershell -ExecutionPolicy Bypass -File ./scripts/build-for-hostinger.ps1",
    "build:check": "npm run prebuild && astro check && astro build",
    "preview": "astro preview",
    "astro": "astro",
    "lint": "eslint \"src/**/*.{ts,astro}\" --max-warnings 0 --quiet",
    "lint:fix": "eslint \"src/**/*.{ts,astro}\" --fix",
    "validate:hreflang": "node scripts/seo/hreflang-validator.mjs",
    "validate:404": "node scripts/validate-404s.mjs",
    "validate:redirects": "node scripts/validate-hreflang-redirects.mjs",
    "validate:canonical": "node scripts/validate-canonical-urls.mjs",
    "validate:links": "node scripts/validate-internal-links.mjs",
    "validate:performance": "node scripts/validate-performance.mjs",
    "validate:urls": "node scripts/validate-url-structure.mjs",
    "validate:seo": "node scripts/pre-deploy/audits/seo-validator.js",
    "validate:all": "npm run validate:hreflang && npm run validate:404 && npm run validate:redirects && npm run validate:canonical && npm run validate:links && npm run validate:performance && npm run validate:urls",
    "generate:pdfs": "python scripts/generate-all-pdfs.py",
    "pdf:metadata": "node scripts/apply-pdf-metadata.mjs",
    "pdf:metadata:dry-run": "node scripts/apply-pdf-metadata.mjs --dry-run --verbose",
    "pre-deploy": "npm run generate:pdfs && npm run build && node scripts/pre-deploy/audit-manager.js",
    "build:validate": "npm run validate:hreflang && npm run build",
    "audit:seo": "npm run build:validate && npm run preview",
    "validate:build": "npm run validate:all && npm run build",
    "fix:links": "node scripts/fix-links.mjs",
    "fix:links:dry-run": "node scripts/fix-links.mjs --dry-run",
    "test:env": "node scripts/test-env.mjs",
    "test:env:raw": "node scripts/test-env.mjs --raw",
    "test:calendar": "node scripts/test-calendar-api.mjs",
    "google:auth": "node scripts/get-google-refresh-token.mjs"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.74.0",
    "@astrojs/check": "^0.9.8",
    "@astrojs/mdx": "^4.3.13",
    "@astrojs/netlify": "^6.6.3",
    "@astrojs/react": "^5.0.3",
    "@astrojs/sitemap": "^3.3.0",
    "@astrolib/seo": "^1.0.0-beta.8",
    "@iconify-json/lucide": "^1.2.51",
    "@iconify-json/tabler": "^1.2.33",
    "@neondatabase/serverless": "^1.0.2",
    "@sentry/astro": "^10.48.0",
    "@types/marked": "^5.0.2",
    "@vercel/analytics": "^2.0.1",
    "@vercel/blob": "^2.3.3",
    "aos": "^2.3.4",
    "astro": "^5.5.3",
    "astro-icon": "^1.1.5",
    "clsx": "^2.1.1",
    "dotenv": "^17.2.3",
    "googleapis": "^161.0.0",
    "gray-matter": "^4.0.3",
    "lucide-astro": "^0.473.0",
    "lucide-react": "^1.7.0",
    "marked": "^18.0.1",
    "node-html-parser": "^7.1.0",
    "pdf-lib": "^1.17.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "readline": "^1.3.0",
    "unpic": "^4.2.2"
  },
  "devDependencies": {
    "@astrojs/tailwind": "^6.0.2",
    "@eslint/js": "^9.39.2",
    "@fullhuman/postcss-purgecss": "^8.0.0",
    "@tailwindcss/aspect-ratio": "^0.4.2",
    "@tailwindcss/forms": "^0.5.10",
    "@tailwindcss/typography": "^0.5.19",
    "@types/aos": "^3.0.7",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vercel/node": "^5.5.16",
    "autoprefixer": "^10.4.21",
    "cross-env": "^10.1.0",
    "eslint": "^8.57.1",
    "eslint-plugin-astro": "^1.7.0",
    "glob": "^11.0.3",
    "postcss": "^8.5.4",
    "postcss-discard-duplicates": "^7.0.2",
    "postcss-merge-longhand": "^7.0.5",
    "prettier": "^3.8.3",
    "prettier-plugin-astro": "^0.14.1",
    "resend": "^6.7.0",
    "sharp": "^0.34.3",
    "tailwind-merge": "^3.3.1",
    "tailwindcss": "^3.4.17",
    "ts-node": "^10.9.2",
    "tsx": "^4.20.3",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.50.0",
    "vite": "^5.4.10"
  }
}
