{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://nyenglishteacher.com/schemas/free-asset.json",
  "title": "Free Asset Schema",
  "description": "Schema for free educational resources on NY English Teacher",
  "type": "object",
  "required": ["metadata", "classification", "targeting", "conversion", "seo", "slugEn", "slugEs", "en", "es"],
  "properties": {
    "metadata": {
      "type": "object",
      "description": "Publishing and versioning information",
      "required": ["id", "version", "datePublished", "author", "language"],
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the asset",
          "pattern": "^[a-z0-9-]+$"
        },
        "version": {
          "type": "string",
          "description": "Semantic version (e.g., 1.0, 1.1, 2.0)",
          "pattern": "^\\d+\\.\\d+$"
        },
        "datePublished": {
          "type": "string",
          "description": "ISO 8601 date (YYYY-MM-DD)",
          "format": "date"
        },
        "dateUpdated": {
          "type": "string",
          "description": "ISO 8601 date of last update",
          "format": "date"
        },
        "author": {
          "type": "string",
          "description": "Content author name"
        },
        "language": {
          "type": "array",
          "description": "Available languages",
          "items": {
            "type": "string",
            "enum": ["en", "es"]
          },
          "minItems": 1
        }
      }
    },
    "classification": {
      "type": "object",
      "description": "Content type and format classification",
      "required": ["contentType", "format", "funnelStage", "difficultyLevel", "timeToComplete"],
      "properties": {
        "contentType": {
          "type": "string",
          "description": "Primary content structure type",
          "enum": ["questions", "sentences", "checklist", "script", "framework", "case-study", "template", "guide", "video", "audio"]
        },
        "format": {
          "type": "string",
          "description": "Delivery format",
          "enum": ["pdf-guide", "pdf-checklist", "pdf-script", "interactive-web", "video", "audio", "email-series"]
        },
        "funnelStage": {
          "type": "string",
          "description": "Marketing funnel position",
          "enum": ["awareness", "consideration", "decision", "retention"]
        },
        "difficultyLevel": {
          "type": "string",
          "description": "Content complexity level",
          "enum": ["beginner", "intermediate", "advanced", "all-levels"]
        },
        "timeToComplete": {
          "type": "string",
          "description": "Estimated time to consume (e.g., '5 minutes', '15 minutes')"
        },
        "estimatedMinutes": {
          "type": "integer",
          "description": "Estimated time in minutes (for sorting/filtering)",
          "minimum": 1
        },
        "pageCount": {
          "type": "integer",
          "description": "Number of pages (for PDF assets)",
          "minimum": 1
        },
        "tags": {
          "type": "array",
          "description": "Flexible content tags for additional categorization",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "targeting": {
      "type": "object",
      "description": "Audience and use case targeting",
      "required": ["primaryPersona", "industries", "scenarios"],
      "properties": {
        "primaryPersona": {
          "type": "array",
          "description": "Target user personas",
          "items": {
            "type": "string",
            "enum": [
              "executive",
              "manager",
              "founder",
              "entrepreneur",
              "consultant",
              "project-manager",
              "engineer",
              "sales",
              "hr-professional",
              "doctor",
              "lawyer",
              "accountant",
              "logistics",
              "real-estate",
              "job-seeker",
              "all"
            ]
          },
          "minItems": 1
        },
        "industries": {
          "type": "array",
          "description": "Target industries",
          "items": {
            "type": "string",
            "enum": [
              "technology",
              "healthcare",
              "legal",
              "finance",
              "logistics",
              "real-estate",
              "professional-services",
              "manufacturing",
              "retail",
              "all"
            ]
          },
          "minItems": 1
        },
        "scenarios": {
          "type": "array",
          "description": "Use case scenarios",
          "items": {
            "type": "string",
            "enum": [
              "interviews",
              "negotiations",
              "presentations",
              "client-meetings",
              "leadership",
              "email-writing",
              "networking",
              "difficult-conversations",
              "decision-making",
              "meetings",
              "technical-explanation",
              "crisis-management",
              "performance-feedback",
              "sales-calls",
              "status-updates",
              "all"
            ]
          },
          "minItems": 1
        },
        "painPoints": {
          "type": "array",
          "description": "Specific pain points this asset addresses",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "conversion": {
      "type": "object",
      "description": "Conversion and funnel strategy",
      "required": ["ctaType", "nextStep"],
      "properties": {
        "ctaType": {
          "type": "string",
          "description": "Primary call-to-action type",
          "enum": ["strategy-call", "email-signup", "quiz", "contact", "service-page", "related-asset"]
        },
        "nextStep": {
          "type": "string",
          "description": "Suggested next action for the user"
        },
        "relatedAssets": {
          "type": "array",
          "description": "Related asset IDs for cross-promotion",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "seo": {
      "type": "object",
      "description": "SEO and social sharing optimization",
      "required": ["metaDescription", "keywords"],
      "properties": {
        "metaDescription": {
          "type": "string",
          "description": "Meta description (110-160 characters)",
          "minLength": 110,
          "maxLength": 160
        },
        "keywords": {
          "type": "array",
          "description": "Target SEO keywords",
          "items": {
            "type": "string"
          },
          "minItems": 3
        },
        "ogImage": {
          "type": "string",
          "description": "Custom Open Graph image path (optional)"
        }
      }
    },
    "analytics": {
      "type": "object",
      "description": "Usage analytics (optional, can be updated dynamically)",
      "properties": {
        "downloadCount": {
          "type": "integer",
          "description": "Number of PDF downloads",
          "minimum": 0,
          "default": 0
        },
        "viewCount": {
          "type": "integer",
          "description": "Number of page views",
          "minimum": 0,
          "default": 0
        },
        "lastAccessed": {
          "type": ["string", "null"],
          "description": "ISO 8601 timestamp of last access",
          "format": "date-time"
        }
      }
    },
    "slugEn": {
      "type": "string",
      "description": "English URL slug",
      "pattern": "^[a-z0-9-]+$"
    },
    "slugEs": {
      "type": "string",
      "description": "Spanish URL slug",
      "pattern": "^[a-z0-9-]+$"
    },
    "en": {
      "type": "object",
      "description": "English content (structure varies by contentType)"
    },
    "es": {
      "type": "object",
      "description": "Spanish content (structure varies by contentType)"
    }
  }
}
