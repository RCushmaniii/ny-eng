{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://nyenglishteacher.com/schemas/free-asset.json",
  "title": "Free Asset Schema",
  "description": "Strict schema for free educational resources on NY English Teacher",
  "type": "object",
  "required": [
    "metadata",
    "classification",
    "targeting",
    "conversion",
    "seo",
    "slugEn",
    "slugEs",
    "en",
    "es"
  ],
  "definitions": {
    "standardItem": {
      "type": "object",
      "description": "The universal content block. ALL content types (questions, mistakes, steps) must map to these keys.",
      "additionalProperties": false,
      "properties": {
        "number": {
          "type": "integer",
          "description": "Ordering number (e.g., 1, 2, 3)"
        },
        "title": {
          "type": "string",
          "description": "The main header. Maps to: Question text, Mistake name, Step title, or Script line speaker."
        },
        "content": {
          "type": "string",
          "description": "The main body text. Maps to: Answer, Problem description, Script dialogue."
        },
        "phrase": {
          "type": "string",
          "description": "Specific English phrase being taught (if applicable)."
        },
        "situation": {
          "type": "string",
          "description": "Context for when this occurs."
        },
        "when": {
          "type": "string",
          "description": "Timing instruction."
        },
        "why": {
          "type": "string",
          "description": "Educational reasoning."
        },
        "actionItem": {
          "type": "string",
          "description": "The immediate takeaway. Maps to: The Fix, The Solution, The Task."
        },
        "doNotSay": {
          "type": "string",
          "description": "Negative example or warning."
        },
        "howToSay": {
          "type": "string",
          "description": "Positive example or correction."
        },
        "variations": {
          "description": "Alternative ways to say it",
          "oneOf": [
            { "type": "string" },
            { "type": "array", "items": { "type": "string" } }
          ]
        },
        "example": {
          "description": "Concrete examples of the concept",
          "oneOf": [
            { "type": "string" },
            {
              "type": "object",
              "required": ["wrong", "right"],
              "properties": {
                "wrong": { "type": "string" },
                "right": { "type": "string" },
                "why": { "type": "string" }
              }
            }
          ]
        }
      }
    },
    "localizedContent": {
      "type": "object",
      "required": ["title", "subtitle", "sections"],
      "additionalProperties": true,
      "properties": {
        "title": { "type": "string" },
        "subtitle": { "type": "string" },
        "description": { "type": "string" },
        "headline": { "type": "string" },
        "valueProposition": { "type": "string" },
        "intro": {
          "description": "Introduction text structure",
          "oneOf": [
            { "type": "string" },
            {
              "type": "object",
              "properties": {
                "line1": { "type": "string" },
                "line2": { "type": "string" },
                "paragraph": { "type": "string" }
              }
            }
          ]
        },
        "sections": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "items"],
            "properties": {
              "id": { "type": "string" },
              "title": { "type": "string" },
              "content": {
                "description": "Section introduction text",
                "oneOf": [
                  { "type": "string" },
                  { "type": "array", "items": { "type": "string" } }
                ]
              },
              "items": {
                "type": "array",
                "items": { "$ref": "#/definitions/standardItem" }
              }
            }
          }
        },
        "leadCapture": {
          "type": "object",
          "properties": {
            "formHeadline": { "type": "string" },
            "formSubheadline": { "type": "string" },
            "buttonText": { "type": "string" },
            "successMessage": { "type": "string" }
          }
        }
      }
    }
  },
  "properties": {
    "metadata": {
      "type": "object",
      "required": ["id", "version", "datePublished", "author", "language"],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
        "version": { "type": "string", "pattern": "^\\d+\\.\\d+$" },
        "datePublished": { "type": "string", "format": "date" },
        "dateUpdated": { "type": "string", "format": "date" },
        "author": { "type": "string" },
        "language": {
          "type": "array",
          "items": { "type": "string", "enum": ["en", "es"] },
          "minItems": 1
        }
      }
    },
    "classification": {
      "type": "object",
      "required": [
        "contentType",
        "format",
        "funnelStage",
        "difficultyLevel",
        "timeToComplete"
      ],
      "properties": {
        "contentType": {
          "type": "string",
          "enum": [
            "questions",
            "sentences",
            "checklist",
            "script",
            "framework",
            "case-study",
            "template",
            "guide",
            "video",
            "audio"
          ]
        },
        "format": {
          "type": "string",
          "enum": [
            "pdf-guide",
            "pdf-checklist",
            "pdf-script",
            "interactive-web",
            "video",
            "audio",
            "email-series"
          ]
        },
        "funnelStage": {
          "type": "string",
          "enum": ["awareness", "consideration", "decision", "retention"]
        },
        "difficultyLevel": {
          "type": "string",
          "enum": ["beginner", "intermediate", "advanced", "all-levels"]
        },
        "timeToComplete": { "type": "string" },
        "estimatedMinutes": { "type": "integer", "minimum": 1 },
        "pageCount": { "type": "integer", "minimum": 1 },
        "tags": { "type": "array", "items": { "type": "string" } }
      }
    },
    "targeting": {
      "type": "object",
      "required": ["primaryPersona", "industries", "scenarios"],
      "properties": {
        "primaryPersona": { "type": "array", "items": { "type": "string" } },
        "industries": { "type": "array", "items": { "type": "string" } },
        "scenarios": { "type": "array", "items": { "type": "string" } },
        "painPoints": { "type": "array", "items": { "type": "string" } }
      }
    },
    "conversion": {
      "type": "object",
      "required": ["ctaType", "nextStep"],
      "properties": {
        "ctaType": {
          "type": "string",
          "enum": [
            "strategy-call",
            "email-signup",
            "quiz",
            "contact",
            "service-page",
            "related-asset"
          ]
        },
        "nextStep": { "type": "string" },
        "relatedAssets": { "type": "array", "items": { "type": "string" } }
      }
    },
    "seo": {
      "type": "object",
      "required": ["metaDescription", "keywords"],
      "properties": {
        "metaDescription": {
          "type": "string",
          "minLength": 10,
          "maxLength": 160
        },
        "keywords": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 3
        },
        "ogImage": { "type": "string" }
      }
    },
    "analytics": {
      "type": "object",
      "properties": {
        "downloadCount": { "type": "integer" },
        "viewCount": { "type": "integer" },
        "lastAccessed": { "type": "string" }
      }
    },
    "slugEn": { "type": "string", "pattern": "^[a-z0-9-]+$" },
    "slugEs": { "type": "string", "pattern": "^[a-z0-9-]+$" },
    "en": { "$ref": "#/definitions/localizedContent" },
    "es": { "$ref": "#/definitions/localizedContent" }
  }
}
