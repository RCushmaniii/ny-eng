@layer components {
    /* Button Styles */
    .btn {
        @apply relative inline-flex overflow-hidden items-center justify-center font-medium transition-all duration-300 ease-out;
        @apply focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-offset-2;
        @apply disabled:pointer-events-none disabled:opacity-50 rounded-md flex items-center gap-2;
    }
    
    .btn-primary {
        background-color: var(--color-primary, #3557c1);
        color: white;
    }
    .btn-primary:hover {
        background-color: var(--color-primary-light, #4b6ed4);
    }
    .btn-primary:focus-visible {
        --tw-ring-color: var(--color-primary, #3557c1);
    }
    
    .btn-secondary {
        background-color: var(--color-secondary, #cc9900);
        color: white;
    }
    .btn-secondary:hover {
        background-color: var(--color-secondary-light, #e6b800);
    }
    .btn-secondary:focus-visible {
        --tw-ring-color: var(--color-secondary, #cc9900);
    }
    
    .btn-accent {
        background-color: var(--color-accent, #1e3c8c);
        color: white;
    }
    .btn-accent:hover {
        opacity: 0.9;
    }
    .btn-accent:focus-visible {
        --tw-ring-color: var(--color-accent, #1e3c8c);
    }
    
    .btn-ghostLight {
        color: white;
        --tw-ring-color: white;
    }
    .btn-ghostLight:hover {
        --tw-ring-color: black;
    }
    
    .btn-ghostDark {
        color: var(--color-body-base, #1a1f3c);
        --tw-ring-color: var(--color-body-base, #1a1f3c);
    }
    .btn-ghostDark:hover {
        --tw-ring-color: black;
    }
    
    .btn-whatsapp {
        background-color: #25D366;
        color: white;
    }
    .btn-whatsapp:hover {
        background-color: #1EBE5B;
    }
    .btn-whatsapp:focus-visible {
        --tw-ring-color: #25D366;
    }
    
    /* Button Sizes */
    .btn-sm {
        height: 2.25rem;
        padding-left: 0.75rem;
        padding-right: 0.75rem;
        font-size: 0.75rem;
        line-height: 1rem;
    }
    
    .btn-md {
        height: 2.5rem;
        padding: 0.5rem 1rem;
        font-size: 0.875rem;
        line-height: 1.25rem;
    }
    
    .btn-lg {
        height: 2.75rem;
        padding-left: 2rem;
        padding-right: 2rem;
        font-size: 1rem;
        line-height: 1.5rem;
    }

    html {
        font-size: 16px;
        color: var(--color-text-base);
    }

    body {
        background-color: var(--color-background);
        font-size: var(--text-base);
        font-weight: 400;
    }

    h1 {
        font-size: var(--text-h1);
        font-family: var(--font-headline);
        font-weight: 400;
    }

    h2 {
        font-size: var(--text-h2);
        font-family: var(--font-headline);
        font-weight: 400;
    }

    h3 {
        font-size: var(--text-h3);
        font-family: var(--font-headline);
        font-weight: 400;
    }

    h4 {
        font-size: var(--text-h4);
    }

    h5 {
        font-size: var(--text-h5);
    }

    h6 {
        font-size: var(--text-h6);
        font-weight: 400;
    }

    a {
        color: var(--color-primary);
    }

    p {
        color: var(--color-text-base);
    }

    article h1 {
        font-size: var(--text-article-h1);
        margin: 0 0 2rem
    }

    article h2 {
        font-size: var(--text-article-h2);
        margin: 0 0 2rem
    }

    article h3 {
        font-size: var(--text-article-h3);
        margin: 0 0 1.75rem
    }

    article h4 {
        font-size: var(--text-article-h4);
        margin: 0 0 1.5rem
    }

    article h5 {
        font-size: var(--text-article-h5);
        margin: 0 0 1.25rem
    }

    article h6 {
        font-size: var(--text-article-h6);
        margin: 0 0 1rem
    }

    article p {
        font-size: var(--text-base);
        margin: 0 0 1.75rem;
        line-height: 1.8;
    }

    article ol {
        font-size: var(--text-base);
        margin: 0 0 2rem;
        padding-left: 2rem;
        list-style-type: decimal;
    }

    article ol ::marker {
        color: var(--color-primary);
    }

    article ul {
        font-size: var(--text-base);
        margin: 0 0 2rem;
        padding-left: 2rem;
        list-style-type: disc;
    }

    article ul ::marker {
        color: var(--color-primary);
    }

    article blockquote {
        font-size: var(--text-base);
        margin: 0 0 1.75rem;
        padding-left: 2rem;
        border-left: 4px solid var(--color-primary);
    }

}

@layer utilities {
    .text-header-logo {
        color: var(--color-header-logo);
    }

    .text-footer-logo {
        color: var(--color-footer-logo);
    }

    .pt-small {
        padding-top: var(--spacing-small);
    }

    .pt-base {
        padding-top: var(--spacing-base);
    }

    .pt-large {
        padding-top: var(--spacing-large);
    }

    .pb-small {
        padding-bottom: var(--spacing-small);
    }

    .pb-base {
        padding-bottom: var(--spacing-base);
    }

    .pb-large {
        padding-bottom: var(--spacing-large);
    }

    .py-small {
        padding-top: var(--spacing-small);
        padding-bottom: var(--spacing-small);
    }

    .py-base {
        padding-top: var(--spacing-base);
        padding-bottom: var(--spacing-base);
    }

    .py-large {
        padding-top: var(--spacing-large);
        padding-bottom: var(--spacing-large);
    }

    .cursor-pointer {
        cursor: pointer;
    }

    .fade-in-up {
        opacity: 0;
        transform: translateY(60px);
        transition: opacity 0.6s ease-out, transform 0.6s ease-out;
    }
    .fade-in-up.animate {
        opacity: 1;
        transform: translateY(0);
    }
    .fade-in-up.delay-1 { transition-delay: 0.3s; }
    .fade-in-up.delay-2 { transition-delay: 0.6s; }
    .fade-in-up.delay-3 { transition-delay: 0.9s; }
}

html,
body {
    margin: 0;
    width: 100%;
    height: 100%;
}

[x-cloak] {
    display: none !important;
}

.site-container {
    margin-left: auto;
    margin-right: auto;
    max-width: var(--container-base);
    width: 100%;
}

.site-container--small {
    margin-left: auto;
    margin-right: auto;
    max-width: var(--container-small);
    width: 100%;
}

.header-offset {
    padding-top: 6rem; /* pt-24 = 6rem */
}

.hero-background {
    --s: 34px;
    /* control the size*/
    --c1: var(--color-primary);
    --c2: var(--color-primary-dark);

    --_g:
        var(--c1) 0% 5%, var(--c2) 6% 15%, var(--c1) 16% 25%, var(--c2) 26% 35%, var(--c1) 36% 45%,
        var(--c2) 46% 55%, var(--c1) 56% 65%, var(--c2) 66% 75%, var(--c1) 76% 85%, var(--c2) 86% 95%,
        #0000 96%;
    background:
        radial-gradient(50% 50% at 100% 0, var(--_g)),
        radial-gradient(50% 50% at 0 100%, var(--_g)),
        radial-gradient(50% 50%, var(--_g)),
        radial-gradient(50% 50%, var(--_g)) calc(var(--s)/2) calc(var(--s)/2) var(--c1);
    background-size: var(--s) var(--s);
}

/* Style the pre element containing the code */
pre {
    padding: 1rem;
    margin: 1rem 0;
    border-radius: 0.5rem;
    overflow-x: auto;
}

/* Style code blocks with a specific language */
pre[class*="language-"] {
    position: relative;
}

/* Style line numbers if enabled */
.line-number {
    color: #888;
    margin-right: 1rem;
}

:where(p, li, strong, em, b, i, u, s, a, blockquote, h1, h2, h3, h4, h5, h6)>code:not([class*="language-"]) {
    font-size: var(--text-small);
    background-color: var(--color-background-light);
    color: var(--color-primary);
    padding: 0.2rem 0.5rem;
    border-radius: 2px;
    font-weight: 400;
}

/* Ensure body background uses --color-background-light for zeus theme */
[data-theme="zeus"] body {
    background-color: var(--color-background-light) !important;
}