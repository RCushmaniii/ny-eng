---
export const prerender = true;

import Base from "@layouts/Base.astro";
import InnerHero from "@components/sections/InnerHero.astro";
import BookingFormSteps from "@components/booking/BookingFormSteps.astro";
import bookingHero from "@assets/images/contact/book-hero.jpg";

const metadata = {
  title: "Executive Strategy Session | NY English",
  description:
    "Schedule your 15-minute strategy session. No sales scripts—just a direct conversation about where your English is helping you and where it's holding you back.",
};

const heroContent = {
  title: "Book Your Strategy Session",
  description:
    "No sales scripts. Just a 15-minute analysis of where your English is helping you — and where it's holding you back.",
  backgroundImage: bookingHero,
  overlayOpacity: 0.6,
};
---

<Base
  lang="en"
  tkey="book"
  title={metadata.title}
  description={metadata.description}
  ogImage={{ src: "/images/logos/new-york-english-sq-og.jpg" }}
>
  <main>
    <InnerHero content={heroContent} />

    <section class="py-16 md:py-24 bg-background-light">
      <div class="site-container px-4">
        <!-- Booking Form with Steps -->
        <BookingFormSteps lang="en" />
      </div>
    </section>
  </main>
</Base>
