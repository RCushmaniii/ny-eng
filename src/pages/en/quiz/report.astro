function generateQuestionHTML(questionIds) {
  let html = '';
  
  questionIds.forEach(qId => {
    const question = questionsEn.find(q => q.id === qId);
    const userAnswer = answers[qId];
    const selectedOption = question.options.find(opt => opt.value === userAnswer);
    const isLow = userAnswer < 7;
    
    html += `
      <div class="question-item">
        <div class="question-header">
          <div class="question-number">${qId}</div>
          <div class="question-text">${question.question}</div>
          <div class="question-score">${userAnswer}/10</div>
        </div>
        <div class="your-answer">
          <strong>Your Answer:</strong> ${selectedOption.text}
        </div>
        <div class="insight">
          <strong>Insight:</strong> ${insights[qId][isLow ? 'low' : 'high']}
        </div>
      </div>
    `;
  });
  
  return html;
}

