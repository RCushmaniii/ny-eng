  /**
   * Generate HTML for question analysis cards
   * @param questionIds - Array of question IDs to display
   * @returns HTML string for all question cards
   */
  function generateQuestionHTML(questionIds: number[]): string {
    let html = "";

    /**
     * Get color based on question score
     * @param score - Score out of 10
     * @returns Hex color code
     */
    function getScoreColor(score: number): string {
      if (score >= 8) return "#10b981"; // Green - Excellent
      if (score >= 6) return "#f59e0b"; // Orange - Good
      if (score >= 4) return "#ef4444"; // Red - Needs Work
      return "#dc2626"; // Dark Red - Critical
    }

    questionIds.forEach((qId: number) => {
      try {
        // Find question data
        const question = questionsEn.find((q: any) => q.id === qId);
        if (!question) {
          console.warn(`Question ${qId} not found`);
          return;
        }

        // Get user's answer
        const userAnswer = answers[qId.toString()];
        if (userAnswer === undefined) {
          console.warn(`No answer found for question ${qId}`);
          return;
        }

        // Find selected option text
        const selectedOption = question.options.find(
          (opt: any) => opt.value === userAnswer
        );
        if (!selectedOption) {
          console.warn(
            `No option found for answer value ${userAnswer} in question ${qId}`
          );
          return;
        }

        // Calculate display values
        const isLow = userAnswer < 7;
        const color = getScoreColor(userAnswer);
        const percentage = (userAnswer / 10) * 100;
        const insightText = insights[qId]
          ? insights[qId][isLow ? "low" : "high"]
          : "No insight available";

        // Build question card HTML with two-column layout
        const scorePercentage = Math.round((userAnswer / 10) * 100);

        html += `
        <div style="background: #ffffff; padding: 1.25rem; margin-bottom: 1.25rem; border-radius: 12px; border: 2px solid #e2e8f0; box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04);">
          
          <!-- Question Number and Text -->
          <div style="margin-bottom: 1rem;">
            <span style="font-size: 1.25rem; font-weight: 700; color: #0f172a; margin-right: 0.5rem;">${qId}.</span>
            <span style="font-size: 1rem; font-weight: 600; color: #0f172a; line-height: 1.5;">${question.question}</span>
          </div>
          
          <!-- Two Column Layout -->
          <div style="display: grid; grid-template-columns: 30% 70%; gap: 1.5rem;" class="question-grid">
            
            <!-- Left Column: Score Circle (30%) -->
            <div style="background: #f8fafc; border-radius: 8px; padding: 1.5rem; display: flex; align-items: center; justify-content: center; min-height: 140px;">
              <div style="position: relative; width: 100px; height: 100px; border-radius: 50%; background: conic-gradient(${color} ${percentage}%, #e2e8f0 0); display: flex; align-items: center; justify-content: center;">
                <div style="position: absolute; width: 80px; height: 80px; border-radius: 50%; background: #ffffff; z-index: 1;"></div>
                <div style="position: relative; z-index: 2; text-align: center;">
                  <span style="font-size: 1.4rem; font-weight: 700; line-height: 1; color: ${color}; display: block;">${scorePercentage}%</span>
                </div>
              </div>
            </div>
            
            <!-- Right Column: Answer and Insight (70%) -->
            <div style="display: flex; flex-direction: column; gap: 1rem;">
              
              <!-- Your Answer -->
              <div>
                <div style="font-weight: 700; color: #0f172a; margin-bottom: 0.5rem; font-size: 0.875rem;">Your Answer:</div>
                <div style="color: #475569; line-height: 1.6;">${selectedOption.text}</div>
              </div>
              
              <!-- Insight -->
              <div>
                <div style="font-weight: 700; color: #92400e; margin-bottom: 0.5rem; font-size: 0.875rem; display: flex; align-items: center; gap: 0.5rem;">
                  <span style="font-size: 1.25rem;">💡</span>
                  <span>Insight:</span>
                </div>
                <div style="color: #78350f; line-height: 1.6; background: #fffbeb; padding: 0.75rem; border-radius: 6px; border-left: 3px solid #fbbf24;">${insightText}</div>
              </div>
              
            </div>
          </div>
        </div>
      `;
      } catch (error) {
        console.error(`Error generating HTML for question ${qId}:`, error);
      }
    });

    return html;
  }

  /**
   * Toggle insight visibility for a question
   * @param questionId - ID of the question
   */
  function toggleInsight(questionId: number): void {
    const insightElement = document.getElementById(`insight-${questionId}`);
    if (insightElement) {
      const isHidden =
        insightElement.style.maxHeight === "0px" ||
        insightElement.style.maxHeight === "";
      if (isHidden) {
        insightElement.style.maxHeight = "500px";
        insightElement.style.opacity = "1";
      } else {
        insightElement.style.maxHeight = "0";
        insightElement.style.opacity = "0";
      }
    }
  }

  if (questionsAnalysis) {
    questionsAnalysis.innerHTML = generateQuestionHTML([
