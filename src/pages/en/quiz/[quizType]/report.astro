---
/**
 * Dynamic Quiz Report Page
 *
 * Route: /en/quiz/[quizType]/report/
 * Displays detailed quiz results with gap analysis
 * Uses the polished QuizReport.tsx React component
 */

import Base from "@layouts/Base.astro";
import QuizReport from "@components/QuizReport.tsx";
import {
  getQuizConfig,
  isQuizTypeAvailable,
  getAvailableQuizTypes,
} from "@/data/quiz/configs";
import type { QuizType } from "@/data/quiz/types";

export const prerender = true;

export function getStaticPaths() {
  return getAvailableQuizTypes().map((qt) => ({ params: { quizType: qt } }));
}

// Get quiz type from URL params
const { quizType } = Astro.params;

// Validate quiz type
if (!quizType || !isQuizTypeAvailable(quizType)) {
  return Astro.redirect("/en/404");
}

// Get quiz configuration
const config = getQuizConfig(quizType as QuizType, "en");

const title = `Report | ${config.title}`;
const description =
  "Your personalized Communication Confidence report with detailed gap analysis, strengths assessment, and customized 30-day improvement roadmap.";
---

<Base
  title={title}
  description={description}
  lang="en"
  tkey="quiz/report"
  hideCta={true}
  hideLanguageSwitcher={true}
>
  <div class="quiz-report-wrapper">
    <QuizReport client:only="react" />
  </div>
</Base>

<style>
  .quiz-report-wrapper {
    padding-top: 5rem;
    min-height: 100vh;
  }
</style>
