---
/**
 * Dynamic Quiz Report Page
 *
 * Route: /en/quiz/[quizType]/report/
 * Displays detailed quiz results with gap analysis
 */

import Base from "@layouts/Base.astro";
import {
  getQuizConfig,
  isQuizTypeAvailable,
  getAvailableQuizTypes,
} from "@/data/quiz/configs";
import type { QuizType } from "@/data/quiz/types";

export const prerender = true;

export function getStaticPaths() {
  return getAvailableQuizTypes().map((qt) => ({ params: { quizType: qt } }));
}

// Get quiz type from URL params
const { quizType } = Astro.params;

// Validate quiz type
if (!quizType || !isQuizTypeAvailable(quizType)) {
  return Astro.redirect("/en/404");
}

// Get quiz configuration
const config = getQuizConfig(quizType as QuizType, "en");

const title = `Report | ${config.title}`;
const description =
  "Your personalized Communication Confidence report with detailed gap analysis, strengths assessment, and customized 30-day improvement roadmap.";
---

<Base
  title={title}
  description={description}
  lang="en"
  tkey="quiz/report"
  hideCta={true}
  hideLanguageSwitcher={true}
>
  <section class="quiz-report pt-28 pb-16 md:pt-32 md:pb-20">
    <div class="container-report">
      <!-- No Data Warning -->
      <div class="no-data-warning" id="no-data-warning" style="display: none;">
        <div class="warning-content">
          <div class="warning-icon">⚠️</div>
          <h2>No Report Available</h2>
          <p class="warning-text">
            You need to complete the quiz and submit your email to view your
            report.
          </p>
          <a href={`/en/quiz/${quizType}/question/1`} class="start-button">
            Start the Quiz →
          </a>
        </div>
      </div>

      <!-- Report Content -->
      <div class="report-content" id="report-content" style="display: none;">
        <!-- Header -->
        <div class="report-header">
          <h1>Your Communication Confidence Report</h1>
          <p class="report-subtitle" id="lead-name">
            <!-- Filled by script -->
          </p>
        </div>

        <!-- Score Overview -->
        <div class="score-overview">
          <div class="score-display">
            <div class="score-number" id="total-score">0</div>
            <div class="score-label">/ 100</div>
          </div>
          <div class="score-tier-badge" id="tier-badge">
            <!-- Filled by script -->
          </div>
        </div>

        <!-- Category Breakdown -->
        <div class="category-breakdown">
          <h2>Category Breakdown</h2>
          <div class="categories-grid" id="categories-grid">
            <!-- Filled by script -->
          </div>
        </div>

        <!-- Gap Analysis -->
        <div class="gap-analysis">
          <h2>Your Top 2 Improvement Areas</h2>

          <div class="gap-card primary-gap" id="primary-gap">
            <!-- Filled by script -->
          </div>

          <div class="gap-card secondary-gap" id="secondary-gap">
            <!-- Filled by script -->
          </div>
        </div>

        <!-- CTA Section -->
        <div class="report-cta">
          <h2>Ready to Close These Gaps?</h2>
          <p>
            Book a free 30-minute strategy call to create your personalized
            improvement plan.
          </p>
          <a href="/en/contact" class="cta-button">
            Book Your Strategy Call →
          </a>
          <button onclick="window.print()" class="print-button">
            Print Report
          </button>
        </div>
      </div>
    </div>
  </section>
</Base>

<style>
  .container-report {
    max-width: 900px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .quiz-report {
    background: linear-gradient(135deg, #f0f9ff 0%, #e0e7ff 100%);
    min-height: calc(100vh - 80px);
  }

  /* Warning */
  .no-data-warning {
    background: white;
    padding: 4rem 3rem;
    border-radius: 16px;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
    text-align: center;
  }

  .warning-content {
    max-width: 600px;
    margin: 0 auto;
  }

  .warning-icon {
    font-size: 4rem;
    margin-bottom: 1.5rem;
  }

  .no-data-warning h1 {
    font-size: 2.5rem;
    font-weight: 700;
    color: #0f172a;
    margin-bottom: 1rem;
  }

  .warning-text {
    font-size: 1.25rem;
    color: #475569;
    margin-bottom: 2rem;
    line-height: 1.6;
  }

  .start-button {
    display: inline-block;
    padding: 1rem 2rem;
    background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%);
    color: white;
    font-weight: 600;
    border-radius: 8px;
    text-decoration: none;
    transition: transform 0.2s;
  }

  .start-button:hover {
    transform: translateY(-2px);
  }

  /* Report Content */
  .report-content {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .report-header {
    background: white;
    padding: 3rem;
    border-radius: 16px;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
    text-align: center;
  }

  .report-header h1 {
    font-size: 2.5rem;
    font-weight: 800;
    color: #0f172a;
    margin-bottom: 0.5rem;
  }

  .report-subtitle {
    font-size: 1.125rem;
    color: #64748b;
  }

  /* Score Overview */
  .score-overview {
    background: white;
    padding: 3rem;
    border-radius: 16px;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
  }

  .score-display {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .score-number {
    font-size: 5rem;
    font-weight: 800;
    color: #3b82f6;
  }

  .score-label {
    font-size: 2rem;
    color: #64748b;
    align-self: flex-end;
    margin-bottom: 1rem;
  }

  .score-tier-badge {
    padding: 0.75rem 1.5rem;
    border-radius: 9999px;
    font-size: 1.25rem;
    font-weight: 600;
  }

  /* Category Breakdown */
  .category-breakdown {
    background: white;
    padding: 3rem;
    border-radius: 16px;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
  }

  .category-breakdown h2 {
    font-size: 2rem;
    font-weight: 700;
    color: #0f172a;
    margin-bottom: 2rem;
  }

  .categories-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }

  @media (min-width: 768px) {
    .categories-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .category-item {
    padding: 1.5rem;
    background: #f8fafc;
    border-radius: 12px;
    border: 2px solid #e2e8f0;
  }

  .category-name {
    font-size: 1.125rem;
    font-weight: 600;
    color: #334155;
    margin-bottom: 0.5rem;
  }

  .category-score {
    font-size: 2rem;
    font-weight: 700;
    color: #3b82f6;
  }

  /* Gap Analysis */
  .gap-analysis {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .gap-analysis h2 {
    font-size: 2rem;
    font-weight: 700;
    color: #0f172a;
    padding: 0 1.5rem;
  }

  .gap-card {
    background: white;
    padding: 2.5rem;
    border-radius: 16px;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
  }

  .gap-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1.5rem;
  }

  .gap-title {
    font-size: 1.5rem;
    font-weight: 700;
    color: #0f172a;
  }

  .gap-urgency {
    padding: 0.5rem 1rem;
    border-radius: 9999px;
    font-size: 0.875rem;
    font-weight: 600;
    text-transform: uppercase;
  }

  .urgency-high {
    background: #fee2e2;
    color: #991b1b;
  }

  .urgency-medium {
    background: #fef3c7;
    color: #92400e;
  }

  .urgency-low {
    background: #dbeafe;
    color: #1e40af;
  }

  .gap-score {
    font-size: 1.125rem;
    color: #64748b;
    margin-bottom: 1rem;
  }

  .gap-impact,
  .gap-recommendation {
    margin-bottom: 1.5rem;
  }

  .gap-impact h4,
  .gap-recommendation h4 {
    font-size: 1rem;
    font-weight: 600;
    color: #334155;
    margin-bottom: 0.5rem;
  }

  .gap-impact p,
  .gap-recommendation p {
    font-size: 1rem;
    color: #475569;
    line-height: 1.6;
  }

  /* CTA Section */
  .report-cta {
    background: white;
    padding: 3rem;
    border-radius: 16px;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
    text-align: center;
  }

  .report-cta h2 {
    font-size: 2rem;
    font-weight: 700;
    color: #0f172a;
    margin-bottom: 1rem;
  }

  .report-cta p {
    font-size: 1.125rem;
    color: #475569;
    margin-bottom: 2rem;
  }

  .cta-button {
    display: inline-block;
    padding: 1rem 2rem;
    background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%);
    color: white;
    font-weight: 600;
    font-size: 1.125rem;
    border-radius: 8px;
    text-decoration: none;
    transition: transform 0.2s;
    margin-right: 1rem;
  }

  .cta-button:hover {
    transform: translateY(-2px);
  }

  .print-button {
    padding: 1rem 2rem;
    background: white;
    color: #3b82f6;
    border: 2px solid #3b82f6;
    font-weight: 600;
    font-size: 1.125rem;
    border-radius: 8px;
    cursor: pointer;
    transition: all 0.2s;
  }

  .print-button:hover {
    background: #eff6ff;
  }

  @media (max-width: 768px) {
    .report-header,
    .score-overview,
    .category-breakdown,
    .gap-card,
    .report-cta {
      padding: 2rem 1.5rem;
    }

    .report-header h1 {
      font-size: 2rem;
    }

    .score-number {
      font-size: 4rem;
    }

    .cta-button,
    .print-button {
      display: block;
      width: 100%;
      margin: 0.5rem 0;
    }
  }

  @media print {
    .report-cta {
      display: none;
    }
  }
</style>

<script>
  import { QuizStorage } from "@/lib/quiz-storage";
  import { calculateQuizScore } from "@/data/quiz/scoring";
  import { getQuizConfig } from "@/data/quiz/configs";
  import type { QuizType } from "@/data/quiz/types";

  // Get quiz type from URL
  const urlParts = window.location.pathname.split("/");
  const quizType = urlParts[3] as QuizType;

  // Check if we have quiz data
  const answers = QuizStorage.getAnswers(quizType);
  const leadData = QuizStorage.getLeadData(quizType);

  if (!answers || !leadData) {
    // Show warning
    document.getElementById("no-data-warning")!.style.display = "block";
  } else {
    // Calculate score
    const config = getQuizConfig(quizType, "en");
    const scoreBreakdown = calculateQuizScore(answers, config);

    // Show report
    document.getElementById("report-content")!.style.display = "block";

    // Fill in lead name
    document.getElementById("lead-name")!.textContent =
      `Prepared for ${leadData.name}`;

    // Fill in score
    document.getElementById("total-score")!.textContent =
      scoreBreakdown.totalScore.toString();

    // Fill in tier badge
    const tierBadge = document.getElementById("tier-badge")!;
    tierBadge.textContent = scoreBreakdown.scoreTier;

    if (scoreBreakdown.scoreTier === "Conversation-Ready") {
      tierBadge.style.background = "#d1fae5";
      tierBadge.style.color = "#065f46";
    } else if (scoreBreakdown.scoreTier === "Million-Dollar Gap") {
      tierBadge.style.background = "#fef3c7";
      tierBadge.style.color = "#92400e";
    } else {
      tierBadge.style.background = "#fee2e2";
      tierBadge.style.color = "#991b1b";
    }

    // Fill in categories
    const categoriesGrid = document.getElementById("categories-grid")!;
    Object.entries(scoreBreakdown.categoryScores).forEach(
      ([category, score]) => {
        const categoryItem = document.createElement("div");
        categoryItem.className = "category-item";

        // Get category name from gap definitions
        const gapDef =
          config.gapDefinitions[category as keyof typeof config.gapDefinitions];
        const categoryName = gapDef?.name || category;

        categoryItem.innerHTML = `
      <div class="category-name">${categoryName}</div>
      <div class="category-score">${score}/100</div>
    `;
        categoriesGrid.appendChild(categoryItem);
      }
    );

    // Fill in primary gap
    const primaryGapEl = document.getElementById("primary-gap")!;
    const primaryGap = scoreBreakdown.primaryGap;
    primaryGapEl.innerHTML = `
    <div class="gap-header">
      <h3 class="gap-title">#1: ${primaryGap.categoryName}</h3>
      <span class="gap-urgency urgency-${primaryGap.urgency}">${primaryGap.urgency}</span>
    </div>
    <div class="gap-score">Your Score: ${primaryGap.score}/100</div>
    <div class="gap-impact">
      <h4>Impact:</h4>
      <p>${primaryGap.impact}</p>
    </div>
    <div class="gap-recommendation">
      <h4>Recommendation:</h4>
      <p>${primaryGap.recommendation}</p>
    </div>
  `;

    // Fill in secondary gap
    const secondaryGapEl = document.getElementById("secondary-gap")!;
    const secondaryGap = scoreBreakdown.secondaryGap;
    secondaryGapEl.innerHTML = `
    <div class="gap-header">
      <h3 class="gap-title">#2: ${secondaryGap.categoryName}</h3>
      <span class="gap-urgency urgency-${secondaryGap.urgency}">${secondaryGap.urgency}</span>
    </div>
    <div class="gap-score">Your Score: ${secondaryGap.score}/100</div>
    <div class="gap-impact">
      <h4>Impact:</h4>
      <p>${secondaryGap.impact}</p>
    </div>
    <div class="gap-recommendation">
      <h4>Recommendation:</h4>
      <p>${secondaryGap.recommendation}</p>
    </div>
  `;
  }
</script>
