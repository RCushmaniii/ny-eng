---
/**
 * Dynamic Quiz Question Page
 * 
 * Route: /en/quiz/[quizType]/question/[id]/
 * Displays individual quiz questions with progress tracking
 */

import Base from '@layouts/Base.astro';
import Button from '@components/ui/Button.astro';
import { getQuizConfig, isQuizTypeAvailable, getAvailableQuizTypes } from '@/data/quiz/configs';
import { QuizStorage } from '@/lib/quiz-storage';
import type { QuizType } from '@/data/quiz/types';

export const prerender = true;

export function getStaticPaths() {
  const quizTypes = getAvailableQuizTypes();
  const paths: { params: { quizType: string; id: string } }[] = [];
  
  quizTypes.forEach(qt => {
    const config = getQuizConfig(qt, 'en');
    config.questions.forEach(q => {
      paths.push({ params: { quizType: qt, id: q.id.toString() } });
    });
  });
  
  return paths;
}

// Get params
const { quizType, id } = Astro.params;

// Validate quiz type
if (!quizType || !isQuizTypeAvailable(quizType)) {
  return Astro.redirect('/en/404');
}

// Get quiz configuration
const config = getQuizConfig(quizType as QuizType, 'en');

// Validate question ID
const currentQuestion = parseInt(id || '1');
const validQuestion = config.questions.find(q => q.id === currentQuestion);
const hasValidQuestion = !!validQuestion;

const totalQuestions = config.questions.length;
const progress = (currentQuestion / totalQuestions) * 100;

const title = hasValidQuestion 
  ? `Question ${currentQuestion} of ${totalQuestions} | ${config.title}`
  : `Quiz Error | ${config.title}`;
const description = config.subtitle;
---

<Base 
  title={title} 
  description={description}
  lang="en"
  noindex={true}
  customCanonical={`https://www.nyenglishteacher.com/en/quiz/${quizType}/question/${id}/`}
  customHreflangs={[
    { lang: "en-US", href: `https://www.nyenglishteacher.com/en/quiz/${quizType}/question/${id}/` },
    { lang: "es-MX", href: `https://www.nyenglishteacher.com/es/quiz/${quizType}/question/${id}/` }
  ]}
  hideCta={true}
  hideNav={true}
  hideLanguageSwitcher={true}
>

<section class="quiz-question pt-28 pb-16 md:pt-32 md:pb-20">
  <div class="container-narrow">
    
    {!hasValidQuestion ? (
      <!-- No Quiz Data Warning -->
      <div class="no-quiz-warning">
        <div class="warning-content">
          <div class="warning-icon">⚠️</div>
          <h1>Please Start from the Beginning</h1>
          <p class="warning-text">
            To get accurate results, you need to start the quiz from the beginning and answer all questions in order.
          </p>
          <p class="warning-subtext">
            The Communication Confidence Assessment takes about 90 seconds and will give you a personalized score.
          </p>
          <Button 
            href={`/en/quiz/${quizType}/question/1`}
            variant="primary" 
            size="lg"
            class="start-quiz-button"
          >
            Start the Quiz →
          </Button>
        </div>
      </div>
    ) : (
      <>
    <!-- Progress Bar -->
    <div class="progress-container">
      <div class="progress-bar">
        <div class="progress-fill" style={`width: ${progress}%`}></div>
      </div>
      <div class="progress-text">
        Question {currentQuestion} of {totalQuestions}
      </div>
    </div>

    <!-- Question Card -->
    <div class="question-card">
      <h1 class="question-text">{validQuestion.question}</h1>

      <div class="options-container" id="quiz-options" data-question-id={validQuestion.id} data-quiz-type={quizType}>
        {validQuestion.answers.map((answer) => (
          <button 
            type="button"
            class="option-button"
            data-answer-index={answer.index}
          >
            <span class="option-letter">{String.fromCharCode(65 + answer.index)}</span>
            <span class="option-text">{answer.label}</span>
          </button>
        ))}
      </div>
    </div>
    </>
    )}
  </div>
</section>

</Base>

<style>
.container-narrow {
  max-width: 800px;
  margin: 0 auto;
  padding: 0 1.5rem;
}

.quiz-question {
  background: linear-gradient(135deg, #f0f9ff 0%, #e0e7ff 100%);
  min-height: calc(100vh - 80px);
}

/* No Quiz Warning */
.no-quiz-warning {
  background: white;
  padding: 4rem 3rem;
  border-radius: 16px;
  box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
  text-align: center;
}

.warning-content {
  max-width: 600px;
  margin: 0 auto;
}

.warning-icon {
  font-size: 4rem;
  margin-bottom: 1.5rem;
  animation: pulse 2s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.1); }
}

.no-quiz-warning h1 {
  font-size: 2.5rem;
  font-weight: 700;
  color: #0f172a;
  margin-bottom: 1rem;
}

.warning-text {
  font-size: 1.25rem;
  color: #475569;
  margin-bottom: 1rem;
  line-height: 1.6;
}

.warning-subtext {
  font-size: 1rem;
  color: #64748b;
  margin-bottom: 2rem;
  line-height: 1.6;
}

.start-quiz-button {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 0.5rem;
}

/* Progress Bar */
.progress-container {
  margin-bottom: 2rem;
}

.progress-bar {
  width: 100%;
  height: 8px;
  background: #e2e8f0;
  border-radius: 4px;
  overflow: hidden;
  margin-bottom: 0.5rem;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #3b82f6 0%, #2563eb 100%);
  transition: width 0.3s ease;
}

.progress-text {
  text-align: center;
  font-size: 0.875rem;
  color: #64748b;
  font-weight: 500;
}

/* Question Card */
.question-card {
  background: white;
  padding: 3rem;
  border-radius: 16px;
  box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
}

.question-text {
  font-size: 1.75rem;
  font-weight: 600;
  color: #0f172a;
  line-height: 1.4;
  margin-bottom: 2.5rem;
}

/* Options Container */
.options-container {
  display: flex;
  flex-direction: column;
  gap: 1rem;
}

.option-button {
  display: flex;
  align-items: center;
  gap: 1rem;
  padding: 1.25rem 1.5rem;
  background: #f8fafc;
  border: 2px solid #e2e8f0;
  border-radius: 12px;
  cursor: pointer;
  transition: all 0.2s ease;
  width: 100%;
  text-align: left;
  font-family: inherit;
}

/* Premium Hover State */
.option-button:hover {
  background: #f1f5f9;
  border-color: #3b82f6;
  transform: translateY(-2px);
  box-shadow: 0 4px 12px rgba(59, 130, 246, 0.15);
}

/* Active/Selected State */
.option-button.selected {
  background: #3b82f6;
  border-color: #3b82f6;
  box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.2);
}

.option-button.selected .option-letter {
  background: white;
  border-color: white;
  color: #3b82f6;
}

.option-button.selected .option-text {
  color: white;
  font-weight: 500;
}

.option-letter {
  width: 32px;
  height: 32px;
  background: white;
  border: 2px solid #cbd5e1;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 600;
  color: #64748b;
  flex-shrink: 0;
  transition: all 0.2s ease;
}

.option-text {
  font-size: 1rem;
  color: #334155;
  line-height: 1.5;
  transition: all 0.2s ease;
}

@media (max-width: 768px) {
  .question-card {
    padding: 2rem 1.5rem;
  }

  .question-text {
    font-size: 1.5rem;
  }

  .option-content {
    padding: 1rem;
  }
}
</style>

<script>
import { QuizStorage } from '@/lib/quiz-storage';
import type { QuizType } from '@/data/quiz/types';

// Handle auto-advance quiz with click-to-advance
const optionsContainer = document.getElementById('quiz-options');

if (optionsContainer) {
  const questionId = optionsContainer.getAttribute('data-question-id');
  const quizType = optionsContainer.getAttribute('data-quiz-type') as QuizType;
  
  // Save start time on first question
  if (questionId === '1' && quizType) {
    QuizStorage.saveStartTime(quizType);
  }
  
  // Add click handlers to all option buttons
  const optionButtons = optionsContainer.querySelectorAll('.option-button');
  
  optionButtons.forEach((button) => {
    button.addEventListener('click', () => {
      const answerIndex = button.getAttribute('data-answer-index');
      
      if (!answerIndex || !quizType || !questionId) return;
      
      // Remove selected state from all buttons (radio button behavior)
      optionButtons.forEach(btn => btn.classList.remove('selected'));
      
      // Add selected state to clicked button for visual feedback
      button.classList.add('selected');
      
      // Get existing answers from namespaced storage
      const answers = QuizStorage.getAnswers(quizType) || {};
      
      // Store this answer with 'q' prefix to match expected format
      const answerKey = `q${questionId}`;
      answers[answerKey] = parseInt(answerIndex);
      QuizStorage.saveAnswers(quizType, answers);
      
      // Auto-advance after 800ms for satisfying "I clicked something" feedback
      setTimeout(() => {
        const currentId = parseInt(questionId);
        const totalQuestions = 6;
        
        if (currentId < totalQuestions) {
          window.location.href = `/en/quiz/${quizType}/question/${currentId + 1}/`;
        } else {
          window.location.href = `/en/quiz/${quizType}/results/`;
        }
      }, 800);
    });
  });
}
</script>
