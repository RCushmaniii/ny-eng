---
import Base from '@layouts/Base.astro';
import Button from '@components/ui/Button.astro';

const title = "Speaking Confidence Quiz: Are You Ready for North American Clients?";
const description = "Discover the hidden speaking gaps costing your IT team contracts, credibility, and career growth. Take the 3-minute assessment.";
---

<Base 
  title={title} 
  description={description}
  lang="en"
  customCanonical="https://www.nyenglishteacher.com/en/quiz/"
  customHreflangs={[
    { lang: "en-US", href: "https://www.nyenglishteacher.com/en/quiz/" },
    { lang: "es-MX", href: "https://www.nyenglishteacher.com/es/quiz/" }
  ]}
  hideCta={true}
>

<!-- HERO SECTION -->
<section class="quiz-landing-hero">
  <div class="container-custom">
    <div class="hero-grid">
      <div class="hero-content">
        <span class="eyebrow">Free 3-Minute Assessment</span>
        
        <h1>Can Your Team Defend a $200K Price Tag on a Live Zoom Call?</h1>
        
        <p class="hero-subhead">
          Grammarly can fix your emails. AI can write your proposals. 
          But when you're live with a Fortune 500 client and they ask a tough question...
          <strong>your spoken English IS your credibility.</strong>
        </p>

        <div class="value-props">
          <div class="value-prop">
            <span class="icon">🎯</span>
            <span>Discover which speaking moments are costing you deals</span>
          </div>
          <div class="value-prop">
            <span class="icon">📊</span>
            <span>See your Communication Confidence Score (0-100)</span>
          </div>
          <div class="value-prop">
            <span class="icon">🚀</span>
            <span>Get a personalized roadmap to speaking mastery</span>
          </div>
        </div>

        <Button 
          href="/en/quiz/start" 
          variant="primary" 
          size="lg"
          class="cta-start-quiz"
        >
          Start Your Free Assessment →
        </Button>

        <div class="trust-signals">
          <span>⏱️ Takes 3 minutes</span>
          <span>📧 Results emailed instantly</span>
          <span>🔒 100% confidential</span>
        </div>
      </div>

      <div class="hero-visual">
        <!-- Placeholder for screenshot of results page or testimonial card -->
        <div class="visual-placeholder">
          <div class="sample-score-card">
            <div class="score-header">Your Communication Confidence Score</div>
            <div class="score-number">73</div>
            <div class="score-label">Room for Growth</div>
            <div class="score-insight">
              <strong>Key Finding:</strong> Your team hesitates during pricing discussions, 
              signaling uncertainty to clients.
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- WHY SPOKEN ENGLISH MATTERS -->
<section class="why-spoken-english">
  <div class="container-narrow">
    <h2>Why Spoken English is Your Real Competitive Advantage</h2>
    
    <div class="reason-cards">
      <div class="reason-card">
        <h3>💰 Written English is Solved</h3>
        <p>
          Grammarly, ChatGPT, and AI writing tools can make your emails and 
          proposals flawless. <strong>But they can't help you on a live call.</strong>
        </p>
      </div>

      <div class="reason-card">
        <h3>🎤 High-Stakes Moments are Spoken</h3>
        <p>
          Sales pitches. Negotiations. Client Q&A. Technical presentations. 
          Project problem-solving. <strong>These happen in real-time, with no "edit" button.</strong>
        </p>
      </div>

      <div class="reason-card">
        <h3>⚡ Hesitation = Lost Credibility</h3>
        <p>
          That 3-second pause while you translate in your head? North American 
          clients interpret it as uncertainty or lack of expertise. 
          <strong>Even when you know the answer perfectly.</strong>
        </p>
      </div>

      <div class="reason-card">
        <h3>📈 Speaking Confidence = Pricing Power</h3>
        <p>
          When you can articulate value clearly and defend your pricing without 
          fumbling, clients stop negotiating on price. 
          <strong>They start negotiating on partnership terms.</strong>
        </p>
      </div>
    </div>
  </div>
</section>

<!-- THE HIDDEN COST -->
<section class="hidden-cost">
  <div class="container-narrow">
    <h2>The Million-Dollar Question</h2>
    
    <div class="cost-callout">
      <p class="cost-question">
        How many times has your team said <em>"Let me follow up via email"</em> 
        in a client call... when they actually <strong>knew the answer</strong>?
      </p>
      
      <p class="cost-impact">
        That deflection costs you:
      </p>
      
      <ul class="cost-list">
        <li>❌ Immediate credibility (clients sense hesitation)</li>
        <li>❌ Deal momentum (email replies take days)</li>
        <li>❌ Pricing power (you can't defend value in writing)</li>
        <li>❌ Your time (you become the bottleneck for every call)</li>
      </ul>
      
      <p class="cost-solution">
        <strong>The fix isn't more vocabulary.</strong><br>
        It's deliberate practice in high-pressure speaking situations.
      </p>
    </div>
  </div>
</section>

<!-- WHAT YOU'LL DISCOVER -->
<section class="what-youll-discover">
  <div class="container-custom">
    <h2>What This 3-Minute Quiz Reveals</h2>
    
    <div class="discovery-grid">
      <div class="discovery-item">
        <div class="discovery-number">1</div>
        <h3>Your Speaking Readiness Score</h3>
        <p>
          A 0-100 assessment of how confidently your team can handle 
          high-stakes conversations with North American clients.
        </p>
      </div>

      <div class="discovery-item">
        <div class="discovery-number">2</div>
        <h3>Your Biggest Speaking Gap</h3>
        <p>
          Is it real-time clarity under pressure? Negotiation confidence? 
          Meeting leadership? We'll pinpoint your #1 opportunity.
        </p>
      </div>

      <div class="discovery-item">
        <div class="discovery-number">3</div>
        <h3>What It's Costing You</h3>
        <p>
          See exactly how speaking gaps translate to lost deals, longer 
          sales cycles, and lower contract values.
        </p>
      </div>

      <div class="discovery-item">
        <div class="discovery-number">4</div>
        <h3>How to Fix It (Fast)</h3>
        <p>
          Your personalized report includes specific speaking drills and 
          a 30-day improvement roadmap.
        </p>
      </div>
    </div>
  </div>
</section>

<!-- SOCIAL PROOF -->
<section class="social-proof">
  <div class="container-narrow">
    <h2>Join 200+ Tech Leaders Who've Taken This Assessment</h2>
    
    <div class="testimonial-cards">
      <div class="testimonial-card">
        <p class="testimonial-text">
          "I scored a 58 and thought, 'That's not bad.' Then I read the report 
          and realized we were leaving $100K+ on the table every quarter because 
          our PMs couldn't command client calls."
        </p>
        <cite>— Founder, 35-person dev shop, Mexico City</cite>
      </div>

      <div class="testimonial-card">
        <p class="testimonial-text">
          "The quiz forced me to admit what I already knew: I was the bottleneck. 
          Every important call had to go through me because my team wasn't confident 
          enough. Now they lead discovery calls themselves."
        </p>
        <cite>— CTO, SaaS consultancy, Bogotá</cite>
      </div>

      <div class="testimonial-card">
        <p class="testimonial-text">
          "We thought our English was 'good enough.' This assessment showed us 
          the specific moments where we were losing credibility. Six weeks later, 
          we closed our first $180K contract."
        </p>
        <cite>— VP Engineering, fintech startup, Buenos Aires</cite>
      </div>
    </div>
  </div>
</section>

<!-- FINAL CTA -->
<section class="final-cta">
  <div class="container-narrow">
    <h2>Ready to See Where You Stand?</h2>
    
    <p class="cta-subtext">
      Take the 3-minute Speaking Confidence Quiz and get your personalized 
      report instantly.
    </p>
    
    <Button 
      href="/en/quiz/start" 
      variant="primary" 
      size="lg"
    >
      Start Your Free Assessment →
    </Button>
    
    <div class="trust-signals">
      <span>⏱️ 3 minutes</span>
      <span>📧 Instant results</span>
      <span>🔒 No spam</span>
    </div>
  </div>
</section>

</Base>

<style>
/* Container Utilities */
.container-custom {
  max-width: 1200px;
  margin: 0 auto;
  padding: 0 1.5rem;
}

.container-narrow {
  max-width: 900px;
  margin: 0 auto;
  padding: 0 1.5rem;
}

/* Hero Section */
.quiz-landing-hero {
  padding: 4rem 0;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
}

.hero-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 3rem;
  align-items: center;
}

.hero-content {
  max-width: 600px;
}

.eyebrow {
  display: inline-block;
  background: rgba(255, 255, 255, 0.2);
  padding: 0.5rem 1rem;
  border-radius: 20px;
  font-size: 0.875rem;
  font-weight: 600;
  margin-bottom: 1rem;
  backdrop-filter: blur(10px);
}

.quiz-landing-hero h1 {
  font-size: 2.5rem;
  line-height: 1.2;
  margin-bottom: 1.5rem;
  font-weight: 700;
}

.hero-subhead {
  font-size: 1.25rem;
  line-height: 1.6;
  margin-bottom: 2rem;
  opacity: 0.95;
}

.value-props {
  display: flex;
  flex-direction: column;
  gap: 1rem;
  margin-bottom: 2rem;
}

.value-prop {
  display: flex;
  align-items: center;
  gap: 1rem;
  font-size: 1.1rem;
}

.value-prop .icon {
  font-size: 1.5rem;
  flex-shrink: 0;
}

.cta-start-quiz {
  margin-bottom: 1rem;
}

.trust-signals {
  display: flex;
  gap: 2rem;
  margin-top: 1rem;
  font-size: 0.9rem;
  opacity: 0.9;
}

/* Hero Visual */
.hero-visual {
  display: flex;
  align-items: center;
  justify-content: center;
}

.visual-placeholder {
  width: 100%;
  max-width: 400px;
}

.sample-score-card {
  background: white;
  color: #2d3748;
  padding: 2rem;
  border-radius: 16px;
  box-shadow: 0 20px 40px rgba(0, 0, 0, 0.2);
  text-align: center;
}

.score-header {
  font-size: 0.875rem;
  font-weight: 600;
  text-transform: uppercase;
  color: #718096;
  margin-bottom: 1rem;
}

.score-number {
  font-size: 4rem;
  font-weight: 700;
  color: #667eea;
  line-height: 1;
  margin-bottom: 0.5rem;
}

.score-label {
  font-size: 1.25rem;
  font-weight: 600;
  color: #4a5568;
  margin-bottom: 1.5rem;
}

.score-insight {
  background: #f7fafc;
  padding: 1rem;
  border-radius: 8px;
  font-size: 0.875rem;
  line-height: 1.5;
  text-align: left;
}

/* Why Spoken English */
.why-spoken-english {
  padding: 4rem 0;
  background: #f7fafc;
}

.why-spoken-english h2 {
  text-align: center;
  font-size: 2rem;
  margin-bottom: 3rem;
  color: #2d3748;
}

.reason-cards {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
  gap: 2rem;
}

.reason-card {
  background: white;
  padding: 2rem;
  border-radius: 12px;
  box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
  transition: transform 0.3s ease, box-shadow 0.3s ease;
}

.reason-card:hover {
  transform: translateY(-4px);
  box-shadow: 0 8px 12px rgba(0, 0, 0, 0.15);
}

.reason-card h3 {
  font-size: 1.25rem;
  margin-bottom: 1rem;
  color: #2d3748;
}

.reason-card p {
  color: #4a5568;
  line-height: 1.6;
}

/* Hidden Cost */
.hidden-cost {
  padding: 4rem 0;
  background: white;
}

.hidden-cost h2 {
  text-align: center;
  font-size: 2rem;
  margin-bottom: 2rem;
  color: #2d3748;
}

.cost-callout {
  background: #fff5f5;
  border-left: 4px solid #e53e3e;
  padding: 2rem;
  border-radius: 8px;
}

.cost-question {
  font-size: 1.5rem;
  font-weight: 600;
  margin-bottom: 1.5rem;
  color: #2d3748;
}

.cost-impact {
  font-weight: 600;
  margin-bottom: 1rem;
  color: #2d3748;
}

.cost-list {
  list-style: none;
  padding: 0;
  margin-bottom: 1.5rem;
}

.cost-list li {
  padding: 0.5rem 0;
  font-size: 1.1rem;
  color: #4a5568;
}

.cost-solution {
  font-size: 1.1rem;
  color: #2d3748;
  padding-top: 1rem;
  border-top: 2px solid #feb2b2;
}

/* What You'll Discover */
.what-youll-discover {
  padding: 4rem 0;
  background: white;
}

.what-youll-discover h2 {
  text-align: center;
  font-size: 2rem;
  margin-bottom: 3rem;
  color: #2d3748;
}

.discovery-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
  gap: 2rem;
}

.discovery-item {
  text-align: center;
}

.discovery-number {
  width: 60px;
  height: 60px;
  background: #667eea;
  color: white;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 1.5rem;
  font-weight: bold;
  margin: 0 auto 1rem;
}

.discovery-item h3 {
  font-size: 1.25rem;
  margin-bottom: 1rem;
  color: #2d3748;
}

.discovery-item p {
  color: #4a5568;
  line-height: 1.6;
}

/* Social Proof */
.social-proof {
  padding: 4rem 0;
  background: #f7fafc;
}

.social-proof h2 {
  text-align: center;
  font-size: 2rem;
  margin-bottom: 3rem;
  color: #2d3748;
}

.testimonial-cards {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
  gap: 2rem;
}

.testimonial-card {
  background: white;
  padding: 2rem;
  border-radius: 12px;
  box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
}

.testimonial-text {
  font-size: 1rem;
  line-height: 1.6;
  color: #2d3748;
  margin-bottom: 1rem;
  font-style: italic;
}

.testimonial-card cite {
  font-size: 0.875rem;
  color: #718096;
  font-style: normal;
}

/* Final CTA */
.final-cta {
  padding: 4rem 0;
  background: white;
  text-align: center;
}

.final-cta h2 {
  font-size: 2rem;
  margin-bottom: 1rem;
  color: #2d3748;
}

.cta-subtext {
  font-size: 1.25rem;
  margin-bottom: 2rem;
  color: #4a5568;
}

.final-cta .trust-signals {
  justify-content: center;
  margin-top: 1.5rem;
}

/* Responsive */
@media (max-width: 768px) {
  .hero-grid {
    grid-template-columns: 1fr;
    gap: 2rem;
  }

  .hero-visual {
    order: -1;
  }

  .quiz-landing-hero h1 {
    font-size: 2rem;
  }

  .hero-subhead {
    font-size: 1.1rem;
  }
  
  .trust-signals {
    flex-direction: column;
    gap: 0.5rem;
    align-items: flex-start;
  }

  .final-cta .trust-signals {
    align-items: center;
  }

  .reason-cards,
  .discovery-grid,
  .testimonial-cards {
    grid-template-columns: 1fr;
  }

  .cost-question {
    font-size: 1.25rem;
  }
}
</style>
