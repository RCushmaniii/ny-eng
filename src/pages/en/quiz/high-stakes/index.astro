---
/**
 * High-Stakes English Assessment Landing Page
 * URL: /en/quiz/high-stakes/
 * Target Keyword: English for Job Interviews / Presentation Skills Coaching
 */
export const prerender = true;

import Base from "@layouts/Base.astro";
import Button from "@components/ui/Button.astro";
import QuizSchema from "@components/seo/QuizSchema.astro";
import {
  Presentation,
  CheckCircle,
  Clock,
  TrendingUp,
  ChevronDown,
  Theater,
  Zap,
  Target,
  XCircle,
} from "lucide-astro";
import heroSkyline from "@assets/images/home/new-york-city-skyline.webp";

// SEO metadata - optimized for 50-60 characters title, 150-160 chars description
const title = "Pressure Performance Score | High-Stakes Communication";
const description =
  "Brilliant in your native language but freezing in English? Measure your Business English Pressure Score in 90 seconds and get a personalized gap analysis.";

// FAQ data for SEO content
const faqs = [
  {
    question: "How long does the high-stakes communication assessment take?",
    answer:
      "90 seconds. You'll answer 6 scenario-based questions and receive your Pressure Performance Score (0-100) plus a personalized gap analysis immediately after.",
  },
  {
    question: "What is the 'Language Gap' this assessment measures?",
    answer:
      "The Language Gap is the difference between your intelligence in your native language and how you come across in high-pressure English situations. You might be brilliant in casual conversations but freeze during interviews or presentations. This assessment quantifies that gap and provides a roadmap to close it.",
  },
  {
    question: "What will I receive after completing the assessment?",
    answer:
      "Your Pressure Performance Score (0-100), analysis of your strengths and gaps across three dimensions (Stage Presence, Processing Speed, and Persuasive Impact), plus a personalized 30-day roadmap with specific exercises to build high-stakes confidence.",
  },
  {
    question: "Who should take this assessment?",
    answer:
      "Professionals preparing for job interviews, keynote presentations, investor pitches, or any career-defining moment where English performance matters. If you're fluent in casual settings but your mind goes blank under pressure, this assessment is for you.",
  },
  {
    question: "Will this help with public speaking anxiety?",
    answer:
      "Yes. Most public speaking anxiety for non-native speakers stems from language uncertainty—the fear of freezing, forgetting words, or being misunderstood. This assessment identifies the root cause (processing speed, vocabulary gaps, or cultural fluency) and provides targeted strategies to build confidence.",
  },
  {
    question: "What happens after I get my results?",
    answer:
      "You'll receive an email with your detailed scorecard and the option to book a free 20-minute consultation to discuss your personalized roadmap for high-stakes communication mastery.",
  },
];

// Testimonials data
const testimonials = [
  {
    quote:
      "Failed 2 final-round interviews at Amazon before this. The processing speed exercises changed everything—landed the offer on my third attempt.",
    name: "Ricardo M.",
    title: "Senior Product Manager, Amazon",
    location: "Mexico City → Seattle",
  },
  {
    quote:
      "I used to black out during investor pitches. Now I actually enjoy them. Raised $4M in our Series A—the presence training was worth 100x the investment.",
    name: "Sofia L.",
    title: "CEO, Fintech Startup",
    location: "Bogotá",
  },
  {
    quote:
      "Keynoted a 2,000-person conference in English. Six months ago, I would have said no. The 'freeze to flow' framework made it possible.",
    name: "Dr. Marco V.",
    title: "AI Research Director",
    location: "São Paulo → Austin",
  },
];
---

<Base
  title={title}
  description={description}
  lang="en"
  tkey="quiz/high-stakes"
  hideCta={true}
  hideNav={true}
>
  <QuizSchema lang="en" slot="head" />

  <!-- Hero Section with NYC Skyline Background -->
  <section class="hero">
    <img
      src={heroSkyline.src}
      alt="High-Stakes Communication Assessment"
      class="hero-bg-image"
      loading="eager"
    />
    <div class="hero-overlay"></div>
    <div class="container">
      <div class="hero-content">
        <span class="eyebrow">The 90-Second Assessment</span>

        <h1>Measure Your Business English Pressure Score</h1>

        <p class="discover-label">Three things you'll discover:</p>

        <div class="benefits">
          <div class="benefit">
            <CheckCircle size={20} />
            <span>Your English Pressure Performance Score (0-100)</span>
          </div>
          <div class="benefit">
            <CheckCircle size={20} />
            <span>Why you freeze when the language stakes are highest</span>
          </div>
          <div class="benefit">
            <CheckCircle size={20} />
            <span>Your 30-day roadmap to fluent high-stakes confidence</span>
          </div>
        </div>

        <Button
          href="/en/quiz/high-stakes/question/1"
          variant="primary"
          size="lg"
          class="cta-button gold-cta"
        >
          Start Free Assessment →
        </Button>

        <p class="trust-line">
          Quick. Insightful. Trusted by 200+ professionals seeking fluency and
          confidence.
        </p>
      </div>
    </div>
  </section>

  <!-- SECTION 1: The Business Case -->
  <section class="business-case-section">
    <div class="container">
      <h2>Why Your "Interview Self" Is Costing You $100K+ Offers</h2>
      <p class="section-intro">
        You're articulate in meetings. Confident with colleagues. But when the
        stakes are high—final-round interviews, investor pitches, keynote
        stages—something breaks. That gap has a price tag.
      </p>

      <div class="cost-grid">
        <div class="cost-item">
          <div class="cost-icon"><XCircle size={32} /></div>
          <h3>Lost Offers</h3>
          <p>
            You made it to the final round. Your skills were enough to get
            there. But the offer went to someone who "interviewed better."
          </p>
        </div>
        <div class="cost-item">
          <div class="cost-icon"><TrendingUp size={32} /></div>
          <h3>Lower Compensation</h3>
          <p>
            Hesitation in salary negotiations costs 10-20% of your package.
            That's $15K-$50K per year you're leaving on the table.
          </p>
        </div>
        <div class="cost-item">
          <div class="cost-icon"><Presentation size={32} /></div>
          <h3>Avoided Opportunities</h3>
          <p>
            The keynote you declined. The board presentation you delegated.
            Every "no" to visibility is a "no" to career acceleration.
          </p>
        </div>
        <div class="cost-item">
          <div class="cost-icon"><Clock size={32} /></div>
          <h3>Extended Job Searches</h3>
          <p>
            Interview anxiety extends job searches by 3-6 months. That's
            $50K-$150K in lost income while you "prepare more."
          </p>
        </div>
      </div>

      <div class="monetary-reality">
        <p>
          <strong>The uncomfortable truth:</strong> The difference between you and
          the candidate who got the offer isn't skill—it's performance under pressure.
          One bad interview can cost you <strong>$100K+ in compensation</strong>
          and set your career back years.
        </p>
      </div>

      <div class="section-cta">
        <Button
          href="/en/quiz/high-stakes/question/1"
          variant="primary"
          size="lg"
          class="gold-cta"
        >
          Discover Your Pressure Gaps in 90 Seconds →
        </Button>
      </div>
    </div>
  </section>

  <!-- SECTION 2: The 3 Gaps -->
  <section class="gaps-section">
    <div class="container">
      <h2>
        The 3 Performance Dimensions That Separate "Almost Hired" from "You're
        Our Top Choice"
      </h2>
      <p class="section-intro">
        This assessment measures the exact skills that determine whether you
        freeze or flow when career-defining moments arrive.
      </p>

      <div class="gap-cards">
        <div class="gap-card">
          <div class="gap-header">
            <Theater size={40} class="gap-icon" />
            <h3>Gap #1: Stage Presence</h3>
            <span class="gap-subtitle"
              >Command the Room or Apologize for Existing</span
            >
          </div>
          <p class="gap-description">
            The first 30 seconds of an interview or presentation determine 80%
            of the outcome. Presence isn't about charisma—it's about projecting
            authority even when your heart is racing.
          </p>
          <div class="what-we-measure">
            <h4>What we measure:</h4>
            <ul>
              <li>Opening strength (confident entry vs. apologetic hedging)</li>
              <li>Vocal authority under pressure (pace, pauses, projection)</li>
              <li>Recovery patterns when you lose your train of thought</li>
            </ul>
          </div>
          <p class="why-matters">
            <strong>Why it matters:</strong> Interviewers decide "hire" or "pass"
            in the first minutes. If you start with "Sorry, I'm a little nervous"
            or speak too fast, you've already lost ground you'll never recover.
          </p>
        </div>

        <div class="gap-card">
          <div class="gap-header">
            <Zap size={40} class="gap-icon" />
            <h3>Gap #2: Processing Speed</h3>
            <span class="gap-subtitle">The Freeze/Flow Factor</span>
          </div>
          <p class="gap-description">
            When an interviewer throws a curveball question, your brain has 2
            seconds to respond before the pause becomes awkward. If you're still
            translating from your native language, you've already lost.
          </p>
          <div class="what-we-measure">
            <h4>What we measure:</h4>
            <ul>
              <li>Response latency on unexpected questions</li>
              <li>Ability to think out loud without freezing</li>
              <li>Recovery speed after a mental blank</li>
            </ul>
          </div>
          <p class="why-matters">
            <strong>Why it matters:</strong> Processing speed is the #1 predictor
            of interview success for non-native speakers. It's not about having perfect
            answers—it's about having <em>any</em> answer without a 10-second freeze.
          </p>
        </div>

        <div class="gap-card">
          <div class="gap-header">
            <Target size={40} class="gap-icon" />
            <h3>Gap #3: Persuasive Impact</h3>
            <span class="gap-subtitle">Information vs. Inspiration</span>
          </div>
          <p class="gap-description">
            Most candidates answer questions. Top candidates move the room.
            Persuasive impact is the difference between "solid candidate" and
            "we need to hire this person before someone else does."
          </p>
          <div class="what-we-measure">
            <h4>What we measure:</h4>
            <ul>
              <li>Storytelling structure (STAR method execution)</li>
              <li>Emotional resonance and strategic framing</li>
              <li>Closing strength (landing the plane with impact)</li>
            </ul>
          </div>
          <p class="why-matters">
            <strong>Why it matters:</strong> In a final round with 3 qualified candidates,
            the offer goes to whoever makes the interviewers <em>feel</em>
            something. Information is forgettable. Stories are memorable.
          </p>
        </div>
      </div>

      <div class="section-cta">
        <Button
          href="/en/quiz/high-stakes/question/1"
          variant="primary"
          size="lg"
          class="gold-cta"
        >
          Take the 90-Second Assessment →
        </Button>
      </div>
    </div>
  </section>

  <!-- SECTION 3: Who This Is For -->
  <section class="who-section">
    <div class="container">
      <h2>Is This High-Stakes Assessment Right for You?</h2>

      <div class="who-grid">
        <div class="who-card designed-for">
          <h3>This assessment is designed for:</h3>
          <ul>
            <li>
              <strong>Job seekers</strong> preparing for final-round interviews at
              top companies
            </li>
            <li>
              <strong>Executives and founders</strong> pitching to investors, boards,
              or enterprise clients
            </li>
            <li>
              <strong>Professionals</strong> preparing for keynotes, conferences,
              or high-visibility presentations
            </li>
            <li>
              <strong>Career transitioners</strong> entering English-dominant markets
              for the first time
            </li>
            <li>
              <strong>Anyone</strong> whose English is fine in casual settings but
              breaks under pressure
            </li>
          </ul>
        </div>

        <div class="who-card ready-if">
          <h3>You're ready for this assessment if:</h3>
          <ul class="checkmark-list">
            <li>
              You've lost job offers despite being qualified because you "didn't
              interview well"
            </li>
            <li>
              You avoid high-visibility opportunities because you're afraid of
              freezing
            </li>
            <li>
              You over-prepare scripts and then sound robotic and inauthentic
            </li>
            <li>Your mind goes blank when asked unexpected questions</li>
            <li>
              You know you're smarter than how you come across in English under
              pressure
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- SECTION 4: Comparison Table -->
  <section class="comparison-section">
    <div class="container">
      <h2>The Performance Gap Between "Almost" and "Hired"</h2>
      <p class="section-intro">
        The candidates who land offers don't have better skills—they perform
        better when it counts.
      </p>

      <div class="comparison-table-wrapper">
        <table class="comparison-table">
          <thead>
            <tr>
              <th>Freezing Under Pressure</th>
              <th>Flowing Under Pressure</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>Long pauses while translating internally</td>
              <td>Think out loud in English without hesitation</td>
            </tr>
            <tr>
              <td>Over-prepare scripts, sound robotic</td>
              <td>Prepare frameworks, sound natural and adaptive</td>
            </tr>
            <tr>
              <td>Ramble when nervous, lose the thread</td>
              <td>Deliver structured 60-second stories with impact</td>
            </tr>
            <tr>
              <td>Apologize for accent or nervousness</td>
              <td>Project authority from the first sentence</td>
            </tr>
            <tr>
              <td>Leave interviews hoping they "saw past" the nerves</td>
              <td>Leave interviews knowing you commanded the room</td>
            </tr>
          </tbody>
        </table>
      </div>

      <p class="comparison-conclusion">
        <strong>The difference?</strong> High-stakes performers trained their pressure
        response. It's a skill—and it can be learned.
      </p>

      <div class="section-cta">
        <Button
          href="/en/quiz/high-stakes/question/1"
          variant="primary"
          size="lg"
          class="gold-cta"
        >
          Find Your Gaps. Fix Them. Perform. →
        </Button>
      </div>
    </div>
  </section>

  <!-- SECTION 5: Testimonials -->
  <section class="testimonials-section">
    <div class="container">
      <h2>Trusted by 200+ Professionals Who Stopped Freezing</h2>

      <div class="testimonials-grid">
        {
          testimonials.map((testimonial) => (
            <div class="testimonial-card">
              <blockquote>"{testimonial.quote}"</blockquote>
              <div class="testimonial-author">
                <strong>{testimonial.name}</strong>
                <span>{testimonial.title}</span>
                <span class="location">{testimonial.location}</span>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- SECTION 6: FAQ -->
  <section class="faq-section">
    <div class="container">
      <h2>Frequently Asked Questions</h2>
      {
        faqs.map((faq) => (
          <details class="faq-item">
            <summary>
              <h3>{faq.question}</h3>
              <ChevronDown size={20} class="chevron" />
            </summary>
            <div class="faq-answer">
              <p>{faq.answer}</p>
            </div>
          </details>
        ))
      }
    </div>
  </section>

  <!-- SECTION 7: Final CTA -->
  <section class="final-cta-section">
    <div class="container">
      <h2>Your Next Interview Doesn't Have to Feel Like a Hostage Situation</h2>
      <p class="final-cta-text">
        The professionals who land dream jobs and command keynote stages aren't
        more talented than you. They trained their pressure response. They
        learned to flow instead of freeze. They stopped letting anxiety steal
        opportunities they'd earned.
      </p>
      <p class="final-cta-highlight">Your 90-second assessment starts now.</p>
      <div class="cta-center">
        <Button
          href="/en/quiz/high-stakes/question/1"
          variant="primary"
          size="lg"
          class="gold-cta"
        >
          Take the Assessment →
        </Button>
      </div>
      <p class="trust-final">
        90 seconds. Instant results. Zero risk. Join 200+ professionals who
        stopped freezing.
      </p>
    </div>
  </section>

  <style>
    /* Hero Section with Background Image */
    .hero {
      position: relative;
      padding: 10rem 1.5rem 6rem;
      min-height: 100vh;
      display: flex;
      align-items: center;
      overflow: hidden;
    }

    .hero-bg-image {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: center;
      z-index: 0;
    }

    /* Mobile: shift image right to show Empire State Building */
    @media (max-width: 767px) {
      .hero-bg-image {
        object-position: 75% center;
      }
    }

    .hero-overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(
        135deg,
        rgba(15, 23, 42, 0.5) 0%,
        rgba(30, 41, 59, 0.4) 100%
      );
      z-index: 1;
    }

    @media (min-width: 768px) {
      .hero-overlay {
        background: linear-gradient(
          to right,
          rgba(15, 23, 42, 0.65) 0%,
          rgba(15, 23, 42, 0.55) 50%,
          rgba(30, 41, 59, 0.45) 100%
        );
      }
    }

    .container {
      max-width: 1200px;
      margin: 0 auto;
      width: 100%;
      position: relative;
      z-index: 2;
    }

    .hero-content {
      max-width: 650px;
      display: flex;
      flex-direction: column;
      gap: 1.5rem;
    }

    @media (min-width: 1024px) {
      .hero-content {
        max-width: 700px;
      }
    }

    .eyebrow {
      display: inline-block;
      font-size: 0.875rem;
      font-weight: 700;
      color: #0f172a;
      background: rgba(251, 191, 36, 0.95);
      padding: 0.625rem 1.25rem;
      border-radius: 9999px;
      width: fit-content;
      box-shadow: 0 4px 12px rgba(251, 191, 36, 0.3);
      letter-spacing: 0.025em;
      text-transform: uppercase;
    }

    h1 {
      font-size: 2.5rem;
      font-weight: 900;
      line-height: 1.1;
      color: #ffffff;
      margin: 0;
      text-shadow: 0 2px 8px rgba(0, 0, 0, 0.3);
    }

    @media (min-width: 768px) {
      h1 {
        font-size: 3.5rem;
      }
    }

    @media (min-width: 1024px) {
      h1 {
        font-size: 4rem;
      }
    }

    .discover-label {
      font-size: 1.125rem;
      color: #f1f5f9;
      margin: 0 0 0.5rem 0;
      font-weight: 500;
      text-shadow: 0px 1px 3px rgba(0, 0, 0, 0.8);
    }

    .benefits {
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
      margin: 1rem 0;
    }

    .benefit {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      font-size: 1.0625rem;
      color: #ffffff;
      font-weight: 500;
      text-shadow: 0px 1px 3px rgba(0, 0, 0, 0.8);
    }

    .benefit :global(svg) {
      color: #10b981;
      flex-shrink: 0;
      filter: drop-shadow(0 2px 4px rgba(16, 185, 129, 0.5));
    }

    .trust-line {
      font-size: 0.9375rem;
      color: #cbd5e1;
      text-align: center;
      margin-top: 1rem;
      font-weight: 500;
      text-shadow: 0px 1px 2px rgba(0, 0, 0, 0.6);
    }

    /* Gold CTA Button Override */
    :global(.gold-cta) {
      background: linear-gradient(135deg, #fbbf24 0%, #f59e0b 100%) !important;
      color: #0f172a !important;
      font-weight: 700 !important;
      box-shadow: 0 4px 16px rgba(251, 191, 36, 0.4) !important;
      border: none !important;
    }

    :global(.gold-cta:hover) {
      background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%) !important;
      transform: translateY(-2px);
      box-shadow: 0 6px 20px rgba(251, 191, 36, 0.5) !important;
    }

    /* Shared Section Styles */
    .section-intro {
      font-size: 1.125rem;
      color: #475569;
      text-align: center;
      max-width: 800px;
      margin: 0 auto 2.5rem;
      line-height: 1.7;
    }

    .section-cta {
      text-align: center;
      margin-top: 2.5rem;
    }

    .cta-center {
      text-align: center;
      margin-top: 2rem;
    }

    /* SECTION 1: Business Case */
    .business-case-section {
      padding: 4rem 1.5rem;
      background: white;
    }

    .business-case-section h2 {
      font-size: 2rem;
      font-weight: 700;
      color: #1e293b;
      text-align: center;
      margin-bottom: 1rem;
    }

    .cost-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 1.5rem;
      max-width: 1000px;
      margin: 0 auto 2.5rem;
    }

    @media (min-width: 768px) {
      .cost-grid {
        grid-template-columns: repeat(2, 1fr);
      }
    }

    @media (min-width: 1024px) {
      .cost-grid {
        grid-template-columns: repeat(4, 1fr);
      }
    }

    .cost-item {
      background: #f8fafc;
      border: 1px solid #e2e8f0;
      border-radius: 1rem;
      padding: 1.5rem;
      text-align: center;
    }

    .cost-icon {
      margin-bottom: 1rem;
      color: #ef4444;
    }

    .cost-item h3 {
      font-size: 1.125rem;
      font-weight: 600;
      color: #1e293b;
      margin-bottom: 0.5rem;
    }

    .cost-item p {
      font-size: 0.9375rem;
      color: #475569;
      line-height: 1.5;
      margin: 0;
    }

    .monetary-reality {
      background: linear-gradient(135deg, #fef3c7 0%, #fde68a 100%);
      border: 2px solid #f59e0b;
      border-radius: 1rem;
      padding: 1.5rem 2rem;
      max-width: 800px;
      margin: 0 auto;
      text-align: center;
    }

    .monetary-reality p {
      font-size: 1.125rem;
      color: #78350f;
      margin: 0;
      line-height: 1.6;
    }

    /* SECTION 2: Gaps Section */
    .gaps-section {
      padding: 4rem 1.5rem;
      background: #f8fafc;
    }

    .gaps-section h2 {
      font-size: 2rem;
      font-weight: 700;
      color: #1e293b;
      text-align: center;
      margin-bottom: 1rem;
    }

    .gap-cards {
      display: flex;
      flex-direction: column;
      gap: 2rem;
      max-width: 900px;
      margin: 0 auto;
    }

    .gap-card {
      background: white;
      border: 1px solid #e2e8f0;
      border-radius: 1rem;
      padding: 2rem;
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
    }

    .gap-header {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      gap: 1rem;
      margin-bottom: 1rem;
      padding-bottom: 1rem;
      border-bottom: 1px solid #e2e8f0;
    }

    .gap-header :global(.gap-icon) {
      color: #3b82f6;
    }

    .gap-header h3 {
      font-size: 1.375rem;
      font-weight: 700;
      color: #1e293b;
      margin: 0;
    }

    .gap-subtitle {
      font-size: 1rem;
      color: #64748b;
      font-style: italic;
    }

    .gap-description {
      font-size: 1rem;
      color: #475569;
      line-height: 1.6;
      margin-bottom: 1.5rem;
    }

    .what-we-measure {
      background: #f8fafc;
      border-radius: 0.5rem;
      padding: 1.25rem;
      margin-bottom: 1.5rem;
    }

    .what-we-measure h4 {
      font-size: 0.875rem;
      font-weight: 600;
      color: #1e293b;
      text-transform: uppercase;
      letter-spacing: 0.05em;
