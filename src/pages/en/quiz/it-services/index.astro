---
/**
 * IT English Assessment Landing Page
 * URL: /en/quiz/it-services/
 * Target Keyword: English for IT Professionals / Technical Communication Skills
 */
export const prerender = true;

import Base from "@layouts/Base.astro";
import Button from "@components/ui/Button.astro";
import QuizSchema from "@components/seo/QuizSchema.astro";
import {
  CheckCircle,
  Clock,
  TrendingUp,
  ChevronDown,
  MessageSquare,
  Zap,
  Globe,
  GitPullRequest,
  Users,
} from "lucide-astro";
import heroSkyline from "@assets/images/home/new-york-city-skyline.webp";

// SEO metadata - optimized for 50-60 characters title, 150-160 chars description
const title = "Technical Authority Score | Senior Developer Assessment";
const description =
  "Your code is Senior-Level. Your English sounds Junior. Is a language barrier capping your growth to Staff Engineer? Measure your Technical Persuasion Score in 90 seconds.";

// FAQ data for SEO content
const faqs = [
  {
    question: "How long does the technical communication assessment take?",
    answer:
      "90 seconds. You'll answer 6 targeted questions and receive your Technical Authority Score (0-100) plus a personalized gap analysis immediately after.",
  },
  {
    question: "Is this just another grammar or accent test?",
    answer:
      "No. This assessment measures the communication patterns that determine promotion velocity—how you explain architecture decisions, lead code reviews, and influence technical direction. Grammar and accent are irrelevant if your ideas consistently get deprioritized.",
  },
  {
    question: "What will I receive after completing the assessment?",
    answer:
      "Your Technical Authority Score (0-100), analysis of your strengths and gaps across three dimensions (Technical Translation, Processing Speed, and Cultural Calibration), plus a personalized 30-day roadmap with specific exercises to accelerate your communication mastery.",
  },
  {
    question: "Who should take this assessment?",
    answer:
      "Senior developers, software engineers, and tech leads working with North American teams—whether at FAANG, startups, or remote-first companies. If you're technically strong but your ideas don't get the traction they deserve, this assessment is for you.",
  },
  {
    question: "Will this help me pass FAANG interviews?",
    answer:
      "Yes. Big tech interviews aren't just about algorithms—they evaluate your ability to think out loud, explain trade-offs, and collaborate under pressure. This assessment identifies your 'processing speed' gaps and provides a roadmap to improve interview performance.",
  },
  {
    question: "What happens after I get my results?",
    answer:
      "You'll receive an email with your detailed scorecard and the option to book a free 20-minute consultation to discuss your personalized roadmap for technical leadership communication.",
  },
];

// Testimonials data
const testimonials = [
  {
    quote:
      "I went from 'that quiet senior dev' to leading architecture discussions in 3 months. The processing speed exercises changed everything.",
    name: "Miguel S.",
    title: "Staff Engineer, Fintech Startup",
    location: "Mexico City → Remote (US)",
  },
  {
    quote:
      "Failed 3 FAANG interviews before this. Finally understood why—my explanations were technically correct but 2x too long. Landed at Google on my next attempt.",
    name: "Ana R.",
    title: "Software Engineer, Google",
    location: "São Paulo → Bay Area",
  },
  {
    quote:
      "My PRs used to get buried. Now I'm the one approving them. The cultural calibration module was a game-changer for async communication.",
    name: "Carlos M.",
    title: "Tech Lead, Series B SaaS",
    location: "Guadalajara",
  },
];
---

<Base
  title={title}
  description={description}
  lang="en"
  tkey="quiz/it-services"
  hideCta={true}
  hideNav={true}
>
  <QuizSchema lang="en" slot="head" />

  <!-- Hero Section with NYC Skyline Background -->
  <section class="hero">
    <img
      src={heroSkyline.src}
      alt="Technical Communication Assessment"
      class="hero-bg-image"
      loading="eager"
    />
    <div class="hero-overlay"></div>
    <div class="container">
      <div class="hero-content">
        <span class="eyebrow"
          >Your code is Senior-Level. Your English sounds Junior.</span
        >

        <h1>
          The 90-Second Assessment: Is a Language Barrier Capping Your Growth to
          Staff Engineer?
        </h1>

        <p class="discover-label">Three things you'll discover:</p>

        <div class="benefits">
          <div class="benefit">
            <CheckCircle size={20} />
            <span>Your Technical Persuasion Score (0-100)</span>
          </div>
          <div class="benefit">
            <CheckCircle size={20} />
            <span>Why your architecture proposals die in translation</span>
          </div>
          <div class="benefit">
            <CheckCircle size={20} />
            <span
              >The roadmap to explaining complex tech to non-technical execs</span
            >
          </div>
        </div>

        <Button
          href="/en/quiz/it-services/question/1"
          variant="primary"
          size="lg"
          class="cta-button gold-cta"
        >
          Start Free Assessment →
        </Button>

        <p class="trust-line">
          Quick. Insightful. Trusted by 200+ professionals seeking fluency and
          confidence.
        </p>
      </div>
    </div>
  </section>

  <!-- SECTION 1: The Business Case -->
  <section class="business-case-section">
    <div class="container">
      <h2>Why Technical Authority Is Your Hidden $150K Career Asset</h2>
      <p class="section-intro">
        Your LeetCode is sharp. Your system design is solid. But the engineers
        who get promoted aren't always the best coders—they're the ones whose
        ideas get heard.
      </p>

      <div class="cost-grid">
        <div class="cost-item">
          <div class="cost-icon"><TrendingUp size={32} /></div>
          <h3>Stuck at Senior</h3>
          <p>
            The IC5 → Staff promotion has a 70% fail rate at most companies.
            Technical skill is table stakes—communication is the differentiator.
          </p>
        </div>
        <div class="cost-item">
          <div class="cost-icon"><GitPullRequest size={32} /></div>
          <h3>Buried PRs</h3>
          <p>
            Your pull requests get approved, but your RFCs and architecture
            proposals get "deprioritized" or endlessly bikeshedded.
          </p>
        </div>
        <div class="cost-item">
          <div class="cost-icon"><Users size={32} /></div>
          <h3>Invisible in Meetings</h3>
          <p>
            By the time you've formulated your point in English, someone else
            has already said something similar—and gets the credit.
          </p>
        </div>
        <div class="cost-item">
          <div class="cost-icon"><Clock size={32} /></div>
          <h3>Interview Ceiling</h3>
          <p>
            You ace the coding rounds but get dinged on "communication" in
            system design and behavioral interviews.
          </p>
        </div>
      </div>

      <div class="monetary-reality">
        <p>
          <strong>The math is simple:</strong> The gap between Senior Engineer and
          Staff at a FAANG company? <strong>$150K-$300K annually</strong> in total
          comp. If communication gaps delay your promotion by 2 years, that's a
          <strong>$500K opportunity cost.</strong>
        </p>
      </div>

      <div class="section-cta">
        <Button
          href="/en/quiz/it-services/question/1"
          variant="primary"
          size="lg"
          class="gold-cta"
        >
          Discover Your Communication Gaps in 90 Seconds →
        </Button>
      </div>
    </div>
  </section>

  <!-- SECTION 2: The 3 Gaps -->
  <section class="gaps-section">
    <div class="container">
      <h2>
        The 3 Communication Dimensions That Separate Senior Devs from Staff
        Engineers
      </h2>
      <p class="section-intro">
        This assessment measures the exact skills that distinguish engineers who
        get promoted from engineers who get "more scope."
      </p>

      <div class="gap-cards">
        <div class="gap-card">
          <div class="gap-header">
            <MessageSquare size={40} class="gap-icon" />
            <h3>Gap #1: Technical Translation</h3>
            <span class="gap-subtitle">Complexity → Clarity in 60 Seconds</span>
          </div>
          <p class="gap-description">
            Staff engineers don't just understand systems—they translate
            complexity for PMs, executives, and cross-functional stakeholders
            without losing technical accuracy.
          </p>
          <div class="what-we-measure">
            <h4>What we measure:</h4>
            <ul>
              <li>
                Ability to explain technical debt to a CFO in business terms
              </li>
              <li>
                Distilling architecture decisions into 60-second summaries
              </li>
              <li>
                Writing RFCs that get approved, not endless comment threads
              </li>
            </ul>
          </div>
          <p class="why-matters">
            <strong>Why it matters:</strong> Your director has 5 minutes for your
            quarterly review. If you start with implementation details instead of
            business impact, you've already lost the promotion conversation.
          </p>
        </div>

        <div class="gap-card">
          <div class="gap-header">
            <Zap size={40} class="gap-icon" />
            <h3>Gap #2: Processing Speed</h3>
            <span class="gap-subtitle">Real-Time Technical Authority</span>
          </div>
          <p class="gap-description">
            In code reviews, incident response, and architecture discussions,
            hesitation reads as uncertainty. Your "thinking-in-English" speed
            directly impacts your perceived technical authority.
          </p>
          <div class="what-we-measure">
            <h4>What we measure:</h4>
            <ul>
              <li>Response latency in high-pressure technical discussions</li>
              <li>Ability to think out loud during system design interviews</li>
              <li>Confidence patterns in real-time debugging sessions</li>
            </ul>
          </div>
          <p class="why-matters">
            <strong>Why it matters:</strong> In a production incident, the engineer
            who speaks first shapes the response. If you're still translating while
            others are deciding, you're not leading.
          </p>
        </div>

        <div class="gap-card">
          <div class="gap-header">
            <Globe size={40} class="gap-icon" />
            <h3>Gap #3: Cultural Calibration</h3>
            <span class="gap-subtitle">Navigating the Unwritten Rules</span>
          </div>
          <p class="gap-description">
            North American tech culture has unwritten rules: directness without
            aggression, "disagree and commit," async-first communication. These
            patterns aren't taught—they're absorbed.
          </p>
          <div class="what-we-measure">
            <h4>What we measure:</h4>
            <ul>
              <li>
                PR comment tone (constructive vs. perceived as harsh or passive)
              </li>
              <li>Ability to push back on senior engineers diplomatically</li>
              <li>Slack/async communication patterns that build influence</li>
            </ul>
          </div>
          <p class="why-matters">
            <strong>Why it matters:</strong> A technically correct code review comment
            can still damage your reputation if the tone feels off. The engineers
            who get promoted know how to be direct without being dismissed.
          </p>
        </div>
      </div>

      <div class="section-cta">
        <Button
          href="/en/quiz/it-services/question/1"
          variant="primary"
          size="lg"
          class="gold-cta"
        >
          Take the 90-Second Assessment →
        </Button>
      </div>
    </div>
  </section>

  <!-- SECTION 3: Who This Is For -->
  <section class="who-section">
    <div class="container">
      <h2>Is This Technical Communication Assessment Right for You?</h2>

      <div class="who-grid">
        <div class="who-card designed-for">
          <h3>This assessment is designed for:</h3>
          <ul>
            <li>
              <strong>Senior developers (IC4-IC5)</strong> at FAANG, Big Tech, or
              high-growth startups
            </li>
            <li>
              <strong>Tech leads and engineering managers</strong> who lead distributed
              or cross-cultural teams
            </li>
            <li>
              <strong>Remote engineers</strong> working async-first with North American
              companies
            </li>
            <li>
              <strong>Engineers preparing for Big Tech interviews</strong> who want
              to nail the communication bar
            </li>
            <li>
              <strong>International developers</strong> with strong technical skills
              but English as a second language
            </li>
          </ul>
        </div>

        <div class="who-card ready-if">
          <h3>You're ready for this assessment if:</h3>
          <ul class="checkmark-list">
            <li>
              You're technically strong but your ideas don't get the traction
              they deserve
            </li>
            <li>
              You've been told you're "too quiet" in meetings or need to "speak
              up more"
            </li>
            <li>
              You can debug anything but struggle to explain your approach in
              real-time
            </li>
            <li>
              Your written English is solid, but you freeze in live discussions
            </li>
            <li>
              You've been passed over for Staff or Tech Lead despite strong
              technical output
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- SECTION 4: Comparison Table -->
  <section class="comparison-section">
    <div class="container">
      <h2>The Communication Gap Between Senior Devs and Staff Engineers</h2>
      <p class="section-intro">
        The engineers who reach Staff+ don't just write better code—they
        communicate with a different operating system.
      </p>

      <div class="comparison-table-wrapper">
        <table class="comparison-table">
          <thead>
            <tr>
              <th>Senior Developer Patterns</th>
              <th>Staff Engineer Communication</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>Over-explain to prove technical depth</td>
              <td>Lead with the "so what" and let others ask for details</td>
            </tr>
            <tr>
              <td>Wait for the "right moment" to speak (it never comes)</td>
              <td>Interject early with structured, concise points</td>
            </tr>
            <tr>
              <td>Write RFCs that are technically exhaustive but ignored</td>
              <td>Write RFCs that build consensus before they're published</td>
            </tr>
            <tr>
              <td>Get defensive when architecture is challenged</td>
              <td>Disagree and commit with explicit trade-off framing</td>
            </tr>
            <tr>
              <td>Ace coding rounds but get dinged on "communication"</td>
              <td>Think out loud in a way that demonstrates leadership</td>
            </tr>
          </tbody>
        </table>
      </div>

      <p class="comparison-conclusion">
        <strong>The difference?</strong> Staff engineers learned to communicate like
        leaders. It's a skill that can be trained—if you know your gaps.
      </p>

      <div class="section-cta">
        <Button
          href="/en/quiz/it-services/question/1"
          variant="primary"
          size="lg"
          class="gold-cta"
        >
          Find Your Gaps. Fix Them. Get Promoted. →
        </Button>
      </div>
    </div>
  </section>

  <!-- SECTION 5: Testimonials -->
  <section class="testimonials-section">
    <div class="container">
      <h2>Trusted by 200+ Senior Engineers</h2>

      <div class="testimonials-grid">
        {
          testimonials.map((testimonial) => (
            <div class="testimonial-card">
              <blockquote>"{testimonial.quote}"</blockquote>
              <div class="testimonial-author">
                <strong>{testimonial.name}</strong>
                <span>{testimonial.title}</span>
                <span class="location">{testimonial.location}</span>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- SECTION 6: FAQ -->
  <section class="faq-section">
    <div class="container">
      <h2>Frequently Asked Questions</h2>
      {
        faqs.map((faq) => (
          <details class="faq-item">
            <summary>
              <h3>{faq.question}</h3>
              <ChevronDown size={20} class="chevron" />
            </summary>
            <div class="faq-answer">
              <p>{faq.answer}</p>
            </div>
          </details>
        ))
      }
    </div>
  </section>

  <!-- SECTION 7: Final CTA -->
  <section class="final-cta-section">
    <div class="container">
      <h2>Your Code Is Already Good Enough for Staff</h2>
      <p class="final-cta-text">
        The engineers who get promoted to Staff, Principal, and beyond aren't
        always the best coders. They're the ones who learned to translate
        technical excellence into organizational influence. The ones whose ideas
        don't just ship—they shape direction.
      </p>
      <p class="final-cta-highlight">Your 90-second assessment starts now.</p>
      <div class="cta-center">
        <Button
          href="/en/quiz/it-services/question/1"
          variant="primary"
          size="lg"
          class="gold-cta"
        >
          Take the Assessment →
        </Button>
      </div>
      <p class="trust-final">
        90 seconds. Instant results. Zero risk. Trusted by engineers at Google,
        Meta, Amazon, and 50+ startups.
      </p>
    </div>
  </section>

  <style>
    /* Hero Section with Background Image */
    .hero {
      position: relative;
      padding: 10rem 1.5rem 6rem;
      min-height: 100vh;
      display: flex;
      align-items: center;
      overflow: hidden;
    }

    .hero-bg-image {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: center;
      z-index: 0;
    }

    /* Mobile: shift image right to show Empire State Building */
    @media (max-width: 767px) {
      .hero-bg-image {
        object-position: 75% center;
      }
    }

    .hero-overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(
        135deg,
        rgba(15, 23, 42, 0.5) 0%,
        rgba(30, 41, 59, 0.4) 100%
      );
      z-index: 1;
    }

    @media (min-width: 768px) {
      .hero-overlay {
        background: linear-gradient(
          to right,
          rgba(15, 23, 42, 0.65) 0%,
          rgba(15, 23, 42, 0.55) 50%,
          rgba(30, 41, 59, 0.45) 100%
        );
      }
    }

    .container {
      max-width: 1200px;
      margin: 0 auto;
      width: 100%;
      position: relative;
      z-index: 2;
    }

    .hero-content {
      max-width: 650px;
      display: flex;
      flex-direction: column;
      gap: 1.5rem;
    }

    @media (min-width: 1024px) {
      .hero-content {
        max-width: 700px;
      }
    }

    .eyebrow {
      display: inline-block;
      font-size: 0.875rem;
      font-weight: 700;
      color: #0f172a;
      background: rgba(251, 191, 36, 0.95);
      padding: 0.625rem 1.25rem;
      border-radius: 9999px;
      width: fit-content;
      box-shadow: 0 4px 12px rgba(251, 191, 36, 0.3);
      letter-spacing: 0.025em;
      text-transform: uppercase;
    }

    h1 {
      font-size: 2.5rem;
      font-weight: 900;
      line-height: 1.1;
      color: #ffffff;
      margin: 0;
      text-shadow: 0 2px 8px rgba(0, 0, 0, 0.3);
    }

    @media (min-width: 768px) {
      h1 {
        font-size: 3.5rem;
      }
    }

    @media (min-width: 1024px) {
      h1 {
        font-size: 4rem;
      }
    }

    .discover-label {
      font-size: 1.125rem;
      color: #f1f5f9;
      margin: 0 0 0.5rem 0;
      font-weight: 500;
      text-shadow: 0px 1px 3px rgba(0, 0, 0, 0.8);
    }

    .benefits {
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
      margin: 1rem 0;
    }

    .benefit {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      font-size: 1.0625rem;
      color: #ffffff;
      font-weight: 500;
      text-shadow: 0px 1px 3px rgba(0, 0, 0, 0.8);
    }

    .benefit :global(svg) {
      color: #10b981;
      flex-shrink: 0;
      filter: drop-shadow(0 2px 4px rgba(16, 185, 129, 0.5));
    }

    .trust-line {
      font-size: 0.9375rem;
      color: #cbd5e1;
      text-align: center;
      margin-top: 1rem;
      font-weight: 500;
      text-shadow: 0px 1px 2px rgba(0, 0, 0, 0.6);
    }

    /* Gold CTA Button Override */
    :global(.gold-cta) {
      background: linear-gradient(135deg, #fbbf24 0%, #f59e0b 100%) !important;
      color: #0f172a !important;
      font-weight: 700 !important;
      box-shadow: 0 4px 16px rgba(251, 191, 36, 0.4) !important;
      border: none !important;
    }

    :global(.gold-cta:hover) {
      background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%) !important;
      transform: translateY(-2px);
      box-shadow: 0 6px 20px rgba(251, 191, 36, 0.5) !important;
    }

    /* Shared Section Styles */
    .section-intro {
      font-size: 1.125rem;
      color: #475569;
      text-align: center;
      max-width: 800px;
      margin: 0 auto 2.5rem;
      line-height: 1.7;
    }

    .section-cta {
      text-align: center;
      margin-top: 2.5rem;
    }

    .cta-center {
      text-align: center;
      margin-top: 2rem;
    }

    /* SECTION 1: Business Case */
    .business-case-section {
      padding: 4rem 1.5rem;
      background: white;
    }

    .business-case-section h2 {
      font-size: 2rem;
      font-weight: 700;
      color: #1e293b;
      text-align: center;
      margin-bottom: 1rem;
    }

    .cost-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 1.5rem;
      max-width: 1000px;
      margin: 0 auto 2.5rem;
    }

    @media (min-width: 768px) {
      .cost-grid {
        grid-template-columns: repeat(2, 1fr);
      }
    }

    @media (min-width: 1024px) {
      .cost-grid {
        grid-template-columns: repeat(4, 1fr);
      }
    }

    .cost-item {
      background: #f8fafc;
      border: 1px solid #e2e8f0;
      border-radius: 1rem;
      padding: 1.5rem;
      text-align: center;
    }

    .cost-icon {
      margin-bottom: 1rem;
      color: #ef4444;
    }

    .cost-item h3 {
      font-size: 1.125rem;
      font-weight: 600;
      color: #1e293b;
      margin-bottom: 0.5rem;
    }

    .cost-item p {
      font-size: 0.9375rem;
      color: #475569;
      line-height: 1.5;
      margin: 0;
    }

    .monetary-reality {
      background: linear-gradient(135deg, #fef3c7 0%, #fde68a 100%);
      border: 2px solid #f59e0b;
      border-radius: 1rem;
      padding: 1.5rem 2rem;
      max-width: 800px;
      margin: 0 auto;
      text-align: center;
    }

    .monetary-reality p {
      font-size: 1.125rem;
      color: #78350f;
      margin: 0;
      line-height: 1.6;
    }

    /* SECTION 2: Gaps Section */
    .gaps-section {
      padding: 4rem 1.5rem;
      background: #f8fafc;
    }

    .gaps-section h2 {
      font-size: 2rem;
      font-weight: 700;
      color: #1e293b;
      text-align: center;
      margin-bottom: 1rem;
    }

    .gap-cards {
      display: flex;
      flex-direction: column;
      gap: 2rem;
      max-width: 900px;
      margin: 0 auto;
    }

    .gap-card {
      background: white;
      border: 1px solid #e2e8f0;
      border-radius: 1rem;
      padding: 2rem;
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
    }

    .gap-header {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      gap: 1rem;
      margin-bottom: 1rem;
      padding-bottom: 1rem;
      border-bottom: 1px solid #e2e8f0;
    }

    .gap-header :global(.gap-icon) {
      color: #3b82f6;
    }

    .gap-header h3 {
      font-size: 1.375rem;
      font-weight: 700;
      color: #1e293b;
      margin: 0;
    }

    .gap-subtitle {
      font-size: 1rem;
      color: #64748b;
      font-style: italic;
    }

    .gap-description {
      font-size: 1rem;
      color: #475569;
      line-height: 1.6;
      margin-bottom: 1.5rem;
    }

    .what-we-measure {
      background: #f8fafc;
      border-radius: 0.5rem;
      padding: 1.25rem;
      margin-bottom: 1.5rem;
    }

    .what-we-measure h4 {
      font-size: 0.875rem;
      font-weight: 600;
      color: #1e293b;
      text-transform: uppercase;
      letter-spacing: 0.05em;
