---
/**
 * Executive Communication Assessment Landing Page
 * URL: /en/quiz/executives/
 * Target Keyword: Business English for Executives / Leadership Communication
 */

export const prerender = true;

import Base from "@layouts/Base.astro";
import Button from "@components/ui/Button.astro";
import QuizSchema from "@components/seo/QuizSchema.astro";
import {
  Briefcase,
  CheckCircle,
  Clock,
  TrendingUp,
  ChevronDown,
  Target,
  Mic,
  Scale,
} from "lucide-astro";
import heroSkyline from "@assets/images/home/new-york-city-skyline.webp";

// SEO metadata - optimized for 50-60 characters title, 150-160 chars description
const title = "C-Suite Influence Score | Executive English Quiz";
const description =
  "You command respect in your native language. Do you lose it in English? Measure your Bilingual Leadership Gap in 90 seconds.";

// FAQ data for SEO content
const faqs = [
  {
    question: "How long does the executive English assessment take?",
    answer:
      "90 seconds. You'll receive your Executive Influence Score (0-100) and personalized roadmap immediately after completing the assessment.",
  },
  {
    question: "Is this just a grammar or accent test?",
    answer:
      "No. This assessment measures strategic communication skills—how you lead meetings, negotiate, and command authority. Grammar and accent are irrelevant if your message is unclear or your presence is weak.",
  },
  {
    question: "What will I receive after completing the assessment?",
    answer:
      "Your Executive Influence Score (0-100), analysis of your strengths and gaps across Strategic Clarity, Executive Presence, and Negotiation Power, plus a personalized roadmap with specific next steps to accelerate your executive communication mastery.",
  },
  {
    question: "Who should take this executive communication assessment?",
    answer:
      "Latin American executives, directors, and business owners who work with North American clients, boards, or investors. If you're fluent in English but know your communication style sometimes undermines your authority, this assessment is for you.",
  },
  {
    question: "Is my information confidential?",
    answer:
      "Yes. Your assessment results are completely private and will never be shared without your permission.",
  },
  {
    question: "What happens after I get my results?",
    answer:
      "You'll receive an email with your detailed scorecard and the option to book a free 20-minute consultation to discuss your personalized roadmap for executive English mastery.",
  },
];

// Testimonials data
const testimonials = [
  {
    quote:
      "Robert's coaching helped me land my first board seat. The 'so what' framework transformed how I present strategy to investors.",
    name: "Maria C.",
    title: "VP Strategy, Tech Startup",
    location: "Mexico City",
  },
  {
    quote:
      "I closed a $12M partnership using the negotiation techniques from this program. The ROI was immediate.",
    name: "Carlos R.",
    title: "Business Development Director, SaaS",
    location: "Guadalajara",
  },
  {
    quote:
      "After 15 years in tech, I finally feel like my English matches my expertise. The executive presence training changed everything.",
    name: "Ana L.",
    title: "CTO, Fintech",
    location: "São Paulo",
  },
];
---

<Base
  title={title}
  description={description}
  lang="en"
  tkey="quiz/executives"
  hideCta={true}
  hideNav={true}
>
  <QuizSchema lang="en" slot="head" />

  <!-- Hero Section with NYC Skyline Background -->
  <section class="hero">
    <img
      src={heroSkyline.src}
      alt="Executive Communication Assessment"
      class="hero-bg-image"
      loading="eager"
    />
    <div class="hero-overlay"></div>
    <div class="container">
      <div class="hero-content">
        <span class="eyebrow">The 90-Second Assessment</span>

        <h1>Measure Your Bilingual Leadership Gap</h1>

        <p class="discover-label">Three things you'll discover:</p>

        <div class="benefits">
          <div class="benefit">
            <CheckCircle size={20} />
            <span
              >Your True Authority Score (vs. your English Perceived Score)</span
            >
          </div>
          <div class="benefit">
            <CheckCircle size={20} />
            <span>Why you lose your persuasive edge in complex meetings</span>
          </div>
          <div class="benefit">
            <CheckCircle size={20} />
            <span>Your roadmap to commanding the room in any language</span>
          </div>
        </div>

        <Button
          href="/en/quiz/executives/question/1"
          variant="primary"
          size="lg"
          class="cta-button gold-cta"
        >
          Start Free Assessment →
        </Button>

        <p class="trust-line">
          Quick. Insightful. Trusted by 200+ professionals seeking fluency and
          confidence.
        </p>
      </div>
    </div>
  </section>

  <!-- SECTION 1: The Business Case (SEO + Conversion) -->
  <section class="business-case-section">
    <div class="container">
      <h2>Why Executive English Mastery Is Your Hidden $500K Career Asset</h2>
      <p class="section-intro">
        Your technical expertise got you here. Your English fluency determines
        how far you go.
      </p>

      <div class="cost-grid">
        <div class="cost-item">
          <div class="cost-icon"><TrendingUp size={32} /></div>
          <h3>Missed Promotions</h3>
          <p>
            67% of executives report English proficiency as a promotion barrier
            for non-native speakers in North American markets.
          </p>
        </div>
        <div class="cost-item">
          <div class="cost-icon"><Scale size={32} /></div>
          <h3>Lost Deals</h3>
          <p>
            High-stakes negotiations fail when you can't disagree diplomatically
            or close with authority.
          </p>
        </div>
        <div class="cost-item">
          <div class="cost-icon"><Mic size={32} /></div>
          <h3>Diminished Influence</h3>
          <p>
            Board presentations that run too long or lack strategic clarity cost
            you credibility—and internal champions.
          </p>
        </div>
        <div class="cost-item">
          <div class="cost-icon"><Clock size={32} /></div>
          <h3>Slower Career Velocity</h3>
          <p>
            The gap between director and VP? Often 60 seconds of executive
            presence.
          </p>
        </div>
      </div>

      <div class="monetary-reality">
        <p>
          <strong>The monetary reality:</strong> The difference between VP and C-suite
          compensation in North American markets? <strong
            >$200K-$500K annually.</strong
          > If communication gaps delay your promotion by just 2 years, that's a
          <strong>$1M opportunity cost.</strong>
        </p>
      </div>

      <div class="section-cta">
        <Button
          href="/en/quiz/executives/question/1"
          variant="primary"
          size="lg"
          class="gold-cta"
        >
          Discover Your Communication Gaps in 90 Seconds →
        </Button>
      </div>
    </div>
  </section>

  <!-- SECTION 2: The 3 Executive Gaps (Keyword-Rich) -->
  <section class="gaps-section">
    <div class="container">
      <h2>
        The 3 Executive Communication Dimensions That Separate Managers from
        C-Suite Leaders
      </h2>
      <p class="section-intro">
        This executive English assessment measures the precise skills that North
        American boards, investors, and C-suite peers use to evaluate leadership
        readiness.
      </p>

      <div class="gap-cards">
        <div class="gap-card">
          <div class="gap-header">
            <Target size={40} class="gap-icon" />
            <h3>Gap #1: Strategic Clarity</h3>
            <span class="gap-subtitle">Can You Lead with the 'So What'?</span>
          </div>
          <p class="gap-description">
            Executive communication isn't about saying more—it's about saying
            less, with precision.
          </p>
          <div class="what-we-measure">
            <h4>What we measure:</h4>
            <ul>
              <li>
                Ability to distill complex strategies into 60-second board
                updates
              </li>
              <li>Leading with conclusions, not chronology</li>
              <li>Eliminating filler that signals uncertainty</li>
            </ul>
          </div>
          <p class="why-matters">
            <strong>Why it matters:</strong> CEOs have 7 minutes of attention for
            your quarterly review. If you start with background instead of impact,
            you've already lost the room.
          </p>
        </div>

        <div class="gap-card">
          <div class="gap-header">
            <Mic size={40} class="gap-icon" />
            <h3>Gap #2: Executive Presence</h3>
            <span class="gap-subtitle">Authority, Not Apology</span>
          </div>
          <p class="gap-description">
            Your tone, pace, and word choice signal whether you belong in the
            C-suite—or still need "development."
          </p>
          <div class="what-we-measure">
            <h4>What we measure:</h4>
            <ul>
              <li>Unconscious hedging language ("I think," "maybe," "just")</li>
              <li>Vocal authority and intentional pauses</li>
              <li>Confidence vs. over-explanation patterns</li>
            </ul>
          </div>
          <p class="why-matters">
            <strong>Why it matters:</strong> Research shows non-native English speakers
            over-explain by 40% compared to native speakers—a pattern that reads
            as insecurity, not thoroughness.
          </p>
        </div>

        <div class="gap-card">
          <div class="gap-header">
            <Scale size={40} class="gap-icon" />
            <h3>Gap #3: Negotiation Power</h3>
            <span class="gap-subtitle"
              >Closing Deals Without Conceding Ground</span
            >
          </div>
          <p class="gap-description">
            High-stakes negotiations require you to disagree diplomatically,
            handle objections, and hold your position—without damaging critical
            relationships.
          </p>
          <div class="what-we-measure">
            <h4>What we measure:</h4>
            <ul>
              <li>Ability to interrupt or redirect conversations smoothly</li>
              <li>Assertive language that maintains warmth</li>
              <li>Closing techniques that create urgency without pressure</li>
            </ul>
          </div>
          <p class="why-matters">
            <strong>Why it matters:</strong> In North American business culture,
            "polite" can be mistaken for "pushover." The executives who close 8-figure
            deals know how to be firm without being harsh.
          </p>
        </div>
      </div>

      <div class="section-cta">
        <Button
          href="/en/quiz/executives/question/1"
          variant="primary"
          size="lg"
          class="gold-cta"
        >
          Take the 90-Second Assessment →
        </Button>
      </div>
    </div>
  </section>

  <!-- SECTION 3: Who This Is For (SEO + Qualification) -->
  <section class="who-section">
    <div class="container">
      <h2>Is This Executive English Assessment Right for You?</h2>

      <div class="who-grid">
        <div class="who-card designed-for">
          <h3>This assessment is designed for:</h3>
          <ul>
            <li>
              <strong>Latin American executives</strong> working with North American
              clients, boards, or investors
            </li>
            <li>
              <strong>VP/Director-level professionals</strong> positioning for C-suite
              roles
            </li>
            <li>
              <strong>Business owners and entrepreneurs</strong> negotiating high-stakes
              partnerships or funding
            </li>
            <li>
              <strong>Technical experts</strong> (engineers, scientists, finance
              professionals) transitioning to leadership
            </li>
            <li>
              <strong>Non-native English speakers</strong> with advanced fluency
              who want executive-level mastery
            </li>
          </ul>
        </div>

        <div class="who-card ready-if">
          <h3>You're ready for this assessment if:</h3>
          <ul class="checkmark-list">
            <li>
              You're fluent in English but know your accent or phrasing
              sometimes undermines your authority
            </li>
            <li>
              You've been told you're "too detailed" or "need to get to the
              point faster"
            </li>
            <li>
              You can handle casual business English but struggle in
              high-pressure negotiations or board presentations
            </li>
            <li>
              You're preparing for a promotion that will require more visibility
              with North American stakeholders
            </li>
            <li>
              You've invested in general business English training but need
              executive-specific communication coaching
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- SECTION 4: Comparison Table -->
  <section class="comparison-section">
    <div class="container">
      <h2>The Communication Gap Between Managers and C-Suite Leaders</h2>
      <p class="section-intro">
        The executives who command boardrooms don't just speak English—they
        wield it strategically.
      </p>

      <div class="comparison-table-wrapper">
        <table class="comparison-table">
          <thead>
            <tr>
              <th>Common Patterns (Manager-Level)</th>
              <th>Executive-Level Communication</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>Over-explain to compensate for accent or uncertainty</td>
              <td>Deliver 60-second updates with zero fluff</td>
            </tr>
            <tr>
              <td>Use hedging language ("maybe," "I think," "possibly")</td>
              <td>Command attention with declarative statements</td>
            </tr>
            <tr>
              <td>Struggle to interrupt or redirect senior stakeholders</td>
              <td>Redirect conversations smoothly with diplomatic authority</td>
            </tr>
            <tr>
              <td>Concede ground quickly to avoid conflict</td>
              <td>Negotiate assertively while maintaining relationships</td>
            </tr>
            <tr>
              <td>Miss promotions despite strong business acumen</td>
              <td>Build cross-cultural influence instantly</td>
            </tr>
          </tbody>
        </table>
      </div>

      <p class="comparison-conclusion">
        <strong>The difference?</strong> Executive communication training that addresses
        the specific challenges non-native speakers face in North American business
        culture.
      </p>

      <div class="section-cta">
        <Button
          href="/en/quiz/executives/question/1"
          variant="primary"
          size="lg"
          class="gold-cta"
        >
          Find Your Gaps. Fix Them. Lead. →
        </Button>
      </div>
    </div>
  </section>

  <!-- SECTION 5: Social Proof / Testimonials -->
  <section class="testimonials-section">
    <div class="container">
      <h2>Trusted by 200+ Global Executives</h2>

      <div class="testimonials-grid">
        {
          testimonials.map((testimonial) => (
            <div class="testimonial-card">
              <blockquote>"{testimonial.quote}"</blockquote>
              <div class="testimonial-author">
                <strong>{testimonial.name}</strong>
                <span>{testimonial.title}</span>
                <span class="location">{testimonial.location}</span>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- SECTION 6: FAQ (SEO Gold Mine) -->
  <section class="faq-section">
    <div class="container">
      <h2>Frequently Asked Questions About the Executive English Assessment</h2>
      {
        faqs.map((faq) => (
          <details class="faq-item">
            <summary>
              <h3>{faq.question}</h3>
              <ChevronDown size={20} class="chevron" />
            </summary>
            <div class="faq-answer">
              <p>{faq.answer}</p>
            </div>
          </details>
        ))
      }
    </div>
  </section>

  <!-- SECTION 7: Final CTA (Strong Close) -->
  <section class="final-cta-section">
    <div class="container">
      <h2>Don't Let Communication Gaps Cost You Your Next Promotion</h2>
      <p class="final-cta-text">
        The executives who lead with clarity, negotiate with authority, and
        command boardrooms didn't get there by accident. They mastered the
        strategic communication skills that North American business culture
        demands.
      </p>
      <p class="final-cta-highlight">Your 90-second assessment starts now.</p>
      <div class="cta-center">
        <Button
          href="/en/quiz/executives/question/1"
          variant="primary"
          size="lg"
          class="gold-cta"
        >
          Take the Assessment →
        </Button>
      </div>
      <p class="trust-final">
        90 seconds. Instant results. Zero risk. Trusted by 200+ global
        executives.
      </p>
    </div>
  </section>

  <style>
    /* Hero Section with Background Image */
    .hero {
      position: relative;
      padding: 10rem 1.5rem 6rem;
      min-height: 100vh;
      display: flex;
      align-items: center;
      overflow: hidden;
    }

    .hero-bg-image {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: center;
      z-index: 0;
    }

    /* Mobile: shift image right to show Empire State Building */
    @media (max-width: 767px) {
      .hero-bg-image {
        object-position: 75% center;
      }
    }

    .hero-overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(
        135deg,
        rgba(15, 23, 42, 0.5) 0%,
        rgba(30, 41, 59, 0.4) 100%
      );
      z-index: 1;
    }

    @media (min-width: 768px) {
      .hero-overlay {
        background: linear-gradient(
          to right,
          rgba(15, 23, 42, 0.65) 0%,
          rgba(15, 23, 42, 0.55) 50%,
          rgba(30, 41, 59, 0.45) 100%
        );
      }
    }

    .container {
      max-width: 1200px;
      margin: 0 auto;
      width: 100%;
      position: relative;
      z-index: 2;
    }

    .hero-content {
      max-width: 650px;
      display: flex;
      flex-direction: column;
      gap: 1.5rem;
    }

    @media (min-width: 1024px) {
      .hero-content {
        max-width: 700px;
      }
    }

    .eyebrow {
      display: inline-block;
      font-size: 0.875rem;
      font-weight: 700;
      color: #0f172a;
      background: rgba(251, 191, 36, 0.95);
      padding: 0.625rem 1.25rem;
      border-radius: 9999px;
      width: fit-content;
      box-shadow: 0 4px 12px rgba(251, 191, 36, 0.3);
      letter-spacing: 0.025em;
      text-transform: uppercase;
    }

    h1 {
      font-size: 2.5rem;
      font-weight: 900;
      line-height: 1.1;
      color: #ffffff;
      margin: 0;
      text-shadow: 0 2px 8px rgba(0, 0, 0, 0.3);
    }

    @media (min-width: 768px) {
      h1 {
        font-size: 3.5rem;
      }
    }

    @media (min-width: 1024px) {
      h1 {
        font-size: 4rem;
      }
    }

    .discover-label {
      font-size: 1.125rem;
      color: #f1f5f9;
      margin: 0 0 0.5rem 0;
      font-weight: 500;
      text-shadow: 0px 1px 3px rgba(0, 0, 0, 0.8);
    }

    .benefits {
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
      margin: 1rem 0;
    }

    .benefit {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      font-size: 1.0625rem;
      color: #ffffff;
      font-weight: 500;
      text-shadow: 0px 1px 3px rgba(0, 0, 0, 0.8);
    }

    .benefit :global(svg) {
      color: #10b981;
      flex-shrink: 0;
      filter: drop-shadow(0 2px 4px rgba(16, 185, 129, 0.5));
    }

    .trust-line {
      font-size: 0.9375rem;
      color: #cbd5e1;
      text-align: center;
      margin-top: 1rem;
      font-weight: 500;
      text-shadow: 0px 1px 2px rgba(0, 0, 0, 0.6);
    }

    /* Gold CTA Button Override */
    :global(.gold-cta) {
      background: linear-gradient(135deg, #fbbf24 0%, #f59e0b 100%) !important;
      color: #0f172a !important;
      font-weight: 700 !important;
      box-shadow: 0 4px 16px rgba(251, 191, 36, 0.4) !important;
      border: none !important;
    }

    :global(.gold-cta:hover) {
      background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%) !important;
      transform: translateY(-2px);
      box-shadow: 0 6px 20px rgba(251, 191, 36, 0.5) !important;
    }

    /* Shared Section Styles */
    .section-intro {
      font-size: 1.125rem;
      color: #475569;
      text-align: center;
      max-width: 800px;
      margin: 0 auto 2.5rem;
      line-height: 1.7;
    }

    .section-cta {
      text-align: center;
      margin-top: 2.5rem;
    }

    .cta-center {
      text-align: center;
      margin-top: 2rem;
    }

    /* SECTION 1: Business Case */
    .business-case-section {
      padding: 4rem 1.5rem;
      background: white;
    }

    .business-case-section h2 {
      font-size: 2rem;
      font-weight: 700;
      color: #1e293b;
      text-align: center;
      margin-bottom: 1rem;
    }

    .cost-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 1.5rem;
      max-width: 1000px;
      margin: 0 auto 2.5rem;
    }

    @media (min-width: 768px) {
      .cost-grid {
        grid-template-columns: repeat(2, 1fr);
      }
    }

    @media (min-width: 1024px) {
      .cost-grid {
        grid-template-columns: repeat(4, 1fr);
      }
    }

    .cost-item {
      background: #f8fafc;
      border: 1px solid #e2e8f0;
      border-radius: 1rem;
      padding: 1.5rem;
      text-align: center;
    }

    .cost-icon {
      margin-bottom: 1rem;
      color: #ef4444;
    }

    .cost-item h3 {
      font-size: 1.125rem;
      font-weight: 600;
      color: #1e293b;
      margin-bottom: 0.5rem;
    }

    .cost-item p {
      font-size: 0.9375rem;
      color: #475569;
      line-height: 1.5;
      margin: 0;
    }

    .monetary-reality {
      background: linear-gradient(135deg, #fef3c7 0%, #fde68a 100%);
      border: 2px solid #f59e0b;
      border-radius: 1rem;
      padding: 1.5rem 2rem;
      max-width: 800px;
      margin: 0 auto;
      text-align: center;
    }

    .monetary-reality p {
      font-size: 1.125rem;
      color: #78350f;
      margin: 0;
      line-height: 1.6;
    }

    /* SECTION 2: Gaps Section */
    .gaps-section {
      padding: 4rem 1.5rem;
      background: #f8fafc;
    }

    .gaps-section h2 {
      font-size: 2rem;
      font-weight: 700;
      color: #1e293b;
      text-align: center;
      margin-bottom: 1rem;
    }

    .gap-cards {
      display: flex;
      flex-direction: column;
      gap: 2rem;
      max-width: 900px;
      margin: 0 auto;
    }

    .gap-card {
      background: white;
      border: 1px solid #e2e8f0;
      border-radius: 1rem;
      padding: 2rem;
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
    }

    .gap-header {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      gap: 1rem;
      margin-bottom: 1rem;
      padding-bottom: 1rem;
      border-bottom: 1px solid #e2e8f0;
    }

    .gap-header :global(.gap-icon) {
      color: #3b82f6;
    }

    .gap-header h3 {
      font-size: 1.375rem;
      font-weight: 700;
      color: #1e293b;
      margin: 0;
    }

    .gap-subtitle {
      font-size: 1rem;
      color: #64748b;
      font-style: italic;
    }

    .gap-description {
      font-size: 1rem;
      color: #475569;
      line-height: 1.6;
      margin-bottom: 1.5rem;
    }

    .what-we-measure {
      background: #f8fafc;
      border-radius: 0.5rem;
      padding: 1.25rem;
      margin-bottom: 1.5rem;
    }

    .what-we-measure h4 {
      font-size: 0.875rem;
      font-weight: 600;
      color: #1e293b;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      margin-bottom: 0.75rem;
    }

    .what-we-measure ul {
      list-style: none;
      padding: 0;
      margin: 0;
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
    }

    .what-we-measure li {
      font-size: 0.9375rem;
      color: #475569;
      padding-left: 1.5rem;
      position: relative;
    }

    .what-we-measure li::before {
      content: "✓";
      position: absolute;
      left: 0;
      color: #10b981;
