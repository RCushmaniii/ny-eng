---
/**
 * Dynamic route for all executive resources (English)
 * Automatically generates pages for any JSON file in src/data/free/
 *
 * Example URLs:
 * - /en/resources/5-questions/
 * - /en/resources/negotiation-phrases/
 * - /en/resources/video-call-checklist/
 */

import Base from "@layouts/Base.astro";
import GenericFreeAsset from "@components/free/GenericFreeAsset";
import { getCollection } from "astro:content";
import type { TKey } from "../../../lib/i18n";

// Generate static paths for all free assets
export async function getStaticPaths() {
  // Get all JSON files from src/data/free/ (excluding schema.json)
  const freeAssets = import.meta.glob("/src/data/free/*.json", { eager: true });

  return Object.entries(freeAssets)
    .filter(([path]) => !path.includes("schema.json")) // Exclude schema.json
    .map(([path, module]) => {
      // Extract slug from file path (e.g., "5-questions" from "/src/data/free/5-questions.json")
      const slug = path.split("/").pop()?.replace(".json", "") || "";
      const content = module as any;

      return {
        params: { slug },
        props: { content, slug },
      };
    });
}

const { slug } = Astro.params;
const { content } = Astro.props;

// Extract metadata from content - support both old and new schema
const contentType =
  content.classification?.contentType || content.type || "default";
const enContent = content.en || content.content?.en;
const seoData = content.seo || {};

// SEO metadata - use proper SEO fields from JSON
// Title: Keep it concise (under 60 chars) using just the asset title
const title = enContent.title;

// Description: Use the SEO metaDescription from JSON (already optimized for length)
// Fallback to subtitle if not available
const description =
  seoData.metaDescription ||
  enContent.subtitle ||
  enContent.intro?.paragraph?.substring(0, 160) ||
  `Free bilingual resource for business professionals: ${enContent.title}`;

// Determine PDF file name
const pdfFile = `${slug}.pdf`;
const bookingUrl = "/en/book/";
---

<Base
  title={title}
  description={description}
  lang="en"
  tkey={`resources/${slug}` as TKey}
  ogImage={{
    src: "/images/logos/new-york-english-og.jpg",
    alt: `${enContent.title} - Executive Resource`,
  }}
  hideCta={true}
>
  <!-- JSON-LD Schema for Educational Resource -->
  <script
    type="application/ld+json"
    slot="head"
    set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "LearningResource",
      name: enContent.title,
      description: enContent.subtitle || description,
      learningResourceType: "Guide",
      educationalLevel: "Professional",
      audience: {
        "@type": "Audience",
        audienceType: "Business Professionals",
      },
      inLanguage: ["en-US", "es-MX"],
      isAccessibleForFree: true,
      creator: {
        "@type": "Person",
        name: "Robert Cushman",
        jobTitle: "Business English Coach",
        url: "https://www.nyenglishteacher.com/en/about/",
      },
      publisher: {
        "@type": "Organization",
        name: "NY English Teacher",
        url: "https://www.nyenglishteacher.com",
        logo: {
          "@type": "ImageObject",
          url: "https://www.nyenglishteacher.com/images/logos/new-york-english-512x512.png",
        },
      },
      datePublished: new Date().toISOString().split("T")[0],
      keywords: [
        "executive communication",
        "business English",
        "professional development",
        "leadership",
      ],
    })}
  />

  <GenericFreeAsset
    client:load
    content={content}
    lang="en"
    pdfFile={pdfFile}
    bookingUrl={bookingUrl}
    contentType={contentType}
  />
</Base>

<style is:global>
  /* Global styles for free resource pages */
  .free-asset-page {
    min-height: 100vh;
  }

  /* Smooth scrolling */
  html {
    scroll-behavior: smooth;
  }

  /* Table responsive wrapper */
  .free-asset-page table {
    min-width: 600px;
  }

  /* Print styles */
  @media print {
    .free-asset-page section:not(:first-child) {
      page-break-before: auto;
    }

    .free-asset-page button,
    .free-asset-page .no-print {
      display: none !important;
    }
  }
</style>
