---
export const prerender = true;

import Base from "@layouts/Base.astro";
import Hero from "@components/sections/Hero.astro";
import SplitPanel from "@components/sections/SplitPanel.astro";
import Features from "@components/sections/Features.astro";
import RecentPosts from "@components/sections/RecentPosts.astro";
import Testimonials from "@components/sections/Testimonials-titan.astro";
import QuizPromotion from "@components/sections/QuizPromotion.astro";
import HomepageFAQ from "@components/HomepageFAQ";

// Define language and tkey for i18n
const lang = "en";
const tkey = "home";

import { statsLists } from "@data/stats";
import { logoLists } from "@data/logos";
import { testimonials } from "@data/testimonials";

import { GraduationCap, Briefcase, Presentation, Users } from "lucide-astro";

import heroSkyline from "@assets/images/home/new-york-city-skyline.webp";
import styleGuideImage from "@assets/images/home/developer.jpg";

// This is the English homepage, so we define the path to its Spanish counterpart.
const spanishHomepageUrl = "/es/";

const testimonialsBlock = {
  eyebrow: "Real Results",
  title: "Why Top-Level Professionals Choose Coaching with Robert",
  description:
    "Executives, entrepreneurs, and experts across industries trust New York English to elevate fluency, confidence, and global impact.",
  testimonials,
  cta: {
    heading: "For Executives Who Lead in English",
    description:
      "Start with a complimentary strategy session to identify your communication gaps and map your goals.",
    text: "Book My Strategy Session",
    link: "/en/book/",
  },
};

const seoTitle = "Professional English Coaching | New York English Teacher";
const seoDescription =
  "Boost your English fluency and confidence with personalized coaching tailored for professionals, executives, and companies worldwide.";

const heroContent = {
  // Shortened to define the category instantly
  eyebrow: "Executive Communication Coaching",

  // Big, clear promise. No fluff.
  title: "Master Executive Business English",

  // Focused on THEM (the lead), not YOU (the coach).
  // Removed "I coach..." to focus on the result: Authority & Trust.
  description:
    "Lead global meetings with calm authority. Specialized coaching for international leaders to earn trust instantly.",

  trustLine: "Trusted by leaders at Fortune 500 companies and global startups.",
  trustLineLink: "/en/testimonials/",

  buttons: [
    {
      text: "Book a Private Consultation",
      link: "/en/book/",
      // DESIGN NOTE:
      // To get the Gold/Orange button that pops against the blue,
      // your 'primary' variant CSS should look like this in Tailwind:
      // className="bg-amber-500 hover:bg-amber-400 text-white font-bold shadow-lg"
      variant: "primary" as const,
    },
    // CRITICAL UX CHANGE:
    // I commented out the second button.
    // Two buttons = Decision Paralysis.
    // If you want high conversion, give them ONE path.
    /* {
      text: "Start the Executive Assessment",
      link: "/en/assessments/",
      variant: "secondary" as const,
    }, 
    */
  ],
  backgroundImage: heroSkyline,
  backgroundImageMobile: heroSkyline,

  // INCREASED OPACITY:
  // Changed from 0.3 to 0.7.
  // This darkens the background image so your white text
  // is actually readable against the city lights.
  overlayOpacity: 0.9,

  fullHeight: true,
} as const;

const featuresSection = {
  eyebrow: "NY ENGLISH OFFERS",
  title: "Select Your Specialized Track",
  description:
    "Choose the focused pathway that aligns with your specific professional goals.",
  features: [
    {
      title: "Executive Business English",
      description:
        "Command the boardroom and negotiate complex deals with nuance—without translating in your head.",
      icon: Briefcase,
      link: "/en/quiz/executives/",
    },
    {
      title: "English for Tech Leaders",
      description:
        "Translate complex technical concepts into clear business value for global clients and stakeholders.",
      icon: Presentation,
      link: "/en/quiz/it-services/",
    },
    {
      title: "Professional Services (Medical & Legal)",
      description:
        "Build absolute trust with international clients and patients. For experts demanding precision and clarity.",
      icon: Users,
      link: "/en/quiz/professional-services/",
    },
    {
      title: "Interviews & Major Presentations",
      description:
        "Ace your next decisive moment. Targeted preparation for job interviews, investor pitches, and critical speeches.",
      icon: GraduationCap,
      link: "/en/quiz/high-stakes/",
    },
  ],
} as const;

const FooterCta = {
  eyebrow: "",
  title: "Ready to Command the Room?",
  description:
    "Stop letting language barriers limit your career. Book your strategy session to gain the clarity and impact your role demands.",
  hideCta: false,
  button: {
    text: "Book My Strategy Session",
    link: "/en/book/",
  },
} as const;

const styleGuideSection = {
  eyebrow: "My Methodology",
  headline: "High-Impact Coaching for Real-World Success",
  description:
    "I discard generic textbooks to focus on your specific professional reality. Whether you are preparing for a board meeting or a job interview, our work is designed for immediate application.",
  descriptionPoints: [
    "A curriculum built 100% around your actual role, industry, and deadlines.",
    "Tactical feedback on tone, nuance, and pronunciation to sharpen your executive presence.",
    "Real-world simulations of your upcoming pitches, negotiations, and client calls.",
  ],
  image: {
    src: styleGuideImage,
    alt: "Executive coaching session in progress",
  },
  buttons: [
    {
      text: "Explore The Framework",
      link: "/en/about/",
      variant: "primary" as const,
    },
  ],
} as const;

const sideBySideStats = {
  eyebrow: "STATS",
  title: "Speak and Write English with Clarity, Confidence & Ease",
  description:
    "I help professionals speak and write English with clarity, purpose, and confidence.Whether you're preparing for interviews, presentations, or everyday business conversations, I'll provide the support you need.",
  variant: "side-by-side" as const,
  stats: statsLists.withContent.stats,
  content: {
    title: "Speak and Write English with Clarity, Confidence & Ease",
    description:
      "I help professionals speak and write English with clarity, purpose, and confidence.Whether you're preparing for interviews, presentations, or everyday business conversations, I'll provide the support you need.",
    button: {
      text: "Let's Work Together",
      link: "/en/contact/",
    },
  },
} as const;

const mainCta = {
  eyebrow: "Build Blocks",
  title: "Ready-to-Use Components",
  description:
    "Save development time with our pre-built, accessible components. Each one is designed to integrate seamlessly with your projects while maintaining excellent performance.",
  button: {
    text: "View All Components",
    link: "/en/components",
    variant: "primary" as const,
  },
} as const;

const logosSection = {
  eyebrow: "Our Clients",
  logos: logoLists.main.logos,
} as const;

const recentPostsSection = {
  eyebrow: "LATEST ARTICLES",
  title: "Executive Communication Insights",
  description:
    "Actionable strategies to lead meetings, refine your delivery, and speak with absolute confidence.",
  button: {
    text: "Read the Blog",
    link: "/en/blog/",
  },
} as const;
---

<Base
  lang="en"
  tkey={tkey}
  title={seoTitle}
  description={seoDescription}
  heroImage={heroContent.backgroundImage}
  heroImageMobile={heroContent.backgroundImageMobile}
  ogImage={{ src: "/images/logos/new-york-english-sq-og.jpg" }}
  transparentHeader={true}
>
  <div class="relative bg-background-light">
    <Hero content={heroContent} />
    <Features content={featuresSection} padding="small" background="light" />
    <QuizPromotion lang="en" />
    <div class="mb-15 pb-0">
      <Testimonials
        content={testimonialsBlock}
        background="base"
        padding="small"
      />
    </div>

    <div
      class="pt-10 border-t border-gray-200 dark:border-gray-700"
      style="padding-bottom: var(--spacing-small);"
    >
      <RecentPosts
        content={recentPostsSection}
        background="base"
        postsToShow={3}
      />
    </div>

    <SplitPanel
      content={styleGuideSection}
      imagePosition="right"
      background="light"
      padding="base"
    />

    <!-- Homepage FAQ Section -->
    <HomepageFAQ client:load lang="en" />

    <!-- Stats temporarily removed -->
    <!-- <Stats content={sideBySideStats} background="dark" padding="base" /> -->
  </div>
</Base>
