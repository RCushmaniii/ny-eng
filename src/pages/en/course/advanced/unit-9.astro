---
export const prerender = true;

import Base from "@layouts/Base.astro";
import Button from "@components/ui/Button.astro";
import CourseProgress from "@components/course/CourseProgress";
import ErrorSpotter from "@components/course/ErrorSpotter";
import SentenceTransformer from "@components/course/SentenceTransformer";
import { advancedUnits } from "@data/advanced/units";
import { varietyItems, wordOrderItems, linkingTransforms } from "@data/advanced/unit-9";
import { ArrowRight, ArrowLeft, Layers, AlignLeft, Link2 } from "lucide-astro";

const lang = "en";
const tkey = "course/advanced/unit-9" as const;
const progressUnits = advancedUnits.map((u) => ({ id: u.id, slug: u.slug, title: u.title, titleEs: u.titleEs }));
---

<Base lang={lang} tkey={tkey}
  title="Unit 9: Sentence Construction & Flow — Stop Sounding Robotic | Speak with Confidence | NY English Teacher"
  description="Learn how to build sentences that flow naturally in English. Fix choppy sentence variety, word order traps, and robotic connectors. Free advanced English lesson for B2-C1 Spanish speakers."
>
  <CourseProgress client:load units={progressUnits} currentUnit={9} basePath="/en/course/advanced" lang="en" courseId="advanced" />

  <section class="bg-gradient-to-b from-slate-900 to-slate-800 pt-28 pb-16 md:pt-36 md:pb-20">
    <div class="site-container mx-auto px-4 text-white">
      <div class="max-w-3xl">
        <div class="flex items-center gap-2 text-violet-400 text-sm font-semibold mb-3"><Layers class="w-4 h-4" /> Unit 9</div>
        <h1 class="text-3xl md:text-5xl font-bold text-white mb-4 leading-tight" style="font-family: 'Noto Sans KR', sans-serif;">
          Sentence Construction<br /><span class="text-amber-400">& Flow</span>
        </h1>
        <p class="text-lg text-slate-200 max-w-2xl leading-relaxed">
          Most advanced speakers know the right words — but string them together like a
          list. This unit fixes that. You'll learn how to combine ideas smoothly, place
          words in the right order, and link sentences the way native speakers actually do.
        </p>
        <div class="mt-6 flex flex-wrap gap-3">
          <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full bg-violet-500/20 text-violet-300 text-sm font-medium"><AlignLeft class="w-3.5 h-3.5" /> Sentence Variety</span>
          <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full bg-violet-500/20 text-violet-300 text-sm font-medium"><Layers class="w-3.5 h-3.5" /> Word Order</span>
          <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full bg-violet-500/20 text-violet-300 text-sm font-medium"><Link2 class="w-3.5 h-3.5" /> Linking Ideas</span>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 md:py-20 bg-white" id="section-1">
    <div class="site-container mx-auto px-4"><div class="max-w-3xl mx-auto">
      <div class="flex items-center gap-3 mb-2">
        <span class="flex items-center justify-center w-8 h-8 rounded-lg bg-violet-500 text-white text-sm font-bold">1</span>
        <h2 class="text-2xl md:text-3xl font-bold text-slate-900">Sentence Variety</h2>
      </div>
      <p class="text-slate-500 mb-8 ml-11">
        Writing three short sentences in a row with the same subject is the #1 sign of
        an intermediate speaker. Spot the repeated word that's making these sentences
        choppy — then see how a professional would combine them.
      </p>
      <ErrorSpotter client:visible items={varietyItems} lang="en" instruction="Tap the repeated word making this sentence choppy:" instructionEs="Toca la palabra repetida que hace esta oración cortada:" />
    </div></div>
  </section>

  <section class="py-16 md:py-20 bg-slate-50" id="section-2">
    <div class="site-container mx-auto px-4"><div class="max-w-3xl mx-auto">
      <div class="flex items-center gap-3 mb-2">
        <span class="flex items-center justify-center w-8 h-8 rounded-lg bg-violet-500 text-white text-sm font-bold">2</span>
        <h2 class="text-2xl md:text-3xl font-bold text-slate-900">Word Order Traps</h2>
      </div>
      <p class="text-slate-500 mb-8 ml-11">
        Spanish and English place adverbs, adjectives, and prepositions differently.
        These are the exact word-order mistakes that native speakers hear immediately —
        even when every individual word is correct. Tap the word that's in the wrong place.
      </p>
      <ErrorSpotter client:visible items={wordOrderItems} lang="en" instruction="Tap the word that is in the wrong position:" instructionEs="Toca la palabra que está en la posición incorrecta:" />
    </div></div>
  </section>

  <section class="py-16 md:py-20 bg-white" id="section-3">
    <div class="site-container mx-auto px-4"><div class="max-w-3xl mx-auto">
      <div class="flex items-center gap-3 mb-2">
        <span class="flex items-center justify-center w-8 h-8 rounded-lg bg-violet-500 text-white text-sm font-bold">3</span>
        <h2 class="text-2xl md:text-3xl font-bold text-slate-900">Linking Ideas Without Sounding Robotic</h2>
      </div>
      <p class="text-slate-500 mb-8 ml-11">
        The flat version shows how you currently sound. The strong version shows how a
        fluent professional says the same thing. Pay attention to the forward slashes —
        they mark natural spoken pauses, the breath chunks that give English its rhythm.
      </p>
      <SentenceTransformer client:visible transforms={linkingTransforms} lang="en" />
    </div></div>
  </section>

  <section class="py-12 bg-slate-50 border-t border-slate-200">
    <div class="site-container mx-auto px-4"><div class="max-w-3xl mx-auto flex justify-between items-center">
      <a href="/en/course/advanced/unit-8/" class="inline-flex items-center gap-1.5 text-sm text-slate-500 hover:text-violet-600 transition-colors"><ArrowLeft class="w-4 h-4" /> Unit 8</a>
      <Button href="/en/course/advanced/unit-10/" variant="primary" size="md">Unit 10 <ArrowRight class="w-4 h-4 ml-1" /></Button>
    </div></div>
  </section>
</Base>
