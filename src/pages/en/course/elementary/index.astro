---
export const prerender = true;

import Base from "@layouts/Base.astro";
import Button from "@components/ui/Button.astro";
import { elementaryUnits } from "@data/elementary/units";
import {
  BookOpen,
  Clock,
  Calendar,
  Rocket,
  Scale,
  Hash,
  MessageCircleQuestion,
  Repeat,
  Pause,
  Sparkles,
  ArrowRight,
  MessageCircle,
  Zap,
} from "lucide-astro";

const lang = "en";
const tkey = "course/elementary" as const;

const iconMap: Record<string, any> = {
  BookOpen,
  Clock,
  Calendar,
  Rocket,
  Scale,
  Hash,
  MessageCircleQuestion,
  Repeat,
  Pause,
  Sparkles,
};

const firstAvailableUnit = elementaryUnits.find((u) => u.published);
const firstUnitHref = firstAvailableUnit
  ? `/en/course/elementary/${firstAvailableUnit.slug}/`
  : "/en/course/beginners/";
const firstUnitLabel = firstAvailableUnit
  ? `Start Unit ${firstAvailableUnit.id} — Free`
  : "Start with First Steps Into English";
---

<Base
  lang={lang}
  tkey={tkey}
  title="Free Elementary English Course A2 | NY English Teacher"
  description="A free 10-unit elementary English course for A2 Spanish speakers. Past simple, future plans, comparatives, and Wh-questions — tell your story."
>
  <!-- Hero -->
  <section class="relative w-full overflow-hidden bg-gradient-to-br from-slate-900 via-slate-800 to-slate-900 pt-32 pb-20 md:pt-40 md:pb-28">
    <div class="absolute inset-0 opacity-10">
      <div class="absolute top-20 left-10 w-72 h-72 bg-sky-500 rounded-full blur-3xl"></div>
      <div class="absolute bottom-10 right-20 w-96 h-96 bg-cyan-500 rounded-full blur-3xl"></div>
    </div>
    <div class="site-container mx-auto px-4 relative z-10 text-white">
      <div class="max-w-3xl">
        <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-sky-500/20 text-sky-300 text-sm font-semibold mb-6">
          <BookOpen class="w-4 h-4" />
          Free Course — 10 Units — A2 Elementary
        </div>
        <h1
          class="text-4xl md:text-5xl lg:text-6xl font-bold text-white mb-6 leading-tight"
          style="font-family: 'Noto Sans KR', sans-serif;"
        >
          Tell Your Story.<br />
          <span class="text-sky-400">Past, Present, and Future.</span>
        </h1>
        <p class="text-xl text-slate-300 mb-8 max-w-2xl leading-relaxed">
          You can speak in present tense — but you can't yet talk about
          <strong class="text-white">yesterday</strong>, make
          <strong class="text-white">plans for tomorrow</strong>, or answer
          beyond yes and no. This course bridges Beginner to Intermediate with
          the building blocks that turn fragments into full stories.
        </p>
        <div class="flex flex-wrap gap-4">
          <Button href={firstUnitHref} variant="primary" size="lg">
            {firstUnitLabel}
            <ArrowRight class="w-5 h-5 ml-1" />
          </Button>
          <a
            href="/en/course/beginners/"
            class="inline-flex items-center gap-2 px-6 py-3 rounded-xl border border-white/20 text-white/80 hover:text-white hover:border-white/40 transition-colors text-sm font-medium"
          >
            Need the basics first?
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Value props -->
  <section class="py-16 md:py-20 bg-white">
    <div class="site-container mx-auto px-4">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="text-center space-y-3 p-6">
          <div class="inline-flex items-center justify-center w-14 h-14 rounded-2xl bg-sky-100 text-sky-600">
            <Clock class="w-7 h-7" />
          </div>
          <h3 class="text-xl font-bold text-slate-900">Past, Future, and the Day Itself</h3>
          <p class="text-slate-600 leading-relaxed">
            Past simple (regular and irregular), going to and will, and the time markers that make any story land.
            The grammar that turns isolated sentences into a real timeline.
          </p>
        </div>
        <div class="text-center space-y-3 p-6">
          <div class="inline-flex items-center justify-center w-14 h-14 rounded-2xl bg-sky-100 text-sky-600">
            <MessageCircle class="w-7 h-7" />
          </div>
          <h3 class="text-xl font-bold text-slate-900">Beyond Yes and No</h3>
          <p class="text-slate-600 leading-relaxed">
            Wh-questions, comparatives, and quantifiers — the toolkit that takes you from "yes" and "no" answers
            to real conversations about your life, your plans, and your opinions.
          </p>
        </div>
        <div class="text-center space-y-3 p-6">
          <div class="inline-flex items-center justify-center w-14 h-14 rounded-2xl bg-sky-100 text-sky-600">
            <Sparkles class="w-7 h-7" />
          </div>
          <h3 class="text-xl font-bold text-slate-900">Capstone — Your Real Story</h3>
          <p class="text-slate-600 leading-relaxed">
            Unit 10 is your story: a 60-second recording about your real life, combining everything you've learned.
            Submit it and Robert listens personally.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Course Units -->
  <section class="py-16 md:py-20 bg-slate-50">
    <div class="site-container mx-auto px-4">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold text-slate-900 mb-4">10 Units. Beginner to Storyteller.</h2>
        <p class="text-lg text-slate-600 max-w-2xl mx-auto">
          Each unit unlocks one piece of the storytelling toolkit — past tense, future plans, comparing,
          asking real questions — and ends with a capstone that puts it all together.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4 max-w-4xl mx-auto">
        {elementaryUnits.map((unit) => {
          const Icon = iconMap[unit.icon];
          const isAvailable = unit.published;
          return (
            <a
              href={isAvailable ? `/en/course/elementary/${unit.slug}/` : undefined}
              class:list={[
                "group flex items-start gap-4 p-5 rounded-xl border transition-all duration-200",
                isAvailable
                  ? "bg-sky-50 border-sky-300 hover:shadow-md hover:border-sky-400 cursor-pointer"
                  : "bg-white border-slate-200 opacity-75",
              ]}
            >
              <div
                class:list={[
                  "flex items-center justify-center w-12 h-12 rounded-xl shrink-0",
                  isAvailable ? "bg-sky-500 text-white" : "bg-slate-100 text-slate-400",
                ]}
              >
                {Icon && <Icon class="w-6 h-6" />}
              </div>
              <div>
                <div class="flex items-center gap-2">
                  <span
                    class:list={[
                      "text-xs font-bold uppercase tracking-wider",
                      isAvailable ? "text-sky-600" : "text-slate-400",
                    ]}
                  >
                    Unit {unit.id}
                  </span>
                  {!isAvailable && (
                    <span class="text-xs px-1.5 py-0.5 rounded bg-slate-100 text-slate-400">
                      Coming soon
                    </span>
                  )}
                </div>
                <h3
                  class:list={[
                    "text-lg font-bold mt-0.5",
                    isAvailable ? "text-slate-900" : "text-slate-600",
                  ]}
                >
                  {unit.title}
                </h3>
                <p class="text-sm text-slate-500 mt-1">{unit.subtitle}</p>
                <p class="text-xs text-slate-400 mt-1">{unit.grammarFocus}</p>
              </div>
            </a>
          );
        })}
      </div>

      <!-- Final Exam Card -->
      <div class="max-w-4xl mx-auto mt-6">
        <div
          class="flex items-center gap-4 p-5 rounded-xl border-2 border-dashed border-slate-300 bg-white opacity-75"
        >
          <div class="flex items-center justify-center w-12 h-12 rounded-xl shrink-0 bg-slate-100 text-slate-400">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <div>
            <span class="text-xs font-bold uppercase tracking-wider text-slate-400">After Unit 10</span>
            <h3 class="text-lg font-bold text-slate-600 mt-0.5">Final Exam <span class="text-xs px-1.5 py-0.5 rounded bg-slate-100 text-slate-400 ml-2 font-normal">Coming soon</span></h3>
            <p class="text-sm text-slate-500 mt-1">20 questions covering all 10 units — past tense, future plans, comparatives, quantifiers, questions, and routines.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Method explanation -->
  <section class="py-16 md:py-20 bg-white">
    <div class="site-container mx-auto px-4">
      <div class="max-w-3xl mx-auto">
        <h2 class="text-3xl md:text-4xl font-bold text-slate-900 mb-6 text-center">
          The A2 Gap — and Why This Course Closes It
        </h2>
        <div class="space-y-6 text-lg text-slate-700 leading-relaxed">
          <p>
            After the Beginner course, Spanish speakers can recognize 1,500 cognates and form sentences in present
            tense. But there's a wall: B1-B2 ("Building Fluency") jumps straight to phrasal verbs and conditionals,
            assuming you can already talk about <em>yesterday</em>, make plans, and ask real questions.
          </p>
          <p>
            <strong>Tell Your Story</strong> fills that gap. Past simple (regular and irregular), going to + will,
            comparatives, quantifiers, Wh-questions, frequency adverbs, and past continuous — drilled until each
            one becomes automatic. By Unit 10, you record a 60-second story about your real life.
          </p>
          <p>
            And because we know the <em>specific</em> errors Spanish speakers make at A2 (saying "more better" instead
            of "better", placing "always" in the wrong spot, mixing up "much" and "many"), every unit fixes those
            errors directly.
          </p>
        </div>
        <div class="mt-10 text-center">
          <Button href={firstUnitHref} variant="primary" size="lg">
            {firstUnitLabel}
            <ArrowRight class="w-5 h-5 ml-1" />
          </Button>
        </div>
      </div>
    </div>
  </section>

  <!-- Prerequisites / Level check -->
  <section class="py-16 md:py-20 bg-slate-50">
    <div class="site-container mx-auto px-4">
      <div class="max-w-3xl mx-auto text-center">
        <h2 class="text-2xl font-bold text-slate-900 mb-4">Is This Course Right for You?</h2>
        <p class="text-lg text-slate-600 leading-relaxed mb-6">
          This course is designed for Spanish speakers at the <strong>A2 / Elementary level</strong> — you can hold
          basic present-tense conversations but stall when the topic moves to yesterday, tomorrow, or anything
          requiring detailed answers.
        </p>
        <div class="flex flex-wrap gap-3 justify-center">
          <a
            href="/en/course/beginners/"
            class="text-sky-600 hover:text-sky-700 font-medium underline underline-offset-2"
          >
            Need the basics? Start with First Steps
          </a>
          <span class="text-slate-300">|</span>
          <a
            href="/en/course/intermediate/"
            class="text-sky-600 hover:text-sky-700 font-medium underline underline-offset-2"
          >
            Already past A2? Jump to Building Fluency
          </a>
        </div>
      </div>
    </div>
  </section>

  <script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Course",
  "name": "Free Elementary English Course (A2)",
  "description": "A free 10-unit elementary English course for A2 Spanish speakers. Past simple, future plans, comparatives, and Wh-questions — tell your story.",
  "provider": {
    "@type": "Person",
    "name": "Robert Cushman",
    "url": "https://www.nyenglishteacher.com/en/about/"
  },
  "educationalLevel": "Elementary (A2)",
  "inLanguage": "en",
  "url": "https://www.nyenglishteacher.com/en/course/elementary/",
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "USD",
    "availability": "https://schema.org/InStock"
  }
})} />
</Base>
