---
export const prerender = true;

import Base from "@layouts/Base.astro";
import CourseProgress from "@components/course/CourseProgress";
import CognateDiscovery from "@components/course/CognateDiscovery";
import SentenceBuilder from "@components/course/SentenceBuilder";
import PronunciationDrill from "@components/course/PronunciationDrill";
import ConnectorChallenge from "@components/course/ConnectorChallenge";
import SelfTest from "@components/course/SelfTest";
import { units } from "@data/course/units";
import {
  cognateWaves,
  sentenceBlocks,
  powerVerbBlocks,
  connectorSentences,
  pronunciationDrills,
  vocabularyList,
} from "@data/course/unit-2";
import {
  ArrowRight,
  ArrowLeft,
  Heart,
  Layers,
  Zap,
  Link2,
  Volume2,
  ClipboardCheck,
} from "lucide-astro";

const lang = "en";
const tkey = "course/beginners/unit-2" as const;

const progressUnits = units.map((u) => ({
  id: u.id,
  slug: u.slug,
  title: u.title,
  titleEs: u.titleEs,
}));

const waveData = [cognateWaves.wave1, cognateWaves.wave2, cognateWaves.wave3];
---

<Base
  lang={lang}
  tkey={tkey}
  title="Unit 2: What You Like | NY English Teacher"
  description="Learn to express preferences: I like, I don't like, I would like. Talk about food, daily activities, and the past. Free lesson for Spanish speakers."
>
  <CourseProgress
    client:load
    units={progressUnits}
    currentUnit={2}
    basePath="/en/course/beginners"
    lang="en"
  />

  <!-- Unit hero -->
  <section class="bg-gradient-to-b from-slate-900 to-slate-800 pt-28 pb-16 md:pt-36 md:pb-20">
    <div class="site-container mx-auto px-4 text-white">
      <div class="max-w-3xl">
        <div class="flex items-center gap-2 text-amber-400 text-sm font-semibold mb-3">
          <Heart class="w-4 h-4" />
          Unit 2
        </div>
        <h1
          class="text-3xl md:text-5xl font-bold text-white mb-4 leading-tight"
          style="font-family: 'Noto Sans KR', sans-serif;"
        >
          What You Like
        </h1>
        <p class="text-lg text-slate-300 max-w-2xl leading-relaxed">
          Now that you can build sentences, let's make them personal. You'll learn to talk about
          what you like, what you'd prefer, and what happened yesterday — all using simple patterns.
        </p>
      </div>
    </div>
  </section>

  <!-- Section nav -->
  <nav class="bg-white border-b border-slate-200 sticky top-[52px] z-30 overflow-x-auto">
    <div class="site-container mx-auto px-4">
      <div class="flex items-center gap-1 py-2 text-sm whitespace-nowrap">
        <a href="#cognates" class="px-3 py-1.5 rounded-full hover:bg-amber-50 text-slate-600 hover:text-amber-600 transition-colors flex items-center gap-1.5">
          <Heart class="w-3.5 h-3.5" /> Cognates
        </a>
        <a href="#sentences" class="px-3 py-1.5 rounded-full hover:bg-amber-50 text-slate-600 hover:text-amber-600 transition-colors flex items-center gap-1.5">
          <Layers class="w-3.5 h-3.5" /> I Like
        </a>
        <a href="#power-verbs" class="px-3 py-1.5 rounded-full hover:bg-amber-50 text-slate-600 hover:text-amber-600 transition-colors flex items-center gap-1.5">
          <Zap class="w-3.5 h-3.5" /> Would Like + Past
        </a>
        <a href="#connectors" class="px-3 py-1.5 rounded-full hover:bg-amber-50 text-slate-600 hover:text-amber-600 transition-colors flex items-center gap-1.5">
          <Link2 class="w-3.5 h-3.5" /> Time Words
        </a>
        <a href="#pronunciation" class="px-3 py-1.5 rounded-full hover:bg-amber-50 text-slate-600 hover:text-amber-600 transition-colors flex items-center gap-1.5">
          <Volume2 class="w-3.5 h-3.5" /> Pronunciation
        </a>
        <a href="#self-test" class="px-3 py-1.5 rounded-full hover:bg-amber-50 text-slate-600 hover:text-amber-600 transition-colors flex items-center gap-1.5">
          <ClipboardCheck class="w-3.5 h-3.5" /> Self-Test
        </a>
      </div>
    </div>
  </nav>

  <!-- Section A: Cognate Discovery -->
  <section id="cognates" class="py-12 md:py-16 bg-slate-50">
    <div class="site-container mx-auto px-4">
      <div class="max-w-3xl mx-auto">
        <div class="mb-8">
          <div class="flex items-center gap-2 text-amber-600 text-sm font-semibold mb-2">
            <Heart class="w-4 h-4" />
            Section A
          </div>
          <h2 class="text-2xl md:text-3xl font-bold text-slate-900 mb-3">
            More Words You Already Know
          </h2>
          <p class="text-lg text-slate-600 leading-relaxed">
            Three more cognate patterns that unlock hundreds of English words. The -tion pattern alone covers over 300 words.
          </p>
        </div>
        <CognateDiscovery client:visible waves={waveData} lang="en" />
      </div>
    </div>
  </section>

  <!-- Section B: I Like / I Don't Like -->
  <section id="sentences" class="py-12 md:py-16 bg-white">
    <div class="site-container mx-auto px-4">
      <div class="max-w-3xl mx-auto">
        <div class="mb-8">
          <div class="flex items-center gap-2 text-amber-600 text-sm font-semibold mb-2">
            <Layers class="w-4 h-4" />
            Section B
          </div>
          <h2 class="text-2xl md:text-3xl font-bold text-slate-900 mb-3">
            I Like / I Don't Like
          </h2>
          <p class="text-lg text-slate-600 leading-relaxed">
            Express your preferences. "I like" works with things (I like the food) and actions
            (I like to swim). Add "don't" to say what you don't enjoy.
          </p>
        </div>
        <SentenceBuilder client:visible blocks={sentenceBlocks} lang="en" />
      </div>
    </div>
  </section>

  <!-- Section C: I Would Like + Past Tense -->
  <section id="power-verbs" class="py-12 md:py-16 bg-slate-50">
    <div class="site-container mx-auto px-4">
      <div class="max-w-3xl mx-auto">
        <div class="mb-8">
          <div class="flex items-center gap-2 text-amber-600 text-sm font-semibold mb-2">
            <Zap class="w-4 h-4" />
            Section C
          </div>
          <h2 class="text-2xl md:text-3xl font-bold text-slate-900 mb-3">
            I Would Like + The Past
          </h2>
          <p class="text-lg text-slate-600 leading-relaxed">
            "I would like" is your polite superpower — use it everywhere. Then we unlock the past
            with "it was" and add three powerful words: <strong>myself</strong>, <strong>again</strong>, and <strong>soon</strong>.
          </p>
        </div>
        <SentenceBuilder client:visible blocks={powerVerbBlocks} lang="en" />
      </div>
    </div>
  </section>

  <!-- Section D: Time Words -->
  <section id="connectors" class="py-12 md:py-16 bg-white">
    <div class="site-container mx-auto px-4">
      <div class="max-w-3xl mx-auto">
        <div class="mb-8">
          <div class="flex items-center gap-2 text-amber-600 text-sm font-semibold mb-2">
            <Link2 class="w-4 h-4" />
            Section D
          </div>
          <h2 class="text-2xl md:text-3xl font-bold text-slate-900 mb-3">
            Time Words
          </h2>
          <p class="text-lg text-slate-600 leading-relaxed">
            New time and relationship words that make your sentences richer.
            Tap each one, then try the Boss Sentence.
          </p>
        </div>
        <ConnectorChallenge
          client:visible
          connectors={connectorSentences.connectors}
          bossSentence={connectorSentences.bossSentence}
          lang="en"
        />
      </div>
    </div>
  </section>

  <!-- Section E: Pronunciation Lab -->
  <section id="pronunciation" class="py-12 md:py-16 bg-slate-50">
    <div class="site-container mx-auto px-4">
      <div class="max-w-3xl mx-auto">
        <div class="mb-8">
          <div class="flex items-center gap-2 text-rose-500 text-sm font-semibold mb-2">
            <Volume2 class="w-4 h-4" />
            Pronunciation Lab
          </div>
          <h2 class="text-2xl md:text-3xl font-bold text-slate-900 mb-3">
            B vs. V — They're Different in English!
          </h2>
          <p class="text-lg text-slate-600 leading-relaxed">
            In Spanish, B and V sound the same. In English, they're completely different sounds.
            This is one of the most common mistakes — and one of the easiest to fix.
          </p>
        </div>
        <PronunciationDrill client:visible drills={pronunciationDrills} lang="en" />
      </div>
    </div>
  </section>

  <!-- Section F: Self-Test -->
  <section id="self-test" class="py-12 md:py-16 bg-white">
    <div class="site-container mx-auto px-4">
      <div class="max-w-3xl mx-auto">
        <div class="mb-8">
          <div class="flex items-center gap-2 text-amber-600 text-sm font-semibold mb-2">
            <ClipboardCheck class="w-4 h-4" />
            Self-Test
          </div>
          <h2 class="text-2xl md:text-3xl font-bold text-slate-900 mb-3">
            Test What You Learned
          </h2>
          <p class="text-lg text-slate-600 leading-relaxed">
            Review everything from Unit 2 — plus some Unit 1 vocabulary to keep it fresh.
          </p>
        </div>
        <SelfTest client:visible vocabulary={vocabularyList} lang="en" />
      </div>
    </div>
  </section>

  <!-- Unit complete CTA -->
  <section class="py-16 md:py-20 bg-gradient-to-b from-slate-900 to-slate-800">
    <div class="site-container mx-auto px-4 text-white">
      <div class="max-w-2xl mx-auto text-center space-y-6">
        <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-emerald-500/20 text-emerald-400">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
          </svg>
        </div>
        <h2 class="text-3xl font-bold text-white">Unit 2 Complete!</h2>
        <p class="text-lg text-slate-100 leading-relaxed">
          You can now express likes, preferences, and talk about the past. Combined with Unit 1,
          you can build sentences that most "beginners" couldn't dream of.
        </p>
        <div class="flex flex-wrap gap-4 justify-center pt-4">
          <a
            href="/en/course/beginners/unit-1/"
            class="inline-flex items-center gap-2 px-6 py-3 rounded-xl bg-slate-700 text-slate-300 font-medium hover:bg-slate-600 transition-colors"
          >
            <ArrowLeft class="w-4 h-4" />
            Review Unit 1
          </a>
          <a
            href="/en/course/beginners/unit-3/"
            class="inline-flex items-center gap-2 px-6 py-3 rounded-xl bg-amber-500 text-white font-semibold hover:bg-amber-400 transition-colors shadow-lg"
          >
            Continue to Unit 3 →
          </a>
        </div>
        <div class="pt-8 border-t border-slate-700 mt-8">
          <p class="text-slate-200 text-sm mb-3">
            Want personalized English coaching?
          </p>
          <a
            href="/en/contact/"
            class="text-amber-400 hover:text-amber-300 font-medium underline underline-offset-2"
          >
            Book a free consultation with Robert →
          </a>
        </div>
      </div>
    </div>
  </section>
</Base>
