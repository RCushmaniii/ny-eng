---
export const prerender = true;

import Base from "@layouts/Base.astro";
import CourseProgress from "@components/course/CourseProgress";
import CognateDiscovery from "@components/course/CognateDiscovery";
import SentenceBuilder from "@components/course/SentenceBuilder";
import PronunciationDrill from "@components/course/PronunciationDrill";
import ConnectorChallenge from "@components/course/ConnectorChallenge";
import SelfTest from "@components/course/SelfTest";
import { units } from "@data/course/units";
import {
  cognateWaves,
  sentenceBlocks,
  powerVerbBlocks,
  connectorSentences,
  pronunciationDrills,
  vocabularyList,
} from "@data/course/unit-6";
import {
  ArrowLeft,
  UsersRound,
  Layers,
  Zap,
  Link2,
  Volume2,
  ClipboardCheck,
} from "lucide-astro";

const lang = "en";
const tkey = "course/beginners/unit-6" as const;

const progressUnits = units.map((u) => ({
  id: u.id,
  slug: u.slug,
  title: u.title,
  titleEs: u.titleEs,
}));

const waveData = [cognateWaves.wave1, cognateWaves.wave2, cognateWaves.wave3];
---

<Base
  lang={lang}
  tkey={tkey}
  title="Unit 6: Everyone, Someone, No One — First Steps Into English | NY English Teacher"
  description="Learn indefinite pronouns in English: everyone, someone, nobody. Plus should, shouldn't, and initial S pronunciation. Free interactive lesson for Spanish speakers."
>
  <CourseProgress
    client:load
    units={progressUnits}
    currentUnit={6}
    basePath="/en/course/beginners"
    lang="en"
  />

  <section class="bg-gradient-to-b from-slate-900 to-slate-800 pt-8 pb-16 md:pt-12 md:pb-20">
    <div class="site-container mx-auto px-4 text-white">
      <div class="max-w-3xl">
        <div class="flex items-center gap-2 text-amber-400 text-sm font-semibold mb-3">
          <UsersRound class="w-4 h-4" />
          Unit 6
        </div>
        <h1 class="text-3xl md:text-5xl font-bold text-white mb-4 leading-tight" style="font-family: 'Noto Sans KR', sans-serif;">
          Everyone, Someone, No One
        </h1>
        <p class="text-lg text-slate-300 max-w-2xl leading-relaxed">
          Talk about people without naming them. Everyone knows. Someone told me. Nobody wants to go.
          Plus a new power word: "should" — for giving advice and expressing expectations.
        </p>
      </div>
    </div>
  </section>

  <nav class="bg-white border-b border-slate-200 sticky top-[52px] z-30 overflow-x-auto">
    <div class="site-container mx-auto px-4">
      <div class="flex items-center gap-1 py-2 text-sm whitespace-nowrap">
        <a href="#cognates" class="px-3 py-1.5 rounded-full hover:bg-amber-50 text-slate-600 hover:text-amber-600 transition-colors flex items-center gap-1.5">
          <UsersRound class="w-3.5 h-3.5" /> Cognates
        </a>
        <a href="#sentences" class="px-3 py-1.5 rounded-full hover:bg-amber-50 text-slate-600 hover:text-amber-600 transition-colors flex items-center gap-1.5">
          <Layers class="w-3.5 h-3.5" /> Everyone/Someone/No One
        </a>
        <a href="#power-verbs" class="px-3 py-1.5 rounded-full hover:bg-amber-50 text-slate-600 hover:text-amber-600 transition-colors flex items-center gap-1.5">
          <Zap class="w-3.5 h-3.5" /> Should/Shouldn't
        </a>
        <a href="#connectors" class="px-3 py-1.5 rounded-full hover:bg-amber-50 text-slate-600 hover:text-amber-600 transition-colors flex items-center gap-1.5">
          <Link2 class="w-3.5 h-3.5" /> Advice Words
        </a>
        <a href="#pronunciation" class="px-3 py-1.5 rounded-full hover:bg-amber-50 text-slate-600 hover:text-amber-600 transition-colors flex items-center gap-1.5">
          <Volume2 class="w-3.5 h-3.5" /> Pronunciation
        </a>
        <a href="#self-test" class="px-3 py-1.5 rounded-full hover:bg-amber-50 text-slate-600 hover:text-amber-600 transition-colors flex items-center gap-1.5">
          <ClipboardCheck class="w-3.5 h-3.5" /> Self-Test
        </a>
      </div>
    </div>
  </nav>

  <section id="cognates" class="py-12 md:py-16 bg-slate-50">
    <div class="site-container mx-auto px-4">
      <div class="max-w-3xl mx-auto">
        <div class="mb-8">
          <div class="flex items-center gap-2 text-amber-600 text-sm font-semibold mb-2">
            <UsersRound class="w-4 h-4" />
            Section A
          </div>
          <h2 class="text-2xl md:text-3xl font-bold text-slate-900 mb-3">Three More Patterns You Already Know</h2>
          <p class="text-lg text-slate-600 leading-relaxed">
            The -al pattern (personal, professional), the -id pattern (rapid, solid), and the -ct pattern (correct, perfect).
            Your English vocabulary is growing faster than ever.
          </p>
        </div>
        <CognateDiscovery client:visible waves={waveData} lang="en" />
      </div>
    </div>
  </section>

  <section id="sentences" class="py-12 md:py-16 bg-white">
    <div class="site-container mx-auto px-4">
      <div class="max-w-3xl mx-auto">
        <div class="mb-8">
          <div class="flex items-center gap-2 text-amber-600 text-sm font-semibold mb-2">
            <Layers class="w-4 h-4" />
            Section B
          </div>
          <h2 class="text-2xl md:text-3xl font-bold text-slate-900 mb-3">Everyone / Someone / No One</h2>
          <p class="text-lg text-slate-600 leading-relaxed">
            Three words that let you talk about people without naming them.
            <strong>Everyone</strong> = todos. <strong>Someone</strong> = alguien. <strong>No one</strong> = nadie.
            Watch out: in English, "nobody" takes a singular verb and no double negatives.
          </p>
        </div>
        <SentenceBuilder client:visible blocks={sentenceBlocks} lang="en" />
      </div>
    </div>
  </section>

  <section id="power-verbs" class="py-12 md:py-16 bg-slate-50">
    <div class="site-container mx-auto px-4">
      <div class="max-w-3xl mx-auto">
        <div class="mb-8">
          <div class="flex items-center gap-2 text-amber-600 text-sm font-semibold mb-2">
            <Zap class="w-4 h-4" />
            Section C
          </div>
          <h2 class="text-2xl md:text-3xl font-bold text-slate-900 mb-3">Should / Shouldn't / Should Be Able To</h2>
          <p class="text-lg text-slate-600 leading-relaxed">
            Your new modal verb: <strong>should</strong>. It's softer than "have to" — it gives advice,
            not orders. "You should tell him" = I think it's the right thing to do.
          </p>
        </div>
        <SentenceBuilder client:visible blocks={powerVerbBlocks} lang="en" />
      </div>
    </div>
  </section>

  <section id="connectors" class="py-12 md:py-16 bg-white">
    <div class="site-container mx-auto px-4">
      <div class="max-w-3xl mx-auto">
        <div class="mb-8">
          <div class="flex items-center gap-2 text-amber-600 text-sm font-semibold mb-2">
            <Link2 class="w-4 h-4" />
            Section D
          </div>
          <h2 class="text-2xl md:text-3xl font-bold text-slate-900 mb-3">Advice and Expectations</h2>
          <p class="text-lg text-slate-600 leading-relaxed">
            Words that connect advice and consequences — so, too, already, anyone, something.
          </p>
        </div>
        <ConnectorChallenge
          client:visible
          connectors={connectorSentences.connectors}
          bossSentence={connectorSentences.bossSentence}
          lang="en"
        />
      </div>
    </div>
  </section>

  <section id="pronunciation" class="py-12 md:py-16 bg-slate-50">
    <div class="site-container mx-auto px-4">
      <div class="max-w-3xl mx-auto">
        <div class="mb-8">
          <div class="flex items-center gap-2 text-rose-500 text-sm font-semibold mb-2">
            <Volume2 class="w-4 h-4" />
            Pronunciation Lab
          </div>
          <h2 class="text-2xl md:text-3xl font-bold text-slate-900 mb-3">The Initial S — No "Es-" Prefix</h2>
          <p class="text-lg text-slate-600 leading-relaxed">
            One of the most recognizable features of a Spanish accent: adding "e" before S + consonant.
            "Especial" instead of "special." "Estudent" instead of "student."
            This lesson breaks that habit for good.
          </p>
        </div>
        <PronunciationDrill client:visible drills={pronunciationDrills} lang="en" />
      </div>
    </div>
  </section>

  <section id="self-test" class="py-12 md:py-16 bg-white">
    <div class="site-container mx-auto px-4">
      <div class="max-w-3xl mx-auto">
        <div class="mb-8">
          <div class="flex items-center gap-2 text-amber-600 text-sm font-semibold mb-2">
            <ClipboardCheck class="w-4 h-4" />
            Self-Test
          </div>
          <h2 class="text-2xl md:text-3xl font-bold text-slate-900 mb-3">Test What You Learned</h2>
          <p class="text-lg text-slate-600 leading-relaxed">
            Indefinite pronouns, should/shouldn't, and advice vocabulary — plus review from Units 1-5.
          </p>
        </div>
        <SelfTest client:visible vocabulary={vocabularyList} lang="en" />
      </div>
    </div>
  </section>

  <section class="py-16 md:py-20 bg-gradient-to-b from-slate-900 to-slate-800">
    <div class="site-container mx-auto px-4 text-white">
      <div class="max-w-2xl mx-auto text-center space-y-6">
        <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-emerald-500/20 text-emerald-400">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
          </svg>
        </div>
        <h2 class="text-3xl font-bold text-white">Unit 6 Complete!</h2>
        <p class="text-lg text-slate-100 leading-relaxed">
          You can now talk about everyone, someone, and no one — plus give advice with "should."
          Six units and you're expressing opinions and expectations in real English.
        </p>
        <div class="flex flex-wrap gap-4 justify-center pt-4">
          <a href="/en/course/beginners/unit-5/" class="inline-flex items-center gap-2 px-6 py-3 rounded-xl bg-slate-700 text-slate-300 font-medium hover:bg-slate-600 transition-colors">
            <ArrowLeft class="w-4 h-4" /> Review Unit 5
          </a>
          <a href="/en/course/beginners/" class="inline-flex items-center gap-2 px-6 py-3 rounded-xl bg-amber-500 text-white font-semibold hover:bg-amber-400 transition-colors shadow-lg">
            Back to Course Overview
          </a>
        </div>
        <div class="pt-8 border-t border-slate-700 mt-8">
          <p class="text-slate-200 text-sm mb-3">Want personalized English coaching?</p>
          <a href="/en/contact/" class="text-amber-400 hover:text-amber-300 font-medium underline underline-offset-2">
            Book a free consultation with Robert →
          </a>
        </div>
      </div>
    </div>
  </section>
</Base>
