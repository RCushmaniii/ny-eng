---
export const prerender = true;

import Base from "@layouts/Base.astro";
import CourseProgress from "@components/course/CourseProgress";
import CognateDiscovery from "@components/course/CognateDiscovery";
import SentenceBuilder from "@components/course/SentenceBuilder";
import PronunciationDrill from "@components/course/PronunciationDrill";
import ConnectorChallenge from "@components/course/ConnectorChallenge";
import SelfTest from "@components/course/SelfTest";
import { units } from "@data/course/units";
import {
  cognateWaves,
  sentenceBlocks,
  powerVerbBlocks,
  connectorSentences,
  pronunciationDrills,
  vocabularyList,
} from "@data/course/unit-8";
import {
  ArrowLeft,
  ArrowRight,
  Compass,
  Layers,
  Zap,
  Link2,
  Volume2,
  ClipboardCheck,
} from "lucide-astro";

const lang = "en";
const tkey = "course/beginners/unit-8" as const;

const progressUnits = units.map((u) => ({
  id: u.id,
  slug: u.slug,
  title: u.title,
  titleEs: u.titleEs,
}));

const waveData = [cognateWaves.wave1, cognateWaves.wave2, cognateWaves.wave3];
---

<Base
  lang={lang}
  tkey={tkey}
  title="Unit 8: Feelings and Curiosity | NY English Teacher"
  description="Learn to express feelings and curiosity in English: I feel like, I wonder, they forms. Plus -ence/-ance cognates and question intonation. Free interactive lesson for Spanish speakers."
>
  <CourseProgress
    client:load
    units={progressUnits}
    currentUnit={8}
    basePath="/en/course/beginners"
    lang="en"
  />

  <section class="bg-gradient-to-b from-slate-900 to-slate-800 pt-28 pb-16 md:pt-36 md:pb-20">
    <div class="site-container mx-auto px-4 text-white">
      <div class="max-w-3xl">
        <div class="flex items-center gap-2 text-amber-400 text-sm font-semibold mb-3">
          <Compass class="w-4 h-4" />
          Unit 8
        </div>
        <h1 class="text-3xl md:text-5xl font-bold text-white mb-4 leading-tight" style="font-family: 'Noto Sans KR', sans-serif;">
          Feelings and Curiosity
        </h1>
        <p class="text-lg text-slate-300 max-w-2xl leading-relaxed">
          Express what you're in the mood for. Wonder about things you don't know.
          Talk about what "they" are doing. I feel like going out. I wonder where it is. They want to know.
        </p>
      </div>
    </div>
  </section>

  <nav class="bg-white border-b border-slate-200 sticky top-[52px] z-30 overflow-x-auto">
    <div class="site-container mx-auto px-4">
      <div class="flex items-center gap-1 py-2 text-sm whitespace-nowrap">
        <a href="#cognates" class="px-3 py-1.5 rounded-full hover:bg-amber-50 text-slate-600 hover:text-amber-600 transition-colors flex items-center gap-1.5">
          <Compass class="w-3.5 h-3.5" /> Cognates
        </a>
        <a href="#sentences" class="px-3 py-1.5 rounded-full hover:bg-amber-50 text-slate-600 hover:text-amber-600 transition-colors flex items-center gap-1.5">
          <Layers class="w-3.5 h-3.5" /> Feel Like/Wonder/Where
        </a>
        <a href="#power-verbs" class="px-3 py-1.5 rounded-full hover:bg-amber-50 text-slate-600 hover:text-amber-600 transition-colors flex items-center gap-1.5">
          <Zap class="w-3.5 h-3.5" /> They Forms
        </a>
        <a href="#connectors" class="px-3 py-1.5 rounded-full hover:bg-amber-50 text-slate-600 hover:text-amber-600 transition-colors flex items-center gap-1.5">
          <Link2 class="w-3.5 h-3.5" /> Feelings Words
        </a>
        <a href="#pronunciation" class="px-3 py-1.5 rounded-full hover:bg-amber-50 text-slate-600 hover:text-amber-600 transition-colors flex items-center gap-1.5">
          <Volume2 class="w-3.5 h-3.5" /> Pronunciation
        </a>
        <a href="#self-test" class="px-3 py-1.5 rounded-full hover:bg-amber-50 text-slate-600 hover:text-amber-600 transition-colors flex items-center gap-1.5">
          <ClipboardCheck class="w-3.5 h-3.5" /> Self-Test
        </a>
      </div>
    </div>
  </nav>

  <section id="cognates" class="py-12 md:py-16 bg-slate-50">
    <div class="site-container mx-auto px-4">
      <div class="max-w-3xl mx-auto">
        <div class="mb-8">
          <div class="flex items-center gap-2 text-amber-600 text-sm font-semibold mb-2">
            <Compass class="w-4 h-4" />
            Section A
          </div>
          <h2 class="text-2xl md:text-3xl font-bold text-slate-900 mb-3">Experience, Confidence, Patience</h2>
          <p class="text-lg text-slate-600 leading-relaxed">
            The -ence and -ance patterns give you powerful abstract nouns — the kind of words
            that make your English sound educated and precise. Plus essential feelings vocabulary.
          </p>
        </div>
        <CognateDiscovery client:visible waves={waveData} lang="en" />
      </div>
    </div>
  </section>

  <section id="sentences" class="py-12 md:py-16 bg-white">
    <div class="site-container mx-auto px-4">
      <div class="max-w-3xl mx-auto">
        <div class="mb-8">
          <div class="flex items-center gap-2 text-amber-600 text-sm font-semibold mb-2">
            <Layers class="w-4 h-4" />
            Section B
          </div>
          <h2 class="text-2xl md:text-3xl font-bold text-slate-900 mb-3">I Feel Like / I Wonder / Where Is It?</h2>
          <p class="text-lg text-slate-600 leading-relaxed">
            Two powerful new expressions: <strong>"I feel like"</strong> for moods and desires (tengo ganas de),
            and <strong>"I wonder"</strong> for curiosity (me pregunto). Plus asking and answering "where" questions.
          </p>
        </div>
        <SentenceBuilder client:visible blocks={sentenceBlocks} lang="en" />
      </div>
    </div>
  </section>

  <section id="power-verbs" class="py-12 md:py-16 bg-slate-50">
    <div class="site-container mx-auto px-4">
      <div class="max-w-3xl mx-auto">
        <div class="mb-8">
          <div class="flex items-center gap-2 text-amber-600 text-sm font-semibold mb-2">
            <Zap class="w-4 h-4" />
            Section C
          </div>
          <h2 class="text-2xl md:text-3xl font-bold text-slate-900 mb-3">They Can / They Want / They Feel Like</h2>
          <p class="text-lg text-slate-600 leading-relaxed">
            The last pronoun group: <strong>"they."</strong> Good news again — like "we," verbs don't change for "they."
            They can, they want, they have to, they feel like, they wonder. You now have every pronoun covered.
          </p>
        </div>
        <SentenceBuilder client:visible blocks={powerVerbBlocks} lang="en" />
      </div>
    </div>
  </section>

  <section id="connectors" class="py-12 md:py-16 bg-white">
    <div class="site-container mx-auto px-4">
      <div class="max-w-3xl mx-auto">
        <div class="mb-8">
          <div class="flex items-center gap-2 text-amber-600 text-sm font-semibold mb-2">
            <Link2 class="w-4 h-4" />
            Section D
          </div>
          <h2 class="text-2xl md:text-3xl font-bold text-slate-900 mb-3">Feelings and Questions</h2>
          <p class="text-lg text-slate-600 leading-relaxed">
            Words for places, activities, and questions — to the beach, a film, how, to ask, far.
          </p>
        </div>
        <ConnectorChallenge
          client:visible
          connectors={connectorSentences.connectors}
          bossSentence={connectorSentences.bossSentence}
          lang="en"
        />
      </div>
    </div>
  </section>

  <section id="pronunciation" class="py-12 md:py-16 bg-slate-50">
    <div class="site-container mx-auto px-4">
      <div class="max-w-3xl mx-auto">
        <div class="mb-8">
          <div class="flex items-center gap-2 text-rose-500 text-sm font-semibold mb-2">
            <Volume2 class="w-4 h-4" />
            Pronunciation Lab
          </div>
          <h2 class="text-2xl md:text-3xl font-bold text-slate-900 mb-3">Question Intonation — Up or Down?</h2>
          <p class="text-lg text-slate-600 leading-relaxed">
            English questions have two melody patterns: yes/no questions go UP at the end,
            and WH-questions (where, what, why) go DOWN. Getting this right makes you sound
            natural and confident — getting it wrong can confuse listeners.
          </p>
        </div>
        <PronunciationDrill client:visible drills={pronunciationDrills} lang="en" />
      </div>
    </div>
  </section>

  <section id="self-test" class="py-12 md:py-16 bg-white">
    <div class="site-container mx-auto px-4">
      <div class="max-w-3xl mx-auto">
        <div class="mb-8">
          <div class="flex items-center gap-2 text-amber-600 text-sm font-semibold mb-2">
            <ClipboardCheck class="w-4 h-4" />
            Self-Test
          </div>
          <h2 class="text-2xl md:text-3xl font-bold text-slate-900 mb-3">Test What You Learned</h2>
          <p class="text-lg text-slate-600 leading-relaxed">
            Feel like, wonder, they forms, feelings vocabulary, and -ence/-ance cognates — plus review from Units 1-7.
          </p>
        </div>
        <SelfTest client:visible vocabulary={vocabularyList} lang="en" />
      </div>
    </div>
  </section>

  <section class="py-16 md:py-20 bg-gradient-to-b from-slate-900 to-slate-800">
    <div class="site-container mx-auto px-4 text-white">
      <div class="max-w-2xl mx-auto text-center space-y-6">
        <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-emerald-500/20 text-emerald-400">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
          </svg>
        </div>
        <h2 class="text-3xl font-bold text-white">Unit 8 Complete!</h2>
        <p class="text-lg text-slate-100 leading-relaxed">
          You can now express feelings, wonder about things, and talk about what "they" are doing.
          Eight units complete — you have every pronoun in English. Only two units left!
        </p>
        <div class="flex flex-wrap gap-4 justify-center pt-4">
          <a href="/en/course/beginners/unit-7/" class="inline-flex items-center gap-2 px-6 py-3 rounded-xl bg-slate-700 text-slate-300 font-medium hover:bg-slate-600 transition-colors">
            <ArrowLeft class="w-4 h-4" /> Review Unit 7
          </a>
          <a href="/en/course/beginners/unit-9/" class="inline-flex items-center gap-2 px-6 py-3 rounded-xl bg-amber-500 text-white font-semibold hover:bg-amber-400 transition-colors shadow-lg">
            Unit 9: Telling Stories <ArrowRight class="w-4 h-4" />
          </a>
        </div>
        <div class="pt-8 border-t border-slate-700 mt-8">
          <p class="text-slate-200 text-sm mb-3">Want personalized English coaching?</p>
          <a href="/en/contact/" class="text-amber-400 hover:text-amber-300 font-medium underline underline-offset-2">
            Book a free consultation with Robert →
          </a>
        </div>
      </div>
    </div>
  </section>
</Base>
