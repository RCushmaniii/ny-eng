---
export const prerender = true;

import Base from "@layouts/Base.astro";
import Button from "@components/ui/Button.astro";
import CapstoneUploadForm from "@components/course/CapstoneUploadForm";
import { Crown, Calendar, Mic, ArrowLeft, CheckCircle2 } from "lucide-astro";

const lang = "en";
const tkey = "course/executive/capstone" as const;

const bookingLink =
  "/en/book/?notes=" +
  encodeURIComponent(
    "I just completed the Executive Communication course and recorded my capstone presentation. I would like live coaching feedback on my delivery and executive presence."
  );
---

<Base
  lang={lang}
  tkey={tkey}
  title="Executive Capstone — 90-Second Presentation | NY English"
  description="Record a 90-second executive update using the frameworks you mastered. Submit it for personal feedback from Robert — or present it live in a strategy session."
>
  <!-- Hero -->
  <section
    class="relative w-full overflow-hidden bg-gradient-to-br from-slate-950 via-slate-900 to-amber-950 pt-32 pb-20 md:pt-40 md:pb-28"
  >
    <div class="absolute inset-0 opacity-10 pointer-events-none">
      <div class="absolute top-20 left-10 w-72 h-72 bg-amber-500 rounded-full blur-3xl"></div>
      <div class="absolute bottom-10 right-10 w-96 h-96 bg-slate-400 rounded-full blur-3xl"></div>
    </div>
    <div class="site-container mx-auto px-4 relative z-10 text-white">
      <div class="max-w-3xl">
        <a
          href="/en/course/executive/unit-10/"
          class="inline-flex items-center gap-1.5 text-sm text-slate-400 hover:text-white transition-colors mb-6"
        >
          <ArrowLeft class="w-4 h-4" />
          Back to Unit 10
        </a>
        <div
          class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-amber-500/20 text-amber-300 text-sm font-semibold mb-6"
        >
          <Crown class="w-4 h-4" />
          The Capstone
        </div>
        <h1
          class="text-4xl md:text-5xl lg:text-6xl font-bold text-white mb-6 leading-tight"
          style="font-family: 'Noto Sans KR', sans-serif;"
        >
          Your Executive Voice,<br />
          <span class="text-amber-400">Recorded.</span>
        </h1>
        <p class="text-xl text-slate-200 max-w-2xl leading-relaxed">
          Ten units. 130+ drills. Every framework you've internalized. Now put it all
          together in one 90-second executive presentation — and get Robert's personal
          feedback on your delivery.
        </p>
      </div>
    </div>
  </section>

  <!-- The Prompt -->
  <section class="py-16 md:py-20 bg-white">
    <div class="site-container mx-auto px-4">
      <div class="max-w-3xl mx-auto">
        <p class="text-[11px] font-mono uppercase tracking-[0.3em] text-amber-600 mb-4">
          Your Assignment
        </p>
        <h2
          class="text-2xl md:text-3xl font-bold text-slate-900 mb-6"
          style="font-family: 'Noto Sans KR', sans-serif;"
        >
          Record a 90-second executive update.
        </h2>
        <div class="bg-slate-50 border-l-4 border-amber-400 rounded-r-xl p-6 md:p-8 mb-8">
          <p class="text-lg text-slate-800 leading-relaxed font-medium">
            Choose a real project you are currently leading. Brief it as if you are
            speaking to senior leadership — using the
            <strong>Context → Tension → Insight → Action → Outcome</strong> framework
            from Unit 5. 90 seconds. No notes. Speak from knowledge, not a script.
          </p>
        </div>

        <!-- How to record -->
        <div class="bg-amber-50 border border-amber-200 rounded-xl p-6">
          <div class="flex items-center gap-2 mb-4">
            <Mic class="w-5 h-5 text-amber-600" />
            <p class="text-sm font-bold text-amber-800 uppercase tracking-wide">How to Record</p>
          </div>
          <ul class="space-y-2 text-sm text-amber-900 leading-relaxed">
            <li><strong>iPhone:</strong> Open the Voice Memos app → tap the red button → save and export as M4A.</li>
            <li><strong>Android:</strong> Use the built-in Voice Recorder app → export as MP3 or M4A.</li>
            <li><strong>Computer:</strong> Use Zoom (record a meeting with yourself), Loom, or QuickTime audio recording.</li>
          </ul>
          <p class="text-xs text-amber-700 mt-4">
            Any audio format works: MP3, M4A, WAV, or OGG. Keep it under 50 MB (all voice recordings qualify).
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Submission — Upload form + Booking CTA -->
  <section class="py-16 md:py-20 bg-slate-50">
    <div class="site-container mx-auto px-4">
      <div class="max-w-4xl mx-auto">
        <p class="text-[11px] font-mono uppercase tracking-[0.3em] text-amber-600 mb-4 text-center">
          Submit Your Work
        </p>
        <h2
          class="text-2xl md:text-3xl font-bold text-slate-900 mb-3 text-center"
          style="font-family: 'Noto Sans KR', sans-serif;"
        >
          Choose your path.
        </h2>
        <p class="text-slate-600 text-center mb-10">
          Both options include personal feedback from Robert.
        </p>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 items-start">
          <!-- Path A: Upload -->
          <div>
            <div class="flex items-center gap-2 mb-4">
              <span class="w-6 h-6 rounded-full bg-amber-500 text-white text-xs font-bold flex items-center justify-center">A</span>
              <h3 class="text-lg font-bold text-slate-900">Upload Your Recording</h3>
            </div>
            <p class="text-sm text-slate-600 mb-5 leading-relaxed">
              Record on your phone or computer, then upload it here. Robert listens personally
              and emails you detailed feedback within 48 hours.
            </p>
            <CapstoneUploadForm client:load lang="en" />
          </div>

          <!-- Path B: Strategy Session -->
          <div class="md:mt-14">
            <div class="flex items-center gap-2 mb-4">
              <span class="w-6 h-6 rounded-full bg-slate-800 text-white text-xs font-bold flex items-center justify-center">B</span>
              <h3 class="text-lg font-bold text-slate-900">Present Live with Robert</h3>
              <span class="text-xs font-bold uppercase tracking-wider text-amber-600 bg-amber-50 border border-amber-200 px-2 py-0.5 rounded-full ml-auto">
                Recommended
              </span>
            </div>
            <p class="text-sm text-slate-600 mb-6 leading-relaxed">
              Book a free 30-minute strategy session. Deliver your 90-second update live —
              then get real-time coaching on your delivery, word choice, and executive
              presence on the spot. This is the highest-value path.
            </p>
            <div class="bg-white rounded-2xl border-2 border-amber-300 p-6 shadow-sm">
              <div class="flex items-center gap-3 mb-4">
                <Calendar class="w-6 h-6 text-amber-600" />
                <div>
                  <p class="text-sm font-bold text-slate-900">Free Strategy Session</p>
                  <p class="text-xs text-slate-500">30 minutes · Google Meet · No prep required</p>
                </div>
              </div>
              <p class="text-xs text-slate-500 mb-5 leading-relaxed">
                Your session context is pre-filled — Robert will know you're coming from the
                Executive Course and have your capstone ready.
              </p>
              <Button href={bookingLink} variant="primary" size="lg" class="w-full">
                <Calendar class="w-4 h-4" />
                Book Your Strategy Session
              </Button>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Robert's Coaching Reminders -->
  <section class="py-16 md:py-20 bg-white">
    <div class="site-container mx-auto px-4">
      <div class="max-w-3xl mx-auto">
        <p class="text-[11px] font-mono uppercase tracking-[0.3em] text-amber-600 mb-4">
          Robert's Reminders
        </p>
        <h2
          class="text-2xl font-bold text-slate-900 mb-8"
          style="font-family: 'Noto Sans KR', sans-serif;"
        >
          Four things I listen for.
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          {
            [
              {
                tip: "Executive verbs — not 'looked into' but 'diagnosed.' Not 'worked on' but 'drove.' (Unit 1)",
              },
              {
                tip: "Zero filler. No 'I think', 'kind of', 'basically', 'you know.' If you catch yourself, pause — then continue. (Unit 2)",
              },
              {
                tip: "A named framework. The briefing should have a clear structure anyone could follow. (Units 3–5)",
              },
              {
                tip: "Calm delivery. Slow down by 20% from your natural pace. Brevity and stillness signal authority. (Unit 10)",
              },
            ].map((item) => (
              <div class="flex items-start gap-3 p-5 bg-slate-50 rounded-xl border border-slate-100">
                <CheckCircle2 class="w-5 h-5 text-amber-500 shrink-0 mt-0.5" />
                <p class="text-sm text-slate-700 leading-relaxed">{item.tip}</p>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <!-- Bottom Encouragement -->
  <section class="py-20 md:py-28 bg-slate-950 text-white">
    <div class="site-container mx-auto px-4">
      <div class="max-w-2xl mx-auto text-center">
        <Crown class="w-10 h-10 text-amber-400 mx-auto mb-6" />
        <h2
          class="text-3xl md:text-4xl font-bold mb-6 leading-tight"
          style="font-family: 'Noto Sans KR', sans-serif;"
        >
          This is not a test.<br />
          <span class="text-amber-400">This is your moment.</span>
        </h2>
        <p class="text-lg text-slate-300 leading-relaxed">
          Every drill, every framework, every correction in this course built toward
          this. Record your 90 seconds. Send it. Own it.
        </p>
      </div>
    </div>
  </section>

  <script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "LearningResource",
  "name": "Executive English Capstone — 90-Second Presentation Challenge",
  "description": "Record a 90-second executive update using the frameworks you mastered. Submit it for personal feedback from Robert — or present it live in a strategy session.",
  "learningResourceType": "Assessment",
  "educationalLevel": "C1-C2",
  "inLanguage": "en",
  "url": "https://www.nyenglishteacher.com/en/course/executive/capstone/",
  "isAccessibleForFree": true,
  "isPartOf": {
    "@type": "Course",
    "name": "Executive English Course (C1-C2)",
    "url": "https://www.nyenglishteacher.com/en/course/executive/"
  }
})} />
</Base>
