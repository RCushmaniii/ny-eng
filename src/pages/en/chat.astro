---
export const prerender = true;

import Base from "@layouts/Base.astro";
import ChatEmbed from "@components/chat/ChatEmbed.astro";

const seoTitle = "AI English Coach Chat | New York English Teacher";
const seoDescription =
  "Chat with our AI English Coach to explore coaching options, get pricing details, and discover the fastest way to close your professional Communication Gap.";
---

<Base
  lang="en"
  tkey="chat"
  title={seoTitle}
  description={seoDescription}
  ogImage={{ src: "/images/logos/new-york-english-sq-og.jpg" }}
  noindex={true}
>
  <ChatEmbed lang="en" />

  <script>
    // Prevent automatic scroll on page load
    if ("scrollRestoration" in history) {
      history.scrollRestoration = "manual";
    }
    window.scrollTo(0, 0);
  </script>
</Base>
