---
import { getCollection, type CollectionEntry } from 'astro:content';
import Base from '@layouts/Base.astro';
import BlogPostSchema from '@components/seo/BlogPostSchema.astro';
import CategoryPill from '@components/ui/CategoryPill.astro';
// FIX: Rename the imported component to avoid conflict with the native Date object
import DateComponent from '@components/ui/Date.astro';
import { Image } from 'astro:assets';
import { siteConfig } from '@data/config';
import { normalizeBlogSlug, buildPostUrl, assertNoDoubleLang, stripLangPrefix } from '@utils/i18nRoutes';
import { cleanBlogUrl } from '@utils/url-cleaner';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  // Filter for published English posts
  const enPosts = posts.filter((post: CollectionEntry<'blog'>) => post.slug.startsWith('en/') && post.data.publish !== false);
  
  return enPosts.map((post: CollectionEntry<'blog'>) => {
    // Normalize the slug to prevent duplicate URLs
    const { segments } = normalizeBlogSlug(post.slug);
    
    // For single-segment routes, we only want the first segment
    const singleSegment = segments[0] || '';
    const canonicalUrl = buildPostUrl('en', singleSegment);
    
    // Development guard to catch double language segments
    try {
      assertNoDoubleLang(`/en/blog/${singleSegment}`, 'getStaticPaths(en/[slug])');
    } catch (e: any) {
      console.warn(`[Warning] ${e.message}`);
    }
    
    return {
      params: { slug: singleSegment },
      props: { post, canonicalUrl }
    };
  });
}

interface Props {
  post: CollectionEntry<'blog'>;
  canonicalUrl: string;
}

const { post } = Astro.props as Props;
const { Content } = await post.render();

// Use the canonicalUrl passed from getStaticPaths
const { canonicalUrl } = Astro.props as Props;

// For sharing functionality
const postTitle = post.data.title;
const postUrl = canonicalUrl;

// --- SEO Meta Tags ---
const seoTitle = post.data.seo?.title || post.data.title;
const seoDescription = post.data.seo?.description || post.data.excerpt;
const featuredObj = post.data.featuredImage;
const featuredUrl: string | null = (typeof featuredObj === 'object' && featuredObj?.src)
  ? featuredObj.src
  : (post.data.seo?.image ?? null);

// --- Previous/Next Post Navigation ---
const allPosts = (await getCollection('blog'))
  .filter((p: CollectionEntry<'blog'>) => p.id.startsWith('en/') && p.data.publish !== false)
  .sort((a: CollectionEntry<'blog'>, b: CollectionEntry<'blog'>) => new Date(b.data.publishDate).valueOf() - new Date(a.data.publishDate).valueOf());

// Fix the params.slug type issue
// Type-safe params access
const { slug } = Astro.params as { slug: string };

const currentIndex = allPosts.findIndex((p: CollectionEntry<'blog'>) => {
  // Remove .md extension and compare with current slug
  const postSlug = p.id.replace(/^en\/|\.md$/g, '');
  return postSlug === slug;
});

const previousPost = allPosts[currentIndex + 1] ?? null; // Older post
const nextPost = allPosts[currentIndex - 1] ?? null;     // Newer post

// Get site URL for structured data
const siteUrl = siteConfig.siteUrl || 'https://www.nyenglishteacher.com';
const cleanSiteUrl = siteUrl.replace(/https?:\/\/www\.www\./i, 'https://www.').replace(/\/$/, '');

// Generate proper hreflang for individual blog posts
const lang = 'en';
const fullSiteUrl = 'https://www.nyenglishteacher.com';
const currentUrl = `${fullSiteUrl}${canonicalUrl}`;
const spanishTranslation = post.data.translations?.es;


// Create custom hreflang alternates for this specific post
const customHreflangs = [
  { lang: 'en-US', href: currentUrl },
  ...(spanishTranslation ? [{ 
    lang: 'es-MX', 
    href: cleanBlogUrl(`${fullSiteUrl}/es/blog/${spanishTranslation}/`)
  }] : [])
];
---

<Base
  lang="en"
  tkey="blog"
  customHreflangs={customHreflangs}
  customCanonical={currentUrl}
  title={seoTitle}
  description={seoDescription}
  ogImage={featuredUrl ? { src: featuredUrl, alt: post.data.imageAlt || post.data.title } : undefined}
>
  <BlogPostSchema
    title={post.data.title}
    description={post.data.excerpt}
    publishDate={post.data.publishDate}
    image={featuredUrl || undefined}
    url={postUrl}
    authorName="New York English"
    categories={post.data.categories}
  />
  
  <section class="relative w-full">
    <div class="w-full h-screen fixed top-0 left-0 -z-10 overflow-hidden">
      <div class="absolute top-0 left-0 right-0 h-[25vh] bg-gradient-to-b from-[#eef1ff] via-[#f8f9ff] to-white"></div>
      <div class="absolute top-[25vh] left-0 right-0 bottom-0 bg-white"></div>
    </div>
    
    <article class="site-container--small mx-auto px-4 prose relative z-10 pb-base">
      <div class="mt-[5rem] md:mt-16 mb-6 md:mb-12 pt-8 md:pt-12 text-center relative z-10">
        <h1 class="text-gray-900 text-3xl md:text-4xl font-bold mb-4">{post.data.title}</h1>
        <div class="flex flex-wrap items-center justify-center gap-2 md:gap-4 text-gray-600">
          <DateComponent date={post.data.publishDate} lang="en" />
          {post.data.categories && post.data.categories.map((cat: string) => (
            <CategoryPill category={cat} lang="en" />
          ))}
        </div>
      </div>
      
      {(featuredObj || featuredUrl) && (
        <div class="relative mb-12 rounded-lg overflow-hidden border border-black">
          {featuredObj ? (
            <Image
              src={featuredObj}
              alt={post.data.imageAlt || post.data.title}
              width={1200}
              height={675}
              class="w-full object-cover h-[300px] md:h-[450px] lg:h-[675px]"
              quality={80}
              format="webp"
            />
          ) : (
            <img
              src={featuredUrl!}
              alt={post.data.imageAlt || post.data.title}
              class="w-full object-cover h-[300px] md:h-[450px] lg:h-[675px]"
              loading="eager"
              width="1200"
              height="675"
            />
          )}
          <div class="absolute bottom-0 left-0 right-0 h-16 bg-gradient-to-t from-black/50 to-transparent"></div>
        </div>
      )}
      
      <Content />
      
      {postUrl && postTitle && (
        <>
          <section class="share-bar mt-12 mb-8 mx-auto max-w-3xl">
            <div class="flex items-center justify-center mb-3">
              <span class="font-medium text-center">Share this post:</span>
            </div>
            <div class="flex flex-wrap items-center gap-2 sm:gap-3 justify-center">
              <a href={"https://api.whatsapp.com/send?text=" + encodeURIComponent(postUrl)} target="_blank" rel="noopener noreferrer" class="share-btn px-3 py-1.5 rounded transition hover:bg-primary hover:text-white border border-gray-100 text-sm flex items-center bg-white shadow-sm">
                <span>WhatsApp</span>
              </a>
              <a href={"https://www.facebook.com/sharer/sharer.php?u=" + encodeURIComponent(postUrl)} target="_blank" rel="noopener noreferrer" class="share-btn px-3 py-1.5 rounded transition hover:bg-primary hover:text-white border border-gray-100 text-sm flex items-center bg-white shadow-sm">
                <span class="hidden sm:inline">Facebook</span>
                <span class="sm:hidden">FB</span>
              </a>
              <a href={"https://www.linkedin.com/sharing/share-offsite/?url=" + encodeURIComponent(postUrl)} target="_blank" rel="noopener noreferrer" class="share-btn px-3 py-1.5 rounded transition hover:bg-primary hover:text-white border border-gray-100 text-sm flex items-center bg-white shadow-sm">
                <span class="hidden sm:inline">LinkedIn</span>
                <span class="sm:hidden">LI</span>
              </a>
              <a href={"https://twitter.com/intent/tweet?url=" + encodeURIComponent(postUrl) + "&text=" + encodeURIComponent(postTitle)} target="_blank" rel="noopener noreferrer" class="share-btn px-3 py-1.5 rounded transition hover:bg-primary hover:text-white border border-gray-100 text-sm flex items-center bg-white shadow-sm">
                <span class="hidden sm:inline">Twitter</span>
                <span class="sm:hidden">X</span>
              </a>
              <button id="copy-link-btn" type="button" class="share-btn px-3 py-1.5 rounded transition hover:bg-primary hover:text-white border border-gray-100 text-sm flex items-center bg-white shadow-sm">
                <span>Copy Link</span>
              </button>
            </div>
            <div class="flex justify-center mt-2">
              <span id="copy-link-msg" class="text-green-600 font-semibold text-sm" style="display:none;">Copied!</span>
            </div>
          </section>
          <script>
            document.addEventListener('DOMContentLoaded', function() {
              const btn = document.getElementById('copy-link-btn');
              const msg = document.getElementById('copy-link-msg');
              if (btn) {
                btn.addEventListener('click', function() {
                  navigator.clipboard.writeText(window.location.href).then(function() {
                    if (msg) {
                      msg.style.display = 'inline';
                      setTimeout(() => { msg.style.display = 'none'; }, 1500);
                    }
                  });
                });
              }
            });
          </script>
        </>
      )}
      
      {(previousPost || nextPost) && (
        <section class="mt-16 flex flex-col items-center md:flex-row md:justify-between gap-6 mx-auto max-w-3xl">
        {previousPost && (
          <a
            href={cleanBlogUrl(buildPostUrl('en', stripLangPrefix(previousPost.slug)))}
            rel="prev"
            class="group relative flex-1 max-w-xs border border-gray-200 rounded-lg overflow-hidden transition-transform duration-200 hover:scale-105 hover:border-primary bg-white flex flex-col h-full shadow-sm"
          >
            <div class="flex items-center justify-between h-12 px-4 border-b">
              <span class="text-2xl text-gray-400 transition-colors duration-200 group-hover:text-primary">&#8592;</span>
              <span class="font-medium text-xs text-gray-700">Previous</span>
            </div>
            {(() => {
              const prevObj = previousPost?.data?.featuredImage;
              const prevUrl = (typeof prevObj === 'object' && prevObj?.src) ? prevObj.src : (previousPost?.data?.seo?.image ?? null);
              return prevUrl ? (
                <div class="aspect-video w-full bg-gray-100">
                  <img src={prevUrl} alt={previousPost.data.imageAlt || previousPost.data.title} class="object-cover w-full h-full" />
                </div>
              ) : null;
            })()}
            <div class="flex-grow px-4 py-6 flex flex-col">
              <div class="font-semibold text-base mb-1 line-clamp-2">{previousPost.data.title}</div>
              <div class="text-xs text-gray-500 mb-2">
                <DateComponent date={previousPost.data.publishDate} lang="en" />
              </div>
              <div class="text-sm text-gray-700 line-clamp-3">{previousPost.data.excerpt}</div>
            </div>
          </a>
        )}
        {nextPost && (
          <a
            href={cleanBlogUrl(buildPostUrl('en', stripLangPrefix(nextPost.slug)))}
            rel="next"
            class="group relative flex-1 max-w-xs border border-gray-200 rounded-lg overflow-hidden transition-transform duration-200 hover:scale-105 hover:border-primary bg-white flex flex-col h-full shadow-sm"
          >
            <div class="flex items-center justify-between h-12 px-4 border-b">
              <span class="font-medium text-xs text-gray-700">Next</span>
              <span class="text-2xl text-gray-400 transition-colors duration-200 group-hover:text-primary">&#8594;</span>
            </div>
            {(() => {
              const nextObj = nextPost?.data?.featuredImage;
              const nextUrl = (typeof nextObj === 'object' && nextObj?.src) ? nextObj.src : (nextPost?.data?.seo?.image ?? null);
              return nextUrl ? (
                <div class="aspect-video w-full bg-gray-100">
                  <img src={nextUrl} alt={nextPost.data.imageAlt || nextPost.data.title} class="object-cover w-full h-full" />
                </div>
              ) : null;
            })()}
            <div class="flex-grow px-4 py-6 flex flex-col text-right">
              <div class="font-semibold text-base mb-1 line-clamp-2">{nextPost.data.title}</div>
              <div class="text-xs text-gray-500 mb-2">
                <DateComponent date={nextPost.data.publishDate} lang="en" />
              </div>
              <div class="text-sm text-gray-700 line-clamp-3">{nextPost.data.excerpt}</div>
            </div>
          </a>
        )}
      </section>
      )}
    </article>
  </section>
</Base>