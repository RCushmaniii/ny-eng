---
import { getCollection, type CollectionEntry } from 'astro:content';
import Base from '@layouts/Base.astro';
import BlogPostSchema from '@components/seo/BlogPostSchema.astro';
import BreadcrumbSchema from '@components/seo/BreadcrumbSchema.astro';
import Breadcrumbs from '@components/ui/Breadcrumbs.astro';
import CategoryPill from '@components/ui/CategoryPill.astro';
// FIX: Rename the imported component to avoid conflict with the native Date object
import DateComponent from '@components/ui/Date.astro';
import { Image } from 'astro:assets';
import VideoHero from '@components/blog/VideoHero.tsx';
import SpeakEnglish from '@components/blog/SpeakEnglish.astro';
import { siteConfig } from '@data/config';
import { normalizeBlogSlug, buildPostUrl, assertNoDoubleLang, stripLangPrefix } from '@utils/i18nRoutes';
import { cleanBlogUrl } from '@utils/url-cleaner';

export const prerender = true;

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  // Filter for published English posts
  const enPosts = posts.filter((post: CollectionEntry<'blog'>) => post.slug.startsWith('en/') && post.data.publish !== false);
  
  return enPosts.map((post: CollectionEntry<'blog'>) => {
    // Normalize the slug to prevent duplicate URLs
    const { segments } = normalizeBlogSlug(post.slug);
    
    // For single-segment routes, we only want the first segment
    const singleSegment = segments[0] || '';
    const canonicalUrl = buildPostUrl('en', singleSegment);
    
    // Development guard to catch double language segments
    try {
      assertNoDoubleLang(`/en/blog/${singleSegment}`, 'getStaticPaths(en/[slug])');
    } catch (e: any) {
      console.warn(`[Warning] ${e.message}`);
    }
    
    return {
      params: { slug: singleSegment },
      props: { post, canonicalUrl }
    };
  });
}

interface Props {
  post: CollectionEntry<'blog'>;
  canonicalUrl: string;
}

const { post } = Astro.props as Props;
const { Content } = await post.render();

// Use the canonicalUrl passed from getStaticPaths
const { canonicalUrl } = Astro.props as Props;

// For sharing functionality
const postTitle = post.data.title;
const postUrl = canonicalUrl;

// --- SEO Meta Tags ---
const seoTitle = post.data.seo?.title || post.data.title;
const seoDescription = post.data.seo?.description || post.data.excerpt;
const featuredObj = post.data.featuredImage;

// Extract the actual image path for OG tags (not the Astro image object)
let featuredUrl: string | null = null;
if (typeof featuredObj === 'object' && featuredObj?.src) {
  // This is an Astro image object - we need to construct a public URL path
  // The image is in src/content/blog/en/images/..., which gets copied to /en/blog/images/...
  const imgSrc = featuredObj.src as any;
  if (imgSrc?.src && typeof imgSrc.src === 'string') {
    // Extract the path from the Astro image object
    const match = imgSrc.src.match(/\/images\/(.+)$/);
    if (match) {
      featuredUrl = `/en/blog/images/${match[1]}`;
    }
  } else if (typeof featuredObj.src === 'string') {
    // It's already a string path
    featuredUrl = featuredObj.src.replace('./images/', '/en/blog/images/');
  }
} else if (post.data.seo?.image) {
  featuredUrl = post.data.seo.image;
}

// --- Previous/Next Post Navigation ---
const allPosts = (await getCollection('blog'))
  .filter((p: CollectionEntry<'blog'>) => p.id.startsWith('en/') && p.data.publish !== false)
  .sort((a: CollectionEntry<'blog'>, b: CollectionEntry<'blog'>) => new Date(b.data.publishDate).valueOf() - new Date(a.data.publishDate).valueOf());

// Fix the params.slug type issue
// Type-safe params access
const { slug } = Astro.params as { slug: string };

const currentIndex = allPosts.findIndex((p: CollectionEntry<'blog'>) => {
  // Remove .md extension and compare with current slug
  const postSlug = p.id.replace(/^en\/|\.mdx?$/g, '');
  return postSlug === slug;
});

const previousPost = allPosts[currentIndex + 1] ?? null; // Older post
const nextPost = allPosts[currentIndex - 1] ?? null;     // Newer post

// --- Related Posts by Category Overlap ---
const currentCategories = new Set(post.data.categories || []);
const relatedPosts = allPosts
  .filter((p: CollectionEntry<'blog'>) => p.id !== post.id)
  .map((p: CollectionEntry<'blog'>) => {
    const pCats = p.data.categories || [];
    const overlap = pCats.filter((c: string) => currentCategories.has(c)).length;
    return { post: p, score: overlap };
  })
  .filter((item) => item.score > 0)
  .sort((a, b) => b.score - a.score || new Date(b.post.data.publishDate).valueOf() - new Date(a.post.data.publishDate).valueOf())
  .slice(0, 3)
  .map((item) => item.post);

// Get site URL for structured data
const siteUrl = siteConfig.siteUrl || 'https://www.nyenglishteacher.com';
const cleanSiteUrl = siteUrl.replace(/https?:\/\/www\.www\./i, 'https://www.').replace(/\/$/, '');

// Generate proper hreflang for individual blog posts
const lang = 'en';
const fullSiteUrl = 'https://www.nyenglishteacher.com';
const currentUrl = `${fullSiteUrl}${canonicalUrl}`;
const spanishTranslation = post.data.translations?.es;

// Extract just the slug from translation path (handles both "/es/blog/slug" and "slug" formats)
const extractSlug = (path: string | undefined): string | null => {
  if (!path) return null;
  // If it's a full path like "/es/blog/slug", extract just the slug
  if (path.startsWith('/')) {
    const parts = path.split('/').filter(Boolean);
    return parts[parts.length - 1] || null;
  }
  // Otherwise it's already just the slug
  return path;
};

const spanishSlug = extractSlug(spanishTranslation);

// Create custom hreflang alternates for this specific post
const customHreflangs = [
  { lang: 'en-US', href: currentUrl },
  ...(spanishSlug ? [{ 
    lang: 'es-MX', 
    href: cleanBlogUrl(`${fullSiteUrl}/es/blog/${spanishSlug}/`)
  }] : [])
];
---

<Base
  lang="en"
  customHreflangs={customHreflangs}
  customCanonical={currentUrl}
  title={seoTitle}
  description={seoDescription}
  ogType="article"
  articlePublishedTime={post.data.publishDate.toISOString()}
  articleModifiedTime={post.data.lastmod?.toISOString() || post.data.publishDate.toISOString()}
  articleAuthor="Robert Cushman"
  ogImage={featuredUrl ? { 
    src: featuredUrl, 
    alt: post.data.imageAlt || post.data.title,
    width: 1200,
    height: 675
  } : undefined}
>
  <BlogPostSchema
    title={post.data.title}
    description={post.data.excerpt}
    publishDate={post.data.publishDate}
    image={featuredUrl || undefined}
    url={postUrl}
    authorName="Robert Cushman"
    categories={post.data.categories}
    lang="en"
  />
  <BreadcrumbSchema items={[
    { name: "Home", url: "https://www.nyenglishteacher.com/en/" },
    { name: "Blog", url: "https://www.nyenglishteacher.com/en/blog/" },
    { name: post.data.title, url: `https://www.nyenglishteacher.com${postUrl}` }
  ]} />

  <section class="relative w-full">
    <div class="w-full h-screen fixed top-0 left-0 -z-10 overflow-hidden">
      <div class="absolute top-0 left-0 right-0 h-[25vh] bg-gradient-to-b from-[#eef1ff] via-[#f8f9ff] to-white"></div>
      <div class="absolute top-[25vh] left-0 right-0 bottom-0 bg-white"></div>
    </div>

    <article class="site-container--small mx-auto prose relative z-10 pb-base">
      <div class="mt-[5rem] md:mt-16 pt-8 md:pt-12 relative z-10">
        <Breadcrumbs items={[
          { name: "Home", url: "/en/" },
          { name: "Blog", url: "/en/blog/" },
          { name: post.data.title, url: postUrl }
        ]} />
      </div>
      <div class="mb-6 md:mb-12 text-center relative z-10">
        <h1 class="text-gray-900 text-3xl md:text-4xl font-bold mb-4">{post.data.title}</h1>
        <div class="flex flex-wrap items-center justify-center gap-2 md:gap-4 text-gray-600">
          <DateComponent date={post.data.publishDate} lang="en" />
          {post.data.categories && post.data.categories.map((cat: string) => (
            <CategoryPill category={cat} lang="en" />
          ))}
        </div>
      </div>
      
      {post.data.heroVideo ? (
        <div class="mb-12">
          <VideoHero
            client:load
            src={post.data.heroVideo}
            poster={post.data.heroVideoPoster}
            alt={post.data.imageAlt || post.data.title}
          />
        </div>
      ) : (featuredObj || featuredUrl) && (
        <div class="relative mb-12 rounded-lg shadow-lg" style="overflow: hidden;">
          {featuredObj ? (
            <Image
              src={featuredObj}
              alt={post.data.imageAlt || post.data.title}
              width={1200}
              height={675}
              class="w-full object-cover h-[300px] md:h-[450px] lg:h-[675px] rounded-lg"
              quality={80}
              format="webp"
              style="display: block; margin: 0; padding: 0;"
            />
          ) : (
            <img
              src={featuredUrl!}
              alt={post.data.imageAlt || post.data.title}
              class="w-full object-cover h-[300px] md:h-[450px] lg:h-[675px] rounded-lg"
              loading="eager"
              width="1200"
              height="675"
              style="display: block; margin: 0; padding: 0;"
            />
          )}
          <div class="absolute bottom-0 left-0 right-0 h-16 bg-gradient-to-t from-black/50 to-transparent rounded-b-lg"></div>
        </div>
      )}
      
      <Content />
      <SpeakEnglish />

      {postUrl && postTitle && (
        <>
          <section class="share-bar mt-12 mb-8 mx-auto max-w-3xl">
            <div class="flex items-center justify-center mb-3">
              <span class="font-medium text-center">Share this post:</span>
            </div>
            <div class="flex flex-wrap items-center gap-2 sm:gap-3 justify-center">
              <a href={"https://api.whatsapp.com/send?text=" + encodeURIComponent(postUrl)} target="_blank" rel="noopener noreferrer" class="share-btn px-3 py-1.5 rounded transition hover:bg-primary hover:text-white border border-gray-100 text-sm flex items-center bg-white shadow-sm">
                <span>WhatsApp</span>
              </a>
              <a href={"https://www.facebook.com/sharer/sharer.php?u=" + encodeURIComponent(postUrl)} target="_blank" rel="noopener noreferrer" class="share-btn px-3 py-1.5 rounded transition hover:bg-primary hover:text-white border border-gray-100 text-sm flex items-center bg-white shadow-sm">
                <span class="hidden sm:inline">Facebook</span>
                <span class="sm:hidden">FB</span>
              </a>
              <a href={"https://www.linkedin.com/sharing/share-offsite/?url=" + encodeURIComponent(postUrl)} target="_blank" rel="noopener noreferrer" class="share-btn px-3 py-1.5 rounded transition hover:bg-primary hover:text-white border border-gray-100 text-sm flex items-center bg-white shadow-sm">
                <span class="hidden sm:inline">LinkedIn</span>
                <span class="sm:hidden">LI</span>
              </a>
              <a href={"https://twitter.com/intent/tweet?url=" + encodeURIComponent(postUrl) + "&text=" + encodeURIComponent(postTitle)} target="_blank" rel="noopener noreferrer" class="share-btn px-3 py-1.5 rounded transition hover:bg-primary hover:text-white border border-gray-100 text-sm flex items-center bg-white shadow-sm">
                <span class="hidden sm:inline">Twitter</span>
                <span class="sm:hidden">X</span>
              </a>
              <button id="copy-link-btn" type="button" class="share-btn px-3 py-1.5 rounded transition hover:bg-primary hover:text-white border border-gray-100 text-sm flex items-center bg-white shadow-sm">
                <span>Copy Link</span>
              </button>
            </div>
            <div class="flex justify-center mt-2">
              <span id="copy-link-msg" class="text-green-600 font-semibold text-sm" style="display:none;">Copied!</span>
            </div>
          </section>
          <script>
            document.addEventListener('DOMContentLoaded', function() {
              const btn = document.getElementById('copy-link-btn');
              const msg = document.getElementById('copy-link-msg');
              if (btn) {
                btn.addEventListener('click', function() {
                  navigator.clipboard.writeText(window.location.href).then(function() {
                    if (msg) {
                      msg.style.display = 'inline';
                      setTimeout(() => { msg.style.display = 'none'; }, 1500);
                    }
                  });
                });
              }
            });
          </script>
        </>
      )}
      
      {(previousPost || nextPost) && (
        <section class="mt-16 mb-8 mx-auto max-w-3xl">
          <h2 class="text-2xl font-bold text-gray-900 mb-6 text-center">Continue Reading</h2>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {previousPost && (
          <a
            href={cleanBlogUrl(buildPostUrl('en', stripLangPrefix(previousPost.slug)))}
            rel="prev"
            class="group block bg-white rounded-lg shadow-md hover:shadow-xl transition-shadow duration-300 no-underline"
            style="overflow: hidden; padding: 0; margin: 0;"
          >
            {(() => {
              const prevObj = previousPost?.data?.featuredImage;
              const prevUrl = (typeof prevObj === 'object' && prevObj?.src) ? prevObj.src : (previousPost?.data?.seo?.image ?? previousPost?.data?.heroVideoPoster ?? null);
              return prevUrl ? (
                <div class="w-full h-48 bg-gray-100" style="margin: 0; padding: 0; display: block;">
                  <img src={prevUrl} alt={previousPost.data.imageAlt || previousPost.data.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" loading="lazy" style="display: block; margin: 0; padding: 0;" />
                </div>
              ) : null;
            })()}
            <div class="p-5">
              <div class="flex items-center gap-2 mb-2 text-primary">
                <span>←</span>
                <span class="text-xs font-semibold uppercase tracking-wide">Previous</span>
              </div>
              <h3 class="font-bold text-lg mb-2 text-gray-900 group-hover:text-primary transition-colors line-clamp-2">{previousPost.data.title}</h3>
              <div class="text-xs text-gray-500 mb-2">
                <DateComponent date={previousPost.data.publishDate} lang="en" />
              </div>
              <p class="text-sm text-gray-600 line-clamp-2">{previousPost.data.excerpt}</p>
            </div>
          </a>
        )}
        {nextPost && (
          <a
            href={cleanBlogUrl(buildPostUrl('en', stripLangPrefix(nextPost.slug)))}
            rel="next"
            class="group block bg-white rounded-lg shadow-md hover:shadow-xl transition-shadow duration-300 no-underline"
            style="overflow: hidden; padding: 0; margin: 0;"
          >
            {(() => {
              const nextObj = nextPost?.data?.featuredImage;
              const nextUrl = (typeof nextObj === 'object' && nextObj?.src) ? nextObj.src : (nextPost?.data?.seo?.image ?? nextPost?.data?.heroVideoPoster ?? null);
              return nextUrl ? (
                <div class="w-full h-48 bg-gray-100" style="margin: 0; padding: 0; display: block;">
                  <img src={nextUrl} alt={nextPost.data.imageAlt || nextPost.data.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" loading="lazy" style="display: block; margin: 0; padding: 0;" />
                </div>
              ) : null;
            })()}
            <div class="p-5">
              <div class="flex items-center justify-end gap-2 mb-2 text-primary">
                <span class="text-xs font-semibold uppercase tracking-wide">Next</span>
                <span>→</span>
              </div>
              <h3 class="font-bold text-lg mb-2 text-gray-900 group-hover:text-primary transition-colors line-clamp-2 text-right">{nextPost.data.title}</h3>
              <div class="text-xs text-gray-500 mb-2 text-right">
                <DateComponent date={nextPost.data.publishDate} lang="en" />
              </div>
              <p class="text-sm text-gray-600 line-clamp-2 text-right">{nextPost.data.excerpt}</p>
            </div>
          </a>
        )}
          </div>
      </section>
      )}

      {relatedPosts.length > 0 && (
        <section class="mt-16 mb-8 mx-auto max-w-3xl">
          <h2 class="text-2xl font-bold text-gray-900 mb-6 text-center">Related Articles</h2>
          <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            {relatedPosts.map((related: CollectionEntry<'blog'>) => (
                <a
                  href={cleanBlogUrl(buildPostUrl('en', stripLangPrefix(related.slug)))}
                  class="group block bg-white rounded-lg shadow-md hover:shadow-xl transition-shadow duration-300 no-underline"
                  style="overflow: hidden; padding: 0; margin: 0;"
                >
                  {(() => {
                    const relObj = related?.data?.featuredImage;
                    const relUrl = (typeof relObj === 'object' && relObj?.src) ? relObj.src : (related?.data?.seo?.image ?? related?.data?.heroVideoPoster ?? null);
                    return relUrl ? (
                      <div class="w-full h-36 bg-gray-100" style="margin: 0; padding: 0; display: block;">
                        <img src={relUrl} alt={related.data.imageAlt || related.data.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" loading="lazy" style="display: block; margin: 0; padding: 0;" />
                      </div>
                    ) : null;
                  })()}
                  <div class="p-4">
                    <h3 class="font-bold text-sm mb-2 text-gray-900 group-hover:text-primary transition-colors line-clamp-2">{related.data.title}</h3>
                    <p class="text-xs text-gray-600 line-clamp-2">{related.data.excerpt}</p>
                  </div>
                </a>
            ))}
          </div>
        </section>
      )}
    </article>
  </section>
</Base>