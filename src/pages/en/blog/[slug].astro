---
import { getCollection } from 'astro:content';
import Layout from '@layouts/Layout.astro';
import CategoryPill from '@components/ui/CategoryPill.astro';
import Date from '@components/ui/Date.astro';
import { Image } from 'astro:assets';
import BlogPost from '@components/blog/BlogPost.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  // Only English posts in en/ subfolder
  const enPosts = posts.filter(post => post.slug.startsWith('en/') && post.data.publish !== false);
  return enPosts.map(post => ({
    params: { slug: post.slug.replace(/^en\//, '') }, // removes 'en/' prefix
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();

const allPosts = (await getCollection('blog'))
  .filter(p => p.id.startsWith('en/') && p.data.publish !== false)
  .sort((a, b) => globalThis.Date.parse(String(b.data.publishDate)) - globalThis.Date.parse(String(a.data.publishDate)));
// DEBUG: Log all slugs and featuredImages
console.log("DEBUG: allPosts slugs and featuredImages:", allPosts.map(p => ({ slug: p.slug, featuredImage: p.data.featuredImage })));
// Add back the 'en/' prefix to match the slug in the collection
const currentSlug = `en/${Astro.params.slug}`;
const index = allPosts.findIndex(p => p.slug === currentSlug);
const previousPost = allPosts[index + 1] ?? null; // Older (chronologically next)
const nextPost = allPosts[index - 1] ?? null;     // Newer (chronologically previous)

// Only show if both posts exist, and always render exactly two (no placeholders)
const navPosts = previousPost && nextPost ? [previousPost, nextPost] : [];

const seoTitle = post.data.seo?.title || post.data.title;
const seoDescription = post.data.seo?.description || post.data.excerpt;
let seoImage = post.data.seo?.image;
if (seoImage && !seoImage.startsWith('http')) {
  const siteUrl = import.meta.env.SITE || 'https://www.nyenglishteacher.com';
  seoImage = new URL(seoImage.startsWith('/') ? seoImage : `/${seoImage}`, siteUrl).toString();
} else if (!seoImage && post.data.featuredImage) {
  // Use the featured image for SEO if not overridden
  const siteUrl = import.meta.env.SITE || 'https://www.nyenglishteacher.com';
  seoImage = new URL(post.data.featuredImage.src, siteUrl).toString();
}

const origin = import.meta.env.SITE || 'https://www.nyenglishteacher.com';
const base = origin.endsWith('/') ? origin.slice(0, -1) : origin;
const postSlug = Astro.params.slug;
const postUrl = `${base}/en/blog/${postSlug}`;
const postTitle = post.data.title;
---

<Layout title={seoTitle} description={seoDescription} translationSlugEs={post.data.translations && post.data.translations.es ? post.data.translations.es : undefined}>
  <section class="relative w-full">

    <div class="w-full h-[34rem] absolute top-0 left-0 z-0 overflow-hidden border-b border-black">
      {post.data.featuredImage && (
        <Image
          src={post.data.featuredImage}
          alt={post.data.imageAlt || post.data.title}
          width={1920}
          height={1080}
          class="w-full h-full object-cover grayscale opacity-20"
          quality={60}
        />
      )}
      <div class="absolute inset-0 bg-primary/10 backdrop-blur-md"></div>
    </div>
    <article class="site-container--small mx-auto px-4 prose relative z-10 pb-base">
      <div class="pt-28 mb-12 text-center relative z-10">
        <h1>{post.data.title}</h1>
        <div class="flex items-center justify-center gap-4 text-gray-600">
          <Date date={post.data.publishDate} />
          {post.data.categories && post.data.categories.map(cat => (
            <CategoryPill category={cat} />
          ))}
        </div>
      </div>
      {post.data.featuredImage && (
        <Image
          src={post.data.featuredImage}
          alt={post.data.imageAlt || post.data.title}
          width={1200}
          height={675}
          class="w-full h-[675px] object-cover rounded-lg border mb-12 border-black"
          quality={80}
          format="webp"
        />
      )}
      <Content />
    </article>
    {(previousPost || nextPost) && (
      <section class="mt-16 flex flex-col items-center md:flex-row md:justify-between gap-6 mx-auto max-w-3xl">
        {previousPost && (
          <a href={`/en/blog/${previousPost.data.slug}`} class="btn btn-secondary">← {previousPost.data.title}</a>
        )}
        {nextPost && (
          <a href={`/en/blog/${nextPost.data.slug}`} class="btn btn-secondary">{nextPost.data.title} →</a>
        )}
      </section>
    )}
  </section>
</Layout>
