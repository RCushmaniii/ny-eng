---
import { getCollection, type CollectionEntry } from 'astro:content';
import { blogSetting } from '@data/config';
import PaginatedBlogLayout from '@components/blog/PaginatedBlogLayout.astro';
import blogHero from '@assets/images/blog-hero.jpg';
import type { TKey } from '../../../lib/i18n';
export const prerender = true;

const currentPage = parseInt(Astro.url.searchParams.get('page') || '1');

// Only include English posts from en/ subfolder
const allPosts = await getCollection('blog');
const filteredPosts: CollectionEntry<'blog'>[] = allPosts.filter((post: CollectionEntry<'blog'>) => post.id.startsWith('en/') && post.data.publish === true);

const sortedPosts: CollectionEntry<'blog'>[] = filteredPosts.sort((a: CollectionEntry<'blog'>, b: CollectionEntry<'blog'>) => 
  new Date(b.data.publishDate).getTime() - new Date(a.data.publishDate).getTime()
);

const totalPosts = sortedPosts.length;
// Only show pagination if we have MORE posts than can fit on a single page
// If we have exactly postsPerPage or fewer, don't show pagination at all
const hasMultiplePages = totalPosts > blogSetting.postsPerPage;
const totalPages = hasMultiplePages ? Math.ceil(totalPosts / blogSetting.postsPerPage) : 1;
const start = (currentPage - 1) * blogSetting.postsPerPage;
const end = start + blogSetting.postsPerPage;
const paginatedPosts = sortedPosts.slice(start, end);

// Use centralized i18n system for blog
const lang = 'en';
const tkey = 'blog' as TKey;
---

<PaginatedBlogLayout 
    posts={paginatedPosts}
    currentPage={currentPage}
    totalPages={totalPages}
    baseUrl="/en/blog/"
    title="Business English Blog | Tips for Executives | NY"
    subtitle="Practical tips and real-world insights to master Business English communication."
    heroImage={blogHero}
    heroImageAlt="Blog hero background"
    translationSlugEs="/blog/"
    hasMultiplePages={hasMultiplePages}
    lang="en"
    tkey={tkey}
    description="Expert advice, strategies, and resources to improve your business English communication, confidence, and career success."
/>

