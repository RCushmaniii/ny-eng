---
/**
 * /en/resources/index.astro
 *
 * Executive Resource Library - Field-tested tools for global leaders
 */

import Base from "@layouts/Base.astro";
import Button from "@components/ui/Button.astro";
import FreeResourcesHub from "@components/free/FreeResourcesHub";
import type { FreeAsset } from "@/types/free-asset";

const title = "Executive English Resource Library | New York English";
const description =
  "Field-tested negotiation scripts, communication frameworks, and executive guides designed for Latin American professionals leading global teams.";

// Auto-discover all free resources from JSON files
const allAssets = await Astro.glob("../../data/free/*.json");

// Filter out schema and template files, only keep actual assets with valid content
// Support both new schema (en at root) and old schema (content.en)
const resources: FreeAsset[] = allAssets
  .filter((file) => {
    const data = file.default;
    const enContent = data.en || data.content?.en;
    // Must have metadata, en.title, and not be schema/template
    return data.metadata && enContent?.title && !data.$schema;
  })
  .map((file) => {
    const data = file.default;
    // Normalize old schema to new schema structure
    if (!data.en && data.content?.en) {
      data.en = data.content.en;
      data.es = data.content.es;
      data.slugEn = data.slugEn || data.content.en.slug;
      data.slugEs = data.slugEs || data.content.es?.slug;
    }
    return data as FreeAsset;
  });
---

<Base
  title={title}
  description={description}
  lang="en"
  tkey="resources"
  ogImage={{
    src: "/images/logos/new-york-english-sq-og.jpg",
    alt: "Executive English Resource Library - New York English Teacher",
  }}
  hideCta={true}
>
  <!-- Hero Section -->
  <section class="pt-28 pb-16 md:pt-32 md:pb-20 bg-gray-50">
    <div class="site-container px-4 text-center">
      <span
        class="text-amber-600 font-bold tracking-wider text-sm uppercase mb-4 block"
      >
        Executive Resource Library
      </span>

      <h1 class="text-4xl md:text-5xl font-bold text-slate-900 mb-6">
        Field-Tested Tools for <span class="text-blue-700">Global Leaders</span>
      </h1>

      <p class="text-lg text-slate-600 max-w-2xl mx-auto leading-relaxed">
        Frameworks, negotiation scripts, and communication guides
        designed specifically for Latin American professionals leading global
        teams.
      </p>
    </div>
  </section>

  <!-- Available Resources (Auto-discovered) -->
  <FreeResourcesHub resources={resources} lang="en" client:load />

  <!-- SEO: Static links for crawlers (visually hidden but accessible) -->
  <nav class="sr-only" aria-label="All resources">
    <h2>All Available Resources</h2>
    <ul>
      {resources.map((resource) => (
        <li>
          <a href={`/en/resources/${resource.slugEn || resource.metadata.id}/`}>
            {resource.en.title}
          </a>
        </li>
      ))}
    </ul>
  </nav>

  <!-- CTA Section -->
  <section
    class="cta-section py-16 md:py-20 bg-gradient-to-br from-slate-900 to-slate-800"
  >
    <div class="max-w-4xl mx-auto px-4 sm:px-6 text-center">
      <h2 class="text-3xl md:text-4xl font-bold text-white mb-6">
        Ready to Implement These Strategies?
      </h2>
      <p class="text-lg text-slate-300 mb-8 max-w-2xl mx-auto">
        Reading guides builds awareness. Coaching builds mastery. Book your
        strategy session to apply these frameworks to your specific career
        challenges.
      </p>
      <Button href="/en/book/" variant="primary" size="lg">
        Book My Strategy Session →
      </Button>
    </div>
  </section>
</Base>

<style>
  .hero-section {
    background: linear-gradient(135deg, #f0f9ff 0%, #e0e7ff 100%);
  }

  .resource-card {
    cursor: pointer;
  }

  .upcoming-card {
    transition: opacity 0.3s ease;
  }

  .upcoming-card:hover {
    opacity: 1;
  }
</style>
