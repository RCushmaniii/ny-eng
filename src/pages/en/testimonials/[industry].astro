---
import Base from "@layouts/Base.astro";
import TestimonialsGrid from "@components/sections/TestimonialsGrid.astro";
import { testimonialsByIndustry, industryLabels } from "@data/testimonials/en";
import type { Testimonial } from "@data/testimonials/en";

type ValidIndustry = keyof typeof testimonialsByIndustry;

export const prerender = true;

export async function getStaticPaths() {
  // Get all valid industries that have testimonials
  const validIndustries = Object.keys(testimonialsByIndustry).filter(
    (industry) => testimonialsByIndustry[industry as ValidIndustry]?.length > 0
  );

  return validIndustries.map((industry) => ({
    params: { industry },
  }));
}

// Get industry from URL parameter
const { industry } = Astro.params;

// Validate industry parameter
const validIndustries = Object.keys(testimonialsByIndustry).filter(
  (ind) => testimonialsByIndustry[ind as ValidIndustry]?.length > 0
);

// Default to "all" if industry is invalid
const currentIndustry =
  industry && validIndustries.includes(industry) ? industry : "all";

// Filter testimonials based on selected industry
const filteredTestimonials: Testimonial[] =
  testimonialsByIndustry[currentIndustry as ValidIndustry] || [];

// SEO metadata
const industryLabel =
  industryLabels[currentIndustry as keyof typeof industryLabels];
const title =
  currentIndustry === "all"
    ? "Success Stories | NY English Teacher"
    : `${industryLabel} Success | NY English Teacher`;
const description =
  currentIndustry === "all"
    ? "Read success stories from executives, founders, and professionals who transformed their English communication with personalized coaching. See real results."
    : `Read success stories from ${industryLabel.toLowerCase()} who transformed their English communication with personalized coaching. See real client results and career breakthroughs.`;

// Spanish counterpart for language switcher
const translationSlugEs =
  currentIndustry === "all"
    ? "/es/testimonios/"
    : `/es/testimonios/${currentIndustry}/`;

// Create custom hreflangs for each industry page
const currentUrl =
  currentIndustry === "all"
    ? "https://www.nyenglishteacher.com/en/testimonials/all/"
    : `https://www.nyenglishteacher.com/en/testimonials/${currentIndustry}/`;

const translationUrlEs =
  currentIndustry === "all"
    ? "https://www.nyenglishteacher.com/es/testimonios/all/"
    : `https://www.nyenglishteacher.com/es/testimonios/${currentIndustry}/`;

const customHreflangs = [
  { lang: "en-US", href: currentUrl },
  { lang: "es-MX", href: translationUrlEs },
];
---

<Base
  title={title}
  description={description}
  lang="en"
  customHreflangs={customHreflangs}
  customCanonical={currentUrl}
  hideCta={true}
>
  <TestimonialsGrid
    testimonials={filteredTestimonials}
    title={currentIndustry === "all"
      ? "Client Testimonials"
      : `${industryLabel} Testimonials`}
    description={currentIndustry === "all"
      ? "Discover how professionals across industries have transformed their English communication skills and achieved their career goals."
      : `Discover how ${industryLabel.toLowerCase()} have transformed their English communication skills and achieved their career goals.`}
    showFilters={true}
    selectedIndustry={currentIndustry}
    lang="en"
  />
</Base>
