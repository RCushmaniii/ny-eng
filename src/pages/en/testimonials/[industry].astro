---
import Layout from "@layouts/Layout.astro";
import { testimonials, testimonialsByIndustry, industryLabels } from "@data/testimonials/en";
import TestimonialCard from "@components/TestimonialCard.astro";
import ExpandableTestimonialCard from "@components/ExpandableTestimonialCard.astro";
import Eyebrow from "@components/ui/Eyebrow.astro";
import Button from "@components/ui/Button.astro";

export async function getStaticPaths() {
  // Get all valid industries that have testimonials
  const validIndustries = Object.keys(industryLabels).filter(
    (industry) => testimonialsByIndustry[industry as keyof typeof testimonialsByIndustry]?.length > 0
  );

  return validIndustries.map((industry) => ({
    params: { industry }
  }));
}

// Get industry from URL parameter
const { industry } = Astro.params;

// Validate industry parameter
const validIndustries = Object.keys(industryLabels).filter(
  (ind) => testimonialsByIndustry[ind as keyof typeof testimonialsByIndustry]?.length > 0
);

// Default to "all" if industry is invalid
const currentIndustry = industry && validIndustries.includes(industry) ? industry : "all";

// Filter testimonials based on selected industry
const filteredTestimonials = testimonialsByIndustry[currentIndustry as keyof typeof testimonialsByIndustry] || [];

// SEO metadata
const industryLabel = industryLabels[currentIndustry as keyof typeof industryLabels];
const title = currentIndustry === "all" 
  ? "Client Success Stories | NY English Teacher"
  : `${industryLabel} Success Stories | NY English Teacher`;
const description = currentIndustry === "all"
  ? "Read success stories from executives, founders, and professionals who transformed their English communication with personalized coaching."
  : `Read success stories from ${industryLabel.toLowerCase()} who transformed their English communication with personalized coaching.`;

// Spanish counterpart for language switcher
const translationSlugEs = currentIndustry === "all" 
  ? "/es/testimonios" 
  : `/es/testimonios/${currentIndustry}`;
---

<Layout
  title={title}
  description={description}
  lang="en"
  translationSlugEs={translationSlugEs}
  hideCta={true}
>
  <section class="bg-light py-16 md:py-24">
    <div class="site-container px-4 sm:px-6 md:px-8">
      <div class="text-center mb-12 pt-8">
        <Eyebrow text="Success Stories" background="light" />
        <h1 class="text-h1 text-[--color-headline] mb-4">
          {currentIndustry === "all" ? "Client Testimonials" : `${industryLabel} Testimonials`}
        </h1>
        <p class="text-lg text-[--color-body-base] max-w-2xl mx-auto">
          {currentIndustry === "all" 
            ? "Discover how professionals across industries have transformed their English communication skills and achieved their career goals."
            : `Discover how ${industryLabel.toLowerCase()} have transformed their English communication skills and achieved their career goals.`}
        </p>
      </div>

      <!-- Industry Filter -->
      <div class="mb-10 flex flex-col sm:flex-row justify-center items-center gap-4">
        <label for="industry-filter" class="font-medium text-[--color-headline]">Filter by industry:</label>
        <div class="relative">
          <select
            id="industry-filter"
            class="bg-white border border-gray-300 rounded-md px-4 py-2 focus:outline-none focus:ring-2 focus:ring-primary-500"
          >
            {Object.entries(industryLabels)
              .filter(([key]) => validIndustries.includes(key))
              .map(([key, label]) => (
                <option value={key} selected={currentIndustry === key}>{label}</option>
              ))}
          </select>
          <script>
            const industryFilter = document.getElementById('industry-filter');
            if (industryFilter instanceof HTMLSelectElement) {
              industryFilter.addEventListener('change', function() {
                const selectedIndustry = this.value;
                if (selectedIndustry === 'all') {
                  window.location.href = '/en/testimonials';
                } else {
                  window.location.href = `/en/testimonials/${selectedIndustry}`;
                }
              });
            }
          </script>
        </div>
      </div>

      <!-- Testimonials Grid -->
      <div class="grid gap-8 sm:grid-cols-1 md:grid-cols-2 lg:grid-cols-3">
        {filteredTestimonials.map((testimonial) => (
          testimonial.shortContent ? (
            <ExpandableTestimonialCard
              testimonial={testimonial}
              showHeadline={true}
            />
          ) : (
            <TestimonialCard
              testimonial={testimonial}
              showHeadline={true}
            />
          )
        ))}
      </div>

      {filteredTestimonials.length === 0 && (
        <div class="text-center py-16">
          <p class="text-lg text-[--color-body-base] mb-4">No testimonials found for this industry.</p>
          <Button href="/en/testimonials" variant="primary">View All Testimonials</Button>
        </div>
      )}

       <div class="mt-16 bg-gradient-to-r from-primary-500 to-secondary-500 rounded-2xl p-8 md:p-12 relative overflow-hidden">
         <div class="absolute inset-0 bg-gradient-to-r from-primary-600/30 to-secondary-600/30 backdrop-blur-sm"></div>
         <div class="relative z-10 text-center md:text-left md:flex items-center justify-between">
           <div class="mb-6 md:mb-0 md:mr-8">
             <h3 class="text-2xl md:text-3xl font-bold text-[--color-headline-dark] mb-4">
               Ready to Transform Your Professional English?
             </h3>
             <p class="text-[--color-body-dark] max-w-2xl">
               Book your free consultation to gain the clarity, confidence, and impact your role demands.
             </p>
           </div>
           <Button
             href="https://ny-english-teacher.odoo.com/book/7ceefa20"
             variant="primary"
             target="_blank"
             rel="noopener noreferrer"
           >
             Reserve My Free Consultation
           </Button>
         </div>
       </div>
    </div>
  </section>
</Layout>
