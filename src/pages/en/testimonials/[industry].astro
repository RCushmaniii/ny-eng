---
import Base from "@layouts/Base.astro";
import TestimonialsGrid from "@components/sections/TestimonialsGrid.astro";
import { testimonialsByIndustry, industryLabels } from "@data/testimonials/en";
import { serviceCategories } from "@data/service-categories";
import type { Testimonial } from "@data/testimonials/en";

type ValidIndustry = keyof typeof testimonialsByIndustry;

export const prerender = true;

export async function getStaticPaths() {
  // Get all valid industries that have testimonials
  const validIndustries = Object.keys(testimonialsByIndustry).filter(
    (industry) => testimonialsByIndustry[industry as ValidIndustry]?.length > 0
  );

  return validIndustries.map((industry) => ({
    params: { industry },
  }));
}

// Get industry from URL parameter
const { industry } = Astro.params;

// Validate industry parameter
const validIndustries = Object.keys(testimonialsByIndustry).filter(
  (ind) => testimonialsByIndustry[ind as ValidIndustry]?.length > 0
);

// Default to "all" if industry is invalid
const currentIndustry =
  industry && validIndustries.includes(industry) ? industry : "all";

// Filter testimonials based on selected industry
const filteredTestimonials: Testimonial[] =
  testimonialsByIndustry[currentIndustry as ValidIndustry] || [];

// SEO metadata
const industryLabel =
  industryLabels[currentIndustry as keyof typeof industryLabels];
const title =
  currentIndustry === "all"
    ? "Success Stories | NY English Teacher"
    : `${industryLabel} Reviews | NY English`;
const description =
  currentIndustry === "all"
    ? "Read success stories from executives, founders, and professionals who transformed their English communication with personalized coaching."
    : `Success stories from ${industryLabel.toLowerCase()} who transformed their English communication with personalized coaching. See real results.`;

// Create custom hreflangs for each industry page
const currentUrl =
  currentIndustry === "all"
    ? "https://www.nyenglishteacher.com/en/testimonials/all/"
    : `https://www.nyenglishteacher.com/en/testimonials/${currentIndustry}/`;

const translationUrlEs =
  currentIndustry === "all"
    ? "https://www.nyenglishteacher.com/es/testimonios/all/"
    : `https://www.nyenglishteacher.com/es/testimonios/${currentIndustry}/`;

const customHreflangs = [
  { lang: "en-US", href: currentUrl },
  { lang: "es-MX", href: translationUrlEs },
];

// Get matching service page link for the current industry
const matchingService = currentIndustry !== "all"
  ? serviceCategories.find((cat) => cat.slug === currentIndustry)
  : null;
const serviceLink = matchingService ? `/en/services/${matchingService.slug}/` : null;
---

<Base
  title={title}
  description={description}
  lang="en"
  customHreflangs={customHreflangs}
  customCanonical={currentUrl}
>
  <TestimonialsGrid
    testimonials={filteredTestimonials}
    title={currentIndustry === "all"
      ? "Client Testimonials"
      : `${industryLabel} Testimonials`}
    description="Real results from real professionals. In their own words."
    showFilters={true}
    selectedIndustry={currentIndustry}
    lang="en"
  />

  <!-- Cross-links section -->
  <section class="py-12 bg-white">
    <div class="max-w-3xl mx-auto px-4 text-center">
      {serviceLink && matchingService && (
        <div class="mb-8">
          <p class="text-lg text-gray-700 mb-4">
            Want to learn more about coaching for {industryLabel.toLowerCase()}?
          </p>
          <a
            href={serviceLink}
            class="inline-block px-6 py-3 bg-primary-600 text-white font-medium rounded-lg hover:bg-primary-700 transition-colors"
          >
            Explore {matchingService.label} Coaching
          </a>
        </div>
      )}
      <div class="flex flex-wrap justify-center gap-4 text-sm">
        <a href="/en/testimonials/" class="text-primary-600 hover:text-primary-800 underline">
          All Success Stories
        </a>
        <a href="/en/services/" class="text-primary-600 hover:text-primary-800 underline">
          View All Services
        </a>
        <a href="/en/assessments/" class="text-primary-600 hover:text-primary-800 underline">
          Take a Free Assessment
        </a>
        <a href="/en/book/" class="text-primary-600 hover:text-primary-800 underline">
          Book a Strategy Session
        </a>
      </div>
    </div>
  </section>
</Base>
