---
import Base from "@layouts/Base.astro";
import TestimonialsGrid from "@components/sections/TestimonialsGrid.astro";
import { publishedTestimonials } from "@data/testimonials/en";

const title = "Testimonials | New York English Teacher";
const description =
    "Real results from executives, founders, and professionals who leveled up their English for high-stakes work.";
---

<Base tkey="testimonials" lang="en" title={title} description={description}>
    <TestimonialsGrid
        testimonials={publishedTestimonials}
        title="Client Success Stories"
        description="Read how executives, founders, and professionals transformed their English communication for high-stakes work."
        lang="en"
    />
</Base>
