---
export const prerender = true;

import Base from "@layouts/Base.astro";
import TestimonialsGrid from "@components/sections/TestimonialsGrid.astro";
import { publishedTestimonials } from "@data/testimonials/en";

const title = "Client Success Stories | Executive English Coaching";
const description =
    "Real results from executives, founders, and tech leads who leveled up their English for high-stakes work with personalized coaching.";
---

<Base tkey="testimonials" lang="en" title={title} description={description}>
    <TestimonialsGrid
        testimonials={publishedTestimonials}
        title="Client Success Stories"
        description="Executives, founders, and tech leaders share how personalized coaching transformed their professional English."
        showFilters={true}
        selectedIndustry="all"
        lang="en"
    />

    <!-- Cross-links for better internal linking -->
    <section class="py-12 bg-white">
        <div class="max-w-3xl mx-auto px-4 text-center">
            <p class="text-lg text-gray-700 mb-6">
                Ready to write your own success story?
            </p>
            <div class="flex flex-wrap justify-center gap-4">
                <a
                    href="/en/book/"
                    class="inline-block px-6 py-3 bg-primary-600 text-white font-medium rounded-lg hover:bg-primary-700 transition-colors"
                >
                    Book a Free Strategy Session
                </a>
                <a
                    href="/en/assessments/"
                    class="inline-block px-6 py-3 border border-primary-600 text-primary-600 font-medium rounded-lg hover:bg-primary-50 transition-colors"
                >
                    Take a Free Assessment
                </a>
            </div>
        </div>
    </section>
</Base>
