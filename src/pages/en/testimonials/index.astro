---
export const prerender = true;

import Base from "@layouts/Base.astro";
import TestimonialsGrid from "@components/sections/TestimonialsGrid.astro";
import { publishedTestimonials } from "@data/testimonials/en";

const title = "Client Success Stories | Executive English Coaching";
const description =
    "Real results from executives and professionals who leveled up their English for high-stakes work with personalized coaching.";
---

<Base tkey="testimonials" lang="en" title={title} description={description}>
    <TestimonialsGrid
        testimonials={publishedTestimonials}
        title="Client Success Stories"
        description="Real results from real professionals. In their own words."
        lang="en"
    />
</Base>
