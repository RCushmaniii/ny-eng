---
/**
 * /en/free/index.astro
 *
 * Free Resources Hub - Dashboard showing all available free resources
 */

import Base from "@layouts/Base.astro";
import Button from "@components/ui/Button.astro";
import FreeResourcesHub from "@components/free/FreeResourcesHub";
import { Sparkles, FileText, Headphones, MessageCircle } from "lucide-astro";
import type { FreeAsset } from "@/types/free-asset";

const title = "Free Resources | Business English | NY English";
const description =
  "Free guides, cheat sheets, and tools to help Latin American tech professionals communicate with executive-level confidence in English.";

// Auto-discover all free resources from JSON files
const allAssets = await Astro.glob("../../data/free/*.json");

// Filter out schema and template files, only keep actual assets with valid content
// Support both new schema (en at root) and old schema (content.en)
const resources: FreeAsset[] = allAssets
  .filter((file) => {
    const data = file.default;
    const enContent = data.en || data.content?.en;
    // Must have metadata, en.title, and not be schema/template
    return data.metadata && enContent?.title && !data.$schema;
  })
  .map((file) => {
    const data = file.default;
    // Normalize old schema to new schema structure
    if (!data.en && data.content?.en) {
      data.en = data.content.en;
      data.es = data.content.es;
      data.slugEn = data.slugEn || data.content.en.slug;
      data.slugEs = data.slugEs || data.content.es?.slug;
    }
    return data as FreeAsset;
  });
---

<Base
  title={title}
  description={description}
  lang="en"
  tkey="free"
  ogImage={{
    src: "/images/logos/new-york-english-og.jpg",
    alt: "Free Business English Resources - New York English Teacher",
  }}
  hideCta={true}
>
  <!-- Hero Section -->
  <section class="hero-section pt-28 pb-16 md:pt-32 md:pb-20">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <div class="text-center max-w-3xl mx-auto">
        <div
          class="inline-flex items-center gap-2 bg-blue-100 text-blue-700 px-4 py-2 rounded-full text-sm font-semibold mb-6"
        >
          <Sparkles class="w-4 h-4" />
          <span>100% Free Resources</span>
        </div>

        <h1
          class="text-4xl md:text-5xl lg:text-6xl font-bold text-slate-900 mb-6 leading-tight"
        >
          Level Up Your
          <span class="text-blue-600"> Executive English</span>
        </h1>

        <p class="text-lg md:text-xl text-slate-600 leading-relaxed">
          Practical guides, cheat sheets, and tools designed for Latin American
          tech professionals who communicate with North American clients.
        </p>
      </div>
    </div>
  </section>

  <!-- Available Resources (Auto-discovered) -->
  <FreeResourcesHub resources={resources} lang="en" client:load />

  <!-- CTA Section -->
  <section
    class="cta-section py-16 md:py-20 bg-gradient-to-br from-slate-900 to-slate-800"
  >
    <div class="max-w-4xl mx-auto px-4 sm:px-6 text-center">
      <h2 class="text-3xl md:text-4xl font-bold text-white mb-6">
        Want Faster Results?
      </h2>
      <p class="text-lg text-slate-300 mb-8 max-w-2xl mx-auto">
        Free resources build awareness. Professional coaching builds
        transformation. Book a free strategy call to discuss your team's
        specific challenges.
      </p>
      <Button href="/en/book/" variant="primary" size="lg">
        Book Free Strategy Call →
      </Button>
    </div>
  </section>
</Base>

<style>
  .hero-section {
    background: linear-gradient(135deg, #f0f9ff 0%, #e0e7ff 100%);
  }

  .resource-card {
    cursor: pointer;
  }

  .upcoming-card {
    transition: opacity 0.3s ease;
  }

  .upcoming-card:hover {
    opacity: 1;
  }
</style>
