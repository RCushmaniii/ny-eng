---
import { getEntryBySlug } from 'astro:content';
import Layout from '@layouts/Layout.astro';
import InnerHero from '@components/sections/InnerHero.astro';
import ContactInfo from '@components/sections/ContactInfo.astro';
import type { CollectionEntry } from 'astro:content';

const entry = await getEntryBySlug('legal', 'privacy-policy') as CollectionEntry<'legal'> | null;
if (!entry) throw new Error('Privacy Policy content not found');

const { Content } = await entry.render();

const heroContent = {
  title: entry.data.title,
  description: entry.data.seo?.description || "",
  overlayOpacity: 0.8
} as const;

const footerCta = {
  eyebrow: "",
  title: "Transform Your Professional English Today",
  description: "Book your free consultation to gain the clarity, confidence, and impact your role demands.",
  hideCta: false,
  button: {
    text: "Reserve My Free Consultation",
    link: "https://ny-english-teacher.odoo.com/book/7ceefa20",
    target: "_blank",
    variant: "primary" as const
  }
} as const;
---

<Layout 
  title={entry.data.seo?.title || entry.data.title}
  description={entry.data.seo?.description || ""}
  lang="en"
  noIndex={true}
  footerCta={footerCta}
  translationSlugEs="/es/legal/privacy-policy"
>
  <InnerHero content={heroContent} />
  <article class="site-container--small mx-auto px-8 prose pb-base">
    <Content />
  </article>
</Layout>