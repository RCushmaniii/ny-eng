---
import { getCollection, type CollectionEntry } from 'astro:content';
import Layout from '@layouts/Layout.astro';
import InnerHero from '@components/sections/InnerHero.astro';

export async function getStaticPaths() {
  const legalEntries = await getCollection('legal', ({ slug }) => {
    // Filter for entries that are NOT Spanish (i.e., their slug doesn't start with 'es/')
    return !slug.startsWith('es/');
  });
  return legalEntries.map(entry => ({
    // The slug for English content is just the filename, e.g., 'privacy-policy'
    params: { slug: entry.slug }, 
    props: { entry },
  }));
}

interface Props {
  entry: CollectionEntry<'legal'>;
}

const { entry } = Astro.props;
import { getLegalContent } from '@utils/legalContent.js';
const legalData = await getLegalContent(entry.slug, 'en');
const { Content } = legalData;

// Use SEO data from frontmatter if available, fallback to regular entry data
const seoTitle = entry.data.seo?.title || entry.data.title;
const seoDescription = entry.data.seo?.description || '';

// Format the last updated date
const formattedDate = new Intl.DateTimeFormat('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
}).format(entry.data.lastUpdated);

// Hero content
const heroContent = {
  title: entry.data.title,
  description: '', // No description needed for legal page hero
  overlayOpacity: 0.8
};

const englishSlug = entry.slug; // e.g., 'privacy-policy'
const spanishSlugPath = `/es/legal/${englishSlug}`;

--- 

<Layout 
  title={seoTitle}
  description={seoDescription}
  lang="en"
  noIndex={true}
  footerCta={{
  title: "",
  description: "",
  hideCta: true,
  button: { text: "", link: "" }
}}
  translationSlugEs={spanishSlugPath}
>
  <InnerHero content={heroContent} />
  
  <article class="site-container--small mx-auto px-8 prose pb-base">
    <div class="mt-12 mb-8">
      <p class="text-sm text-body-base/80">Last updated: {formattedDate}</p>
    </div>
    
    <Content />
  </article>
</Layout>
