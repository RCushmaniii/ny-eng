---
// Import components
import Layout from "@layouts/Layout.astro";
import InnerHero from "@components/sections/InnerHero.astro";
import Challenge from "@components/sections/Challenge.astro";
import MethodologySection from "@components/sections/MethodologySection.astro";
import FeaturedTestimonial from "@components/sections/FeaturedTestimonial.astro";
import CtaSection from "@components/sections/CtaSection.astro";

// Import data
import { services } from "@data/services";
import { coreMethodology } from "@data/methodology";
import { testimonials } from "@data/testimonials/en";

// Get service data for tech english
const serviceSlug = "tech-english";
const serviceData = services.find(service => service.slug === serviceSlug);

// Hero content using service data (matching working pattern)
const heroContent = {
  title: "Master Technical English for Global Impact",
  description: "Communicate complex technical concepts with clarity and precision. From code reviews to architecture discussions, speak the language of technology with confidence.",
  backgroundImage: serviceData?.backgroundImage,
  overlayOpacity: 0.7
};

// Challenge content with dynamic image
const challengeContent = {
  headline: "Does This Sound Familiar?",
  painPoints: [
    "You struggle to explain complex technical concepts clearly in English",
    "Code reviews and technical discussions feel overwhelming in a second language",
    "You avoid speaking up in architecture meetings due to language barriers",
    "Documentation and technical writing take much longer than they should",
    "You miss out on leadership opportunities because of communication hesitation"
  ],
  icon: "💻",
  image: serviceData?.squareImage
};

// Get Julio's testimonial (perfect for tech since he mentions tech topics)
const julioTestimonial = testimonials.find(t => t.slug === "julio-smarttie");

// CTA content
const ctaContent = {
  eyebrow: "Take the Final Step",
  title: "Transform Your Technical Communication",
  description: "A free, no-obligation strategy session is the best way to understand how targeted coaching can accelerate your tech career through better English communication.",
  buttonText: "Book My Free Strategy Session",
  buttonLink: "https://ny-english-teacher.odoo.com/book/7ceefa20",
  whatToExpectTitle: "In Your Free Session, We Will:",
  whatToExpectList: [
    "Assess your current technical communication strengths and gaps",
    "Practice explaining complex technical concepts clearly",
    "Create a personalized plan to boost your confidence in tech discussions"
  ]
};

// Translation slug for Spanish version
const translationSlug = "ingles-para-tecnologia";
---

<Layout 
  title="Technical English Coaching | Master Tech Communication | NY English"
  description="Master technical English communication for software development, engineering, and IT. Explain complex concepts clearly, lead technical discussions, and advance your tech career."
  lang="en"
  translationSlugEs={`/es/servicios/${translationSlug}`}
  image={serviceData?.backgroundImage || "/images/logos/new-york-english-og-wide.jpg"}
  footerCta={{
  title: "",
  description: "",
  button: { text: "", link: "#" },
  hideCta: true
}}
>
  <!-- Hero Section -->
  <InnerHero content={heroContent} />
  
  <!-- Challenge Section -->
  <Challenge content={challengeContent} />
  
  <!-- Methodology Section -->
  <MethodologySection content={coreMethodology} />
  
  <!-- Featured Testimonial -->
  {julioTestimonial && (
    <FeaturedTestimonial testimonial={julioTestimonial} />
  )}
  
  <!-- CTA Section -->
  <CtaSection content={ctaContent} />
</Layout>
