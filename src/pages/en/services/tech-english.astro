---
export const prerender = true;

// Import components
import Base from "@layouts/Base.astro";
import InnerHero from "@components/sections/InnerHero.astro";
import Challenge from "@components/sections/Challenge.astro";
import MethodologySection from "@components/sections/MethodologySection.astro";
import FeaturedTestimonial from "@components/sections/FeaturedTestimonial.astro";
import CtaSection from "@components/sections/CtaSection.astro";
import ServiceFAQ from "@components/sections/ServiceFAQ.astro";
import BreadcrumbSchema from "@components/seo/BreadcrumbSchema.astro";
import Breadcrumbs from "@components/ui/Breadcrumbs.astro";
import { serviceFaqs } from "@data/service-faqs";

// Import data
import { services } from "@data/services";
import { coreMethodology } from "@data/methodology";
import { testimonials } from "@data/testimonials/en";

// Get service data for tech english
const serviceSlug = "tech-english";
const serviceData = services.find((service) => service.slug === serviceSlug);

// Hero content using service data (matching working pattern)
const heroContent = {
  title: "Your code is flawless. Your explanation loses the room.",
  description:
    "Coaching for tech leaders who need to turn technical complexity into clear business value — without losing precision or credibility.",
  backgroundImage: serviceData?.backgroundImage,
  overlayOpacity: 0.7,
};

// Challenge content with dynamic image
const challengeContent = {
  headline: "Does This Sound Familiar?",
  painPoints: [
    "You understand the architecture perfectly — but when you explain it in English, non-technical stakeholders check out.",
    "In sprint ceremonies, your ideas get passed over because someone else articulates them better — not because they're better ideas.",
    "You avoid speaking up in cross-team meetings. Not because you don't have the answer, but because constructing it in English takes too long.",
  ],
  icon: "😰",
  image: serviceData?.squareImage,
  quizCta: {
    text: "Get your Technical Communication Score in 60 seconds.",
    link: "/en/quiz/it-services/question/1",
    linkLabel: "Start the Quiz →",
  },
};

// Get Julio's testimonial (perfect for tech since he mentions tech topics)
const julioTestimonial = testimonials[0]; // Julio Aldana testimonial

// CTA content
const ctaContent = {
  eyebrow: "",
  title: "You already lead. Now sound like it — in English.",
  description:
    "Book a private strategy session. 30 minutes: I'll spot the gaps between your English and the technical leadership your role demands.",
  buttonText: "Book My Tech Strategy Session",
  buttonLink: "/en/book/",
  whatToExpectTitle: "In Your Free Session, We Will:",
  whatToExpectList: [
    "Assess how your English impacts technical discussions and stakeholder trust",
    "Identify the scenarios where communication costs you influence",
    "Create a plan to explain complex ideas clearly — in any room",
  ],
};

// Translation slug for Spanish version
const translationSlug = "ingles-para-tecnologia";

const faqs = serviceFaqs["tech-english"]?.en || [];
---

<Base
  title="Tech English Coaching for IT Professionals | NY"
  description="Master technical English for IT and engineering. Explain complex ideas clearly, lead code reviews, and boost your tech career with confidence."
  lang="en"
  tkey="services/tech-english"
  ogImage={{
    src:
      typeof serviceData?.backgroundImage === "string"
        ? serviceData.backgroundImage
        : "/images/logos/new-york-english-sq-og.jpg",
  }}
  customHreflangs={[
    {
      lang: "en-US",
      href: "https://www.nyenglishteacher.com/en/services/tech-english/",
    },
    {
      lang: "es-MX",
      href: "https://www.nyenglishteacher.com/es/servicios/ingles-para-tecnologia/",
    },
  ]}
  customCanonical="https://www.nyenglishteacher.com/en/services/tech-english/"
>
  <!-- Hero Section -->
  <InnerHero content={heroContent} />

  <!-- Challenge Section -->
  <Challenge content={challengeContent} />

  <!-- Methodology Section -->
  <MethodologySection content={coreMethodology} />

  <!-- Featured Testimonial -->
  {julioTestimonial && <FeaturedTestimonial testimonial={julioTestimonial} />}

  <!-- More testimonials link -->
  <div class="text-center py-4 -mt-8 bg-slate-900">
    <a href="/en/testimonials/tech-english/" class="text-blue-400 hover:text-blue-300 font-medium transition-colors">
      Read more success stories from engineers &amp; tech leads &rarr;
    </a>
  </div>

  <!-- CTA Section -->
  <CtaSection content={ctaContent} />

  <BreadcrumbSchema items={[
    { name: "Home", url: "https://www.nyenglishteacher.com/en/" },
    { name: "Services", url: "https://www.nyenglishteacher.com/en/services/" },
    { name: "Tech English", url: "https://www.nyenglishteacher.com/en/services/tech-english/" }
  ]} />
  <ServiceFAQ faqs={faqs} lang="en" />
</Base>
