---
export const prerender = true;

import Base from "@layouts/Base.astro";
import InnerHero from "@components/sections/InnerHero.astro";
import Challenge from "@components/sections/Challenge.astro";
import MethodologySection from "@components/sections/MethodologySection.astro";
import FeaturedTestimonial from "@components/sections/FeaturedTestimonial.astro";
import CtaSection from "@components/sections/CtaSection.astro";
import ServiceFAQ from "@components/sections/ServiceFAQ.astro";
import BreadcrumbSchema from "@components/seo/BreadcrumbSchema.astro";
import Breadcrumbs from "@components/ui/Breadcrumbs.astro";
import { serviceFaqs } from "@data/service-faqs";

// prevent autosave tools from removing imports (used in template)
void Base;
void InnerHero;
void Challenge;
void MethodologySection;
void FeaturedTestimonial;
void CtaSection;

// Import services data
import { services } from "@data/services";

// Get the logistics service data
const logisticsService = services.find((s) => s.slug === "logistics-english");

// Import methodology content
import { coreMethodology } from "@data/methodology";

// Import testimonials and select featured one
import { testimonials } from "@data/testimonials/en";
const featuredTestimonialSlug = "karla-sanmina-corporation";
const featuredTestimonial = testimonials.find(
  (t) => t.slug === featuredTestimonialSlug
);

// SEO metadata
const title = "Logistics English Coaching for Supply Chain | NY";
const seoDescription =
  "Master logistics English for global supply chain management. Communicate with precision across carriers, customs, and international clients.";

// Hero content
const heroContent = {
  title: "Your operations run tight. Your communication with US partners doesn't.",
  description:
    "Coaching for logistics professionals who need to navigate customs, freight forwarding, and cross-border operations in English — with precision.",
  backgroundImage: logisticsService?.backgroundImage,
  overlayOpacity: 0.7,
};

// Challenge section content
const challengeContent = {
  headline: "Does This Sound Familiar?",
  painPoints: [
    "A miscommunication over BOLs or incoterms has already cost you time, money, or a client relationship.",
    "You can handle the operation — but explaining a shipping disruption to a US client in real-time English is a different kind of pressure.",
    "Negotiating rates and terms with international freight forwarders feels harder than it should because the language gets in the way.",
  ],
  icon: "😰",
  image: logisticsService?.squareImage,
  quizCta: {
    text: "Discover your Logistics Communication Score in 60 seconds.",
    link: "/en/quiz/executives/question/1",
    linkLabel: "Start the Quiz →",
  },
};

// Final CTA content
const ctaContent = {
  eyebrow: "",
  title: "You already lead. Now sound like it — in English.",
  description:
    "Book a private strategy session. 30 minutes: I'll spot the gaps between your English and the precision your logistics role demands.",
  buttonText: "Book My Logistics Strategy Session",
  buttonLink: "/en/book/",
  whatToExpectTitle: "In Your Free Session, We Will:",
  whatToExpectList: [
    "Assess how your English impacts broker, carrier, and client interactions",
    "Identify the communication gaps that slow down your operations",
    "Create a plan built around your actual cross-border scenarios",
  ],
};

// Translation slug for Spanish version
const translationSlug = "ingles-para-logistica";

const faqs = serviceFaqs["logistics-english"]?.en || [];
---

<Base
  title={title}
  description={seoDescription}
  lang="en"
  tkey="services/logistics-english"
  ogImage={{
    src:
      typeof logisticsService?.backgroundImage === "string"
        ? logisticsService.backgroundImage
        : "/images/logos/new-york-english-sq-og.jpg",
  }}
  customHreflangs={[
    {
      lang: "en-US",
      href: "https://www.nyenglishteacher.com/en/services/logistics-english/",
    },
    {
      lang: "es-MX",
      href: "https://www.nyenglishteacher.com/es/servicios/ingles-para-logistica/",
    },
  ]}
  customCanonical="https://www.nyenglishteacher.com/en/services/logistics-english/"
>
  <!-- Hero Section -->
  <InnerHero content={heroContent} />

  <!-- Challenge Section -->
  <Challenge content={challengeContent} background="white" padding="lg" />

  <!-- Methodology Section -->
  <MethodologySection
    content={coreMethodology}
    background="light"
    padding="lg"
  />

  <!-- Featured Testimonial -->
  {
    featuredTestimonial && (
      <FeaturedTestimonial testimonial={featuredTestimonial} />
    )
  }

  <!-- Final CTA -->
  <CtaSection content={ctaContent} />

  <BreadcrumbSchema items={[
    { name: "Home", url: "https://www.nyenglishteacher.com/en/" },
    { name: "Services", url: "https://www.nyenglishteacher.com/en/services/" },
    { name: "Logistics English", url: "https://www.nyenglishteacher.com/en/services/logistics-english/" }
  ]} />
  <ServiceFAQ faqs={faqs} lang="en" />
</Base>
