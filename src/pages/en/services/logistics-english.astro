---
import Layout from "@layouts/Layout.astro";
import InnerHero from "@components/sections/InnerHero.astro";
import Challenge from "@components/sections/Challenge.astro";
import MethodologySection from "@components/sections/MethodologySection.astro";
import FeaturedTestimonial from "@components/sections/FeaturedTestimonial.astro";
import CtaSection from "@components/sections/CtaSection.astro";

// Import services data
import { services } from "@data/services";

// Get the logistics service data
const logisticsService = services.find(s => s.slug === 'logistics-english');

// Import methodology content
import { coreMethodology } from "@data/methodology";

// Import testimonials and select featured one
import { testimonials } from "@data/testimonials/en";
const featuredTestimonialSlug = 'karla-sanmina-corporation';
const featuredTestimonial = testimonials.find(t => t.slug === featuredTestimonialSlug);

// SEO metadata
const title = "Logistics English Coaching | Master Supply Chain Communication | NY English Teacher";
const seoDescription = "Master the language of the global supply chain. Communicate with precision across carriers, customs, and clients to keep your operations moving smoothly.";

// Hero content
const heroContent = {
  title: "Master the Language of the Global Supply Chain",
  description: "Communicate with precision across carriers, customs, and clients to keep your operations moving.",
  backgroundImage: logisticsService?.backgroundImage,
  overlayOpacity: 0.7
};

// Challenge section content
const challengeContent = {
  headline: "Are You Facing These Challenges?",
  painPoints: [
    "Misunderstandings over BOLs, incoterms, or customs paperwork have caused costly delays.",
    "You struggle to negotiate effectively with international freight forwarders.",
    "Explaining shipping disruptions to clients is stressful and often unclear."
  ],
  icon: "🤔",
  image: logisticsService?.squareImage
};

// Final CTA content
const ctaContent = {
  eyebrow: "Take the Final Step",
  title: "Transform Your Logistics Communication",
  description: "A free, no-obligation strategy session is the best way to understand how targeted coaching can eliminate communication errors and boost your career.",
  buttonText: "Book My Free Strategy Session",
  buttonLink: "https://ny-english-teacher.odoo.com/book/7ceefa20",
  whatToExpectTitle: "In Your Free Session, We Will:",
  whatToExpectList: [
    "Pinpoint your specific communication challenges in supply chain operations",
    "Define 1-2 key goals for your professional growth in logistics",
    "Outline a sample learning path tailored to your industry needs"
  ]
};

// Translation slug for Spanish version
const translationSlug = "ingles-para-logistica";
---

<Layout
  title={title}
  description={seoDescription}
  lang="en"
  translationSlugEs={`/es/servicios/${translationSlug}`}
  image={logisticsService?.backgroundImage || "/images/logos/new-york-english-og-wide.jpg"}
  hideCta={true}
>
  <!-- Hero Section -->
  <InnerHero content={heroContent} />
  
  <!-- Challenge Section -->
  <Challenge content={challengeContent} background="white" padding="lg" />
  
  <!-- Methodology Section -->
  <MethodologySection content={coreMethodology} background="light" padding="lg" />
  
  <!-- Featured Testimonial -->
  {featuredTestimonial && (
    <FeaturedTestimonial testimonial={featuredTestimonial} />
  )}
  
  <!-- Final CTA -->
  <CtaSection content={ctaContent} />
</Layout>
