---
export const prerender = true;

import Base from "@layouts/Base.astro";
import InnerHero from "@components/sections/InnerHero.astro";
import Challenge from "@components/sections/Challenge.astro";
import MethodologySection from "@components/sections/MethodologySection.astro";
import FeaturedTestimonial from "@components/sections/FeaturedTestimonial.astro";
import CtaSection from "@components/sections/CtaSection.astro";
import ServiceFAQ from "@components/sections/ServiceFAQ.astro";
import BreadcrumbSchema from "@components/seo/BreadcrumbSchema.astro";
import { serviceFaqs } from "@data/service-faqs";

// Import services data
import { services } from "@data/services";

// Get the professional service data
const professionalService = services.find(
  (s) => s.slug === "professional-english"
);

// Import methodology content
import { coreMethodology } from "@data/methodology";

// Import testimonials and select an appropriate testimonial
import { testimonials } from "@data/testimonials/en";
const featuredTestimonialSlug = "dra-erika-itzel-medical-doctor"; // Use the same medical testimonial since it's related
const featuredTestimonial = testimonials.find(
  (t) => t.slug === featuredTestimonialSlug
);

// SEO metadata
const title = "Professional English Coaching for Specialists | NY";
const seoDescription =
  "Master professional English for medical and legal specialists. Communicate clearly with international clients, colleagues, and stakeholders.";

// Hero content
const heroContent = {
  title: "One wrong word can cost more than your fee.",
  description:
    "Precision English for medical and legal professionals who need absolute clarity when the stakes are real.",
  backgroundImage: professionalService?.backgroundImage,
  overlayOpacity: 0.7,
};

// Challenge section content
const challengeContent = {
  headline: "Does This Sound Familiar?",
  painPoints: [
    "You're an expert in your field — but explaining a diagnosis or legal position in English makes you sound less certain than you are.",
    "International patients or clients sense your hesitation. It's not your competence — it's the language creating distance.",
    "You avoid conferences, cross-border cases, or international referrals because the English feels like a risk you can't afford.",
  ],
  icon: "😰",
  image: professionalService?.squareImage,
  quizCta: {
    text: "Get your Professional Communication Score in 60 seconds.",
    link: "/en/quiz/professional-services/question/1",
    linkLabel: "Start the Quiz →",
  },
};

// CTA content
const ctaContent = {
  eyebrow: "",
  title: "You already lead. Now sound like it — in English.",
  description:
    "Book a private strategy session. 30 minutes: I'll spot the gaps between your English and the precision your professional role demands.",
  buttonText: "Book My Professional Strategy Session",
  buttonLink: "/en/book/",
  whatToExpectTitle: "In Your Free Session, We Will:",
  whatToExpectList: [
    "Assess how your English impacts patient or client trust",
    "Identify the specific interactions where precision matters most",
    "Create a plan built around your actual professional scenarios",
  ],
};


const faqs = serviceFaqs["professional-english"]?.en || [];
---

<Base
  title={title}
  description={seoDescription}
  lang="en"
  tkey="services/professional-english"
  ogImage={{
    src:
      typeof professionalService?.backgroundImage === "string"
        ? professionalService.backgroundImage
        : "/images/logos/new-york-english-sq-og.jpg",
  }}
  customHreflangs={[
    {
      lang: "en-US",
      href: "https://www.nyenglishteacher.com/en/services/professional-english/",
    },
    {
      lang: "es-MX",
      href: "https://www.nyenglishteacher.com/es/servicios/ingles-para-profesionales/",
    },
  ]}
  customCanonical="https://www.nyenglishteacher.com/en/services/professional-english/"
>
  <!-- Hero Section -->
  <InnerHero content={heroContent} />

  <!-- Challenge Section -->
  <Challenge content={challengeContent} />

  <!-- Methodology Section -->
  <MethodologySection content={coreMethodology} />

  <!-- Featured Testimonial -->
  {
    featuredTestimonial && (
      <FeaturedTestimonial testimonial={featuredTestimonial} />
    )
  }

  <!-- Final CTA -->
  <CtaSection content={ctaContent} />

  <BreadcrumbSchema items={[
    { name: "Home", url: "https://www.nyenglishteacher.com/en/" },
    { name: "Services", url: "https://www.nyenglishteacher.com/en/services/" },
    { name: "Professional English", url: "https://www.nyenglishteacher.com/en/services/professional-english/" }
  ]} />
  <ServiceFAQ faqs={faqs} lang="en" />
</Base>
