---
export const prerender = true;

// src/pages/en/services/index.astro
import Base from "@layouts/Base.astro";
import Hero from "@components/sections/Hero.astro";
import ServicesGrid from "@components/sections/ServicesGrid.astro";
import ProfessionalProfiles from "@components/sections/ProfessionalProfiles.astro";
import CtaBanner from "@components/sections/CtaBanner.astro";
import { services, professionalProfiles } from "@data/services";
import servicesHeroImage from "@assets/images/services/services-hero.jpg";

// i18n configuration
const lang = "en";
const tkey = "services";

// SEO metadata
const seoTitle = "Business English Coaching Services | NY English";
const seoDescription =
  "Explore personalized English coaching for executives, tech, and medical professionals. Improve your fluency and confidence in business settings.";

// Reuse hero content from homepage for brand consistency
const heroContent = {
  title: "You already lead. Now sound like it — in English.",
  description:
    "Private coaching for the specific moments where your English matters most.",
  buttons: [
    {
      text: "Book Your Free Consultation",
      link: "/en/book/",
      variant: "primary" as const,
    },
  ],
  backgroundImage: servicesHeroImage,
  backgroundImageMobile: servicesHeroImage,
  backgroundImageAlt: "Professional business English coaching services",
  overlayOpacity: 0.3,
};

// Professional Profiles section content
const professionalProfilesContent = {
  title: "Find coaching for your role",
  description:
    "Each role has different pressure points. Pick yours.",
};

// CTA Banner content
const ctaContent = {
  eyebrow: "",
  title: "You already lead. Now sound like it — in English.",
  description:
    "Book a private strategy session. 30 minutes: I'll spot the gaps between your English and the executive presence your role demands.",
  button: {
    text: "Book My Strategy Session",
    link: "/en/book/",
    variant: "primary" as const,
  },
} as const;
---

<Base
  title={seoTitle}
  description={seoDescription}
  lang={lang}
  tkey={tkey}
  ogImage={{ src: "/images/logos/new-york-english-og-wide.jpg" }}
  heroImage={servicesHeroImage}
  hideCta={true}
>
  <!-- Hero Section - Reused from homepage for consistency -->
  <Hero content={heroContent} />

  <!-- Services Grid -->
  <ServicesGrid
    services={services}
    title=""
    description=""
  />

  <!-- Professional Profiles Section -->
  <ProfessionalProfiles
    profiles={professionalProfiles}
    content={professionalProfilesContent}
  />

  <!-- Final CTA -->
  <CtaBanner content={ctaContent} />
</Base>
