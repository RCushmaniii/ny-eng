---
export const prerender = true;

import Base from "@layouts/Base.astro";
import InnerHero from "@components/sections/InnerHero.astro";
import Challenge from "@components/sections/Challenge.astro";
import MethodologySection from "@components/sections/MethodologySection.astro";
import FeaturedTestimonial from "@components/sections/FeaturedTestimonial.astro";
import CtaSection from "@components/sections/CtaSection.astro";
import ServiceFAQ from "@components/sections/ServiceFAQ.astro";
import BreadcrumbSchema from "@components/seo/BreadcrumbSchema.astro";
import Breadcrumbs from "@components/ui/Breadcrumbs.astro";
import { serviceFaqs } from "@data/service-faqs";

// prevent autosave tools from removing imports (used in template)
void Base;
void InnerHero;
void Challenge;
void MethodologySection;
void FeaturedTestimonial;
void CtaSection;

// Import services data
import { services } from "@data/services";

// Get the high-stakes service data
const highStakesService = services.find(
  (s) => s.slug === "high-stakes-english"
);

// Import methodology content
import { coreMethodology } from "@data/methodology";
// Import testimonials and select Hugo Lopez testimonial
import { testimonials } from "@data/testimonials/en";
const featuredTestimonial = testimonials[9]; // Hugo Lopez testimonial

// SEO metadata
const title = "High-Stakes English Coaching for Presentations | NY";
const seoDescription =
  "Master English for critical presentations, job interviews, and high-stakes negotiations. Build confidence when it matters most.";

// Hero content
const heroContent = {
  title: "You get one shot. Sound ready.",
  description:
    "Targeted preparation for the interview, investor pitch, or career-defining presentation you can't afford to fumble.",
  backgroundImage: highStakesService?.backgroundImage,
  overlayOpacity: 0.7,
};

// Challenge section content
const challengeContent = {
  headline: "Does This Sound Familiar?",
  painPoints: [
    "You've rehearsed the content a dozen times — but the moment you present in English, your confidence drops and your delivery flattens.",
    "In interviews, you know you're qualified. But your English makes you sound less experienced than you are.",
    "The presentation went fine. But 'fine' doesn't get you the job, the deal, or the promotion.",
  ],
  icon: "😰",
  image: highStakesService?.squareImage,
  quizCta: {
    text: "Discover your Presentation Readiness Score in 60 seconds.",
    link: "/en/quiz/high-stakes/question/1",
    linkLabel: "Start the Assessment →",
  },
};

// CTA content
const ctaContent = {
  eyebrow: "",
  title: "You already lead. Now sound like it — in English.",
  description:
    "Book a private strategy session. 30 minutes: I'll spot the gaps between your English and the impact your next presentation demands.",
  buttonText: "Book My Presentation Strategy Session",
  buttonLink: "/en/book/",
  whatToExpectTitle: "In Your Free Session, We Will:",
  whatToExpectList: [
    "Assess how your English impacts your delivery under pressure",
    "Identify the specific moments where your confidence drops",
    "Create a preparation plan for your next high-stakes moment",
  ],
};

// Translation slug for Spanish version
const translationSlug = "ingles-para-presentaciones";

const faqs = serviceFaqs["high-stakes-english"]?.en || [];
---

<Base
  title={title}
  description={seoDescription}
  lang="en"
  tkey="services/high-stakes-english"
  ogImage={{
    src:
      typeof highStakesService?.backgroundImage === "string"
        ? highStakesService.backgroundImage
        : "/images/logos/new-york-english-og.jpg",
  }}
  customHreflangs={[
    {
      lang: "en-US",
      href: "https://www.nyenglishteacher.com/en/services/high-stakes-english/",
    },
    {
      lang: "es-MX",
      href: "https://www.nyenglishteacher.com/es/servicios/ingles-para-presentaciones/",
    },
  ]}
  customCanonical="https://www.nyenglishteacher.com/en/services/high-stakes-english/"
>
  <!-- Hero Section -->
  <InnerHero content={heroContent} />

  <!-- Challenge Section -->
  <Challenge content={challengeContent} />

  <!-- Methodology Section -->
  <MethodologySection content={coreMethodology} />

  <!-- Featured Testimonial -->
  {
    featuredTestimonial && (
      <FeaturedTestimonial testimonial={featuredTestimonial} />
    )
  }

  <!-- Final CTA -->
  <CtaSection content={ctaContent} />

  <BreadcrumbSchema items={[
    { name: "Home", url: "https://www.nyenglishteacher.com/en/" },
    { name: "Services", url: "https://www.nyenglishteacher.com/en/services/" },
    { name: "High-Stakes English", url: "https://www.nyenglishteacher.com/en/services/high-stakes-english/" }
  ]} />
  <ServiceFAQ faqs={faqs} lang="en" />
</Base>
