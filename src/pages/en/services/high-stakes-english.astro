---
import Layout from "@layouts/Layout.astro";
import InnerHero from "@components/sections/InnerHero.astro";
import Challenge from "@components/sections/Challenge.astro";
import MethodologySection from "@components/sections/MethodologySection.astro";
import FeaturedTestimonial from "@components/sections/FeaturedTestimonial.astro";
import CtaSection from "@components/sections/CtaSection.astro";

// Import services data
import { services } from "@data/services";

// Get the high-stakes service data
const highStakesService = services.find(s => s.slug === 'high-stakes-english');

// Import methodology content
import { coreMethodology } from "@data/methodology";

// Import testimonials and select Hugo's testimonial (mentions presentations)
import { testimonials } from "@data/testimonials/en";
const featuredTestimonialSlug = 'hugo-lopez-continental';
const featuredTestimonial = testimonials.find(t => t.slug === featuredTestimonialSlug);

// SEO metadata
const title = "High-Stakes English Coaching | Presentations & Interviews | NY English Teacher";
const seoDescription = "Captivate any audience, ace interviews, and deliver powerful presentations with confidence in English. Master high-pressure communication scenarios.";

// Hero content
const heroContent = {
  title: "High-Stakes English",
  description: "Captivate any audience, ace interviews, and deliver powerful presentations with confidence.",
  backgroundImage: highStakesService?.backgroundImage,
  overlayOpacity: 0.7
};

// Challenge section content
const challengeContent = {
  headline: "Are You Facing These Challenges?",
  painPoints: [
    "You feel nervous and lose confidence when presenting to English-speaking audiences.",
    "Interview situations in English make you anxious and unable to showcase your true abilities.",
    "You struggle to engage your audience and deliver your message with impact and authority."
  ],
  icon: "🤔",
  image: highStakesService?.squareImage
};

// CTA content
const ctaContent = {
  eyebrow: "Take the Final Step",
  title: "Master High-Pressure Communication",
  description: "A free, no-obligation strategy session is the best way to understand how targeted coaching can boost your confidence and communication effectiveness.",
  buttonText: "Book My Free Strategy Session",
  buttonLink: "https://ny-english-teacher.odoo.com/book/7ceefa20",
  whatToExpectTitle: "In Your Free Session, We Will:",
  whatToExpectList: [
    "Assess your current presentation and interview skills",
    "Identify specific areas for improvement in high-stakes scenarios",
    "Create a personalized plan to overcome speaking anxiety and build confidence"
  ]
};

// Translation slug for Spanish version
const translationSlug = "ingles-para-presentaciones";
---

<Layout
  title={title}
  description={seoDescription}
  lang="en"
  translationSlugEs={`/es/servicios/${translationSlug}`}
  image={highStakesService?.backgroundImage || "/images/logos/new-york-english-og-wide.jpg"}
  footerCta={{
    title: "",
    description: "",
    button: { text: "", link: "#" },
    hideCta: true
  }}
>
  <!-- Hero Section -->
  <InnerHero content={heroContent} />
  
  <!-- Challenge Section -->
  <Challenge content={challengeContent} />
  
  <!-- Methodology Section -->
  <MethodologySection content={coreMethodology} />
  
  <!-- Featured Testimonial -->
  {featuredTestimonial && (
    <FeaturedTestimonial testimonial={featuredTestimonial} />
  )}
  
  <!-- Final CTA -->
  <CtaSection content={ctaContent} />
</Layout>
