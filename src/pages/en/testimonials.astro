---
import Layout from "@layouts/Layout.astro";
import { testimonials, testimonialsByIndustry, industryLabels } from "@data/testimonials/en";
import TestimonialCard from "@components/TestimonialCard.astro";
import ExpandableTestimonialCard from "@components/ExpandableTestimonialCard.astro";
import Eyebrow from "@components/ui/Eyebrow.astro";
import Button from "@components/ui/Button.astro";

// Toggle to show/hide CTA links on testimonial cards
const showCtaLinks = true; // Set to false to hide all CTA links

// Get all published testimonials for client-side filtering
const publishedTestimonials = testimonials.filter(t => t.status !== "draft");

// Get valid industries that have testimonials
const validIndustries = Object.keys(industryLabels).filter(
  (industry) => testimonialsByIndustry[industry as keyof typeof testimonialsByIndustry]?.length > 0
);

// SEO metadata
const title = "Client Success Stories | NY English Teacher";
const description = "Read success stories from executives, founders, and professionals who transformed their English communication with personalized coaching.";

// Spanish counterpart for language switcher
const translationSlugEs = "/es/testimonios";
const seoDescription = description;

// Hide CTA section
const hideCta = true;

---

<Layout
  title={title}
  description={seoDescription}
  lang="en"
  translationSlugEs={translationSlugEs}
  hideCta={hideCta}
  image="/images/logos/new-york-english-og-wide.jpg"
  whatsappImage="/images/logos/new-york-english-og.jpg"
  linkedinImage="/images/logos/new-york-english-og-wide.jpg"
>
  <section class="bg-light py-16 md:py-24">
    <div class="site-container px-4 sm:px-6 md:px-8">
      <div class="text-center mb-12 pt-8">
        <Eyebrow text="Success Stories" background="light" />
        <h1 class="text-h1 text-[--color-headline] mb-4">Client Testimonials</h1>
        <p class="text-lg text-[--color-body-base] max-w-2xl mx-auto">
          Discover how professionals across industries have transformed their English communication skills and achieved their career goals.
        </p>
      </div>

      <!-- Industry Filter -->
      <div class="mb-10 flex flex-col sm:flex-row justify-center items-center gap-4">
        <label for="industry-filter" class="font-medium text-[--color-headline]">Filter by industry:</label>
        <div class="relative">
          <select
            id="industry-filter"
            class="appearance-none bg-white border border-gray-300 rounded-md px-4 py-2 pr-8 focus:outline-none focus:ring-2 focus:ring-primary-500 z-50 block w-full"
            style="position: relative; z-index: 50;"
          >
            {Object.entries(industryLabels)
              .filter(([key]) => validIndustries.includes(key))
              .map(([key, label]) => (
                <option value={key}>{label}</option>
              ))}
          </select>
          <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center px-2 text-gray-700">
            <svg class="fill-current h-4 w-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20">
              <path d="M9.293 12.95l.707.707L15.657 8l-1.414-1.414L10 10.828 5.757 6.586 4.343 8z" />
            </svg>
          </div>
        </div>
      </div>

      <!-- Testimonials Grid -->
      <div id="testimonials-grid" class="grid gap-8 sm:grid-cols-1 md:grid-cols-2 lg:grid-cols-3">
        {publishedTestimonials.map((testimonial) => (
          <div class="testimonial-item" data-industries={testimonial.industries.join(",")}>
            {testimonial.shortContent ? (
              <ExpandableTestimonialCard
                testimonial={testimonial}
                showHeadline={true}
                showCtaLink={showCtaLinks}
              />
            ) : (
              <TestimonialCard
                testimonial={testimonial}
                showHeadline={true}
                showCtaLink={showCtaLinks}
              />
            )}
          </div>
        ))}
      </div>

      <div id="no-results" class="text-center py-16 hidden">
        <p class="text-lg text-[--color-body-base] mb-4">No testimonials found for this industry.</p>
        <button 
          class="bg-primary-500 text-white px-6 py-3 rounded-md font-medium hover:bg-primary-600 transition-colors"
        >
          View All Testimonials
        </button>
      </div>

       <div class="mt-16 bg-gradient-to-r from-primary-500 to-secondary-500 rounded-2xl p-8 md:p-12 relative overflow-hidden">
         <div class="absolute inset-0 bg-gradient-to-r from-primary-600/30 to-secondary-600/30 backdrop-blur-sm"></div>
         <div class="relative z-10 text-center md:text-left md:flex items-center justify-between">
           <div class="mb-6 md:mb-0 md:mr-8">
             <h3 class="text-2xl md:text-3xl font-bold text-[--color-headline-dark] mb-4">
               Ready to Transform Your Professional English?
             </h3>
             <p class="text-[--color-body-dark] max-w-2xl">
               Book your free consultation to gain the clarity, confidence, and impact your role demands.
             </p>
           </div>
           <Button
             href="https://ny-english-teacher.odoo.com/book/7ceefa20"
             variant="primary"
             target="_blank"
             rel="noopener noreferrer"
           >
             Reserve My Free Consultation
           </Button>
         </div>
       </div>
    </div>
  </section>

  <script>
    // Client-side filtering functionality
    const industryFilter = document.getElementById('industry-filter') as HTMLSelectElement;
    const testimonialItems = document.querySelectorAll('.testimonial-item');
    const noResultsDiv = document.getElementById('no-results');
    const showAllBtn = noResultsDiv?.querySelector('button');

    function filterTestimonials(selectedIndustry: string) {
      let visibleCount = 0;
      
      testimonialItems.forEach((item) => {
        // Get comma-separated list of industries and convert to array
        const industriesAttr = item.getAttribute('data-industries') || '';
        const itemIndustries = industriesAttr.split(',').map(industry => industry.trim());
        
        // Show if 'all' is selected or if the item belongs to the selected industry
        if (selectedIndustry === 'all' || itemIndustries.includes(selectedIndustry)) {
          (item as HTMLElement).style.display = 'block';
          visibleCount++;
        } else {
          (item as HTMLElement).style.display = 'none';
        }
      });

      // Show/hide no results message
      if (visibleCount === 0) {
        noResultsDiv?.classList.remove('hidden');
      } else {
        noResultsDiv?.classList.add('hidden');
      }
    }

    // Add event listener to filter dropdown
    industryFilter?.addEventListener('change', function() {
      filterTestimonials(this.value);
    });

    // Add event listener to "Show All" button
    showAllBtn?.addEventListener('click', function(e) {
      e.preventDefault();
      industryFilter.value = 'all';
      filterTestimonials('all');
    });

    // Initialize with all testimonials visible
    filterTestimonials('all');
  </script>
</Layout>
