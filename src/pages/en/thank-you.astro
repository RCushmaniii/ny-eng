---
import Base from "@layouts/Base.astro";
import InnerHero from "@components/sections/InnerHero.astro";
import Button from "@components/ui/Button.astro";
import nycImage from "@assets/images/nyc-thank-you.jpg";

const metadata = {
  title: "Thank You | Business English Communication Coach",
  description: "Thank you for your message. I'll be in touch soon to discuss your communication goals and executive English coaching.",
};

const heroContent = {
  title: "Thank You — I’ve Received Your Message!",
  description: "I'll be in touch shortly to schedule your introduction call.",
  backgroundImage: nycImage,
  overlayOpacity: 0.4,
};

---

<Base
  lang="en"
  tkey="thank-you"
  title={metadata.title}
  description={metadata.description}
  ogImage={{ src: "/images/logos/new-york-english-og.jpg" }}
  hideCta={false}
>
  <InnerHero content={heroContent} />

  <!-- Optional: Add a button to navigate back to the English homepage -->
  <div class="text-center mt-8">
    <Button href="/en/">Back to Homepage</Button>
  </div>

  <section class="py-16 md:py-24">
    <div class="site-container px-4 text-center max-w-2xl mx-auto">
      <p class="text-lg text-gray-700 dark:text-gray-300 mb-8">
        We’ll discuss your goals and how I can help you communicate with clarity
        and confidence.
      </p>

      <h2 class="text-2xl font-semibold text-gray-900 dark:text-white mb-4">
        What’s Next?
      </h2>

      <p class="text-lg text-gray-700 dark:text-gray-300 mb-8">
        In the meantime, explore how I help professionals like you lead with
        confidence in English — in meetings, pitches, interviews, and more.
      </p>
    </div>
  </section>
</Base>
