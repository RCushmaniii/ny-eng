---
export const prerender = true;

import Base from "@layouts/Base.astro";
import { Image } from "astro:assets";
import Button from "@components/ui/Button.astro";
import meImage from "@assets/images/about/me-blue-shirt.jpg";
import ceoImage from "@assets/images/about/working-with-client-1200.jpg";
import { testimonials } from "@data/testimonials-about";

const seoDescription =
  "Robert Cushman spent 20 years in IT — 17 at a Fortune 500. Now he coaches international professionals to sound like the leaders they already are, in English.";
const metadata = {
  title: "About Robert Cushman | Executive English Coach",
  description: seoDescription,
};

const FooterCta = {
  Eyebrow: "",
  title: "You already lead. Now sound like it — in English.",
  description:
    "Book a private strategy session. In 30 minutes, I'll identify the specific gaps between your current English and the executive presence your role demands.",
  hideCta: false,
  button: {
    text: "Book My Strategy Session",
    link: "/en/book/",
    variant: "primary",
  },
};
---

<Base
  {...metadata}
  lang="en"
  tkey="about"
  ogImage={{
    src: "/images/logos/new-york-english-sq-og.jpg",
    alt: "New York English Teacher - Professional English Communication Coach",
    width: 1200,
    height: 630,
  }}
>
  {/* ── Hero / Intro ── */}
  <section
    id="about-me"
    class="relative pt-28 pb-8 md:pt-32 md:pb-12 overflow-hidden"
  >
    <div class="container mx-auto px-4 max-w-6xl">
      <div class="grid md:grid-cols-12 grid-cols-1 items-start gap-12">
        {/* Left column — Photo */}
        <div class="md:col-span-4 order-2 md:order-1">
          <div class="relative">
            <Image
              src={meImage}
              alt="Robert Cushman - Executive Communication Coach"
              class="rounded-lg shadow-lg w-full"
              width={400}
              height={533}
              loading="eager"
            />
          </div>
        </div>

        {/* Right column — Copy */}
        <div class="md:col-span-8 order-1 md:order-2">
          <div class="lg:ml-8">
            <h1 class="font-heading text-4xl md:text-5xl font-bold mb-4">
              Robert Cushman
            </h1>
            <p class="text-2xl text-primary font-semibold mb-8">
              Executive Communication Coach
            </p>

            <div class="space-y-6 text-lg">
              <p class="text-xl leading-relaxed font-medium">
                I spent 20 years in IT — 17 of them at a Fortune 500, climbing
                from developer to Senior Manager. I've led global teams,
                presented to boardrooms, and navigated the politics of corporate
                leadership at scale.
              </p>

              <p>
                Now I coach international professionals to do the same thing — in
                English.
              </p>

              <p>
                I live in Guadalajara. I married into Mexico. I understand what
                it feels like to operate in a language and culture that isn't
                your first. That perspective shapes every session I design.
              </p>

              <div class="mt-8">
                <Button href="/en/book/" variant="primary" size="lg">
                  Book Your Free Session
                </Button>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  {/* ── Why I Coach Differently ── */}
  <section
    id="about-why"
    class="relative py-16 md:py-24 bg-gray-50 dark:bg-gray-800/50"
  >
    <div class="container mx-auto px-4 max-w-6xl">
      <div class="grid md:grid-cols-12 gap-12 items-center">
        {/* Left Column — Content */}
        <div class="md:col-span-7 order-2 md:order-1">
          <div class="lg:pr-8">
            <h2 class="font-heading text-3xl md:text-4xl font-bold mb-8">
              Why I Coach Differently
            </h2>

            <div class="space-y-6 text-lg text-gray-600 dark:text-gray-300 leading-relaxed">
              <p>
                Most English teachers teach English.
              </p>

              <p class="text-xl font-medium text-gray-900 dark:text-white">
                I teach professionals how to sound like the leaders they already
                are — in a second language.
              </p>

              <p>
                The difference matters. I've sat in the meetings you're preparing
                for. I know what a VP sounds like when they're losing the room,
                and I know what it takes to hold it. That's not something you
                learn from a textbook or a grammar drill.
              </p>

              <p>
                Every session I build starts from your reality — your next
                presentation, your upcoming negotiation, your actual calendar. If
                you have a board meeting Thursday, that's what I prepare you for
                on Wednesday.
              </p>

              <p class="text-xl font-semibold text-primary">
                Authority, not apology. That's the standard.
              </p>
            </div>
          </div>
        </div>

        {/* Right Column — Image */}
        <div class="md:col-span-5 order-1 md:order-2">
          <div class="relative">
            <Image
              src={ceoImage}
              alt="Executive coaching session in progress"
              class="rounded-lg shadow-lg w-full object-cover"
              width={600}
              height={400}
              loading="lazy"
            />
          </div>
        </div>
      </div>
    </div>
  </section>

  {/* ── How It Works ── */}
  <section id="about-methodology" class="relative py-16 md:py-24">
    <div class="container mx-auto px-4 max-w-6xl">
      <div class="max-w-3xl mx-auto text-center mb-16">
        <h2 class="font-heading text-4xl md:text-5xl font-bold mb-6">
          How It Works
        </h2>
      </div>

      <div class="grid md:grid-cols-2 gap-8 md:gap-12 max-w-5xl mx-auto">
        {/* Step 1 */}
        <div class="bg-white dark:bg-gray-800 p-8 rounded-xl shadow-lg border border-gray-100 dark:border-gray-700">
          <div class="flex items-center gap-4 mb-6">
            <span class="flex items-center justify-center w-12 h-12 rounded-full bg-primary text-white font-bold text-lg">
              1
            </span>
            <h3 class="font-heading text-xl font-bold">
              We talk first.
            </h3>
          </div>
          <p class="text-gray-600 dark:text-gray-300">
            A short intro call to understand your role, your goals, and whether
            I'm the right fit. No pressure, no pitch.
          </p>
        </div>

        {/* Step 2 */}
        <div class="bg-white dark:bg-gray-800 p-8 rounded-xl shadow-lg border border-gray-100 dark:border-gray-700">
          <div class="flex items-center gap-4 mb-6">
            <span class="flex items-center justify-center w-12 h-12 rounded-full bg-primary text-white font-bold text-lg">
              2
            </span>
            <h3 class="font-heading text-xl font-bold">
              I build your plan.
            </h3>
          </div>
          <p class="text-gray-600 dark:text-gray-300">
            Based on your level, your industry, and your upcoming pressure
            moments, I design the first sessions specifically for you. Custom
            content, not a course catalog.
          </p>
        </div>

        {/* Step 3 */}
        <div class="bg-white dark:bg-gray-800 p-8 rounded-xl shadow-lg border border-gray-100 dark:border-gray-700">
          <div class="flex items-center gap-4 mb-6">
            <span class="flex items-center justify-center w-12 h-12 rounded-full bg-primary text-white font-bold text-lg">
              3
            </span>
            <h3 class="font-heading text-xl font-bold">
              You practice under pressure.
            </h3>
          </div>
          <p class="text-gray-600 dark:text-gray-300">
            Simulated pitches, negotiations, client calls, and presentations.
            Tactical feedback on tone, pronunciation, and the small signals that
            separate "fluent" from "commanding." You make mistakes with me so you
            don't make them when it counts.
          </p>
        </div>

        {/* Step 4 */}
        <div class="bg-white dark:bg-gray-800 p-8 rounded-xl shadow-lg border border-gray-100 dark:border-gray-700">
          <div class="flex items-center gap-4 mb-6">
            <span class="flex items-center justify-center w-12 h-12 rounded-full bg-primary text-white font-bold text-lg">
              4
            </span>
            <h3 class="font-heading text-xl font-bold">
              I refine as you grow.
            </h3>
          </div>
          <p class="text-gray-600 dark:text-gray-300">
            As your communication sharpens, I adjust. New challenges, new
            scenarios, new targets. The plan evolves with your career.
          </p>
        </div>
      </div>
    </div>
  </section>

  {/* ── Who I Work With ── */}
  <section class="relative py-16 md:py-24 bg-gray-50 dark:bg-gray-800/50">
    <div class="container mx-auto px-4 max-w-4xl">
      <h2 class="font-heading text-3xl md:text-4xl font-bold mb-8 text-center">
        Who I Work With
      </h2>

      <div class="space-y-6 text-lg text-gray-600 dark:text-gray-300 leading-relaxed text-center max-w-3xl mx-auto">
        <p>
          COOs preparing for cross-border board meetings. Founders pitching to US
          investors. Tech leaders explaining architecture to non-technical
          stakeholders. Lawyers and doctors who need precision in English because
          one wrong word changes everything.
        </p>

        <p class="text-xl font-medium text-gray-900 dark:text-white">
          If you're already successful in your field but feel less precise, less
          commanding, less yourself when you switch to English — that's exactly
          the gap I close.
        </p>
      </div>
    </div>
  </section>

  {/* ── What Clients Say ── */}
  <section class="relative py-16 md:py-24">
    <div class="container mx-auto px-4 max-w-6xl">
      <div class="max-w-3xl mx-auto text-center mb-16">
        <h2 class="font-heading text-4xl md:text-5xl font-bold mb-6">
          What Clients Say
        </h2>
      </div>

      <div class="grid md:grid-cols-2 gap-8 md:gap-12 max-w-5xl mx-auto">
        {
          testimonials.map((testimonial, idx) => (
            <div
              class:list={[
                "bg-white dark:bg-gray-700/50 rounded-xl p-8 shadow-lg fade-in-up border border-gray-100 dark:border-gray-600",
                `delay-${idx + 1}`,
              ]}
            >
              <div class="flex items-center mb-6">
                <Image
                  src={testimonial.avatar}
                  alt={testimonial.author}
                  class="w-14 h-14 rounded-full object-cover mr-4 border-2 border-primary"
                  loading="lazy"
                  width={56}
                  height={56}
                />
                <div>
                  <div class="font-heading text-lg font-semibold">
                    {testimonial.author}
                  </div>
                  <div class="text-sm text-gray-500 dark:text-gray-400">
                    {testimonial.position}, {testimonial.company}
                  </div>
                </div>
              </div>
              <blockquote class="mb-2">
                <p class="text-lg text-gray-600 dark:text-gray-300 italic">
                  "<span set:html={testimonial.content} />"
                </p>
              </blockquote>
            </div>
          ))
        }
      </div>

      {/* Bottom CTA */}
      <div
        class="mt-16 bg-gradient-to-r from-primary to-gray-100 dark:from-primary dark:to-gray-800 rounded-2xl p-8 md:p-12 text-center"
      >
        <h3 class="text-2xl font-bold text-white mb-4">
          You already lead. Now sound like it — in English.
        </h3>
        <p class="text-white mb-6">
          Book a private strategy session. In 30 minutes, I'll identify the
          specific gaps between your current English and the executive presence
          your role demands.
        </p>
        <Button
          href="/en/book/"
          variant="ghostLight"
          size="lg"
        >
          Book My Strategy Session
        </Button>
      </div>
    </div>
  </section>
</Base>

<style>
  .leading-relaxed {
    line-height: 1.75;
  }
</style>
