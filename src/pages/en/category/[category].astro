---
import { getCollection, type CollectionEntry } from "astro:content";
import Base from "@layouts/Base.astro";
import BlogList, { type BlogListProps } from "@components/blog/BlogList.astro";
import InnerHero from "@components/sections/InnerHero.astro";
import blogHeroImage from "../../../content/blog/images/blog-hero.jpg";
import { categories, type Category } from "@data/categories";
import { siteConfig, blogSetting } from "@data/config";
import { routeFor, type TKey } from "../../../lib/i18n";

export const prerender = true;

export async function getStaticPaths() {
  return categories.map((category) => {
    const tkey = `category/${category.slug}` as TKey;

    // Only generate English slug for /en/category/ pages
    return {
      params: { category: category.slug },
      props: { categoryData: category, tkey },
    };
  });
}

interface Props {
  categoryData: Category;
  tkey: TKey;
}

const { categoryData, tkey } = Astro.props;

// Get canonical paths from i18n system
const canonicalEnPath = routeFor.en[tkey];
const canonicalEsPath = routeFor.es[tkey];

// If current URL doesn't match the canonical English URL, redirect
if (Astro.url.pathname !== canonicalEnPath) {
  return Astro.redirect(canonicalEnPath, 301);
}

// Fetch all English blog posts
const allPosts = await getCollection("blog");
const allEnglishPosts = allPosts
  .filter((post: CollectionEntry<"blog">) => {
    // Only English posts that are published
    return post.id.startsWith("en/") && post.data.publish !== false;
  })
  .sort(
    (a: CollectionEntry<"blog">, b: CollectionEntry<"blog">) =>
      new Date(b.data.publishDate).getTime() -
      new Date(a.data.publishDate).getTime()
  );

// SEO content
const seoTitle = `${categoryData.name} | ${siteConfig.companyName}`;
const seoDescription =
  categoryData.description ||
  `Explore articles, tips, and resources about ${categoryData.name}. Improve your business English with expert insights.`;

// Create custom hreflangs for this specific category (absolute URLs)
const customHreflangs = [
  { lang: "en-US", href: `https://www.nyenglishteacher.com${canonicalEnPath}` },
  { lang: "es-MX", href: `https://www.nyenglishteacher.com${canonicalEsPath}` },
];

// Hero content
const heroContent = {
  title: categoryData.name,
  description:
    categoryData.description || `All posts related to ${categoryData.name}`,
  backgroundImage: blogHeroImage,
  overlayOpacity: 0.7,
};
---

<Base
  lang="en"
  tkey={tkey}
  title={seoTitle}
  description={seoDescription}
  customHreflangs={customHreflangs}
>
  <main>
    <InnerHero content={heroContent} />
    <BlogList
      posts={allEnglishPosts}
      currentCategory={categoryData.name}
      currentCategorySlug={categoryData.slug}
      lang="en"
    />
  </main>
</Base>
