---
/**
 * Windsurf Rules Documentation - Proper Astro page with markdown import
 */
import MarkdownLayout from '@layouts/MarkdownLayout.astro';
import { marked } from 'marked';

// Import the WindsurfRules.md content
const windsurfContent = await import('../../../../docs/WindsurfRules.md?raw');
const markdownText = windsurfContent.default;

// Convert markdown to HTML
const htmlContent = marked(markdownText);

const frontmatter = {
  title: 'Windsurf Rules',
  description: 'Development rules and coding standards for the project',
  category: 'Development',
  icon: '⚙️'
};
---

<MarkdownLayout frontmatter={frontmatter}>
  <Fragment set:html={htmlContent} />
</MarkdownLayout>
