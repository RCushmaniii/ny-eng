---
/**
 * Documentation Library - Main index page
 * Clean, professional design with blaze orange accents
 */
import DocsLayout from "@layouts/DocsLayout.astro";
import {
  Rocket,
  Globe,
  FileText,
  Link,
  Image as ImageIcon,
  Settings,
  Repeat,
  Target,
  Calendar,
  Code2,
  TrendingUp,
  Wrench,
  BookOpen,
  Layers,
  ChevronRight,
} from "lucide-astro";

// Icon mapping
const iconMap = {
  Rocket: Rocket,
  Globe: Globe,
  FileText: FileText,
  Link: Link,
  ImageIcon: ImageIcon,
  Settings: Settings,
  Repeat: Repeat,
  Target: Target,
  Calendar: Calendar,
  Code2: Code2,
  TrendingUp: TrendingUp,
  Wrench: Wrench,
  BookOpen: BookOpen,
  Layers: Layers,
};

// Organize documentation by category
const documentsByCategory = {
  Overview: [
    {
      name: "Documentation Index",
      icon: "BookOpen",
      route: "/dev/docs/documentation-index/",
      description: "Master overview of all project documentation",
      priority: "high",
      tags: ["overview", "navigation", "index"],
    },
  ],
  Development: [
    {
      name: "Bilingual System Guide",
      icon: "Globe",
      route: "/dev/docs/bilingual-system-guide/",
      description: "Complete i18n architecture and routing system",
      priority: "high",
      tags: ["i18n", "architecture", "core"],
    },
    {
      name: "Windsurf Rules",
      icon: "Settings",
      route: "/dev/docs/windsurf-rules/",
      description: "Coding standards and development guidelines",
      priority: "medium",
      tags: ["standards", "best-practices"],
    },
  ],
  "SEO & Content": [
    {
      name: "Hreflang Fix Summary",
      icon: "Link",
      route: "/dev/docs/hreflang-fix-summary/",
      description: "Hreflang implementation and SEO audit results",
      priority: "high",
      tags: ["seo", "international", "critical"],
    },
    {
      name: "Blog i18n Edge Cases",
      icon: "FileText",
      route: "/dev/docs/blog-i18n-edge-cases/",
      description: "Blog internationalization patterns and solutions",
      priority: "medium",
      tags: ["blog", "i18n", "content"],
    },
    {
      name: "Redirect Analysis",
      icon: "Repeat",
      route: "/dev/docs/redirect-analysis-summary/",
      description: "URL redirect chains and optimization strategy",
      priority: "medium",
      tags: ["seo", "urls", "redirects"],
    },
  ],
  "Marketing Systems": [
    {
      name: "Quiz Lead Magnet",
      icon: "Target",
      route: "/dev/docs/quiz-lead-magnet-system/",
      description: "Communication Confidence Quiz system documentation",
      priority: "high",
      tags: ["lead-gen", "conversion", "quiz"],
    },
    {
      name: "Booking System",
      icon: "Calendar",
      route: "/dev/docs/booking-system/",
      description: "Google Calendar integration and self-scheduling",
      priority: "high",
      tags: ["appointments", "automation", "google"],
    },
  ],
  Operations: [
    {
      name: "Deployment Checklist",
      icon: "Rocket",
      route: "/dev/docs/deployment-checklist/",
      description: "Pre-deployment validation and testing procedures",
      priority: "high",
      tags: ["deployment", "qa", "testing"],
    },
    {
      name: "Image Optimization",
      icon: "ImageIcon",
      route: "/dev/docs/image-optimization-priorities/",
      description: "Performance optimization and image strategy",
      priority: "medium",
      tags: ["performance", "images", "optimization"],
    },
  ],
};

// Quick start guides for different roles
const quickStartGuides = [
  {
    role: "Developer",
    icon: Code2,
    description: "Building features and fixing bugs",
    docs: [
      { name: "Bilingual System", route: "/dev/docs/bilingual-system-guide/" },
      { name: "Coding Standards", route: "/dev/docs/windsurf-rules/" },
    ],
  },
  {
    role: "SEO/Content",
    icon: TrendingUp,
    description: "Optimizing search and content",
    docs: [
      { name: "Hreflang Guide", route: "/dev/docs/hreflang-fix-summary/" },
      { name: "Blog i18n", route: "/dev/docs/blog-i18n-edge-cases/" },
    ],
  },
  {
    role: "Marketing",
    icon: Target,
    description: "Lead generation systems",
    docs: [
      { name: "Quiz System", route: "/dev/docs/quiz-lead-magnet-system/" },
      { name: "Booking Flow", route: "/dev/docs/booking-system/" },
    ],
  },
  {
    role: "DevOps",
    icon: Wrench,
    description: "Deployment and monitoring",
    docs: [
      { name: "Deploy Checklist", route: "/dev/docs/deployment-checklist/" },
      {
        name: "Performance",
        route: "/dev/docs/image-optimization-priorities/",
      },
    ],
  },
];

const allDocs = Object.values(documentsByCategory).flat();
const totalDocs = allDocs.length;
const highPriorityDocs = allDocs.filter((d) => d.priority === "high").length;
---

<DocsLayout
  title="Documentation Library"
  description="NY English Teacher project documentation library"
>
  <!-- Hero Section -->
  <div class="hero-section">
    <div class="hero-content">
      <div class="hero-icon">
        <BookOpen size={32} />
      </div>
      <div class="hero-text">
        <h1>Documentation Library</h1>
        <p>Complete technical documentation for NY English Teacher platform</p>
      </div>
    </div>
    <div class="hero-stats">
      <div class="stat-item">
        <FileText size={18} />
        <span><strong>{totalDocs}</strong> Documents</span>
      </div>
      <div class="stat-item">
        <Layers size={18} />
        <span
          ><strong>{Object.keys(documentsByCategory).length}</strong> Categories</span
        >
      </div>
      <div class="stat-item">
        <Target size={18} />
        <span><strong>{highPriorityDocs}</strong> High Priority</span>
      </div>
    </div>
  </div>

  <!-- Quick Start by Role -->
  <section class="section">
    <div class="section-header">
      <h2>
        <Rocket size={24} />
        Quick Start by Role
      </h2>
      <p>Jump to documentation relevant to your work</p>
    </div>

    <div class="role-grid">
      {
        quickStartGuides.map((guide) => {
          const IconComponent = guide.icon;
          return (
            <div class="role-card">
              <div class="role-header">
                <div class="role-icon">
                  <IconComponent size={24} />
                </div>
                <div>
                  <h3>{guide.role}</h3>
                  <p>{guide.description}</p>
                </div>
              </div>
              <div class="role-links">
                {guide.docs.map((doc) => (
                  <a href={doc.route} class="role-link">
                    <ChevronRight size={16} />
                    <span>{doc.name}</span>
                  </a>
                ))}
              </div>
            </div>
          );
        })
      }
    </div>
  </section>

  <!-- All Documentation by Category -->
  <section class="section">
    <div class="section-header">
      <h2>
        <Layers size={24} />
        Browse by Category
      </h2>
      <p>All documentation organized by topic</p>
    </div>

    {
      Object.entries(documentsByCategory).map(([category, docs]) => (
        <div class="category-section">
          <div class="category-header">
            <h3>{category}</h3>
            <span class="doc-count">
              {docs.length} document{docs.length !== 1 ? "s" : ""}
            </span>
          </div>

          <div class="docs-grid">
            {docs.map((doc) => {
              const IconComponent = iconMap[doc.icon as keyof typeof iconMap];
              return (
                <a
                  href={doc.route}
                  class={`doc-card ${doc.priority === "high" ? "priority" : ""}`}
                >
                  <div class="doc-icon">
                    <IconComponent size={20} />
                  </div>
                  <div class="doc-content">
                    <div class="doc-title-row">
                      <h4>{doc.name}</h4>
                      {doc.priority === "high" && (
                        <span class="priority-badge">HIGH</span>
                      )}
                    </div>
                    <p>{doc.description}</p>
                    <div class="doc-tags">
                      {doc.tags.map((tag) => (
                        <span class="tag">{tag}</span>
                      ))}
                    </div>
                  </div>
                </a>
              );
            })}
          </div>
        </div>
      ))
    }
  </section>

  <!-- System Info Footer -->
  <div class="system-info">
    <div class="info-item">
      <span class="label">Source:</span>
      <code>/docs/</code>
    </div>
    <div class="info-item">
      <span class="label">Layout:</span>
      <code>MarkdownLayout.astro</code>
    </div>
    <div class="info-item">
      <span class="label">Route:</span>
      <code>/dev/docs/</code>
    </div>
  </div>
</DocsLayout>

<style>
  /* 
   * Documentation Index Page Styles
   * Uses CSS variables from DocsLayout.astro
   * Dark theme: default | Light theme: body.light-theme
   */

  /* Local shadow variables */
  :root {
    --shadow: 0 1px 3px 0 rgb(0 0 0 / 0.1);
    --shadow-md: 0 4px 6px -1px rgb(0 0 0 / 0.1);
  }

  /* Hero Section */
  .hero-section {
    background: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: 12px;
    padding: 2rem;
    margin-bottom: 2.5rem;
    box-shadow: var(--shadow);
  }

  .hero-content {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    margin-bottom: 1.5rem;
  }

  .hero-icon {
    width: 64px;
    height: 64px;
    background: var(--docs-accent);
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    flex-shrink: 0;
  }

  .hero-text h1 {
    font-size: 2rem;
    font-weight: 700;
    color: var(--text-primary) !important;
    margin: 0 0 0.5rem 0;
    border-bottom: none;
    padding-bottom: 0;
  }

  .hero-text p {
    font-size: 1rem;
    color: var(--text-secondary) !important;
    margin: 0;
  }

  .hero-stats {
    display: flex;
    flex-wrap: wrap;
    gap: 1.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border-color);
  }

  .stat-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--text-secondary) !important;
    font-size: 0.875rem;
  }

  .stat-item strong {
    color: var(--docs-accent);
    font-weight: 600;
  }

  /* Section Styles */
  .section {
    margin-bottom: 2.5rem;
  }

  .section-header {
    margin-bottom: 1.5rem;
  }

  .section-header h2 {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--docs-accent) !important;
    margin: 0 0 0.5rem 0;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    border-left: none;
    padding-left: 0;
  }

  .section-header p {
    font-size: 0.875rem;
    color: var(--text-muted) !important;
    margin: 0;
  }

  /* Role Cards */
  .role-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1rem;
  }

  .role-card {
    background: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: 8px;
    padding: 1.5rem;
    transition: all 0.2s ease;
  }

  .role-card:hover {
    border-color: var(--docs-accent);
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
  }

  .role-header {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    margin-bottom: 1rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--border-color);
  }

  .role-icon {
    width: 48px;
    height: 48px;
    background: var(--bg-secondary);
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--docs-accent);
    flex-shrink: 0;
  }

  .role-header h3 {
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--text-primary) !important;
    margin: 0 0 0.25rem 0;
  }

  .role-header p {
    font-size: 0.875rem;
    color: var(--text-secondary) !important;
    margin: 0;
  }

  .role-links {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .role-link {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.875rem;
    color: var(--text-secondary) !important;
    text-decoration: none;
    padding: 0.5rem;
    border-radius: 4px;
    transition: all 0.2s ease;
  }

  .role-link:hover {
    background: var(--bg-secondary);
    color: var(--docs-accent) !important;
    transform: translateX(4px);
  }

  /* Category Sections */
  .category-section {
    background: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: 8px;
    padding: 1.5rem;
    margin-bottom: 1.5rem;
  }

  .category-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--border-color);
  }

  .category-header h3 {
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--text-primary) !important;
    margin: 0;
  }

  .doc-count {
    font-size: 0.875rem;
    color: var(--text-muted) !important;
  }

  /* Documentation Cards */
  .docs-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1rem;
  }

  .doc-card {
    display: flex;
    gap: 1rem;
    padding: 1rem;
    background: var(--bg-secondary);
    border: 1px solid var(--border-color);
    border-radius: 6px;
    text-decoration: none;
    transition: all 0.2s ease;
  }

  .doc-card:hover {
    border-color: var(--docs-accent);
    box-shadow: var(--shadow);
    transform: translateY(-1px);
  }

  .doc-card.priority {
    border-left: 3px solid var(--docs-accent);
  }

  .doc-icon {
    width: 40px;
    height: 40px;
    background: var(--card-bg);
    border-radius: 6px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--text-secondary);
    flex-shrink: 0;
  }

  .doc-card:hover .doc-icon {
    color: var(--docs-accent);
  }

  .doc-content {
    flex: 1;
    min-width: 0;
  }

  .doc-title-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    margin-bottom: 0.5rem;
  }

  .doc-content h4 {
    font-size: 1rem;
    font-weight: 600;
    color: var(--text-primary) !important;
    margin: 0;
  }

  .priority-badge {
    font-size: 0.625rem;
    font-weight: 700;
    padding: 0.25rem 0.5rem;
    background: var(--docs-accent);
    color: white;
    border-radius: 4px;
    flex-shrink: 0;
  }

  .doc-content p {
    font-size: 0.875rem;
    color: var(--text-secondary) !important;
    margin: 0 0 0.75rem 0;
    line-height: 1.5;
  }

  .doc-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .tag {
    font-size: 0.75rem;
    padding: 0.25rem 0.5rem;
    background: var(--card-bg);
    color: var(--text-muted) !important;
    border-radius: 4px;
  }

  /* System Info */
  .system-info {
    display: flex;
    flex-wrap: wrap;
    gap: 2rem;
    padding: 1.5rem;
    background: var(--bg-secondary);
    border: 1px solid var(--border-color);
    border-radius: 8px;
    margin-top: 2.5rem;
  }

  .info-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.875rem;
  }

  .info-item .label {
    color: var(--text-secondary) !important;
    font-weight: 500;
  }

  .info-item code {
    padding: 0.25rem 0.5rem;
    background: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: 4px;
    font-size: 0.75rem;
    color: var(--docs-accent) !important;
    font-family: "Courier New", monospace;
  }

  /* Responsive Design */
  @media (max-width: 768px) {
    .hero-content {
      flex-direction: column;
      align-items: flex-start;
    }

    .hero-icon {
      width: 48px;
      height: 48px;
    }

    .hero-text h1 {
      font-size: 1.5rem;
    }

    .hero-stats {
      flex-direction: column;
      gap: 0.75rem;
    }

    .role-grid {
      grid-template-columns: 1fr;
    }

    .docs-grid {
      grid-template-columns: 1fr;
    }

    .system-info {
      flex-direction: column;
      gap: 1rem;
    }
  }
</style>
