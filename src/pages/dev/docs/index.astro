---
/**
 * Documentation Library - Main index page with links to all documentation
 */

import DocsLayout from '@layouts/DocsLayout.astro';
import { Home, Rocket, Globe, FileText, Link, Image as ImageIcon, Settings, Repeat, Target, Calendar, Code2, TrendingUp, Wrench, BookOpen, Database } from 'lucide-astro';

// Create a mapping for all available documentation
function getAvailableDocuments() {
  return [
    { 
      filename: 'INDEX.md', 
      name: 'Documentation Index', 
      category: 'Main', 
      icon: 'Home',
      route: '/dev/docs/documentation-index/',
      description: 'Main documentation overview and navigation'
    },
    { 
      filename: 'DEPLOYMENT-CHECKLIST.md', 
      name: 'Deployment Checklist', 
      category: 'Operations', 
      icon: 'Rocket',
      route: '/dev/docs/deployment-checklist/',
      description: 'Complete pre-deployment verification checklist'
    },
    { 
      filename: 'BILINGUAL-SYSTEM-GUIDE.md', 
      name: 'Bilingual System Guide', 
      category: 'i18n', 
      icon: 'Globe',
      route: '/dev/docs/bilingual-system-guide/',
      description: 'Comprehensive guide to the bilingual architecture'
    },
    { 
      filename: 'BLOG-I18N-EDGE-CASES.md', 
      name: 'Blog i18n Edge Cases', 
      category: 'Blog', 
      icon: 'FileText',
      route: '/dev/docs/blog-i18n-edge-cases/',
      description: 'Edge cases and solutions for blog internationalization'
    },
    { 
      filename: 'HREFLANG-FIX-SUMMARY.md', 
      name: 'Hreflang Fix Summary', 
      category: 'SEO', 
      icon: 'Link',
      route: '/dev/docs/hreflang-fix-summary/',
      description: 'Summary of hreflang implementation and SEO fixes'
    },
    { 
      filename: 'IMAGE-OPTIMIZATION-PRIORITIES.md', 
      name: 'Image Optimization', 
      category: 'Performance', 
      icon: 'ImageIcon',
      route: '/dev/docs/image-optimization-priorities/',
      description: 'Image optimization strategies and priorities'
    },
    { 
      filename: 'WINDSURF-RULES.md', 
      name: 'Windsurf Rules', 
      category: 'Development', 
      icon: 'Settings',
      route: '/dev/docs/windsurf-rules/',
      description: 'Development rules and coding standards'
    },
    { 
      filename: 'REDIRECT-ANALYSIS-SUMMARY.md', 
      name: 'Redirect Analysis', 
      category: 'SEO', 
      icon: 'Repeat',
      route: '/dev/docs/redirect-analysis-summary/',
      description: 'Analysis of redirect chains and URL optimization'
    },
    { 
      filename: 'QUIZ-LEAD-MAGNET-SYSTEM.md', 
      name: 'Quiz Lead Magnet System', 
      category: 'Marketing', 
      icon: 'Target',
      route: '/dev/docs/quiz-lead-magnet-system/',
      description: 'Complete documentation for Communication Confidence Quiz'
    },
    { 
      filename: 'BOOKING-SYSTEM.md', 
      name: 'Booking System', 
      category: 'Marketing', 
      icon: 'Calendar',
      route: '/dev/docs/booking-system/',
      description: 'Self-scheduling appointment system with Google Calendar'
    }
  ];
}

const availableDocs = getAvailableDocuments();
const totalDocs = availableDocs.length;
const pageTitle = 'Documentation Library';

// Icon component map
const iconComponents: Record<string, any> = {
  Home, Rocket, Globe, FileText, Link, ImageIcon, Settings, Repeat, Target, Calendar
};
---

<DocsLayout title={pageTitle} description="NY English Teacher project documentation library">
  <!-- Document Navigation -->
  <div class="mb-8 bg-slate-800 rounded-xl shadow-xl border border-slate-700 overflow-hidden">
    <div class="bg-gradient-to-r from-blue-600 to-blue-700 px-6 py-4 border-b border-blue-800">
      <h2 class="text-xl font-bold text-white flex items-center">
        <FileText size={24} class="mr-3" />
        Documentation Library
      </h2>
      <p class="text-blue-100 text-sm mt-1">{totalDocs} documents available</p>
    </div>
    
    <div class="p-6">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
        {availableDocs.map(doc => {
          const IconComponent = iconComponents[doc.icon];
          return (
            <a 
              href={doc.route}
              class="group block p-4 rounded-lg border-2 transition-all duration-200 transform hover:scale-105 hover:shadow-xl bg-slate-700 border-slate-600 hover:border-blue-500 hover:bg-slate-600"
            >
              <div class="flex items-start gap-3">
                <div class="flex-shrink-0 text-blue-400 group-hover:text-blue-300">
                  <IconComponent size={20} />
                </div>
                <div class="flex-1">
                  <div class="font-semibold text-sm mb-2 text-white group-hover:text-blue-300">
                    {doc.name}
                  </div>
                  <div class="text-xs text-slate-300 mb-2 line-clamp-2">
                    {doc.description}
                  </div>
                  <div class="text-xs inline-flex items-center px-2 py-1 rounded-full bg-slate-600 text-slate-300 group-hover:bg-blue-600 group-hover:text-white">
                    {doc.category}
                  </div>
                </div>
              </div>
            </a>
          );
        })}
      </div>
    </div>
  </div>

  <!-- Getting Started Section -->
  <div class="mt-8 bg-slate-800 rounded-xl shadow-xl border border-slate-700 overflow-hidden">
    <div class="bg-gradient-to-r from-blue-600 to-blue-700 px-8 py-6 border-b border-blue-800">
      <h2 class="text-2xl font-bold text-white flex items-center">
        <Rocket size={28} class="mr-3" />
        Getting Started
      </h2>
      <p class="text-blue-100 mt-2">Quick navigation to key documentation sections</p>
    </div>
    
    <div class="p-8">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        <div class="text-center">
          <div class="flex justify-center mb-3">
            <div class="p-3 bg-blue-600 rounded-full shadow-lg">
              <Code2 size={32} class="text-white" />
            </div>
          </div>
          <h3 class="font-semibold text-white mb-2">For Developers</h3>
          <p class="text-sm text-slate-300 mb-4">Start with system architecture and coding standards</p>
          <div class="space-y-2">
            <a href="/dev/docs/documentation-index/" class="flex items-center justify-center gap-2 text-blue-400 hover:text-blue-300 text-sm transition-colors">
              <BookOpen size={14} /> Documentation Index
            </a>
            <a href="/dev/docs/bilingual-system-guide/" class="flex items-center justify-center gap-2 text-blue-400 hover:text-blue-300 text-sm transition-colors">
              <Globe size={14} /> Bilingual System Guide
            </a>
            <a href="/dev/docs/windsurf-rules/" class="flex items-center justify-center gap-2 text-blue-400 hover:text-blue-300 text-sm transition-colors">
              <Settings size={14} /> Windsurf Rules
            </a>
          </div>
        </div>
        
        <div class="text-center">
          <div class="flex justify-center mb-3">
            <div class="p-3 bg-slate-600 rounded-full shadow-lg">
              <TrendingUp size={32} class="text-blue-300" />
            </div>
          </div>
          <h3 class="font-semibold text-white mb-2">For SEO/Content</h3>
          <p class="text-sm text-slate-300 mb-4">SEO implementation and content guidelines</p>
          <div class="space-y-2">
            <a href="/dev/docs/hreflang-fix-summary/" class="flex items-center justify-center gap-2 text-blue-400 hover:text-blue-300 text-sm transition-colors">
              <Link size={14} /> Hreflang Fix Summary
            </a>
            <a href="/dev/docs/blog-i18n-edge-cases/" class="flex items-center justify-center gap-2 text-blue-400 hover:text-blue-300 text-sm transition-colors">
              <FileText size={14} /> Blog i18n Edge Cases
            </a>
            <a href="/dev/docs/redirect-analysis-summary/" class="flex items-center justify-center gap-2 text-blue-400 hover:text-blue-300 text-sm transition-colors">
              <Repeat size={14} /> Redirect Analysis
            </a>
          </div>
        </div>
        
        <div class="text-center">
          <div class="flex justify-center mb-3">
            <div class="p-3 bg-slate-600 rounded-full shadow-lg">
              <Target size={32} class="text-blue-300" />
            </div>
          </div>
          <h3 class="font-semibold text-white mb-2">For Marketing</h3>
          <p class="text-sm text-slate-300 mb-4">Lead generation and conversion systems</p>
          <div class="space-y-2">
            <a href="/dev/docs/quiz-lead-magnet-system/" class="flex items-center justify-center gap-2 text-blue-400 hover:text-blue-300 text-sm transition-colors">
              <Target size={14} /> Quiz Lead Magnet
            </a>
            <a href="/dev/docs/booking-system/" class="flex items-center justify-center gap-2 text-blue-400 hover:text-blue-300 text-sm transition-colors">
              <Calendar size={14} /> Booking System
            </a>
          </div>
        </div>
        
        <div class="text-center">
          <div class="flex justify-center mb-3">
            <div class="p-3 bg-slate-600 rounded-full shadow-lg">
              <Wrench size={32} class="text-blue-300" />
            </div>
          </div>
          <h3 class="font-semibold text-white mb-2">For DevOps</h3>
          <p class="text-sm text-slate-300 mb-4">Deployment and performance optimization</p>
          <div class="space-y-2">
            <a href="/dev/docs/deployment-checklist/" class="flex items-center justify-center gap-2 text-blue-400 hover:text-blue-300 text-sm transition-colors">
              <Rocket size={14} /> Deployment Checklist
            </a>
            <a href="/dev/docs/image-optimization-priorities/" class="flex items-center justify-center gap-2 text-blue-400 hover:text-blue-300 text-sm transition-colors">
              <ImageIcon size={14} /> Image Optimization
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Development Info -->
  <div class="mt-8 bg-slate-800 rounded-xl border border-slate-700 overflow-hidden shadow-xl">
    <div class="bg-gradient-to-r from-slate-700 to-slate-600 px-6 py-3 border-b border-slate-600">
      <h3 class="font-bold text-white flex items-center">
        <Database size={20} class="mr-2" />
        Development Information
      </h3>
    </div>
    <div class="p-6">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4 text-sm">
        <div class="space-y-3">
          <div class="flex items-center">
            <span class="w-3 h-3 bg-blue-500 rounded-full mr-3"></span>
            <span class="font-medium text-slate-200">Documentation System:</span>
            <code class="ml-2 px-2 py-1 bg-slate-700 text-blue-300 rounded text-xs border border-slate-600">Astro + MarkdownLayout</code>
          </div>
          <div class="flex items-center">
            <span class="w-3 h-3 bg-blue-500 rounded-full mr-3"></span>
            <span class="font-medium text-slate-200">Total Documents:</span>
            <span class="ml-2 px-2 py-1 bg-blue-600 text-white rounded text-xs font-semibold">{totalDocs}</span>
          </div>
        </div>
        <div class="space-y-3">
          <div class="flex items-center">
            <span class="w-3 h-3 bg-blue-500 rounded-full mr-3"></span>
            <span class="font-medium text-slate-200">Source Directory:</span>
            <code class="ml-2 px-2 py-1 bg-slate-700 text-blue-300 rounded text-xs border border-slate-600">/docs/</code>
          </div>
          <div class="flex items-center">
            <span class="w-3 h-3 bg-blue-500 rounded-full mr-3"></span>
            <span class="font-medium text-slate-200">Layout Component:</span>
            <code class="ml-2 px-2 py-1 bg-slate-700 text-blue-300 rounded text-xs border border-slate-600">MarkdownLayout.astro</code>
          </div>
        </div>
      </div>
    </div>
  </div>
</DocsLayout>
