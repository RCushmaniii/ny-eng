---
/**
 * Documentation Library - Main index page
 * Redesigned for better hierarchy and easier navigation
 */

import DocsLayout from "@layouts/DocsLayout.astro";
import {
  Rocket,
  Globe,
  FileText,
  Link,
  Image as ImageIcon,
  Settings,
  Repeat,
  Target,
  Calendar,
  Code2,
  TrendingUp,
  Wrench,
  BookOpen,
  Layers,
} from "lucide-astro";

// Icon mapping - convert string names to components
const iconMap = {
  Rocket: Rocket,
  Globe: Globe,
  FileText: FileText,
  Link: Link,
  ImageIcon: ImageIcon,
  Settings: Settings,
  Repeat: Repeat,
  Target: Target,
  Calendar: Calendar,
  Code2: Code2,
  TrendingUp: TrendingUp,
  Wrench: Wrench,
  BookOpen: BookOpen,
  Layers: Layers,
};

// Organize documentation by category with priority
const documentsByCategory = {
  Overview: [
    {
      name: "Documentation Index",
      icon: "BookOpen",
      route: "/dev/docs/documentation-index/",
      description: "Master overview of all project documentation",
      priority: "high",
      tags: ["overview", "navigation", "index"],
    },
  ],
  Development: [
    {
      name: "Bilingual System Guide",
      icon: "Globe",
      route: "/dev/docs/bilingual-system-guide/",
      description: "Complete i18n architecture and routing system",
      priority: "high",
      tags: ["i18n", "architecture", "core"],
    },
    {
      name: "Windsurf Rules",
      icon: "Settings",
      route: "/dev/docs/windsurf-rules/",
      description: "Coding standards and development guidelines",
      priority: "medium",
      tags: ["standards", "best-practices"],
    },
  ],
  "SEO & Content": [
    {
      name: "Hreflang Fix Summary",
      icon: "Link",
      route: "/dev/docs/hreflang-fix-summary/",
      description: "Hreflang implementation and SEO audit results",
      priority: "high",
      tags: ["seo", "international", "critical"],
    },
    {
      name: "Blog i18n Edge Cases",
      icon: "FileText",
      route: "/dev/docs/blog-i18n-edge-cases/",
      description: "Blog internationalization patterns and solutions",
      priority: "medium",
      tags: ["blog", "i18n", "content"],
    },
    {
      name: "Redirect Analysis",
      icon: "Repeat",
      route: "/dev/docs/redirect-analysis-summary/",
      description: "URL redirect chains and optimization strategy",
      priority: "medium",
      tags: ["seo", "urls", "redirects"],
    },
  ],
  "Marketing Systems": [
    {
      name: "Quiz Lead Magnet",
      icon: "Target",
      route: "/dev/docs/quiz-lead-magnet-system/",
      description: "Communication Confidence Quiz system documentation",
      priority: "high",
      tags: ["lead-gen", "conversion", "quiz"],
    },
    {
      name: "Booking System",
      icon: "Calendar",
      route: "/dev/docs/booking-system/",
      description: "Google Calendar integration and self-scheduling",
      priority: "high",
      tags: ["appointments", "automation", "google"],
    },
  ],
  Operations: [
    {
      name: "Deployment Checklist",
      icon: "Rocket",
      route: "/dev/docs/deployment-checklist/",
      description: "Pre-deployment validation and testing procedures",
      priority: "high",
      tags: ["deployment", "qa", "testing"],
    },
    {
      name: "Image Optimization",
      icon: "ImageIcon",
      route: "/dev/docs/image-optimization-priorities/",
      description: "Performance optimization and image strategy",
      priority: "medium",
      tags: ["performance", "images", "optimization"],
    },
  ],
};

// Quick start guides for different roles
const quickStartGuides = [
  {
    role: "Developer",
    icon: Code2,
    color: "blue",
    description: "Building features and fixing bugs",
    docs: [
      { name: "Bilingual System", route: "/dev/docs/bilingual-system-guide/" },
      { name: "Coding Standards", route: "/dev/docs/windsurf-rules/" },
    ],
  },
  {
    role: "SEO/Content",
    icon: TrendingUp,
    color: "green",
    description: "Optimizing search and content",
    docs: [
      { name: "Hreflang Guide", route: "/dev/docs/hreflang-fix-summary/" },
      { name: "Blog i18n", route: "/dev/docs/blog-i18n-edge-cases/" },
    ],
  },
  {
    role: "Marketing",
    icon: Target,
    color: "purple",
    description: "Lead generation systems",
    docs: [
      { name: "Quiz System", route: "/dev/docs/quiz-lead-magnet-system/" },
      { name: "Booking Flow", route: "/dev/docs/booking-system/" },
    ],
  },
  {
    role: "DevOps",
    icon: Wrench,
    color: "orange",
    description: "Deployment and monitoring",
    docs: [
      { name: "Deploy Checklist", route: "/dev/docs/deployment-checklist/" },
      {
        name: "Performance",
        route: "/dev/docs/image-optimization-priorities/",
      },
    ],
  },
];

const allDocs = Object.values(documentsByCategory).flat();
const totalDocs = allDocs.length;
const highPriorityDocs = allDocs.filter((d) => d.priority === "high").length;
const pageTitle = "Documentation Library";

// Icon component map
const iconComponents: Record<string, any> = {
  Rocket,
  Globe,
  FileText,
  Link,
  ImageIcon,
  Settings,
  Repeat,
  Target,
  Calendar,
  Code2,
  TrendingUp,
  Wrench,
};

// Color schemes for role cards
const colorSchemes: Record<
  string,
  { bg: string; border: string; icon: string }
> = {
  blue: { bg: "bg-blue-600", border: "border-blue-500", icon: "text-blue-300" },
  green: {
    bg: "bg-green-600",
    border: "border-green-500",
    icon: "text-green-300",
  },
  purple: {
    bg: "bg-purple-600",
    border: "border-purple-500",
    icon: "text-purple-300",
  },
  orange: {
    bg: "bg-orange-600",
    border: "border-orange-500",
    icon: "text-orange-300",
  },
};
---

<DocsLayout
  title={pageTitle}
  description="NY English Teacher project documentation library"
>
  <!-- Hero Section -->
  <div
    class="mb-4 bg-gradient-to-br from-blue-600 via-blue-700 to-indigo-800 rounded-xl shadow-xl overflow-hidden"
  >
    <div class="px-5 py-4">
      <div class="flex items-center justify-between gap-4 flex-wrap">
        <div class="flex-1 min-w-[300px]">
          <h1
            class="text-2xl font-bold text-white mb-2 flex items-center gap-2"
          >
            <BookOpen size={28} />
            Documentation Library
          </h1>
          <p class="text-white/80 text-sm mb-3">
            Complete technical documentation for NY English Teacher platform
          </p>
          <div class="flex flex-wrap items-center gap-2 text-xs">
            <span
              class="flex items-center gap-1.5 bg-white/20 px-3 py-1.5 rounded-md backdrop-blur-sm border border-white/30 text-white"
            >
              <FileText size={14} />
              <span class="font-semibold">{totalDocs}</span> Docs
            </span>
            <span
              class="flex items-center gap-1.5 bg-white/20 px-3 py-1.5 rounded-md backdrop-blur-sm border border-white/30 text-white"
            >
              <Layers size={14} />
              <span class="font-semibold"
                >{Object.keys(documentsByCategory).length}</span
              > Categories
            </span>
            <span
              class="flex items-center gap-1.5 bg-white/20 px-3 py-1.5 rounded-md backdrop-blur-sm border border-white/30 text-white"
            >
              <Target size={14} />
              <span class="font-semibold">{highPriorityDocs}</span> Priority
            </span>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Quick Start by Role -->
  <div class="mb-4">
    <div class="mb-2">
      <h2
        class="text-lg font-bold flex items-center gap-2"
        style="color: var(--text-primary);"
      >
        <Rocket size={20} />
        Quick Start by Role
      </h2>
      <p class="mt-0.5 text-xs" style="color: var(--text-muted);">
        Jump to documentation relevant to your work
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-3">
      {
        quickStartGuides.map((guide) => {
          const IconComponent = guide.icon;
          const colors = colorSchemes[guide.color];
          return (
            <div
              class={`${colors.bg} rounded-lg p-4 border-2 ${colors.border} hover:scale-[1.02] transition-transform shadow-lg`}
            >
              <div class="flex items-center gap-2 mb-3">
                <div class="p-2 bg-white/20 rounded-md backdrop-blur-sm">
                  <IconComponent size={20} class="text-white" />
                </div>
                <div>
                  <h3 class="font-bold text-white text-base">{guide.role}</h3>
                  <p class="text-xs text-white/70">{guide.description}</p>
                </div>
              </div>
              <div class="space-y-1.5 mt-3 border-t border-white/20 pt-3">
                {guide.docs.map((doc) => (
                  <a
                    href={doc.route}
                    class="flex items-center gap-2 text-sm text-white hover:text-white/80 hover:translate-x-1 transition-all py-1"
                  >
                    <span class="text-white/60">→</span>
                    {doc.name}
                  </a>
                ))}
              </div>
            </div>
          );
        })
      }
    </div>
  </div>

  <!-- All Documentation by Category -->
  <div class="mb-4">
    <div class="mb-2">
      <h2
        class="text-lg font-bold flex items-center gap-2"
        style="color: var(--text-primary);"
      >
        <Layers size={20} />
        All Documentation by Category
      </h2>
      <p class="mt-0.5 text-xs" style="color: var(--text-muted);">
        All documentation organized by topic
      </p>
    </div>

    {
      Object.entries(documentsByCategory).map(([category, docs]) => (
        <div class="bg-slate-800 rounded-lg shadow-lg border border-slate-700 overflow-hidden mb-3">
          <div class="bg-gradient-to-r from-slate-700 to-slate-600 px-4 py-2.5 border-b border-slate-600">
            <h3 class="text-base font-bold text-white">{category}</h3>
            <p class="text-slate-300 text-xs">
              {docs.length} document{docs.length !== 1 ? "s" : ""}
            </p>
          </div>

          <div class="p-4">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
              {docs.map((doc) => {
                const IconComponent = iconMap[doc.icon as keyof typeof iconMap];
                const isPriority = doc.priority === "high";
                return (
                  <a
                    href={doc.route}
                    class={`group block p-3 rounded-md border transition-all duration-200 hover:scale-[1.01] hover:shadow-lg ${
                      isPriority
                        ? "bg-blue-900/30 border-blue-500 hover:bg-blue-900/50"
                        : "bg-slate-700/50 border-slate-600 hover:border-slate-500 hover:bg-slate-700"
                    }`}
                  >
                    <div class="flex items-start gap-3">
                      <div
                        class={`flex-shrink-0 p-1.5 rounded-md ${isPriority ? "bg-blue-600" : "bg-slate-600"}`}
                      >
                        <IconComponent size={18} class="text-white" />
                      </div>
                      <div class="flex-1 min-w-0">
                        <div class="flex items-start justify-between gap-2 mb-1">
                          <h4 class="text-sm font-semibold text-white group-hover:text-blue-300 transition-colors">
                            {doc.name}
                          </h4>
                          {isPriority && (
                            <span class="flex-shrink-0 px-1.5 py-0.5 text-[10px] font-bold bg-blue-500 text-white rounded-full">
                              HIGH
                            </span>
                          )}
                        </div>
                        <p class="text-xs text-slate-300 mb-2 line-clamp-2">
                          {doc.description}
                        </p>
                        <div class="flex flex-wrap gap-1">
                          {doc.tags.map((tag) => (
                            <span class="text-[10px] px-1.5 py-0.5 rounded bg-slate-600 text-slate-300 group-hover:bg-slate-500 transition-colors">
                              {tag}
                            </span>
                          ))}
                        </div>
                      </div>
                    </div>
                  </a>
                );
              })}
            </div>
          </div>
        </div>
      ))
    }
  </div>

  <!-- System Info Footer -->
  <div class="mt-8 bg-slate-800/50 rounded-lg border border-slate-700 p-6">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 text-sm text-slate-300">
      <div class="flex items-center gap-3">
        <div class="w-2 h-2 bg-blue-500 rounded-full"></div>
        <div>
          <span class="font-medium">Source:</span>
          <code
            class="ml-2 px-2 py-1 bg-slate-700 rounded text-blue-300 text-xs"
            >/docs/</code
          >
        </div>
      </div>
      <div class="flex items-center gap-3">
        <div class="w-2 h-2 bg-blue-500 rounded-full"></div>
        <div>
          <span class="font-medium">Layout:</span>
          <code
            class="ml-2 px-2 py-1 bg-slate-700 rounded text-blue-300 text-xs"
            >MarkdownLayout.astro</code
          >
        </div>
      </div>
      <div class="flex items-center gap-3">
        <div class="w-2 h-2 bg-blue-500 rounded-full"></div>
        <div>
          <span class="font-medium">Route:</span>
          <code
            class="ml-2 px-2 py-1 bg-slate-700 rounded text-blue-300 text-xs"
            >/dev/docs/</code
          >
        </div>
      </div>
    </div>
  </div>
</DocsLayout>
