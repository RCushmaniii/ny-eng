---
export const prerender = false;

import fs from "node:fs";
import path from "node:path";

if (!import.meta.env.DEV) {
  throw new Error("Dashboard only available in development mode");
}

interface ReportSummary {
  totalChecks: number;
  passed: number;
  warnings: number;
  errors: number;
}

interface ReportIssue {
  id: string;
  priority: "Critical" | "High" | "Medium" | "Low";
  impact: string;
  message: string;
  action: string;
}

type StatusType = "green" | "yellow" | "orange" | "red" | "blue";

interface StatusConfig {
  emoji: string;
  color: string;
  buttonColor: string;
  textColor: string;
  label: string;
}

interface Report {
  script: ScriptId;
  runAt: string;
  status: StatusType;
  summary?: ReportSummary;
  issues: ReportIssue[];
  metadata?: Record<string, unknown>;
}

const statusConfig: Record<StatusType, StatusConfig> = {
  green: {
    emoji: "✅",
    color: "bg-green-50 border-green-200",
    buttonColor: "bg-green-600 hover:bg-green-700",
    textColor: "text-green-700",
    label: "Passing",
  },
  yellow: {
    emoji: "⚠️",
    color: "bg-yellow-50 border-yellow-200",
    buttonColor: "bg-yellow-600 hover:bg-yellow-700",
    textColor: "text-yellow-700",
    label: "Warnings",
  },
  orange: {
    emoji: "🚧",
    color: "bg-orange-50 border-orange-200",
    buttonColor: "bg-orange-600 hover:bg-orange-700",
    textColor: "text-orange-700",
    label: "Issues",
  },
  red: {
    emoji: "❌",
    color: "bg-red-50 border-red-200",
    buttonColor: "bg-red-600 hover:bg-red-700",
    textColor: "text-red-700",
    label: "Critical",
  },
  blue: {
    emoji: "🔄",
    color: "bg-blue-50 border-blue-200",
    buttonColor: "bg-blue-600 hover:bg-blue-700",
    textColor: "text-blue-700",
    label: "Not Run",
  },
} as const;

type ScriptId =
  | "report-structure"
  | "validate-urls"
  | "validate-hreflang"
  | "validate-seo"
  | "fix-links"
  | "seo-audit";

interface ScriptConfig {
  id: ScriptId;
  name: string;
  description: string;
}

const scriptConfig: ScriptConfig[] = [
  {
    id: "report-structure",
    name: "Project Structure",
    description: "Analyze project file organization and dependencies",
  },
  {
    id: "validate-urls",
    name: "URL Validation",
    description: "Check URL structure and patterns for SEO compliance",
  },
  {
    id: "validate-hreflang",
    name: "Hreflang Validation",
    description: "Verify international SEO and language configuration",
  },
  {
    id: "validate-seo",
    name: "SEO Audit",
    description: "Comprehensive SEO analysis and recommendations",
  },
  {
    id: "fix-links",
    name: "Link Fixer",
    description: "Identify and fix broken internal and external links",
  },
  {
    id: "seo-audit",
    name: "Advanced SEO",
    description: "Deep SEO performance analysis with actionable insights",
  },
] as const;

const reportsDir = path.join(process.cwd(), "project-reports");
let files: string[] = [];

// Map script IDs to actual report file names
const reportFileMap: Record<ScriptId, string> = {
  "report-structure": "report-structure.json",
  "validate-urls": "validate-url-structure.json", // Match actual script output
  "validate-hreflang": "hreflang-validator.json", // Match actual script output
  "validate-seo": "validate-seo.json",
  "fix-links": "fix-links.json",
  "seo-audit": "seo-audit.json",
};

const reports: Report[] = [];
const reportsByScript = scriptConfig.reduce(
  (acc, script) => {
    acc[script.id] = {
      script: script.id,
      runAt: new Date().toISOString(),
      status: "blue" as StatusType,
      issues: [
        {
          id: `${script.id}-initial`,
          priority: "Medium" as ReportIssue["priority"],
          impact: "System",
          message: `Report not yet generated for ${script.name}`,
          action: `Run ${script.name} to generate a report`,
        },
      ],
    };
    return acc;
  },
  {} as Record<ScriptId, Report>
);

// Load reports with enhanced error handling and validation
for (const script of scriptConfig) {
  const reportFile = reportFileMap[script.id];
  const reportPath = path.join(reportsDir, reportFile);

  try {
    if (fs.existsSync(reportPath)) {
      const fileContent = fs.readFileSync(reportPath, "utf-8");
      let reportData: any;

      try {
        reportData = JSON.parse(fileContent);
      } catch (parseError) {
        throw new Error(
          `Invalid JSON format: ${parseError instanceof Error ? parseError.message : String(parseError)}`
        );
      }

      // Validate required fields
      const validStatuses: StatusType[] = ["green", "yellow", "orange", "red"];
      if (!reportData.status || !validStatuses.includes(reportData.status)) {
        throw new Error("Invalid or missing status field");
      }

      if (!Array.isArray(reportData.issues)) {
        throw new Error("Missing or invalid issues array");
      }

      // Create validated report object
      const report: Report = {
        script: script.id,
        runAt: reportData.runAt || new Date().toISOString(),
        status: reportData.status as StatusType,
        summary: reportData.summary
          ? {
              totalChecks: Number(reportData.summary.totalChecks) || 0,
              passed: Number(reportData.summary.passed) || 0,
              warnings: Number(reportData.summary.warnings) || 0,
              errors: Number(reportData.summary.errors) || 0,
            }
          : undefined,
        issues: reportData.issues.map((issue: any) => ({
          id: issue.id || `${script.id}-${Date.now()}`,
          priority: (issue.priority as ReportIssue["priority"]) || "Medium",
          impact: issue.impact || "Unknown",
          message: issue.message || "No message provided",
          action: issue.action || "Review and fix the reported issue",
        })),
        metadata: reportData.metadata,
      };

      reports.push(report);
      reportsByScript[script.id] = report;
    } else {
      // Create placeholder for missing report
      const placeholderReport: Report = {
        script: script.id,
        runAt: new Date().toISOString(),
        status: "blue" as StatusType,
        issues: [
          {
            id: `${script.id}-missing`,
            priority: "Medium" as ReportIssue["priority"],
            impact: "System",
            message: `No report found for ${script.name}`,
            action: `Run ${script.name} to generate a report`,
          },
        ],
      };
      reports.push(placeholderReport);
      reportsByScript[script.id] = placeholderReport;
    }
  } catch (error) {
    // Create detailed error report
    const errorReport: Report = {
      script: script.id,
      runAt: new Date().toISOString(),
      status: "red" as StatusType,
      issues: [
        {
          id: `${script.id}-error-${Date.now()}`,
          priority: "Critical" as ReportIssue["priority"],
          impact: "System",
          message: `Failed to load report: ${error instanceof Error ? error.message : String(error)}`,
          action: "Check report file format and try running the script again",
        },
      ],
      metadata: {
        error: true,
        errorType: error instanceof Error ? error.name : "Unknown",
        reportFile,
      },
    };
    reports.push(errorReport);
    reportsByScript[script.id] = errorReport;
  }
}

const counts = {
  red: reports.filter((r) => r.status === "red").length,
  orange: reports.filter((r) => r.status === "orange").length,
  yellow: reports.filter((r) => r.status === "yellow").length,
  green: reports.filter((r) => r.status === "green").length,
};
