                  status === "green"
                    ? "btn-green"
                    : status === "yellow"
                      ? "btn-yellow"
                      : status === "orange"
                        ? "btn-orange"
                        : status === "red"
                          ? "btn-red"
                          : "btn-blue";

                return (
                  <div class="bg-gray-50 rounded-lg p-4">
                    <div class="mb-3">
                      <h3 class="font-semibold text-gray-900">{script.name}</h3>
                      <p class="text-sm text-gray-600">{script.description}</p>
                      {report && (
                        <div class="mt-2 flex items-center gap-2 text-xs">
                          <span
                            class={`px-2 py-1 rounded ${statusConfig[status].color} ${statusConfig[status].textColor}`}
                          >
                            {statusConfig[status].emoji}{" "}
                            {statusConfig[status].label}
                          </span>
                          <span class="text-gray-500">
                            {report.issues.length} issues
                          </span>
                        </div>
                      )}
                    </div>
                    <button
                      data-script={script.id}
                      class={`w-full btn-status ${buttonClass} text-white font-medium`}
                      onclick={`runScript('${script.id}')`}
                    >
                      <span class="button-text">Run {script.name}</span>
                    </button>
                  </div>
                );
              })
            }
            <div class="bg-gray-50 rounded-lg p-4">
              <button
                id="runAllButton"
                class="w-full btn-primary"
                onclick="runAllScripts()"
              >
                <span class="button-text">Run All Reports</span>
              </button>
            </div>
          </div>
        </section>

        <!-- Report Cards -->
        <section
          id="reports-grid"
          class="grid grid-cols-1 md:grid-cols-2 gap-6"
        >
          {
            reports.map((report) => {
              const status = statusConfig[report.status];
              return (
                <div
                  class={`report-card card rounded-xl border ${status.color} shadow-lg`}
                  data-status={report.status}
                >
                  <button
                    class="w-full flex justify-between items-center p-6 cursor-pointer hover:bg-black/5 transition-colors rounded-t-xl"
                    onclick="window.toggleCard(this)"
                  >
                    <div class="flex items-center gap-4">
                      <span class="text-2xl">{status.emoji}</span>
                      <div class="text-left">
                        <h2 class="text-lg font-semibold text-gray-900">
                          {report.script.replace(".json", "")}
                        </h2>
                        <p class="text-xs text-gray-500">
                          Last run: {new Date(report.runAt).toLocaleString()}
                        </p>
                        <p class="text-xs text-gray-600 mt-1">
                          {report.issues.length} issues found
                        </p>
                      </div>
                    </div>
                    <span class="chevron text-gray-500 text-xl transition-transform">
                      ▼
                    </span>
                  </button>

                  <div class="max-h-0 overflow-hidden transition-all duration-300">
                    <div class="p-6 space-y-4 bg-white border-t border-gray-200 rounded-b-xl">
                      {report.issues.length === 0 ? (
                        <div class="text-center py-4">
                          <span class="text-green-600 font-medium text-lg">
                            ✨ No issues found
                          </span>
                          <p class="text-gray-500 text-sm mt-1">
                            Everything looks good!
                          </p>
                        </div>
                      ) : (
                        <div class="space-y-3">
                          {report.issues.map((issue, index) => (
                            <div class="bg-gray-50 rounded-lg p-4 border border-gray-200">
                              <div class="flex justify-between items-start mb-2">
                                <span
                                  class={`px-2 py-1 rounded text-xs font-medium ${
                                    issue.priority === "High" ||
                                    issue.priority === "Critical"
                                      ? "bg-red-100 text-red-700"
                                      : issue.priority === "Medium"
                                        ? "bg-orange-100 text-orange-700"
                                        : "bg-yellow-100 text-yellow-700"
                                  }`}
                                >
                                  {issue.priority} Priority
                                </span>
                                <span class="text-xs text-gray-500">
                                  {issue.impact}
                                </span>
                              </div>
                              <p class="font-medium text-gray-900 mb-2">
                                {issue.message}
                              </p>
                              <p class="text-sm text-gray-600 bg-blue-50 p-3 rounded border-l-4 border-blue-400">
                                💡 {issue.action}
                              </p>
                            </div>
                          ))}
                        </div>
                      )}
                      <div class="pt-4 border-t border-gray-200">
                        <button
                          data-script={report.script.replace(".json", "")}
                          class={`btn-status ${
                            status.buttonColor.includes("green")
                              ? "btn-green"
                              : status.buttonColor.includes("yellow")
                                ? "btn-yellow"
                                : status.buttonColor.includes("orange")
                                  ? "btn-orange"
                                  : "btn-red"
                          }`}
                          onclick={`runScript('${report.script.replace(".json", "")}')`}
                        >
                          🔄 Run Again
                        </button>
                      </div>
                    </div>
                  </div>
                </div>
              );
            })
          }
        </section>
      </main>
    </div>

    <!-- Toast Container -->
    <div id="toastContainer"></div>

    <script is:inline>
      // Enhanced Dashboard JavaScript
      class DashboardManager {
        constructor() {
          this.running = false;
          this.activeScripts = new Set();
        }

        showToast(message, type = "success") {
          const container = document.getElementById("toastContainer");
          const toast = document.createElement("div");
          toast.className = `toast ${type}`;
          toast.innerHTML = `
            <div class="flex items-center gap-2">
              <span class="text-lg">${type === "success" ? "✅" : type === "error" ? "❌" : "⚠️"}</span>
              <span class="font-medium">${message}</span>
            </div>
          `;

          container.appendChild(toast);

          setTimeout(() => {
            toast.style.transform = "translateX(100%)";
            toast.style.opacity = "0";
            setTimeout(() => container.removeChild(toast), 300);
          }, 3000);
        }

        updateButtonState(scriptName, state, text) {
          const buttons = document.querySelectorAll(
            `[data-script="${scriptName}"]`
          );
          buttons.forEach((button) => {
            const textElement = button.querySelector(".button-text");
            if (textElement) {
              switch (state) {
                case "running":
                  textElement.innerHTML =
                    '<span class="spinner"></span> Running...';
                  button.disabled = true;
                  button.classList.add("cursor-not-allowed");
                  break;
                case "success":
                  textElement.innerHTML = "✅ Completed";
                  button.disabled = true;
                  setTimeout(
                    () => this.resetButtonState(button, scriptName),
                    2000
                  );
                  break;
                case "error":
                  textElement.innerHTML = "❌ Failed";
                  button.disabled = true;
                  setTimeout(
                    () => this.resetButtonState(button, scriptName),
                    3000
                  );
                  break;
              }
            }
          });
        }

        resetButtonState(button, scriptName) {
          const textElement = button.querySelector(".button-text");
          if (textElement) {
            textElement.textContent = `Run ${scriptName}`;
            button.disabled = false;
            button.classList.remove("cursor-not-allowed");
          }
        }

        async runScript(scriptName) {
          if (this.activeScripts.has(scriptName)) return;

          this.activeScripts.add(scriptName);
          this.updateButtonState(scriptName, "running");

          try {
            const response = await fetch(`/api/run/${scriptName}`, {
              method: "POST",
              headers: { "Content-Type": "application/json" },
            });

            const result = await response.json();

            if (result.success) {
              this.updateButtonState(scriptName, "success");
              this.showToast(`${scriptName} completed successfully`, "success");

              // Reload after short delay to show updated results
              setTimeout(() => window.location.reload(), 1500);
            } else {
              this.updateButtonState(scriptName, "error");
              this.showToast(`${scriptName} failed: ${result.error}`, "error");
            }
          } catch (error) {
            this.updateButtonState(scriptName, "error");
            this.showToast(`${scriptName} execution failed`, "error");
          } finally {
            this.activeScripts.delete(scriptName);
          }
        }

        async runAllScripts() {
          if (this.running) return;

          this.running = true;
          const runAllButton = document.getElementById("runAllButton");
          const progressDiv = document.getElementById("globalProgress");
          const progressBar = document.getElementById("progressBar");
          const progressText = document.getElementById("progressText");

          // Show progress
          progressDiv.classList.remove("hidden");
          runAllButton.querySelector(".button-text").innerHTML =
            '<span class="spinner"></span> Running All...';
          runAllButton.disabled = true;

          try {
            const response = await fetch("/api/run/all", {
              method: "POST",
              headers: { "Content-Type": "application/json" },
            });

            const result = await response.json();

            if (result.success) {
              progressText.textContent = `Completed all scripts successfully!`;
              progressBar.style.width = "100%";
              this.showToast(`All scripts completed successfully!`, "success");
            } else {
              progressText.textContent = `Completed with ${result.summary.failed} failures`;
              this.showToast(
                `${result.summary.succeeded} succeeded, ${result.summary.failed} failed`,
                "warning"
              );
            }

            // Reload to show updated results
            setTimeout(() => window.location.reload(), 2000);
          } catch (error) {
            progressText.textContent = "Execution failed";
            this.showToast("Failed to run scripts", "error");
          } finally {
            this.running = false;
            setTimeout(() => {
              progressDiv.classList.add("hidden");
              runAllButton.querySelector(".button-text").textContent =
                "Run All Reports";
              runAllButton.disabled = false;
            }, 2000);
          }
        }
      }

      // Initialize dashboard
      const dashboard = new DashboardManager();

      // Global functions for onclick handlers
      window.runScript = (script) => dashboard.runScript(script);
      window.runAllScripts = () => dashboard.runAllScripts();

      window.toggleCard = function (button) {
        const content = button.nextElementSibling;
        const chevron = button.querySelector(".chevron");
        if (
          !(content instanceof HTMLElement) ||
          !(chevron instanceof HTMLElement)
        )
          return;

        const isCollapsed = content.classList.contains("max-h-0");
        content.classList.toggle("max-h-0", !isCollapsed);
        content.classList.toggle("max-h-96", isCollapsed);
        chevron.style.transform = isCollapsed
          ? "rotate(180deg)"
          : "rotate(0deg)";
      };

      window.filterReports = function (status, button) {
        // Update button states
        document.querySelectorAll(".filter-btn").forEach((btn) => {
          btn.classList.remove(
            "bg-blue-100",
            "text-blue-700",
            "border-blue-200"
          );
          btn.classList.add("bg-gray-100", "text-gray-700", "border-gray-200");
          btn.setAttribute("data-active", "false");
        });

        button.classList.remove(
          "bg-gray-100",
          "text-gray-700",
          "border-gray-200"
        );
        button.classList.add("bg-blue-100", "text-blue-700", "border-blue-200");
        button.setAttribute("data-active", "true");

        // Filter cards
        document.querySelectorAll(".report-card").forEach((card) => {
          if (status === "all" || card.dataset.status === status) {
            card.style.display = "block";
          } else {
            card.style.display = "none";
          }
        });
      };

      // Auto-refresh every 30 seconds if no scripts are running
      setInterval(() => {
        if (!dashboard.running && dashboard.activeScripts.size === 0) {
          window.location.reload();
        }
      }, 30000);
    </script>
  </body>
</html>
