---
/**
 * /es/gratis/index.astro
 *
 * Free Resources Hub (Spanish) - Dashboard showing all available free resources
 */

import Base from "@layouts/Base.astro";
import Button from "@components/ui/Button.astro";
import FreeResourcesHub from "@components/free/FreeResourcesHub";
import { Sparkles, FileText, Headphones, MessageCircle } from "lucide-astro";
import type { FreeAsset } from "@/types/free-asset";

const title = "Recursos Gratis | Inglés de Negocios | NY English";
const description =
  "Guías gratuitas, hojas de referencia y herramientas para ayudar a profesionales de tecnología latinoamericanos a comunicarse con confianza ejecutiva en inglés.";

// Auto-discover all free resources from JSON files
const allAssets = await Astro.glob("../../data/free/*.json");

// Filter out schema and template files, only keep actual assets with valid content
// Support both new schema (es at root) and old schema (content.es)
const resources: FreeAsset[] = allAssets
  .filter((file) => {
    const data = file.default;
    const esContent = data.es || data.content?.es;
    // Must have metadata, es.title, and not be schema/template
    return data.metadata && esContent?.title && !data.$schema;
  })
  .map((file) => {
    const data = file.default;
    // Normalize old schema to new schema structure
    if (!data.es && data.content?.es) {
      data.en = data.content.en;
      data.es = data.content.es;
      data.slugEn = data.slugEn || data.content.en?.slug;
      data.slugEs = data.slugEs || data.content.es.slug;
    }
    return data as FreeAsset;
  });
---

<Base
  title={title}
  description={description}
  lang="es"
  tkey="free"
  ogImage={{
    src: "/images/logos/new-york-english-og.jpg",
    alt: "Recursos Gratis de Inglés de Negocios - New York English Teacher",
  }}
  hideCta={true}
>
  <!-- Hero Section -->
  <section class="hero-section pt-28 pb-16 md:pt-32 md:pb-20">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <div class="text-center max-w-3xl mx-auto">
        <div
          class="inline-flex items-center gap-2 bg-blue-100 text-blue-700 px-4 py-2 rounded-full text-sm font-semibold mb-6"
        >
          <Sparkles class="w-4 h-4" />
          <span>Recursos 100% Gratis</span>
        </div>

        <h1
          class="text-4xl md:text-5xl lg:text-6xl font-bold text-slate-900 mb-6 leading-tight"
        >
          Mejora Tu
          <span class="text-blue-600"> Inglés Ejecutivo</span>
        </h1>

        <p class="text-lg md:text-xl text-slate-600 leading-relaxed">
          Guías prácticas, hojas de referencia y herramientas diseñadas para
          profesionales de tecnología latinoamericanos que se comunican con
          clientes norteamericanos.
        </p>
      </div>
    </div>
  </section>

  <!-- Available Resources (Auto-discovered) -->
  <FreeResourcesHub resources={resources} lang="es" client:load />

  <!-- CTA Section -->
  <section
    class="cta-section py-16 md:py-20 bg-gradient-to-br from-slate-900 to-slate-800"
  >
    <div class="max-w-4xl mx-auto px-4 sm:px-6 text-center">
      <h2 class="text-3xl md:text-4xl font-bold text-white mb-6">
        ¿Quieres Resultados Más Rápidos?
      </h2>
      <p class="text-lg text-slate-300 mb-8 max-w-2xl mx-auto">
        Los recursos gratuitos crean conciencia. El coaching profesional crea
        transformación. Agenda una llamada estratégica gratis para discutir los
        desafíos específicos de tu equipo.
      </p>
      <Button href="/es/reservar/" variant="primary" size="lg">
        Agendar Llamada Gratis →
      </Button>
    </div>
  </section>
</Base>

<style>
  .hero-section {
    background: linear-gradient(135deg, #f0f9ff 0%, #e0e7ff 100%);
  }

  .resource-card {
    cursor: pointer;
  }

  .upcoming-card {
    transition: opacity 0.3s ease;
  }

  .upcoming-card:hover {
    opacity: 1;
  }
</style>
