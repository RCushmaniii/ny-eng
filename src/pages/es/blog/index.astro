---
import { getCollection, type CollectionEntry } from "astro:content";
import { blogSetting } from "@data/config";
import PaginatedBlogLayout from "@components/blog/PaginatedBlogLayout.astro";
import blogHero from "../../../content/blog/images/blog-hero.jpg";
import type { TKey } from '../../../lib/i18n';
export const prerender = true;

// Get current page from URL, default to 1
const currentPage = parseInt(Astro.url.searchParams.get("page") || "1");

// Get all Spanish posts only
const allPosts = await getCollection("blog");
const filteredPosts: CollectionEntry<'blog'>[] = allPosts.filter(
  (post: CollectionEntry<'blog'>) => post.id.startsWith("es/") && post.data.publish === true,
);

// Sort posts by date
const sortedPosts: CollectionEntry<'blog'>[] = filteredPosts.sort(
  (a: CollectionEntry<'blog'>, b: CollectionEntry<'blog'>) => new Date(b.data.publishDate).getTime() - new Date(a.data.publishDate).getTime(),
);

// Calculate pagination
const totalPosts = sortedPosts.length;
// Only show pagination if we have MORE posts than can fit on a single page
// If we have exactly postsPerPage or fewer, don't show pagination at all
const hasMultiplePages = totalPosts > blogSetting.postsPerPage;
const totalPages = hasMultiplePages
  ? Math.ceil(totalPosts / blogSetting.postsPerPage)
  : 1;
const start = (currentPage - 1) * blogSetting.postsPerPage;
const end = start + blogSetting.postsPerPage;
const paginatedPosts = sortedPosts.slice(start, end);

const seoTitle = "Blog de Inglés Empresarial | NY English";
const seoDescription = "Inglés práctico para los momentos que importan. Artículos, tips y recursos para profesionales que quieren dominar el inglés de negocios.";

// Use centralized i18n system for blog
const lang = 'es';
const tkey = 'blog' as TKey;
---

<PaginatedBlogLayout
  posts={paginatedPosts}
  currentPage={currentPage}
  totalPages={totalPages}
  baseUrl="/es/blog/"
  title={seoTitle}
  heroTitle="Inglés práctico para los momentos que importan."
  description={seoDescription}
  subtitle=""
  heroImage={blogHero}
  heroImageAlt="Blog de New York English - Tips y recursos para el inglés de negocios"
  hasMultiplePages={hasMultiplePages}
  translationSlugEn="/blog/"
  lang="es"
  tkey={tkey}
/>
