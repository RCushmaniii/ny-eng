---
import { getCollection } from "astro:content";
import { blogSetting } from "@data/config";
import PaginatedBlogLayout from "@components/blog/PaginatedBlogLayout.astro";
import blogHero from "../../../content/blog/images/blog-hero.jpg";
import type { TKey } from '../../../lib/i18n';
export const prerender = true;

import type { PaginateFunction } from 'astro';

export async function getStaticPaths({ paginate }: { paginate: PaginateFunction }) {
  // Get all Spanish posts only
  const allPosts = await getCollection("blog");
  const filteredPosts = allPosts.filter(
    (post: { id: string; data: { publish: boolean } }) => post.id.startsWith("es/") && post.data.publish === true,
  );

  // Sort posts by date
  const sortedPosts = filteredPosts.sort(
    (a: { data: { publishDate: Date } }, b: { data: { publishDate: Date } }) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf(),
  );

  // Return paginated collection
  return paginate(sortedPosts, { pageSize: blogSetting.postsPerPage });
}

// Get page details from Astro.props
const { page } = Astro.props;
const { currentPage, data: posts, lastPage, url } = page;

// Setup pagination metadata
const baseUrl = "/es/blog/";
const hasMultiplePages = lastPage > 1;

const seoTitle = "Blog";
const seoDescription = "Tips prácticos y experiencias reales para dominar el inglés de negocios.";

// Use centralized i18n system
const lang = 'es';
const tkey = 'blog' as TKey;
---

<PaginatedBlogLayout
  posts={posts}
  currentPage={currentPage}
  totalPages={lastPage}
  baseUrl={baseUrl}
  title={seoTitle}
  subtitle={seoDescription}
  heroImage={blogHero}
  heroImageAlt="Blog de New York English - Tips y recursos para el inglés de negocios"
  hasMultiplePages={hasMultiplePages}
  lang="es"
  tkey={tkey}
/>
