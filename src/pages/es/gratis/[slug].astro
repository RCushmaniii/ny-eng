---
/**
 * Dynamic route for all free resources (Spanish)
 * Automatically generates pages for any JSON file in src/data/free/
 *
 * Example URLs:
 * - /es/gratis/5-preguntas/
 * - /es/gratis/frases-negociacion/
 * - /es/gratis/checklist-videollamadas/
 */

import Base from "@layouts/Base.astro";
import GenericFreeAsset from "@components/free/GenericFreeAsset";
import type { TKey } from "../../../lib/i18n";

// Generate static paths for all free assets
export async function getStaticPaths() {
  // Get all JSON files from src/data/free/ (excluding schema.json)
  const freeAssets = import.meta.glob("/src/data/free/*.json", { eager: true });

  return Object.entries(freeAssets)
    .filter(([path]) => !path.includes("schema.json")) // Exclude schema.json
    .map(([path, module]) => {
      // Extract slug from file path (e.g., "5-questions" from "/src/data/free/5-questions.json")
      const slug = path.split("/").pop()?.replace(".json", "") || "";
      const content = module as any;

      // Use Spanish slug if provided in content, otherwise use same slug
      const esSlug = content.slugEs || slug;

      return {
        params: { slug: esSlug },
        props: { content, slug },
      };
    });
}

const { slug } = Astro.params;
const { content } = Astro.props;

// Extract metadata from content - support both old and new schema
const contentType =
  content.classification?.contentType || content.type || "default";
const esContent = content.es || content.content?.es;
const seoData = content.seo || {};

// SEO metadata - use proper SEO fields from JSON
// Title: Keep it concise (under 60 chars) using just the asset title
const title = esContent.title;

// Description: Use the SEO metaDescription from JSON (already optimized for length)
// Fallback to subtitle if not available
const description =
  seoData.metaDescription ||
  esContent.subtitle ||
  esContent.intro?.paragraph?.substring(0, 160) ||
  `Recurso bilingüe gratuito para profesionales: ${esContent.title}`;

// Determine PDF file name (same as English version)
const pdfFile = `${content.slugEn || slug}.pdf`;
const bookingUrl = "/es/reservar/";
---

<Base
  title={title}
  description={description}
  lang="es"
  tkey={`free/${content.slugEn || slug}` as TKey}
  ogImage={{
    src: "/images/logos/new-york-english-og.jpg",
    alt: `${esContent.title} - Recurso Gratuito`,
  }}
  hideCta={true}
>
  <!-- JSON-LD Schema for Educational Resource -->
  <script
    type="application/ld+json"
    slot="head"
    set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "LearningResource",
      name: esContent.title,
      description: esContent.subtitle || description,
      learningResourceType: "Guía",
      educationalLevel: "Profesional",
      audience: {
        "@type": "Audience",
        audienceType: "Profesionales de Negocios",
      },
      inLanguage: ["en-US", "es-MX"],
      isAccessibleForFree: true,
      creator: {
        "@type": "Person",
        name: "Robert Cushman",
        jobTitle: "Coach de Inglés de Negocios",
        url: "https://www.nyenglishteacher.com/es/sobre-mi/",
      },
      publisher: {
        "@type": "Organization",
        name: "NY English Teacher",
        url: "https://www.nyenglishteacher.com",
        logo: {
          "@type": "ImageObject",
          url: "https://www.nyenglishteacher.com/images/logos/new-york-english-512x512.png",
        },
      },
      datePublished: new Date().toISOString().split("T")[0],
      keywords: [
        "comunicación ejecutiva",
        "inglés de negocios",
        "desarrollo profesional",
        "liderazgo",
      ],
    })}
  />

  <GenericFreeAsset
    client:load
    content={content}
    lang="es"
    pdfFile={pdfFile}
    bookingUrl={bookingUrl}
    contentType={contentType}
  />
</Base>

<style is:global>
  /* Global styles for free resource pages */
  .free-asset-page {
    min-height: 100vh;
  }

  /* Smooth scrolling */
  html {
    scroll-behavior: smooth;
  }

  /* Table responsive wrapper */
  .free-asset-page table {
    min-width: 600px;
  }

  /* Print styles */
  @media print {
    .free-asset-page section:not(:first-child) {
      page-break-before: auto;
    }

    .free-asset-page button,
    .free-asset-page .no-print {
      display: none !important;
    }
  }
</style>
