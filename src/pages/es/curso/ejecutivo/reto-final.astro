---
export const prerender = true;

import Base from "@layouts/Base.astro";
import Button from "@components/ui/Button.astro";
import CapstoneUploadForm from "@components/course/CapstoneUploadForm";
import { Crown, Calendar, Mic, ArrowLeft, CheckCircle2 } from "lucide-astro";

const lang = "es";
const tkey = "course/executive/capstone" as const;

const bookingLink =
  "/es/reservar/?notes=" +
  encodeURIComponent(
    "Acabo de completar el curso de Comunicación Ejecutiva y grabé mi presentación final. Me gustaría retroalimentación en vivo de Robert sobre mi entrega y presencia ejecutiva."
  );
---

<Base
  lang={lang}
  tkey={tkey}
  title="Reto Final Ejecutivo — Presentación de 90 Seg | NY English"
  description="Graba una actualización ejecutiva de 90 segundos con los marcos que dominaste. Envíala para recibir retroalimentación personal de Robert, o preséntala en vivo."
>
  <!-- Hero -->
  <section
    class="relative w-full overflow-hidden bg-gradient-to-br from-slate-950 via-slate-900 to-amber-950 pt-32 pb-20 md:pt-40 md:pb-28"
  >
    <div class="absolute inset-0 opacity-10 pointer-events-none">
      <div class="absolute top-20 left-10 w-72 h-72 bg-amber-500 rounded-full blur-3xl"></div>
      <div class="absolute bottom-10 right-10 w-96 h-96 bg-slate-400 rounded-full blur-3xl"></div>
    </div>
    <div class="site-container mx-auto px-4 relative z-10 text-white">
      <div class="max-w-3xl">
        <a
          href="/es/curso/ejecutivo/unidad-10/"
          class="inline-flex items-center gap-1.5 text-sm text-slate-400 hover:text-white transition-colors mb-6"
        >
          <ArrowLeft class="w-4 h-4" />
          Volver a Unidad 10
        </a>
        <div
          class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-amber-500/20 text-amber-300 text-sm font-semibold mb-6"
        >
          <Crown class="w-4 h-4" />
          El Reto Final
        </div>
        <h1
          class="text-4xl md:text-5xl lg:text-6xl font-bold text-white mb-6 leading-tight"
          style="font-family: 'Noto Sans KR', sans-serif;"
        >
          Tu Voz Ejecutiva,<br />
          <span class="text-amber-400">Grabada.</span>
        </h1>
        <p class="text-xl text-slate-200 max-w-2xl leading-relaxed">
          Diez unidades. Más de 130 ejercicios. Cada marco que internalizaste. Ahora ponlo
          todo junto en una presentación ejecutiva de 90 segundos — y recibe la
          retroalimentación personal de Robert sobre tu entrega.
        </p>
      </div>
    </div>
  </section>

  <!-- The Prompt -->
  <section class="py-16 md:py-20 bg-white">
    <div class="site-container mx-auto px-4">
      <div class="max-w-3xl mx-auto">
        <p class="text-[11px] font-mono uppercase tracking-[0.3em] text-amber-600 mb-4">
          Tu Tarea
        </p>
        <h2
          class="text-2xl md:text-3xl font-bold text-slate-900 mb-6"
          style="font-family: 'Noto Sans KR', sans-serif;"
        >
          Graba una actualización ejecutiva de 90 segundos.
        </h2>
        <div class="bg-slate-50 border-l-4 border-amber-400 rounded-r-xl p-6 md:p-8 mb-8">
          <p class="text-lg text-slate-800 leading-relaxed font-medium">
            Elige un proyecto real que estés liderando ahora mismo. Preséntalo como si
            estuvieras informando a la dirección senior — usando el marco
            <strong>Contexto → Tensión → Perspectiva → Acción → Resultado</strong>
            de la Unidad 5. 90 segundos. Sin notas. Habla desde el conocimiento, no de un guion.
          </p>
        </div>

        <!-- How to record -->
        <div class="bg-amber-50 border border-amber-200 rounded-xl p-6">
          <div class="flex items-center gap-2 mb-4">
            <Mic class="w-5 h-5 text-amber-600" />
            <p class="text-sm font-bold text-amber-800 uppercase tracking-wide">Cómo Grabar</p>
          </div>
          <ul class="space-y-2 text-sm text-amber-900 leading-relaxed">
            <li><strong>iPhone:</strong> Abre la app Notas de Voz → toca el botón rojo → guarda y exporta como M4A.</li>
            <li><strong>Android:</strong> Usa la app de Grabadora de Voz integrada → exporta como MP3 o M4A.</li>
            <li><strong>Computadora:</strong> Usa Zoom (graba una reunión contigo mismo), Loom o la grabación de audio de QuickTime.</li>
          </ul>
          <p class="text-xs text-amber-700 mt-4">
            Cualquier formato de audio funciona: MP3, M4A, WAV u OGG. Mantenlo bajo 50 MB (todas las grabaciones de voz califican).
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Submission — Upload form + Booking CTA -->
  <section class="py-16 md:py-20 bg-slate-50">
    <div class="site-container mx-auto px-4">
      <div class="max-w-4xl mx-auto">
        <p class="text-[11px] font-mono uppercase tracking-[0.3em] text-amber-600 mb-4 text-center">
          Envía Tu Trabajo
        </p>
        <h2
          class="text-2xl md:text-3xl font-bold text-slate-900 mb-3 text-center"
          style="font-family: 'Noto Sans KR', sans-serif;"
        >
          Elige tu camino.
        </h2>
        <p class="text-slate-600 text-center mb-10">
          Ambas opciones incluyen retroalimentación personal de Robert.
        </p>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 items-start">
          <!-- Path A: Upload -->
          <div>
            <div class="flex items-center gap-2 mb-4">
              <span class="w-6 h-6 rounded-full bg-amber-500 text-white text-xs font-bold flex items-center justify-center">A</span>
              <h3 class="text-lg font-bold text-slate-900">Sube Tu Grabación</h3>
            </div>
            <p class="text-sm text-slate-600 mb-5 leading-relaxed">
              Graba en tu teléfono o computadora y súbela aquí. Robert escucha personalmente
              cada grabación y te envía retroalimentación detallada por correo en 48 horas.
            </p>
            <CapstoneUploadForm client:load lang="es" />
          </div>

          <!-- Path B: Strategy Session -->
          <div class="md:mt-14">
            <div class="flex items-center gap-2 mb-4">
              <span class="w-6 h-6 rounded-full bg-slate-800 text-white text-xs font-bold flex items-center justify-center">B</span>
              <h3 class="text-lg font-bold text-slate-900">Preséntalo en Vivo con Robert</h3>
              <span class="text-xs font-bold uppercase tracking-wider text-amber-600 bg-amber-50 border border-amber-200 px-2 py-0.5 rounded-full ml-auto">
                Recomendado
              </span>
            </div>
            <p class="text-sm text-slate-600 mb-6 leading-relaxed">
              Reserva una sesión de estrategia gratuita de 30 minutos. Entrega tu actualización
              de 90 segundos en vivo — y recibe coaching en tiempo real sobre tu entrega,
              elección de palabras y presencia ejecutiva. Este es el camino de mayor valor.
            </p>
            <div class="bg-white rounded-2xl border-2 border-amber-300 p-6 shadow-sm">
              <div class="flex items-center gap-3 mb-4">
                <Calendar class="w-6 h-6 text-amber-600" />
                <div>
                  <p class="text-sm font-bold text-slate-900">Sesión de Estrategia Gratuita</p>
                  <p class="text-xs text-slate-500">30 minutos · Google Meet · Sin preparación requerida</p>
                </div>
              </div>
              <p class="text-xs text-slate-500 mb-5 leading-relaxed">
                El contexto de tu sesión se pre-llena — Robert sabrá que vienes del
                curso Ejecutivo y tendrá tu reto final listo.
              </p>
              <Button href={bookingLink} variant="primary" size="lg" class="w-full">
                <Calendar class="w-4 h-4" />
                Reservar Sesión de Estrategia
              </Button>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Robert's Coaching Reminders -->
  <section class="py-16 md:py-20 bg-white">
    <div class="site-container mx-auto px-4">
      <div class="max-w-3xl mx-auto">
        <p class="text-[11px] font-mono uppercase tracking-[0.3em] text-amber-600 mb-4">
          Recordatorios de Robert
        </p>
        <h2
          class="text-2xl font-bold text-slate-900 mb-8"
          style="font-family: 'Noto Sans KR', sans-serif;"
        >
          Cuatro cosas que escucho.
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          {
            [
              {
                tip: "Verbos ejecutivos — no 'looked into' sino 'diagnosed.' No 'worked on' sino 'drove.' (Unidad 1)",
              },
              {
                tip: "Cero relleno. Nada de 'I think', 'kind of', 'basically', 'you know.' Si te atrapas, haz una pausa — luego continúa. (Unidad 2)",
              },
              {
                tip: "Un marco con nombre. El briefing debe tener una estructura clara que cualquiera pueda seguir. (Unidades 3–5)",
              },
              {
                tip: "Entrega tranquila. Ve un 20% más lento que tu ritmo natural. La brevedad y la quietud señalan autoridad. (Unidad 10)",
              },
            ].map((item) => (
              <div class="flex items-start gap-3 p-5 bg-slate-50 rounded-xl border border-slate-100">
                <CheckCircle2 class="w-5 h-5 text-amber-500 shrink-0 mt-0.5" />
                <p class="text-sm text-slate-700 leading-relaxed">{item.tip}</p>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <!-- Bottom Encouragement -->
  <section class="py-20 md:py-28 bg-slate-950 text-white">
    <div class="site-container mx-auto px-4">
      <div class="max-w-2xl mx-auto text-center">
        <Crown class="w-10 h-10 text-amber-400 mx-auto mb-6" />
        <h2
          class="text-3xl md:text-4xl font-bold mb-6 leading-tight"
          style="font-family: 'Noto Sans KR', sans-serif;"
        >
          Esto no es un examen.<br />
          <span class="text-amber-400">Este es tu momento.</span>
        </h2>
        <p class="text-lg text-slate-300 leading-relaxed">
          Cada ejercicio, cada marco, cada corrección en este curso fue construido
          para esto. Graba tus 90 segundos. Envíalo. Hazlo tuyo.
        </p>
      </div>
    </div>
  </section>

  <script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "LearningResource",
  "name": "Reto Final Ejecutivo — Presentacion de 90 Segundos",
  "description": "Graba una actualizacion ejecutiva de 90 segundos con los marcos que dominaste. Enviala para recibir retroalimentacion personal de Robert, o presentala en vivo.",
  "learningResourceType": "Assessment",
  "educationalLevel": "C1-C2",
  "inLanguage": "es",
  "url": "https://www.nyenglishteacher.com/es/curso/ejecutivo/reto-final/",
  "isAccessibleForFree": true,
  "isPartOf": {
    "@type": "Course",
    "name": "Curso Ejecutivo de Ingles (C1-C2)",
    "url": "https://www.nyenglishteacher.com/es/curso/ejecutivo/"
  }
})} />
</Base>
