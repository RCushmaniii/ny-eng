---
export const prerender = true;

import Base from "@layouts/Base.astro";
import Button from "@components/ui/Button.astro";
import { elementaryInfo, elementaryUnits } from "@data/elementary/units";
import {
  BookOpen,
  Clock,
  Calendar,
  Rocket,
  Scale,
  Hash,
  MessageCircleQuestion,
  Repeat,
  Pause,
  Sparkles,
  ArrowRight,
  MessageCircle,
  Zap,
} from "lucide-astro";

const lang = "es";
const tkey = "course/elementary" as const;

const iconMap: Record<string, any> = {
  BookOpen,
  Clock,
  Calendar,
  Rocket,
  Scale,
  Hash,
  MessageCircleQuestion,
  Repeat,
  Pause,
  Sparkles,
};

const firstAvailableUnit = elementaryUnits.find((u) => u.published);
const firstUnitHref = firstAvailableUnit
  ? `/es/curso/elemental/${firstAvailableUnit.slugEs}/`
  : "/es/curso/principiantes/";
const firstUnitLabel = firstAvailableUnit
  ? `Empezar Unidad ${firstAvailableUnit.id} — Gratis`
  : "Empieza con Primeros Pasos en Inglés";
---

<Base
  lang={lang}
  tkey={tkey}
  title="Curso Elemental de Inglés Gratis A2 | NY English Teacher"
  description="Curso elemental de inglés gratuito de 10 unidades para hispanohablantes A2. Pasado simple, planes futuros, comparativos y preguntas Wh — cuenta tu historia."
>
  <!-- Hero -->
  <section class="relative w-full overflow-hidden bg-gradient-to-br from-slate-900 via-slate-800 to-slate-900 pt-32 pb-20 md:pt-40 md:pb-28">
    <div class="absolute inset-0 opacity-10">
      <div class="absolute top-20 left-10 w-72 h-72 bg-sky-500 rounded-full blur-3xl"></div>
      <div class="absolute bottom-10 right-20 w-96 h-96 bg-cyan-500 rounded-full blur-3xl"></div>
    </div>
    <div class="site-container mx-auto px-4 relative z-10 text-white">
      <div class="max-w-3xl">
        <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-sky-500/20 text-sky-300 text-sm font-semibold mb-6">
          <BookOpen class="w-4 h-4" />
          Curso Gratis — 10 Unidades — Nivel A2 Elemental
        </div>
        <h1
          class="text-4xl md:text-5xl lg:text-6xl font-bold text-white mb-6 leading-tight"
          style="font-family: 'Noto Sans KR', sans-serif;"
        >
          Cuenta Tu Historia.<br />
          <span class="text-sky-400">Pasado, Presente y Futuro.</span>
        </h1>
        <p class="text-xl text-slate-300 mb-8 max-w-2xl leading-relaxed">
          Puedes hablar en presente — pero todavía no puedes hablar de
          <strong class="text-white">ayer</strong>, hacer
          <strong class="text-white">planes para mañana</strong>, ni responder
          más allá de sí o no. Este curso conecta el nivel principiante con el
          intermedio — los bloques que convierten fragmentos en historias completas.
        </p>
        <div class="flex flex-wrap gap-4">
          <Button href={firstUnitHref} variant="primary" size="lg">
            {firstUnitLabel}
            <ArrowRight class="w-5 h-5 ml-1" />
          </Button>
          <a
            href="/es/curso/principiantes/"
            class="inline-flex items-center gap-2 px-6 py-3 rounded-xl border border-white/20 text-white/80 hover:text-white hover:border-white/40 transition-colors text-sm font-medium"
          >
            ¿Necesitas lo básico primero?
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Value props -->
  <section class="py-16 md:py-20 bg-white">
    <div class="site-container mx-auto px-4">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="text-center space-y-3 p-6">
          <div class="inline-flex items-center justify-center w-14 h-14 rounded-2xl bg-sky-100 text-sky-600">
            <Clock class="w-7 h-7" />
          </div>
          <h3 class="text-xl font-bold text-slate-900">Pasado, Futuro y el Día Mismo</h3>
          <p class="text-slate-600 leading-relaxed">
            Pasado simple (regular e irregular), going to y will, y los marcadores de tiempo que hacen aterrizar
            cualquier historia. La gramática que convierte oraciones aisladas en una línea de tiempo real.
          </p>
        </div>
        <div class="text-center space-y-3 p-6">
          <div class="inline-flex items-center justify-center w-14 h-14 rounded-2xl bg-sky-100 text-sky-600">
            <MessageCircle class="w-7 h-7" />
          </div>
          <h3 class="text-xl font-bold text-slate-900">Más Allá del Sí y No</h3>
          <p class="text-slate-600 leading-relaxed">
            Preguntas Wh-, comparativos y cuantificadores — el kit que te lleva de respuestas con "yes" y "no"
            a conversaciones reales sobre tu vida, tus planes y tus opiniones.
          </p>
        </div>
        <div class="text-center space-y-3 p-6">
          <div class="inline-flex items-center justify-center w-14 h-14 rounded-2xl bg-sky-100 text-sky-600">
            <Sparkles class="w-7 h-7" />
          </div>
          <h3 class="text-xl font-bold text-slate-900">Reto Final — Tu Historia Real</h3>
          <p class="text-slate-600 leading-relaxed">
            La Unidad 10 es tu historia: una grabación de 60 segundos sobre tu vida real, combinando todo lo
            aprendido. Envíala y Robert la escucha personalmente.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Course Units -->
  <section class="py-16 md:py-20 bg-slate-50">
    <div class="site-container mx-auto px-4">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold text-slate-900 mb-4">10 Unidades. De Principiante a Narrador.</h2>
        <p class="text-lg text-slate-600 max-w-2xl mx-auto">
          Cada unidad desbloquea una pieza del kit de narración — pasado, planes futuros, comparar,
          hacer preguntas reales — y termina con un reto final que une todo.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4 max-w-4xl mx-auto">
        {elementaryUnits.map((unit) => {
          const Icon = iconMap[unit.icon];
          const isAvailable = unit.published;
          return (
            <a
              href={isAvailable ? `/es/curso/elemental/${unit.slugEs}/` : undefined}
              class:list={[
                "group flex items-start gap-4 p-5 rounded-xl border transition-all duration-200",
                isAvailable
                  ? "bg-sky-50 border-sky-300 hover:shadow-md hover:border-sky-400 cursor-pointer"
                  : "bg-white border-slate-200 opacity-75",
              ]}
            >
              <div
                class:list={[
                  "flex items-center justify-center w-12 h-12 rounded-xl shrink-0",
                  isAvailable ? "bg-sky-500 text-white" : "bg-slate-100 text-slate-400",
                ]}
              >
                {Icon && <Icon class="w-6 h-6" />}
              </div>
              <div>
                <div class="flex items-center gap-2">
                  <span
                    class:list={[
                      "text-xs font-bold uppercase tracking-wider",
                      isAvailable ? "text-sky-600" : "text-slate-400",
                    ]}
                  >
                    Unidad {unit.id}
                  </span>
                  {!isAvailable && (
                    <span class="text-xs px-1.5 py-0.5 rounded bg-slate-100 text-slate-400">
                      Próximamente
                    </span>
                  )}
                </div>
                <h3
                  class:list={[
                    "text-lg font-bold mt-0.5",
                    isAvailable ? "text-slate-900" : "text-slate-600",
                  ]}
                >
                  {unit.titleEs}
                </h3>
                <p class="text-sm text-slate-500 mt-1">{unit.subtitleEs}</p>
                <p class="text-xs text-slate-400 mt-1">{unit.grammarFocusEs}</p>
              </div>
            </a>
          );
        })}
      </div>

      <!-- Final Exam Card -->
      <div class="max-w-4xl mx-auto mt-6">
        <a
          href="/es/curso/elemental/examen/"
          class="flex items-center gap-4 p-5 rounded-xl border-2 border-amber-300 bg-amber-50 hover:shadow-md hover:border-amber-400 transition-all duration-200 cursor-pointer group"
        >
          <div class="flex items-center justify-center w-12 h-12 rounded-xl shrink-0 bg-amber-500 text-white">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <div>
            <span class="text-xs font-bold uppercase tracking-wider text-amber-600">Después de la Unidad 10</span>
            <h3 class="text-lg font-bold text-slate-900 mt-0.5">Examen Final</h3>
            <p class="text-sm text-slate-600 mt-1">20 preguntas que cubren las 10 unidades — pasado, planes futuros, comparativos, cuantificadores, preguntas y rutinas.</p>
          </div>
          <span class="ml-auto text-amber-600 font-semibold text-sm group-hover:translate-x-1 transition-transform">→</span>
        </a>
      </div>
    </div>
  </section>

  <!-- Method explanation -->
  <section class="py-16 md:py-20 bg-white">
    <div class="site-container mx-auto px-4">
      <div class="max-w-3xl mx-auto">
        <h2 class="text-3xl md:text-4xl font-bold text-slate-900 mb-6 text-center">
          La Brecha A2 — y Por Qué Este Curso La Cierra
        </h2>
        <div class="space-y-6 text-lg text-slate-700 leading-relaxed">
          <p>
            Después del curso para principiantes, los hispanohablantes pueden reconocer 1,500 cognados y formar
            oraciones en presente. Pero hay un muro: B1-B2 ("Construyendo Fluidez") salta directo a phrasal verbs
            y condicionales, asumiendo que ya puedes hablar de <em>ayer</em>, hacer planes y hacer preguntas reales.
          </p>
          <p>
            <strong>Cuenta Tu Historia</strong> llena esa brecha. Pasado simple (regular e irregular), going to + will,
            comparativos, cuantificadores, preguntas Wh-, adverbios de frecuencia y pasado continuo — practicados hasta
            que cada uno se vuelve automático. Para la Unidad 10, grabas una historia de 60 segundos sobre tu vida real.
          </p>
          <p>
            Y porque conocemos los errores <em>específicos</em> que cometen los hispanohablantes en A2 (decir "more better"
            en lugar de "better", colocar "always" en el lugar equivocado, confundir "much" y "many"), cada unidad
            corrige esos errores directamente.
          </p>
        </div>
        <div class="mt-10 text-center">
          <Button href={firstUnitHref} variant="primary" size="lg">
            {firstUnitLabel}
            <ArrowRight class="w-5 h-5 ml-1" />
          </Button>
        </div>
      </div>
    </div>
  </section>

  <!-- Prerequisites / Level check -->
  <section class="py-16 md:py-20 bg-slate-50">
    <div class="site-container mx-auto px-4">
      <div class="max-w-3xl mx-auto text-center">
        <h2 class="text-2xl font-bold text-slate-900 mb-4">¿Es Este Curso Para Ti?</h2>
        <p class="text-lg text-slate-600 leading-relaxed mb-6">
          Este curso está diseñado para hispanohablantes de nivel <strong>A2 / Elemental</strong> — puedes sostener
          conversaciones básicas en presente pero te bloqueas cuando el tema cambia a ayer, mañana, o cualquier
          cosa que requiera respuestas detalladas.
        </p>
        <div class="flex flex-wrap gap-3 justify-center">
          <a
            href="/es/curso/principiantes/"
            class="text-sky-600 hover:text-sky-700 font-medium underline underline-offset-2"
          >
            ¿Necesitas lo básico? Empieza con Primeros Pasos
          </a>
          <span class="text-slate-300">|</span>
          <a
            href="/es/curso/intermedio/"
            class="text-sky-600 hover:text-sky-700 font-medium underline underline-offset-2"
          >
            ¿Ya pasaste el A2? Salta a Construyendo Fluidez
          </a>
        </div>
      </div>
    </div>
  </section>

  <script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Course",
  "name": "Curso Elemental de Ingles Gratis (A2)",
  "description": "Curso elemental de ingles gratuito de 10 unidades para hispanohablantes A2. Pasado simple, planes futuros, comparativos y preguntas Wh - cuenta tu historia.",
  "provider": {
    "@type": "Person",
    "name": "Robert Cushman",
    "url": "https://www.nyenglishteacher.com/es/about/"
  },
  "educationalLevel": "Elementary (A2)",
  "inLanguage": "es",
  "url": "https://www.nyenglishteacher.com/es/curso/elemental/",
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "USD",
    "availability": "https://schema.org/InStock"
  }
})} />
</Base>
