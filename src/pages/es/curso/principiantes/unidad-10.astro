---
export const prerender = true;

import Base from "@layouts/Base.astro";
import CourseProgress from "@components/course/CourseProgress";
import CognateDiscovery from "@components/course/CognateDiscovery";
import SentenceBuilder from "@components/course/SentenceBuilder";
import PronunciationDrill from "@components/course/PronunciationDrill";
import ConnectorChallenge from "@components/course/ConnectorChallenge";
import SelfTest from "@components/course/SelfTest";
import { units } from "@data/course/units";
import {
  cognateWaves,
  sentenceBlocks,
  powerVerbBlocks,
  connectorSentences,
  pronunciationDrills,
  vocabularyList,
} from "@data/course/unit-10";
import {
  ArrowLeft,
  Rocket,
  Layers,
  Zap,
  Link2,
  Volume2,
  ClipboardCheck,
} from "lucide-astro";

const lang = "es";
const tkey = "course/beginners/unit-10" as const;

const progressUnits = units.map((u) => ({
  id: u.id,
  slug: u.slugEs,
  title: u.title,
  titleEs: u.titleEs,
}));

const waveData = [cognateWaves.wave1, cognateWaves.wave2, cognateWaves.wave3];
---

<Base
  lang={lang}
  tkey={tkey}
  title="Unidad 10: Lo Que Viene | NY English Teacher"
  description="El final del curso: futuro con 'going to', pedir significados y habla conectada en inglés. Lección gratuita para hispanohablantes que terminan el nivel básico."
>
  <CourseProgress
    client:load
    units={progressUnits}
    currentUnit={10}
    basePath="/es/curso/principiantes"
    lang="es"
  />

  <section class="bg-gradient-to-b from-slate-900 to-slate-800 pt-28 pb-16 md:pt-36 md:pb-20">
    <div class="site-container mx-auto px-4 text-white">
      <div class="max-w-3xl">
        <div class="flex items-center gap-2 text-amber-400 text-sm font-semibold mb-3">
          <Rocket class="w-4 h-4" />
          Unidad 10 — El Final
        </div>
        <h1 class="text-3xl md:text-5xl font-bold text-white mb-4 leading-tight" style="font-family: 'Noto Sans KR', sans-serif;">
          Lo Que Viene
        </h1>
        <p class="text-lg text-slate-300 max-w-2xl leading-relaxed">
          La unidad final. Habla del futuro con "going to." Pregunta qué significan las cosas.
          Desbloquea el habla conectada — el secreto para sonar natural. Y celebra las más de 1,500 palabras
          que siempre llevaste dentro.
        </p>
      </div>
    </div>
  </section>

  <nav class="bg-white border-b border-slate-200 sticky top-[52px] z-30 overflow-x-auto">
    <div class="site-container mx-auto px-4">
      <div class="flex items-center gap-1 py-2 text-sm whitespace-nowrap">
        <a href="#cognados" class="px-3 py-1.5 rounded-full hover:bg-amber-50 text-slate-600 hover:text-amber-600 transition-colors flex items-center gap-1.5">
          <Rocket class="w-3.5 h-3.5" /> Gran Repaso
        </a>
        <a href="#oraciones" class="px-3 py-1.5 rounded-full hover:bg-amber-50 text-slate-600 hover:text-amber-600 transition-colors flex items-center gap-1.5">
          <Layers class="w-3.5 h-3.5" /> Going To / Significado
        </a>
        <a href="#verbos" class="px-3 py-1.5 rounded-full hover:bg-amber-50 text-slate-600 hover:text-amber-600 transition-colors flex items-center gap-1.5">
          <Zap class="w-3.5 h-3.5" /> Kit Completo
        </a>
        <a href="#conectores" class="px-3 py-1.5 rounded-full hover:bg-amber-50 text-slate-600 hover:text-amber-600 transition-colors flex items-center gap-1.5">
          <Link2 class="w-3.5 h-3.5" /> Palabras Finales
        </a>
        <a href="#pronunciacion" class="px-3 py-1.5 rounded-full hover:bg-amber-50 text-slate-600 hover:text-amber-600 transition-colors flex items-center gap-1.5">
          <Volume2 class="w-3.5 h-3.5" /> Pronunciación
        </a>
        <a href="#auto-evaluacion" class="px-3 py-1.5 rounded-full hover:bg-amber-50 text-slate-600 hover:text-amber-600 transition-colors flex items-center gap-1.5">
          <ClipboardCheck class="w-3.5 h-3.5" /> Auto-Evaluación
        </a>
      </div>
    </div>
  </nav>

  <section id="cognados" class="py-12 md:py-16 bg-slate-50">
    <div class="site-container mx-auto px-4">
      <div class="max-w-3xl mx-auto">
        <div class="mb-8">
          <div class="flex items-center gap-2 text-amber-600 text-sm font-semibold mb-2">
            <Rocket class="w-4 h-4" />
            Sección A
          </div>
          <h2 class="text-2xl md:text-3xl font-bold text-slate-900 mb-3">La Explosión de Vocabulario de 1,500 Palabras</h2>
          <p class="text-lg text-slate-600 leading-relaxed">
            Este es el gran final. Has aprendido 18 patrones de cognados a lo largo de 10 unidades.
            Cada patrón desbloquea docenas — a veces cientos — de palabras.
            Nunca fuiste principiante. Solo no lo sabías todavía.
          </p>
        </div>
        <CognateDiscovery client:visible waves={waveData} lang="es" />
      </div>
    </div>
  </section>

  <section id="oraciones" class="py-12 md:py-16 bg-white">
    <div class="site-container mx-auto px-4">
      <div class="max-w-3xl mx-auto">
        <div class="mb-8">
          <div class="flex items-center gap-2 text-amber-600 text-sm font-semibold mb-2">
            <Layers class="w-4 h-4" />
            Sección B
          </div>
          <h2 class="text-2xl md:text-3xl font-bold text-slate-900 mb-3">Going To / What Does It Mean?</h2>
          <p class="text-lg text-slate-600 leading-relaxed">
            Dos superpoderes finales: <strong>"going to"</strong> para el futuro (voy a),
            y <strong>"what does it mean?"</strong> — la pregunta más importante que un estudiante puede hacer.
            Con estas, tienes pasado, presente y futuro cubiertos.
          </p>
        </div>
        <SentenceBuilder client:visible blocks={sentenceBlocks} lang="es" />
      </div>
    </div>
  </section>

  <section id="verbos" class="py-12 md:py-16 bg-slate-50">
    <div class="site-container mx-auto px-4">
      <div class="max-w-3xl mx-auto">
        <div class="mb-8">
          <div class="flex items-center gap-2 text-amber-600 text-sm font-semibold mb-2">
            <Zap class="w-4 h-4" />
            Sección C
          </div>
          <h2 class="text-2xl md:text-3xl font-bold text-slate-900 mb-3">Juntando Todo</h2>
          <p class="text-lg text-slate-600 leading-relaxed">
            Cada estructura de 10 unidades, combinada. Pasado + presente + futuro. Todos los verbos modales.
            Escenarios del mundo real. Así se ve la fluidez conversacional.
          </p>
        </div>
        <SentenceBuilder client:visible blocks={powerVerbBlocks} lang="es" />
      </div>
    </div>
  </section>

  <section id="conectores" class="py-12 md:py-16 bg-white">
    <div class="site-container mx-auto px-4">
      <div class="max-w-3xl mx-auto">
        <div class="mb-8">
          <div class="flex items-center gap-2 text-amber-600 text-sm font-semibold mb-2">
            <Link2 class="w-4 h-4" />
            Sección D
          </div>
          <h2 class="text-2xl md:text-3xl font-bold text-slate-900 mb-3">El Panorama Completo</h2>
          <p class="text-lg text-slate-600 leading-relaxed">
            El último conjunto de conectores — significado, tiempo, ayuda, sucesos y preparación. Tu kit está completo.
          </p>
        </div>
        <ConnectorChallenge
          client:visible
          connectors={connectorSentences.connectors}
          bossSentence={connectorSentences.bossSentence}
          lang="es"
        />
      </div>
    </div>
  </section>

  <section id="pronunciacion" class="py-12 md:py-16 bg-slate-50">
    <div class="site-container mx-auto px-4">
      <div class="max-w-3xl mx-auto">
        <div class="mb-8">
          <div class="flex items-center gap-2 text-rose-500 text-sm font-semibold mb-2">
            <Volume2 class="w-4 h-4" />
            Laboratorio de Pronunciación
          </div>
          <h2 class="text-2xl md:text-3xl font-bold text-slate-900 mb-3">Habla Conectada — Suena Como un Nativo</h2>
          <p class="text-lg text-slate-600 leading-relaxed">
            El último secreto de pronunciación: los hablantes nativos no dicen cada palabra por separado.
            "Going to" se convierte en "gonna." "Want to" se convierte en "wanna." Las palabras se enlazan y fluyen.
            Domina esto, y entenderás — y te entenderán — a velocidad completa.
          </p>
        </div>
        <PronunciationDrill client:visible drills={pronunciationDrills} lang="es" />
      </div>
    </div>
  </section>

  <section id="auto-evaluacion" class="py-12 md:py-16 bg-white">
    <div class="site-container mx-auto px-4">
      <div class="max-w-3xl mx-auto">
        <div class="mb-8">
          <div class="flex items-center gap-2 text-amber-600 text-sm font-semibold mb-2">
            <ClipboardCheck class="w-4 h-4" />
            Auto-Evaluación
          </div>
          <h2 class="text-2xl md:text-3xl font-bold text-slate-900 mb-3">La Prueba Final</h2>
          <p class="text-lg text-slate-600 leading-relaxed">
            Tiempo futuro, preguntas de significado, habla conectada y un gran repaso de todo de las Unidades 1-10.
          </p>
        </div>
        <SelfTest client:visible vocabulary={vocabularyList} lang="es" />
      </div>
    </div>
  </section>

  <!-- ─── Course Completion Celebration ──────────────────────────────────── -->
  <section class="py-16 md:py-24 bg-gradient-to-b from-amber-500 to-amber-600">
    <div class="site-container mx-auto px-4 text-white">
      <div class="max-w-2xl mx-auto text-center space-y-6">
        <div class="inline-flex items-center justify-center w-20 h-20 rounded-full bg-white/20 text-white">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z" />
          </svg>
        </div>
        <h2 class="text-4xl md:text-5xl font-bold text-white" style="font-family: 'Noto Sans KR', sans-serif;">
          ¡Felicitaciones!
        </h2>
        <p class="text-xl text-amber-100 leading-relaxed">
          Completaste <strong>Primeros Pasos en Inglés</strong> — las 10 unidades.
        </p>
        <div class="bg-white/10 rounded-2xl p-6 md:p-8 text-left space-y-4">
          <h3 class="text-lg font-semibold text-white text-center">Esto es lo que ahora puedes hacer en inglés:</h3>
          <ul class="space-y-2 text-amber-100">
            <li class="flex items-start gap-2"><span class="text-white font-bold mt-0.5">1,500+</span> palabras que reconoces al instante desde el español</li>
            <li class="flex items-start gap-2"><span class="text-white font-bold mt-0.5">11</span> estructuras de verbos modales (can, want, need, have to, should, would like, feel like, wonder, just, used to, going to)</li>
            <li class="flex items-start gap-2"><span class="text-white font-bold mt-0.5">Todos</span> los pronombres: I, you, he, she, we, they, everyone, someone, nobody</li>
            <li class="flex items-start gap-2"><span class="text-white font-bold mt-0.5">3</span> marcos temporales: pasado (was/used to), presente (can/want), futuro (going to)</li>
            <li class="flex items-start gap-2"><span class="text-white font-bold mt-0.5">10</span> habilidades de pronunciación enfocadas en desafíos de hispanohablantes</li>
          </ul>
        </div>
        <p class="text-lg text-amber-100">
          Nunca fuiste principiante. Solo no lo sabías todavía.
        </p>
      </div>
    </div>
  </section>

  <section class="py-16 md:py-20 bg-gradient-to-b from-slate-900 to-slate-800">
    <div class="site-container mx-auto px-4 text-white">
      <div class="max-w-2xl mx-auto text-center space-y-6">
        <h2 class="text-2xl md:text-3xl font-bold text-white">¿Qué Sigue?</h2>
        <p class="text-lg text-slate-300 leading-relaxed">
          Este curso te dio la base. Ahora es hora de construir sobre ella — con conversaciones reales,
          inglés profesional y coaching personalizado.
        </p>
        <div class="flex flex-wrap gap-4 justify-center pt-4">
          <a href="/es/curso/principiantes/unidad-9/" class="inline-flex items-center gap-2 px-6 py-3 rounded-xl bg-slate-700 text-slate-300 font-medium hover:bg-slate-600 transition-colors">
            <ArrowLeft class="w-4 h-4" /> Repasar Unidad 9
          </a>
          <a href="/es/curso/principiantes/examen/" class="inline-flex items-center gap-2 px-6 py-3 rounded-xl bg-amber-500 text-white font-semibold hover:bg-amber-400 transition-colors shadow-lg">
            Tomar el Examen Final
          </a>
        </div>
        <div class="flex flex-wrap gap-4 justify-center">
          <a href="/es/curso/principiantes/" class="text-amber-400 hover:text-amber-300 font-medium underline underline-offset-2">
            Volver al Curso
          </a>
          <span class="text-slate-600">|</span>
          <a href="/es/servicios/" class="text-amber-400 hover:text-amber-300 font-medium underline underline-offset-2">
            Ver Servicios de Coaching
          </a>
        </div>
      </div>
    </div>
  </section>
</Base>
