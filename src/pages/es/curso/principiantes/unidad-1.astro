---
export const prerender = true;

import Base from "@layouts/Base.astro";
import CourseProgress from "@components/course/CourseProgress";
import CognateDiscovery from "@components/course/CognateDiscovery";
import SentenceBuilder from "@components/course/SentenceBuilder";
import PronunciationDrill from "@components/course/PronunciationDrill";
import ConnectorChallenge from "@components/course/ConnectorChallenge";
import SelfTest from "@components/course/SelfTest";
import { units } from "@data/course/units";
import {
  cognateWaves,
  sentenceBlocks,
  powerVerbBlocks,
  connectorSentences,
  pronunciationDrills,
  vocabularyList,
} from "@data/course/unit-1";
import {
  ArrowRight,
  Lightbulb,
  Layers,
  Zap,
  Link2,
  Volume2,
  ClipboardCheck,
  BookOpen,
} from "lucide-astro";

const lang = "es";
const tkey = "course/beginners/unit-1" as const;

const progressUnits = units.map((u) => ({
  id: u.id,
  slug: u.slugEs,
  title: u.title,
  titleEs: u.titleEs,
}));

const waveData = [cognateWaves.wave1, cognateWaves.wave2, cognateWaves.wave3];
---

<Base
  lang={lang}
  tkey={tkey}
  title="Unidad 1: Ya Sabes Inglés | NY English Teacher"
  description="Descubre las 100+ palabras en inglés escondidas en tu español. Construye tus primeras oraciones — desde 'It is possible' a estructuras complejas. Gratis."
>
  <!-- Course progress bar -->
  <CourseProgress
    client:load
    units={progressUnits}
    currentUnit={1}
    basePath="/es/curso/principiantes"
    lang="es"
  />

  <!-- Unit hero -->
  <section class="bg-gradient-to-b from-slate-900 to-slate-800 pt-28 pb-16 md:pt-36 md:pb-20">
    <div class="site-container mx-auto px-4 text-white">
      <div class="max-w-3xl">
        <div class="flex items-center gap-2 text-amber-400 text-sm font-semibold mb-3">
          <Lightbulb class="w-4 h-4" />
          Unidad 1
        </div>
        <h1
          class="text-3xl md:text-5xl font-bold text-white mb-4 leading-tight"
          style="font-family: 'Noto Sans KR', sans-serif;"
        >
          Ya Sabes Inglés
        </h1>
        <p class="text-lg text-slate-300 max-w-2xl leading-relaxed">
          Ahora mismo, sabes más inglés de lo que crees. Vamos a demostrarlo. Vamos a descubrir los
          cientos de palabras en inglés escondidas dentro de tu español — y luego construir oraciones reales con ellas.
        </p>
      </div>
    </div>
  </section>

  <!-- Table of contents / section nav -->
  <nav class="bg-white border-b border-slate-200 sticky top-[52px] z-30 overflow-x-auto">
    <div class="site-container mx-auto px-4">
      <div class="flex items-center gap-1 py-2 text-sm whitespace-nowrap">
        <a href="#cognados" class="px-3 py-1.5 rounded-full hover:bg-amber-50 text-slate-600 hover:text-amber-600 transition-colors flex items-center gap-1.5">
          <Lightbulb class="w-3.5 h-3.5" /> Cognados
        </a>
        <a href="#oraciones" class="px-3 py-1.5 rounded-full hover:bg-amber-50 text-slate-600 hover:text-amber-600 transition-colors flex items-center gap-1.5">
          <Layers class="w-3.5 h-3.5" /> Oraciones
        </a>
        <a href="#verbos" class="px-3 py-1.5 rounded-full hover:bg-amber-50 text-slate-600 hover:text-amber-600 transition-colors flex items-center gap-1.5">
          <Zap class="w-3.5 h-3.5" /> Verbos
        </a>
        <a href="#conectores" class="px-3 py-1.5 rounded-full hover:bg-amber-50 text-slate-600 hover:text-amber-600 transition-colors flex items-center gap-1.5">
          <Link2 class="w-3.5 h-3.5" /> Conectores
        </a>
        <a href="#pronunciacion" class="px-3 py-1.5 rounded-full hover:bg-amber-50 text-slate-600 hover:text-amber-600 transition-colors flex items-center gap-1.5">
          <Volume2 class="w-3.5 h-3.5" /> Pronunciación
        </a>
        <a href="#auto-evaluacion" class="px-3 py-1.5 rounded-full hover:bg-amber-50 text-slate-600 hover:text-amber-600 transition-colors flex items-center gap-1.5">
          <ClipboardCheck class="w-3.5 h-3.5" /> Auto-Evaluación
        </a>
      </div>
    </div>
  </nav>

  <!-- Section A: Cognate Discovery -->
  <section id="cognados" class="py-12 md:py-16 bg-slate-50">
    <div class="site-container mx-auto px-4">
      <div class="max-w-3xl mx-auto">
        <div class="mb-8">
          <div class="flex items-center gap-2 text-amber-600 text-sm font-semibold mb-2">
            <Lightbulb class="w-4 h-4" />
            Sección A
          </div>
          <h2 class="text-2xl md:text-3xl font-bold text-slate-900 mb-3">
            Las Palabras que Ya Conoces
          </h2>
          <p class="text-lg text-slate-600 leading-relaxed">
            Toca cualquier palabra para ver su equivalente en español. Te sorprenderá cuántas reconoces.
            Presiona el ícono de altavoz para escuchar la pronunciación en inglés.
          </p>
        </div>
        <CognateDiscovery client:visible waves={waveData} lang="es" />
      </div>
    </div>
  </section>

  <!-- Section B: First Sentences -->
  <section id="oraciones" class="py-12 md:py-16 bg-white">
    <div class="site-container mx-auto px-4">
      <div class="max-w-3xl mx-auto">
        <div class="mb-8">
          <div class="flex items-center gap-2 text-amber-600 text-sm font-semibold mb-2">
            <Layers class="w-4 h-4" />
            Sección B
          </div>
          <h2 class="text-2xl md:text-3xl font-bold text-slate-900 mb-3">
            Tus Primeras Oraciones
          </h2>
          <p class="text-lg text-slate-600 leading-relaxed">
            Construimos oraciones como bloques apilados. Cada paso agrega un nuevo elemento.
            Escucha cada oración, luego intenta decirla tú mismo antes de continuar.
          </p>
        </div>
        <SentenceBuilder client:visible blocks={sentenceBlocks} lang="es" />
      </div>
    </div>
  </section>

  <!-- Section C: Power Verbs -->
  <section id="verbos" class="py-12 md:py-16 bg-slate-50">
    <div class="site-container mx-auto px-4">
      <div class="max-w-3xl mx-auto">
        <div class="mb-8">
          <div class="flex items-center gap-2 text-amber-600 text-sm font-semibold mb-2">
            <Zap class="w-4 h-4" />
            Sección C
          </div>
          <h2 class="text-2xl md:text-3xl font-bold text-slate-900 mb-3">
            Cuatro Verbos Poderosos
          </h2>
          <p class="text-lg text-slate-600 leading-relaxed">
            Con solo cuatro verbos modales — <strong>I need</strong>, <strong>I want</strong>,
            <strong> I have to</strong>, y <strong>I can</strong> — puedes expresar casi
            cualquier cosa. Cada uno sigue el mismo patrón simple.
          </p>
        </div>
        <SentenceBuilder client:visible blocks={powerVerbBlocks} lang="es" />
      </div>
    </div>
  </section>

  <!-- Section D: Connectors -->
  <section id="conectores" class="py-12 md:py-16 bg-white">
    <div class="site-container mx-auto px-4">
      <div class="max-w-3xl mx-auto">
        <div class="mb-8">
          <div class="flex items-center gap-2 text-amber-600 text-sm font-semibold mb-2">
            <Link2 class="w-4 h-4" />
            Sección D
          </div>
          <h2 class="text-2xl md:text-3xl font-bold text-slate-900 mb-3">
            Conecta Tus Ideas
          </h2>
          <p class="text-lg text-slate-600 leading-relaxed">
            Cinco pequeñas palabras que transforman oraciones simples en habla compleja y natural.
            Toca cada conector para verlo en acción — luego intenta la Oración Maestra.
          </p>
        </div>
        <ConnectorChallenge
          client:visible
          connectors={connectorSentences.connectors}
          bossSentence={connectorSentences.bossSentence}
          lang="es"
        />
      </div>
    </div>
  </section>

  <!-- Section E: Pronunciation Lab -->
  <section id="pronunciacion" class="py-12 md:py-16 bg-slate-50">
    <div class="site-container mx-auto px-4">
      <div class="max-w-3xl mx-auto">
        <div class="mb-8">
          <div class="flex items-center gap-2 text-rose-500 text-sm font-semibold mb-2">
            <Volume2 class="w-4 h-4" />
            Laboratorio de Pronunciación
          </div>
          <h2 class="text-2xl md:text-3xl font-bold text-slate-900 mb-3">
            Acentuación — La Diferencia #1
          </h2>
          <p class="text-lg text-slate-600 leading-relaxed">
            Los hispanohablantes frecuentemente acentúan los cognados a la manera española. Esta sección practica los patrones
            correctos de acentuación en inglés. Presta atención a qué sílaba recibe el énfasis.
          </p>
        </div>
        <PronunciationDrill client:visible drills={pronunciationDrills} lang="es" />
      </div>
    </div>
  </section>

  <!-- Section F: Self-Test -->
  <section id="auto-evaluacion" class="py-12 md:py-16 bg-white">
    <div class="site-container mx-auto px-4">
      <div class="max-w-3xl mx-auto">
        <div class="mb-8">
          <div class="flex items-center gap-2 text-amber-600 text-sm font-semibold mb-2">
            <ClipboardCheck class="w-4 h-4" />
            Auto-Evaluación
          </div>
          <h2 class="text-2xl md:text-3xl font-bold text-slate-900 mb-3">
            Evalúa Lo que Aprendiste
          </h2>
          <p class="text-lg text-slate-600 leading-relaxed">
            Repaso estilo tarjetas de todo lo de la Unidad 1. Cambia entre los modos Español→Inglés
            e Inglés→Español. Sé honesto contigo mismo — marca lo que realmente sabías.
          </p>
        </div>
        <SelfTest client:visible vocabulary={vocabularyList} lang="es" />
      </div>
    </div>
  </section>

  <!-- Unit complete CTA -->
  <section class="py-16 md:py-20 bg-gradient-to-b from-slate-900 to-slate-800">
    <div class="site-container mx-auto px-4 text-white">
      <div class="max-w-2xl mx-auto text-center space-y-6">
        <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-emerald-500/20 text-emerald-400">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
          </svg>
        </div>
        <h2 class="text-3xl font-bold text-white">¡Unidad 1 Completada!</h2>
        <p class="text-lg text-slate-100 leading-relaxed">
          Acabas de descubrir que ya conoces cientos de palabras en inglés, construiste oraciones complejas,
          y aprendiste cuatro verbos modales poderosos. Eso no es nivel principiante — eso es inglés real.
        </p>
        <div class="flex flex-wrap gap-4 justify-center pt-4">
          <a
            href="/es/curso/principiantes/"
            class="inline-flex items-center gap-2 px-6 py-3 rounded-xl bg-slate-700 text-slate-300 font-medium hover:bg-slate-600 transition-colors"
          >
            Vista del Curso
          </a>
          <a
            href="/es/curso/principiantes/unidad-2/"
            class="inline-flex items-center gap-2 px-6 py-3 rounded-xl bg-amber-500 text-white font-semibold hover:bg-amber-400 transition-colors shadow-lg"
          >
            Continuar a Unidad 2 →
          </a>
        </div>
        <div class="pt-8 border-t border-slate-700 mt-8">
          <p class="text-slate-200 text-sm mb-3">
            ¿Quieres coaching personalizado de inglés?
          </p>
          <a
            href="/es/contact/"
            class="text-amber-400 hover:text-amber-300 font-medium underline underline-offset-2"
          >
            Agenda una consulta gratuita con Robert →
          </a>
        </div>
      </div>
    </div>
  </section>
</Base>
