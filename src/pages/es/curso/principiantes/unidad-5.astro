---
export const prerender = true;

import Base from "@layouts/Base.astro";
import CourseProgress from "@components/course/CourseProgress";
import CognateDiscovery from "@components/course/CognateDiscovery";
import SentenceBuilder from "@components/course/SentenceBuilder";
import PronunciationDrill from "@components/course/PronunciationDrill";
import ConnectorChallenge from "@components/course/ConnectorChallenge";
import SelfTest from "@components/course/SelfTest";
import { units } from "@data/course/units";
import {
  cognateWaves,
  sentenceBlocks,
  powerVerbBlocks,
  connectorSentences,
  pronunciationDrills,
  vocabularyList,
} from "@data/course/unit-5";
import {
  ArrowLeft,
  ArrowRight,
  Clock,
  Layers,
  Zap,
  Link2,
  Volume2,
  ClipboardCheck,
} from "lucide-astro";

const lang = "es";
const tkey = "course/beginners/unit-5" as const;

const progressUnits = units.map((u) => ({
  id: u.id,
  slug: u.slugEs,
  title: u.title,
  titleEs: u.titleEs,
}));

const waveData = [cognateWaves.wave1, cognateWaves.wave2, cognateWaves.wave3];
---

<Base
  lang={lang}
  tkey={tkey}
  title="Unidad 5: Lo Que Acaba de Pasar | NY English Teacher"
  description="Aprende a hablar de eventos recientes en inglés con 'just': I just ate, she just told me, he just found out. Pronunciación del pasado -ed. Lección gratuita."
>
  <CourseProgress
    client:load
    units={progressUnits}
    currentUnit={5}
    basePath="/es/curso/principiantes"
    lang="es"
  />

  <section class="bg-gradient-to-b from-slate-900 to-slate-800 pt-8 pb-16 md:pt-12 md:pb-20">
    <div class="site-container mx-auto px-4 text-white">
      <div class="max-w-3xl">
        <div class="flex items-center gap-2 text-amber-400 text-sm font-semibold mb-3">
          <Clock class="w-4 h-4" />
          Unidad 5
        </div>
        <h1 class="text-3xl md:text-5xl font-bold text-white mb-4 leading-tight" style="font-family: 'Noto Sans KR', sans-serif;">
          Lo Que Acaba de Pasar
        </h1>
        <p class="text-lg text-slate-300 max-w-2xl leading-relaxed">
          Algo acaba de pasar y necesitas hablar de ello. Aprenderás a narrar eventos recientes —
          descubrimientos, llegadas, conversaciones — usando la poderosa palabra "just."
        </p>
      </div>
    </div>
  </section>

  <nav class="bg-white border-b border-slate-200 sticky top-[52px] z-30 overflow-x-auto">
    <div class="site-container mx-auto px-4">
      <div class="flex items-center gap-1 py-2 text-sm whitespace-nowrap">
        <a href="#cognados" class="px-3 py-1.5 rounded-full hover:bg-amber-50 text-slate-600 hover:text-amber-600 transition-colors flex items-center gap-1.5">
          <Clock class="w-3.5 h-3.5" /> Cognados
        </a>
        <a href="#oraciones" class="px-3 py-1.5 rounded-full hover:bg-amber-50 text-slate-600 hover:text-amber-600 transition-colors flex items-center gap-1.5">
          <Layers class="w-3.5 h-3.5" /> Acabo de / Acaba de
        </a>
        <a href="#verbos" class="px-3 py-1.5 rounded-full hover:bg-amber-50 text-slate-600 hover:text-amber-600 transition-colors flex items-center gap-1.5">
          <Zap class="w-3.5 h-3.5" /> Verbos en Pasado
        </a>
        <a href="#conectores" class="px-3 py-1.5 rounded-full hover:bg-amber-50 text-slate-600 hover:text-amber-600 transition-colors flex items-center gap-1.5">
          <Link2 class="w-3.5 h-3.5" /> Eventos Recientes
        </a>
        <a href="#pronunciacion" class="px-3 py-1.5 rounded-full hover:bg-amber-50 text-slate-600 hover:text-amber-600 transition-colors flex items-center gap-1.5">
          <Volume2 class="w-3.5 h-3.5" /> Pronunciación
        </a>
        <a href="#auto-evaluacion" class="px-3 py-1.5 rounded-full hover:bg-amber-50 text-slate-600 hover:text-amber-600 transition-colors flex items-center gap-1.5">
          <ClipboardCheck class="w-3.5 h-3.5" /> Auto-Evaluación
        </a>
      </div>
    </div>
  </nav>

  <section id="cognados" class="py-12 md:py-16 bg-slate-50">
    <div class="site-container mx-auto px-4">
      <div class="max-w-3xl mx-auto">
        <div class="mb-8">
          <div class="flex items-center gap-2 text-amber-600 text-sm font-semibold mb-2">
            <Clock class="w-4 h-4" />
            Sección A
          </div>
          <h2 class="text-2xl md:text-3xl font-bold text-slate-900 mb-3">Tres Nuevos Patrones Poderosos</h2>
          <p class="text-lg text-slate-600 leading-relaxed">
            El patrón -sion (decisión, televisión), el patrón -ive (positivo, creativo), y el patrón -ous (famoso, curioso).
            A estas alturas reconoces palabras en inglés en todas partes.
          </p>
        </div>
        <CognateDiscovery client:visible waves={waveData} lang="es" />
      </div>
    </div>
  </section>

  <section id="oraciones" class="py-12 md:py-16 bg-white">
    <div class="site-container mx-auto px-4">
      <div class="max-w-3xl mx-auto">
        <div class="mb-8">
          <div class="flex items-center gap-2 text-amber-600 text-sm font-semibold mb-2">
            <Layers class="w-4 h-4" />
            Sección B
          </div>
          <h2 class="text-2xl md:text-3xl font-bold text-slate-900 mb-3">I Just / He Just / She Just</h2>
          <p class="text-lg text-slate-600 leading-relaxed">
            "Just" es tu clave para hablar del pasado reciente. <strong>I just ate</strong> = acabo de comer.
            <strong>She just told me</strong> = ella me acaba de decir. Simple, poderoso, y se usa constantemente en inglés real.
          </p>
        </div>
        <SentenceBuilder client:visible blocks={sentenceBlocks} lang="es" />
      </div>
    </div>
  </section>

  <section id="verbos" class="py-12 md:py-16 bg-slate-50">
    <div class="site-container mx-auto px-4">
      <div class="max-w-3xl mx-auto">
        <div class="mb-8">
          <div class="flex items-center gap-2 text-amber-600 text-sm font-semibold mb-2">
            <Zap class="w-4 h-4" />
            Sección C
          </div>
          <h2 class="text-2xl md:text-3xl font-bold text-slate-900 mb-3">Find Out / Arrive / See / Leave</h2>
          <p class="text-lg text-slate-600 leading-relaxed">
            Cuatro verbos esenciales para narrar eventos. Aprende sus formas en pasado (found out, arrived, saw, left)
            y combínalos con "just" para contar historias sobre lo que pasó recientemente.
          </p>
        </div>
        <SentenceBuilder client:visible blocks={powerVerbBlocks} lang="es" />
      </div>
    </div>
  </section>

  <section id="conectores" class="py-12 md:py-16 bg-white">
    <div class="site-container mx-auto px-4">
      <div class="max-w-3xl mx-auto">
        <div class="mb-8">
          <div class="flex items-center gap-2 text-amber-600 text-sm font-semibold mb-2">
            <Link2 class="w-4 h-4" />
            Sección D
          </div>
          <h2 class="text-2xl md:text-3xl font-bold text-slate-900 mb-3">Narrando Eventos Recientes</h2>
          <p class="text-lg text-slate-600 leading-relaxed">
            Palabras que te permiten ambientar la escena — about, the problem, the house, at the party, with him, all day.
          </p>
        </div>
        <ConnectorChallenge
          client:visible
          connectors={connectorSentences.connectors}
          bossSentence={connectorSentences.bossSentence}
          lang="es"
        />
      </div>
    </div>
  </section>

  <section id="pronunciacion" class="py-12 md:py-16 bg-slate-50">
    <div class="site-container mx-auto px-4">
      <div class="max-w-3xl mx-auto">
        <div class="mb-8">
          <div class="flex items-center gap-2 text-rose-500 text-sm font-semibold mb-2">
            <Volume2 class="w-4 h-4" />
            Laboratorio de Pronunciación
          </div>
          <h2 class="text-2xl md:text-3xl font-bold text-slate-900 mb-3">Los Tres Sonidos de -ed</h2>
          <p class="text-lg text-slate-600 leading-relaxed">
            Los hispanohablantes frecuentemente agregan una sílaba extra a las palabras en pasado: "work-ED" en vez de "WERKT."
            La verdad es que -ed tiene tres pronunciaciones diferentes: /t/, /d/ y /ɪd/. Una vez que aprendas la regla,
            nunca más te equivocarás.
          </p>
        </div>
        <PronunciationDrill client:visible drills={pronunciationDrills} lang="es" />
      </div>
    </div>
  </section>

  <section id="auto-evaluacion" class="py-12 md:py-16 bg-white">
    <div class="site-container mx-auto px-4">
      <div class="max-w-3xl mx-auto">
        <div class="mb-8">
          <div class="flex items-center gap-2 text-amber-600 text-sm font-semibold mb-2">
            <ClipboardCheck class="w-4 h-4" />
            Auto-Evaluación
          </div>
          <h2 class="text-2xl md:text-3xl font-bold text-slate-900 mb-3">Evalúa Lo que Aprendiste</h2>
          <p class="text-lg text-slate-600 leading-relaxed">
            Construcciones con "just", verbos en pasado y vocabulario de eventos recientes — más repaso de las Unidades 1-4.
          </p>
        </div>
        <SelfTest client:visible vocabulary={vocabularyList} lang="es" />
      </div>
    </div>
  </section>

  <section class="py-16 md:py-20 bg-gradient-to-b from-slate-900 to-slate-800">
    <div class="site-container mx-auto px-4 text-white">
      <div class="max-w-2xl mx-auto text-center space-y-6">
        <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-emerald-500/20 text-emerald-400">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
          </svg>
        </div>
        <h2 class="text-3xl font-bold text-white">¡Unidad 5 Completada!</h2>
        <p class="text-lg text-slate-100 leading-relaxed">
          Ahora puedes narrar eventos recientes — qué acaba de pasar, quién acaba de llegar, qué acabas de descubrir.
          Cinco unidades y ya estás contando historias reales en inglés.
        </p>
        <div class="flex flex-wrap gap-4 justify-center pt-4">
          <a href="/es/curso/principiantes/unidad-4/" class="inline-flex items-center gap-2 px-6 py-3 rounded-xl bg-slate-700 text-slate-300 font-medium hover:bg-slate-600 transition-colors">
            <ArrowLeft class="w-4 h-4" /> Repasar Unidad 4
          </a>
          <a href="/es/curso/principiantes/unidad-6/" class="inline-flex items-center gap-2 px-6 py-3 rounded-xl bg-amber-500 text-white font-semibold hover:bg-amber-400 transition-colors shadow-lg">
            Siguiente: Unidad 6 <ArrowRight class="w-4 h-4" />
          </a>
        </div>
        <div class="pt-8 border-t border-slate-700 mt-8">
          <p class="text-slate-200 text-sm mb-3">¿Quieres coaching personalizado de inglés?</p>
          <a href="/es/contact/" class="text-amber-400 hover:text-amber-300 font-medium underline underline-offset-2">
            Agenda una consulta gratuita con Robert →
          </a>
        </div>
      </div>
    </div>
  </section>
</Base>
