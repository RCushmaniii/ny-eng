---
export const prerender = true;

import Base from "@layouts/Base.astro";
import CourseProgress from "@components/course/CourseProgress";
import CognateDiscovery from "@components/course/CognateDiscovery";
import SentenceBuilder from "@components/course/SentenceBuilder";
import PronunciationDrill from "@components/course/PronunciationDrill";
import ConnectorChallenge from "@components/course/ConnectorChallenge";
import SelfTest from "@components/course/SelfTest";
import { units } from "@data/course/units";
import {
  cognateWaves,
  sentenceBlocks,
  powerVerbBlocks,
  connectorSentences,
  pronunciationDrills,
  vocabularyList,
} from "@data/course/unit-8";
import {
  ArrowLeft,
  ArrowRight,
  Compass,
  Layers,
  Zap,
  Link2,
  Volume2,
  ClipboardCheck,
} from "lucide-astro";

const lang = "es";
const tkey = "course/beginners/unit-8" as const;

const progressUnits = units.map((u) => ({
  id: u.id,
  slug: u.slugEs,
  title: u.title,
  titleEs: u.titleEs,
}));

const waveData = [cognateWaves.wave1, cognateWaves.wave2, cognateWaves.wave3];
---

<Base
  lang={lang}
  tkey={tkey}
  title="Unidad 8: Sentimientos y Curiosidad | NY English Teacher"
  description="Aprende a expresar sentimientos y curiosidad en inglés: I feel like, I wonder, formas de they. Más cognados -ence/-ance y entonación de preguntas. Lección gratuita interactiva."
>
  <CourseProgress
    client:load
    units={progressUnits}
    currentUnit={8}
    basePath="/es/curso/principiantes"
    lang="es"
  />

  <section class="bg-gradient-to-b from-slate-900 to-slate-800 pt-28 pb-16 md:pt-36 md:pb-20">
    <div class="site-container mx-auto px-4 text-white">
      <div class="max-w-3xl">
        <div class="flex items-center gap-2 text-amber-400 text-sm font-semibold mb-3">
          <Compass class="w-4 h-4" />
          Unidad 8
        </div>
        <h1 class="text-3xl md:text-5xl font-bold text-white mb-4 leading-tight" style="font-family: 'Noto Sans KR', sans-serif;">
          Sentimientos y Curiosidad
        </h1>
        <p class="text-lg text-slate-300 max-w-2xl leading-relaxed">
          Expresa lo que tienes ganas de hacer. Pregúntate sobre cosas que no sabes.
          Habla de lo que "ellos" están haciendo. I feel like going out. I wonder where it is. They want to know.
        </p>
      </div>
    </div>
  </section>

  <nav class="bg-white border-b border-slate-200 sticky top-[52px] z-30 overflow-x-auto">
    <div class="site-container mx-auto px-4">
      <div class="flex items-center gap-1 py-2 text-sm whitespace-nowrap">
        <a href="#cognados" class="px-3 py-1.5 rounded-full hover:bg-amber-50 text-slate-600 hover:text-amber-600 transition-colors flex items-center gap-1.5">
          <Compass class="w-3.5 h-3.5" /> Cognados
        </a>
        <a href="#oraciones" class="px-3 py-1.5 rounded-full hover:bg-amber-50 text-slate-600 hover:text-amber-600 transition-colors flex items-center gap-1.5">
          <Layers class="w-3.5 h-3.5" /> Ganas/Pregunto/Dónde
        </a>
        <a href="#verbos" class="px-3 py-1.5 rounded-full hover:bg-amber-50 text-slate-600 hover:text-amber-600 transition-colors flex items-center gap-1.5">
          <Zap class="w-3.5 h-3.5" /> Formas de They
        </a>
        <a href="#conectores" class="px-3 py-1.5 rounded-full hover:bg-amber-50 text-slate-600 hover:text-amber-600 transition-colors flex items-center gap-1.5">
          <Link2 class="w-3.5 h-3.5" /> Sentimientos
        </a>
        <a href="#pronunciacion" class="px-3 py-1.5 rounded-full hover:bg-amber-50 text-slate-600 hover:text-amber-600 transition-colors flex items-center gap-1.5">
          <Volume2 class="w-3.5 h-3.5" /> Pronunciación
        </a>
        <a href="#auto-evaluacion" class="px-3 py-1.5 rounded-full hover:bg-amber-50 text-slate-600 hover:text-amber-600 transition-colors flex items-center gap-1.5">
          <ClipboardCheck class="w-3.5 h-3.5" /> Auto-Evaluación
        </a>
      </div>
    </div>
  </nav>

  <section id="cognados" class="py-12 md:py-16 bg-slate-50">
    <div class="site-container mx-auto px-4">
      <div class="max-w-3xl mx-auto">
        <div class="mb-8">
          <div class="flex items-center gap-2 text-amber-600 text-sm font-semibold mb-2">
            <Compass class="w-4 h-4" />
            Sección A
          </div>
          <h2 class="text-2xl md:text-3xl font-bold text-slate-900 mb-3">Experience, Confidence, Patience</h2>
          <p class="text-lg text-slate-600 leading-relaxed">
            Los patrones -ence y -ance te dan sustantivos abstractos poderosos — el tipo de palabras
            que hacen que tu inglés suene educado y preciso. Más vocabulario esencial de sentimientos.
          </p>
        </div>
        <CognateDiscovery client:visible waves={waveData} lang="es" />
      </div>
    </div>
  </section>

  <section id="oraciones" class="py-12 md:py-16 bg-white">
    <div class="site-container mx-auto px-4">
      <div class="max-w-3xl mx-auto">
        <div class="mb-8">
          <div class="flex items-center gap-2 text-amber-600 text-sm font-semibold mb-2">
            <Layers class="w-4 h-4" />
            Sección B
          </div>
          <h2 class="text-2xl md:text-3xl font-bold text-slate-900 mb-3">I Feel Like / I Wonder / Where Is It?</h2>
          <p class="text-lg text-slate-600 leading-relaxed">
            Dos expresiones nuevas y poderosas: <strong>"I feel like"</strong> para estados de ánimo y deseos (tengo ganas de),
            e <strong>"I wonder"</strong> para curiosidad (me pregunto). Más preguntas y respuestas con "where."
          </p>
        </div>
        <SentenceBuilder client:visible blocks={sentenceBlocks} lang="es" />
      </div>
    </div>
  </section>

  <section id="verbos" class="py-12 md:py-16 bg-slate-50">
    <div class="site-container mx-auto px-4">
      <div class="max-w-3xl mx-auto">
        <div class="mb-8">
          <div class="flex items-center gap-2 text-amber-600 text-sm font-semibold mb-2">
            <Zap class="w-4 h-4" />
            Sección C
          </div>
          <h2 class="text-2xl md:text-3xl font-bold text-slate-900 mb-3">They Can / They Want / They Feel Like</h2>
          <p class="text-lg text-slate-600 leading-relaxed">
            El último grupo de pronombres: <strong>"they."</strong> Buenas noticias otra vez — como "we," los verbos no cambian para "they."
            They can, they want, they have to, they feel like, they wonder. Ahora tienes todos los pronombres cubiertos.
          </p>
        </div>
        <SentenceBuilder client:visible blocks={powerVerbBlocks} lang="es" />
      </div>
    </div>
  </section>

  <section id="conectores" class="py-12 md:py-16 bg-white">
    <div class="site-container mx-auto px-4">
      <div class="max-w-3xl mx-auto">
        <div class="mb-8">
          <div class="flex items-center gap-2 text-amber-600 text-sm font-semibold mb-2">
            <Link2 class="w-4 h-4" />
            Sección D
          </div>
          <h2 class="text-2xl md:text-3xl font-bold text-slate-900 mb-3">Sentimientos y Preguntas</h2>
          <p class="text-lg text-slate-600 leading-relaxed">
            Palabras para lugares, actividades y preguntas — a la playa, una película, cómo, preguntar, lejos.
          </p>
        </div>
        <ConnectorChallenge
          client:visible
          connectors={connectorSentences.connectors}
          bossSentence={connectorSentences.bossSentence}
          lang="es"
        />
      </div>
    </div>
  </section>

  <section id="pronunciacion" class="py-12 md:py-16 bg-slate-50">
    <div class="site-container mx-auto px-4">
      <div class="max-w-3xl mx-auto">
        <div class="mb-8">
          <div class="flex items-center gap-2 text-rose-500 text-sm font-semibold mb-2">
            <Volume2 class="w-4 h-4" />
            Laboratorio de Pronunciación
          </div>
          <h2 class="text-2xl md:text-3xl font-bold text-slate-900 mb-3">Entonación de Preguntas — ¿Sube o Baja?</h2>
          <p class="text-lg text-slate-600 leading-relaxed">
            Las preguntas en inglés tienen dos patrones melódicos: las preguntas de sí/no SUBEN al final,
            y las preguntas WH (where, what, why) BAJAN. Hacerlo bien te hace sonar
            natural y seguro — hacerlo mal puede confundir a los oyentes.
          </p>
        </div>
        <PronunciationDrill client:visible drills={pronunciationDrills} lang="es" />
      </div>
    </div>
  </section>

  <section id="auto-evaluacion" class="py-12 md:py-16 bg-white">
    <div class="site-container mx-auto px-4">
      <div class="max-w-3xl mx-auto">
        <div class="mb-8">
          <div class="flex items-center gap-2 text-amber-600 text-sm font-semibold mb-2">
            <ClipboardCheck class="w-4 h-4" />
            Auto-Evaluación
          </div>
          <h2 class="text-2xl md:text-3xl font-bold text-slate-900 mb-3">Evalúa Lo que Aprendiste</h2>
          <p class="text-lg text-slate-600 leading-relaxed">
            Feel like, wonder, formas de they, vocabulario de sentimientos y cognados -ence/-ance — más repaso de las Unidades 1-7.
          </p>
        </div>
        <SelfTest client:visible vocabulary={vocabularyList} lang="es" />
      </div>
    </div>
  </section>

  <section class="py-16 md:py-20 bg-gradient-to-b from-slate-900 to-slate-800">
    <div class="site-container mx-auto px-4 text-white">
      <div class="max-w-2xl mx-auto text-center space-y-6">
        <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-emerald-500/20 text-emerald-400">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
          </svg>
        </div>
        <h2 class="text-3xl font-bold text-white">¡Unidad 8 Completada!</h2>
        <p class="text-lg text-slate-100 leading-relaxed">
          Ahora puedes expresar sentimientos, preguntarte sobre cosas y hablar de lo que "ellos" están haciendo.
          Ocho unidades completas — tienes todos los pronombres en inglés. ¡Solo quedan dos unidades!
        </p>
        <div class="flex flex-wrap gap-4 justify-center pt-4">
          <a href="/es/curso/principiantes/unidad-7/" class="inline-flex items-center gap-2 px-6 py-3 rounded-xl bg-slate-700 text-slate-300 font-medium hover:bg-slate-600 transition-colors">
            <ArrowLeft class="w-4 h-4" /> Repasar Unidad 7
          </a>
          <a href="/es/curso/principiantes/unidad-9/" class="inline-flex items-center gap-2 px-6 py-3 rounded-xl bg-amber-500 text-white font-semibold hover:bg-amber-400 transition-colors shadow-lg">
            Unidad 9: Historias <ArrowRight class="w-4 h-4" />
          </a>
        </div>
        <div class="pt-8 border-t border-slate-700 mt-8">
          <p class="text-slate-200 text-sm mb-3">¿Quieres coaching personalizado de inglés?</p>
          <a href="/es/contact/" class="text-amber-400 hover:text-amber-300 font-medium underline underline-offset-2">
            Agenda una consulta gratuita con Robert →
          </a>
        </div>
      </div>
    </div>
  </section>
</Base>
