---
import { getCollection, type CollectionEntry } from 'astro:content';
import Layout from '@layouts/Layout.astro';
import InnerHero from '@components/sections/InnerHero.astro';

export async function getStaticPaths() {
  const legalEntries = await getCollection('legal', ({ slug }) => {
    // Filter for entries that ARE Spanish (i.e., their slug starts with 'es/')
    return slug.startsWith('es/');
  });
  return legalEntries.map(entry => ({
    // The slug for Spanish content includes 'es/', e.g., 'es/privacy-policy'
    // We need to remove the 'es/' prefix for the params.slug to match the URL structure /es/legal/privacy-policy
    params: { slug: entry.slug.substring(3) }, // Remove 'es/'
    props: { entry },
  }));
}

interface Props {
  entry: CollectionEntry<'legal'>;
}

const { entry } = Astro.props;
const { Content } = await entry.render();

// Use SEO data from frontmatter if available, fallback to regular entry data
const seoTitle = entry.data.seo?.title || entry.data.title;
const seoDescription = entry.data.seo?.description || '';

// Format the last updated date
const formattedDate = new Intl.DateTimeFormat('es-ES', { // Use Spanish locale for date formatting
  year: 'numeric',
  month: 'long',
  day: 'numeric'
}).format(entry.data.lastUpdated);

// Hero content
const heroContent = {
  title: entry.data.title,
  description: '', // No description needed for legal page hero
  overlayOpacity: 0.8
};

// entry.slug is like 'es/privacy-policy'. We need the base slug 'privacy-policy' for the English link.
const baseSlug = entry.slug.substring(3);
const englishSlugPath = `/en/legal/${baseSlug}`;

--- 

<Layout 
  title={seoTitle}
  description={seoDescription}
  lang="es"
  noIndex={true}
  footerCta={{ hideCta: true }}
  translationSlugEn={englishSlugPath}
>
  <InnerHero content={heroContent} />
  
  <article class="site-container--small mx-auto px-8 prose pb-base">
    <div class="mt-12 mb-8">
      <p class="text-sm text-body-base/80">Última actualización: {formattedDate}</p> {/* Translated text */}
    </div>
    
    <Content />
  </article>
</Layout>
