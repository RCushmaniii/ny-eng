---
import Layout from '@layouts/Layout.astro';
import InnerHero from '@components/sections/InnerHero.astro';
import { getLegalContent } from '@utils/legalContent.js';

// Use the helper function to bypass TypeScript collection errors
const legalData = await getLegalContent('terms-of-service', 'es');
const { Content } = legalData;
const entry = legalData;

const heroContent = {
  title: entry.data.title,
  description: entry.data.seo?.description || "",
  overlayOpacity: 0.8
} as const;

const footerCta = {
  eyebrow: "",
  title: "Transforma Tu Inglés Profesional Hoy",
  description: "Reserva tu consulta gratuita para obtener la claridad, confianza e impacto que tu rol exige.",
  hideCta: true, // Hide the CTA for legal pages
  button: {
    text: "Reservar Mi Consulta Gratuita",
    link: "https://ny-english-teacher.odoo.com/book/7ceefa20",
    target: "_blank"
  }
} as const;
---

<Layout 
  title={legalData.data.seo?.title || legalData.data.title}
  description={legalData.data.seo?.description || ''}
  lang="es"
  noIndex={false}
  footerCta={footerCta}
  translationSlugEn="/en/legal/terms-of-service"
>
  <InnerHero content={heroContent} />
  <article class="site-container--small mx-auto px-8 prose pb-base">
    <Content />
  </article>
</Layout>
