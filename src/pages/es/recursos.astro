---
/**
 * /es/recursos/index.astro
 *
 * Biblioteca de Recursos Ejecutivos - Herramientas probadas para líderes globales
 */

import Base from "@layouts/Base.astro";
import Button from "@components/ui/Button.astro";
import FreeResourcesHub from "@components/free/FreeResourcesHub";
import { Sparkles, FileText, Headphones, MessageCircle } from "lucide-astro";
import type { FreeAsset } from "@/types/free-asset";

const title = "Biblioteca de Recursos Ejecutivos | New York English";
const description =
  "Scripts de negociación probados, marcos de comunicación y guías ejecutivas diseñadas para profesionales latinoamericanos liderando equipos globales.";

// Auto-discover all free resources from JSON files
const allAssets = await Astro.glob("../../data/free/*.json");

// Filter out schema and template files, only keep actual assets with valid content
// Support both new schema (es at root) and old schema (content.es)
const resources: FreeAsset[] = allAssets
  .filter((file) => {
    const data = file.default;
    const esContent = data.es || data.content?.es;
    // Must have metadata, es.title, and not be schema/template
    return data.metadata && esContent?.title && !data.$schema;
  })
  .map((file) => {
    const data = file.default;
    // Normalize old schema to new schema structure
    if (!data.es && data.content?.es) {
      data.en = data.content.en;
      data.es = data.content.es;
      data.slugEn = data.slugEn || data.content.en?.slug;
      data.slugEs = data.slugEs || data.content.es.slug;
    }
    return data as FreeAsset;
  });
---

<Base
  title={title}
  description={description}
  lang="es"
  tkey="resources"
  ogImage={{
    src: "/images/logos/new-york-english-og.jpg",
    alt: "Biblioteca de Recursos Ejecutivos - New York English Teacher",
  }}
  hideCta={true}
>
  <!-- Hero Section -->
  <section class="pt-28 pb-16 md:pt-32 md:pb-20 bg-gray-50">
    <div class="site-container px-4 text-center">
      <span
        class="text-amber-600 font-bold tracking-wider text-sm uppercase mb-4 block"
      >
        Biblioteca de Recursos Ejecutivos
      </span>

      <h1 class="text-4xl md:text-5xl font-bold text-slate-900 mb-6">
        Herramientas Probadas para <span class="text-blue-700"
          >Líderes Globales</span
        >
      </h1>

      <p class="text-lg text-slate-600 max-w-2xl mx-auto leading-relaxed">
        Marcos accionables, scripts de negociación y guías de comunicación
        diseñadas específicamente para profesionales latinoamericanos que
        lideran equipos globales.
      </p>
    </div>
  </section>

  <!-- Available Resources (Auto-discovered) -->
  <FreeResourcesHub resources={resources} lang="es" client:load />

  <!-- CTA Section -->
  <section
    class="cta-section py-16 md:py-20 bg-gradient-to-br from-slate-900 to-slate-800"
  >
    <div class="max-w-4xl mx-auto px-4 sm:px-6 text-center">
      <h2 class="text-3xl md:text-4xl font-bold text-white mb-6">
        ¿Listo para Implementar Estas Estrategias?
      </h2>
      <p class="text-lg text-slate-300 mb-8 max-w-2xl mx-auto">
        Leer guías genera conciencia. El coaching genera maestría. Agenda tu
        sesión estratégica para aplicar estos marcos a tus desafíos
        profesionales específicos.
      </p>
      <Button href="/es/reservar/" variant="primary" size="lg">
        Agendar Mi Sesión Estratégica →
      </Button>
    </div>
  </section>
</Base>

<style>
  .hero-section {
    background: linear-gradient(135deg, #f0f9ff 0%, #e0e7ff 100%);
  }

  .resource-card {
    cursor: pointer;
  }

  .upcoming-card {
    transition: opacity 0.3s ease;
  }

  .upcoming-card:hover {
    opacity: 1;
  }
</style>
