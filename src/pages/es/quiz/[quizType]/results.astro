---
/**
 * Dynamic Quiz Results Page (Spanish)
 *
 * Route: /es/quiz/[quizType]/results/
 * Collects lead info and displays score
 */

import Base from "@layouts/Base.astro";
import Button from "@components/ui/Button.astro";
import {
  getQuizConfig,
  isQuizTypeAvailable,
  getAvailableQuizTypes,
} from "@/data/quiz/configs";
import type { QuizType } from "@/data/quiz/types";
import { Mail } from "lucide-astro";

export const prerender = true;

export function getStaticPaths() {
  return getAvailableQuizTypes().map((qt) => ({ params: { quizType: qt } }));
}

// Get quiz type from URL params
const { quizType } = Astro.params;

// Validate quiz type
if (!quizType || !isQuizTypeAvailable(quizType)) {
  return Astro.redirect("/es/404");
}

// Get quiz configuration
const config = getQuizConfig(quizType as QuizType, "es");

const title = `Resultados | ${config.title}`;
const description =
  "Obtén tu Puntuación de Confianza (0-100) y hoja de ruta. Descubre dónde está tu equipo con la comunicación en inglés de alto impacto.";

const canonicalUrl = `https://www.nyenglishteacher.com/es/quiz/${quizType}/results/`;
const customHreflangs = [
  {
    lang: "en-US",
    href: `https://www.nyenglishteacher.com/en/quiz/${quizType}/results/`,
  },
  { lang: "es-MX", href: canonicalUrl },
];
---

<Base
  title={title}
  description={description}
  lang="es"
  customCanonical={canonicalUrl}
  customHreflangs={customHreflangs}
  hideCta={true}
  hideLanguageSwitcher={true}
>
  <section class="quiz-results pt-28 pb-16 md:pt-32 md:pb-20">
    <div class="container-narrow">
      <!-- SEO H1 (visually hidden but present for SEO) -->
      <h1 class="sr-only">Resultados | {config.title}</h1>

      <!-- No Quiz Data Warning (shown if user hasn't taken quiz) -->
      <div class="no-quiz-warning" id="no-quiz-warning" style="display: none;">
        <div class="warning-content">
          <div class="warning-icon">⚠️</div>
          <h2>Prueba No Completada</h2>
          <p class="warning-text">
            Necesitas completar la Evaluación de Confianza en Comunicación antes
            de ver tus resultados.
          </p>
          <p class="warning-subtext">
            La prueba toma alrededor de 90 segundos y te dará una puntuación
            personalizada que muestra exactamente dónde se encuentra tu equipo
            con la comunicación en inglés de alto impacto.
          </p>
          <Button
            href={`/es/quiz/${quizType}/question/1`}
            variant="primary"
            size="lg"
            class="start-quiz-button"
          >
            Comenzar la Prueba →
          </Button>
        </div>
      </div>

      <!-- Submission Error Message (shown if submission fails) -->
      <div
        class="submission-error"
        id="submission-error"
        style="display: none;"
      >
        <div class="error-content">
          <div class="error-icon">❌</div>
          <h2>Error de Envío</h2>
          <p class="error-text" id="error-message">
            Hubo un error al enviar tu prueba. Por favor, inténtalo de nuevo.
          </p>
          <p class="error-subtext">
            Si el problema persiste, contáctanos directamente o inténtalo más
            tarde.
          </p>
          <button
            onclick="location.reload()"
            class="retry-button px-8 py-4 bg-gradient-to-r from-blue-600 to-blue-700 text-white font-semibold rounded-lg hover:from-blue-700 hover:to-blue-800 transition-all duration-200 text-lg"
          >
            Intentar de Nuevo
          </button>
        </div>
      </div>

      <!-- Lead Capture Form (shown first) -->
      <div class="lead-capture-card" id="lead-capture">
        <div class="capture-header">
          <h2>¡Ya Casi Terminas!</h2>
          <p class="capture-subtext">
            Ingresa tu correo electrónico para recibir tu Puntuación de
            Confianza en Comunicación personalizada y tu hoja de ruta detallada
            de mejora.
          </p>
        </div>

        <form class="capture-form" id="email-form">
          <input type="hidden" name="quizType" value={quizType} />

          <div class="form-group">
            <label for="name" class="form-label">Tu Nombre</label>
            <input
              type="text"
              id="name"
              name="name"
              class="form-input"
              placeholder="Juan Pérez"
              required
            />
          </div>

          <div class="form-group">
            <label for="email" class="form-label">Correo Electrónico</label>
            <input
              type="email"
              id="email"
              name="email"
              class="form-input"
              placeholder="juan@empresa.com"
              required
            />
          </div>

          <div class="form-group">
            <label for="company" class="form-label">Empresa (Opcional)</label>
            <input
              type="text"
              id="company"
              name="company"
              class="form-input"
              placeholder="Nombre de tu Empresa"
            />
          </div>

          <div class="form-group">
            <label for="phone" class="form-label"
              >Número de Teléfono (Opcional)</label
            >
            <input
              type="tel"
              id="phone"
              name="phone"
              class="form-input"
              placeholder="+52 (555) 123-4567"
            />
          </div>

          <Button
            type="submit"
            variant="primary"
            size="lg"
            class="submit-button"
          >
            <Mail size={20} />
            Obtener Mis Resultados →
          </Button>

          <p class="privacy-text">
            Al enviar este formulario, aceptas nuestra <a
              href="/es/legal/privacy-policy"
              target="_blank"
              class="privacy-link">Política de Privacidad</a
            >. Respetamos tu privacidad y nunca venderemos tu información.
          </p>
        </form>
      </div>
    </div>
  </section>
</Base>

<style>
  .container-narrow {
    max-width: 800px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .quiz-results {
    background: linear-gradient(135deg, #f0f9ff 0%, #e0e7ff 100%);
    min-height: calc(100vh - 80px);
  }

  /* Warning/Error States */
  .no-quiz-warning,
  .submission-error {
    background: white;
    padding: 4rem 3rem;
    border-radius: 16px;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
    text-align: center;
  }

  .warning-content,
  .error-content {
    max-width: 600px;
    margin: 0 auto;
  }

  .warning-icon,
  .error-icon {
    font-size: 4rem;
    margin-bottom: 1.5rem;
  }

  .no-quiz-warning h2,
  .submission-error h2 {
    font-size: 2.5rem;
    font-weight: 700;
    color: #0f172a;
    margin-bottom: 1rem;
  }

  .warning-text,
  .error-text {
    font-size: 1.25rem;
    color: #475569;
    margin-bottom: 1rem;
    line-height: 1.6;
  }

  .warning-subtext,
  .error-subtext {
    font-size: 1rem;
    color: #64748b;
    margin-bottom: 2rem;
    line-height: 1.6;
  }

  /* Lead Capture Form */
  .lead-capture-card {
    background: white;
    padding: 3rem;
    border-radius: 16px;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
  }

  .capture-header {
    text-align: center;
    margin-bottom: 2.5rem;
  }

  .capture-header h2 {
    font-size: 2.5rem;
    font-weight: 700;
    color: #0f172a;
    margin-bottom: 1rem;
  }

  .capture-subtext {
    font-size: 1.125rem;
    color: #475569;
    line-height: 1.6;
  }

  .capture-form {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .form-label {
    font-size: 0.875rem;
    font-weight: 600;
    color: #334155;
  }

  .form-input {
    padding: 0.875rem 1rem;
    border: 2px solid #e2e8f0;
    border-radius: 8px;
    font-size: 1rem;
    transition: all 0.2s;
  }

  .form-input:focus {
    outline: none;
    border-color: #3b82f6;
    box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.1);
  }

  .privacy-text {
    font-size: 0.875rem;
    color: #64748b;
    text-align: center;
    line-height: 1.5;
  }

  .privacy-link {
    color: #3b82f6;
    text-decoration: underline;
  }

  @media (max-width: 768px) {
    .lead-capture-card {
      padding: 2rem 1.5rem;
    }

    .capture-header h1 {
      font-size: 2rem;
    }

    .score-number {
      font-size: 4rem;
    }
  }
</style>

<script>
  import { QuizStorage } from "@/lib/quiz-storage";
  import { calculateQuizScore } from "@/data/quiz/scoring";
  import { getQuizConfig } from "@/data/quiz/configs";
  import { getBehavioralData } from "@/lib/device-detection";
  import type { QuizType } from "@/data/quiz/types";

  function stripTags(value: string | null): string | null {
    if (!value) return null;
    return value.replace(/<[^>]*>/g, "").trim();
  }

  function validateSubmission(data: {
    name: string;
    email: string;
    company?: string | null;
  }) {
    const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;

    const cleanedName = stripTags(data.name) || "";
    const cleanedCompany = stripTags(data.company ?? null);

    if (!emailRegex.test(data.email)) {
      throw new Error("Por favor, ingresa un correo electrónico válido.");
    }

    if (cleanedName.length === 0) {
      throw new Error("El nombre es requerido.");
    }

    if (cleanedName.length > 250) {
      throw new Error("El nombre es demasiado largo. Por favor, acórtalo.");
    }

    return {
      ...data,
      name: cleanedName,
      company: cleanedCompany ?? undefined,
    };
  }

  // Get quiz type from URL
  const urlParts = window.location.pathname.split("/");
  const quizType = urlParts[3] as QuizType;

  // Check if quiz was completed
  const answers = QuizStorage.getAnswers(quizType);

  if (!answers || Object.keys(answers).length !== 6) {
    // Show warning
    document.getElementById("no-quiz-warning")!.style.display = "block";
    document.getElementById("lead-capture")!.style.display = "none";
  } else {
    // Handle form submission
    const form = document.getElementById("email-form");

    if (form) {
      form.addEventListener("submit", async (e) => {
        e.preventDefault();

        const formData = new FormData(form as HTMLFormElement);
        const name = (formData.get("name") as string) || "";
        const email = (formData.get("email") as string) || "";
        const companyRaw = (formData.get("company") as string) || "";
        const phone = (formData.get("phone") as string) || "";

        try {
          const validated = validateSubmission({
            name,
            email,
            company: companyRaw,
          });

          const company = validated.company ?? "";
          const safeName = validated.name;
          const safeEmail = validated.email;

          // Get quiz config and calculate score
          const config = getQuizConfig(quizType, "es");
          const scoreBreakdown = calculateQuizScore(answers, config);

          // Get behavioral data
          const behavioralData = getBehavioralData();
          const completionTime = QuizStorage.getCompletionTime(quizType);

          // Build submission payload for API
          const payload = {
            name: safeName,
            email: safeEmail,
            company,
            phone,
            quizType,
            answers,
            language: "es",
            completionTime,
            ...behavioralData,
          };

          // Submit to API (Netlify Function)
          const response = await fetch(
            "https://ny-eng-api.netlify.app/.netlify/functions/quiz-submit",
            {
              method: "POST",
              headers: { "Content-Type": "application/json" },
              body: JSON.stringify(payload),
            }
          );

          const result = await response.json();

          if (result.success) {
            // Save lead data and score for the new config-driven report system
            QuizStorage.saveLeadData(quizType, {
              name: safeName,
              email: safeEmail,
              company,
              phone,
              quizType,
            });
            QuizStorage.saveScore(quizType, scoreBreakdown.totalScore);

            // Backwards-compat: also write legacy keys for the React report
            try {
              sessionStorage.setItem("quizAnswers", JSON.stringify(answers));
              sessionStorage.setItem(
                "leadData",
                JSON.stringify({ name: safeName, company, quizType })
              );
            } catch {}

            // Redirect to the polished report page (uses QuizReport.tsx)
            window.location.href = `/es/quiz/${quizType}/report/`;
          } else {
            // Show error
            document.getElementById("lead-capture")!.style.display = "none";
            document.getElementById("submission-error")!.style.display =
              "block";
            document.getElementById("error-message")!.textContent =
              result.error || "Ocurrió un error desconocido";
          }
        } catch (error) {
          const message =
            error instanceof Error
              ? error.message
              : "Error de red. Por favor, verifica tu conexión e inténtalo de nuevo.";
          document.getElementById("submission-error")!.style.display = "block";
          document.getElementById("error-message")!.textContent = message;
        }
      });
    }
  }
</script>
