---
/**
 * Dynamic Quiz Question Page (Spanish)
 * 
 * Route: /es/quiz/[quizType]/question/[id]/
 */

import Base from '@layouts/Base.astro';
import Button from '@components/ui/Button.astro';
import { getQuizConfig, isQuizTypeAvailable } from '@/data/quiz/configs';
import type { QuizType } from '@/data/quiz/types';

// Get params
const { quizType, id } = Astro.params;

// Validate quiz type
if (!quizType || !isQuizTypeAvailable(quizType)) {
  return Astro.redirect('/es/404');
}

// Get quiz configuration
const config = getQuizConfig(quizType as QuizType, 'es');

// Validate question ID
const currentQuestion = parseInt(id || '1');
const validQuestion = config.questions.find(q => q.id === currentQuestion);
const hasValidQuestion = !!validQuestion;

const totalQuestions = config.questions.length;
const progress = (currentQuestion / totalQuestions) * 100;

const title = hasValidQuestion 
  ? `Pregunta ${currentQuestion} de ${totalQuestions} | ${config.title}`
  : `Error en la Prueba | ${config.title}`;
const description = config.subtitle;
---

<Base 
  title={title} 
  description={description}
  lang="es"
  customCanonical={`https://www.nyenglishteacher.com/es/quiz/${quizType}/`}
  customHreflangs={[
    { lang: "en-US", href: `https://www.nyenglishteacher.com/en/quiz/${quizType}/question/${id}/` },
    { lang: "es-MX", href: `https://www.nyenglishteacher.com/es/quiz/${quizType}/question/${id}/` }
  ]}
  hideCta={true}
  hideLanguageSwitcher={true}
>

<section class="quiz-question pt-28 pb-16 md:pt-32 md:pb-20">
  <div class="container-narrow">
    
    {!hasValidQuestion ? (
      <!-- No Quiz Data Warning -->
      <div class="no-quiz-warning">
        <div class="warning-content">
          <div class="warning-icon">⚠️</div>
          <h1>Por favor, comienza desde el principio</h1>
          <p class="warning-text">
            Para obtener resultados precisos, debes comenzar la prueba desde el principio y responder todas las preguntas en orden.
          </p>
          <p class="warning-subtext">
            La Evaluación de Confianza en Comunicación toma alrededor de 90 segundos y te dará una puntuación personalizada.
          </p>
          <Button 
            href={`/es/quiz/${quizType}/question/1`}
            variant="primary" 
            size="lg"
            class="start-quiz-button"
          >
            Comenzar la Prueba →
          </Button>
        </div>
      </div>
    ) : (
      <>
    <!-- Progress Bar -->
    <div class="progress-container">
      <div class="progress-bar">
        <div class="progress-fill" style={`width: ${progress}%`}></div>
      </div>
      <div class="progress-text">
        Pregunta {currentQuestion} de {totalQuestions}
      </div>
    </div>

    <!-- Question Card -->
    <div class="question-card">
      <h1 class="question-text">{validQuestion.question}</h1>

      <form class="options-form" id="quiz-form">
        <input type="hidden" name="questionId" value={validQuestion.id} />
        <input type="hidden" name="quizType" value={quizType} />
        
        {validQuestion.answers.map((answer) => (
          <label class="option-label">
            <input 
              type="radio" 
              name="answer" 
              value={answer.index}
              class="option-radio"
              required
            />
            <div class="option-content">
              <span class="option-letter">{String.fromCharCode(65 + answer.index)}</span>
              <span class="option-text">{answer.label}</span>
            </div>
          </label>
        ))}

        <div class="button-group">
          <Button 
            type="submit"
            variant="primary" 
            size="lg"
            class="next-button"
          >
            {currentQuestion === totalQuestions ? 'Ver Mis Resultados →' : 'Siguiente Pregunta →'}
          </Button>
        </div>
      </form>
    </div>
    </>
    )}
  </div>
</section>

</Base>

<style>
.container-narrow {
  max-width: 800px;
  margin: 0 auto;
  padding: 0 1.5rem;
}

.quiz-question {
  background: linear-gradient(135deg, #f0f9ff 0%, #e0e7ff 100%);
  min-height: calc(100vh - 80px);
}

/* No Quiz Warning */
.no-quiz-warning {
  background: white;
  padding: 4rem 3rem;
  border-radius: 16px;
  box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
  text-align: center;
}

.warning-content {
  max-width: 600px;
  margin: 0 auto;
}

.warning-icon {
  font-size: 4rem;
  margin-bottom: 1.5rem;
  animation: pulse 2s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.1); }
}

.no-quiz-warning h1 {
  font-size: 2.5rem;
  font-weight: 700;
  color: #0f172a;
  margin-bottom: 1rem;
}

.warning-text {
  font-size: 1.25rem;
  color: #475569;
  margin-bottom: 1rem;
  line-height: 1.6;
}

.warning-subtext {
  font-size: 1rem;
  color: #64748b;
  margin-bottom: 2rem;
  line-height: 1.6;
}

.start-quiz-button {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 0.5rem;
}

/* Progress Bar */
.progress-container {
  margin-bottom: 2rem;
}

.progress-bar {
  width: 100%;
  height: 8px;
  background: #e2e8f0;
  border-radius: 4px;
  overflow: hidden;
  margin-bottom: 0.5rem;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #3b82f6 0%, #2563eb 100%);
  transition: width 0.3s ease;
}

.progress-text {
  text-align: center;
  font-size: 0.875rem;
  color: #64748b;
  font-weight: 500;
}

/* Question Card */
.question-card {
  background: white;
  padding: 3rem;
  border-radius: 16px;
  box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
}

.question-text {
  font-size: 1.75rem;
  font-weight: 600;
  color: #0f172a;
  line-height: 1.4;
  margin-bottom: 2.5rem;
}

/* Options */
.options-form {
  display: flex;
  flex-direction: column;
  gap: 1rem;
}

.option-label {
  display: block;
  cursor: pointer;
}

.option-radio {
  position: absolute;
  opacity: 0;
  pointer-events: none;
}

.option-content {
  display: flex;
  align-items: center;
  gap: 1rem;
  padding: 1.25rem 1.5rem;
  background: #f8fafc;
  border: 2px solid #e2e8f0;
  border-radius: 12px;
  transition: all 0.2s ease;
}

.option-label:hover .option-content {
  background: #f1f5f9;
  border-color: #cbd5e1;
}

.option-radio:checked + .option-content {
  background: #eff6ff;
  border-color: #3b82f6;
  box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.1);
}

.option-letter {
  width: 32px;
  height: 32px;
  background: white;
  border: 2px solid #cbd5e1;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 600;
  color: #64748b;
  flex-shrink: 0;
  transition: all 0.2s ease;
}

.option-radio:checked + .option-content .option-letter {
  background: #3b82f6;
  border-color: #3b82f6;
  color: white;
}

.option-text {
  font-size: 1rem;
  color: #334155;
  line-height: 1.5;
}

.option-radio:checked + .option-content .option-text {
  color: #0f172a;
  font-weight: 500;
}

/* Button Group */
.button-group {
  margin-top: 2rem;
  padding-top: 2rem;
  border-top: 1px solid #e2e8f0;
  display: flex;
  justify-content: center;
}

@media (max-width: 768px) {
  .question-card {
    padding: 2rem 1.5rem;
  }

  .question-text {
    font-size: 1.5rem;
  }

  .option-content {
    padding: 1rem;
  }
}
</style>

<script>
import { QuizStorage } from '@/lib/quiz-storage';
import type { QuizType } from '@/data/quiz/types';

// Handle quiz form submission and store answers
const form = document.getElementById('quiz-form');

if (form) {
  // Save start time on first question
  const urlParams = new URLSearchParams(window.location.search);
  const questionId = (form.querySelector('[name="questionId"]') as HTMLInputElement)?.value;
  const quizTypeInput = form.querySelector('[name="quizType"]') as HTMLInputElement;
  const quizType = quizTypeInput?.value as QuizType;
  
  if (questionId === '1' && quizType) {
    QuizStorage.saveStartTime(quizType);
  }
  
  form.addEventListener('submit', (e) => {
    e.preventDefault();
    
    const formData = new FormData(form as HTMLFormElement);
    const questionId = formData.get('questionId');
    const answer = formData.get('answer');
    const quizType = formData.get('quizType') as QuizType;
    
    if (!answer || !quizType) return;
    
    // Get existing answers from namespaced storage
    const answers = QuizStorage.getAnswers(quizType) || {};
    
    // Store this answer with 'q' prefix to match expected format
    const answerKey = `q${questionId}`;
    answers[answerKey] = parseInt(answer as string);
    QuizStorage.saveAnswers(quizType, answers);
    
    // Navigate to next question or results
    const currentId = parseInt(questionId as string);
    const totalQuestions = 6;
    
    if (currentId < totalQuestions) {
      window.location.href = `/es/quiz/${quizType}/question/${currentId + 1}/`;
    } else {
      window.location.href = `/es/quiz/${quizType}/results/`;
    }
  });
}
</script>
