---
/**
 * Evaluación de Presencia Ejecutiva - Página de Destino
 * URL: /es/quiz/executives/
 * Target Keyword: Habilidades de Comunicación Ejecutiva / Presencia de Liderazgo
 */

export const prerender = true;

import Base from "@layouts/Base.astro";
import Button from "@components/ui/Button.astro";
import QuizSchema from "@components/seo/QuizSchema.astro";
import {
  Briefcase,
  CheckCircle,
  Clock,
  TrendingUp,
  ChevronDown,
  Target,
  Mic,
  Scale,
} from "lucide-astro";
import heroSkyline from "@assets/images/home/new-york-city-skyline.webp";

// SEO metadata
const title = "Puntuación de Influencia C-Suite | Evaluación";
const description =
  "Comandas respeto en tu idioma nativo. ¿Lo pierdes en inglés? Mide tu Brecha de Liderazgo Bilingüe en 90 segundos y recupera tu autoridad.";

// Datos de FAQ
const faqs = [
  {
    question: "¿Cuánto toma la evaluación?",
    answer:
      "Solo 90 segundos. Al terminar, recibes tu Puntuación de Influencia Ejecutiva (0-100) y un plan de acción personalizado de inmediato.",
  },
  {
    question: "¿Es una prueba de gramática o acento?",
    answer:
      "Para nada. Esto mide cómo comunicas estratégicamente—cómo lideras reuniones, negocias y proyectas autoridad. Tu gramática puede ser perfecta, pero si tu mensaje no es claro o tu presencia es débil, pierdes impacto.",
  },
  {
    question: "¿Qué recibo al terminar?",
    answer:
      "Tu Puntuación de Influencia Ejecutiva (0-100), un análisis de tus fortalezas y áreas de mejora en Claridad Estratégica, Presencia Ejecutiva y Poder de Negociación, más un plan de acción con pasos concretos.",
  },
  {
    question: "¿Para quién es esta evaluación?",
    answer:
      "Para ejecutivos, directores y empresarios latinoamericanos que trabajan con clientes, juntas o inversionistas en EE.UU. Si hablas bien inglés pero sientes que a veces tu forma de comunicar te resta autoridad, esto es para ti.",
  },
  {
    question: "¿Mis datos son confidenciales?",
    answer:
      "Totalmente. Tus resultados son privados y jamás los compartimos sin tu autorización.",
  },
  {
    question: "¿Qué sigue después de ver mis resultados?",
    answer:
      "Te enviamos un correo con tu reporte completo y la opción de agendar una llamada gratuita de 20 minutos para revisar tu plan personalizado.",
  },
];

// Datos de testimonios
const testimonials = [
  {
    quote:
      "El coaching de Robert me ayudó a conseguir mi primer asiento en una junta directiva. El framework del 'so what' cambió completamente cómo presento estrategia a inversionistas.",
    name: "María C.",
    title: "VP Estrategia, Startup Tech",
    location: "Ciudad de México",
  },
  {
    quote:
      "Cerré una alianza de $12M usando las técnicas de negociación de este programa. El retorno fue inmediato.",
    name: "Carlos R.",
    title: "Director de Desarrollo de Negocios, SaaS",
    location: "Guadalajara",
  },
  {
    quote:
      "Después de 15 años en tecnología, por fin siento que mi inglés está a la altura de mi experiencia. El entrenamiento de presencia ejecutiva lo cambió todo.",
    name: "Ana L.",
    title: "CTO, Fintech",
    location: "São Paulo",
  },
];
---

<Base
  title={title}
  description={description}
  lang="es"
  tkey="quiz/executives"
  hideCta={true}
  hideNav={true}
>
  <QuizSchema lang="es" slot="head" />

  <section class="hero">
    <img
      src={heroSkyline.src}
      alt="Evaluación de Presencia Ejecutiva"
      class="hero-bg-image"
      loading="eager"
    />
    <div class="hero-overlay"></div>
    <div class="container">
      <div class="hero-content">
        <span class="eyebrow">La Evaluación de 90 Segundos</span>

        <h1>Mide tu Brecha de Liderazgo Bilingüe</h1>

        <p class="discover-label">Vas a descubrir:</p>

        <div class="benefits">
          <div class="benefit">
            <CheckCircle size={20} />
            <span
              >Tu Puntaje Real de Autoridad (vs. tu Puntaje Percibido en Inglés)</span
            >
          </div>
          <div class="benefit">
            <CheckCircle size={20} />
            <span
              >Por qué pierdes tu poder persuasivo en reuniones complejas</span
            >
          </div>
          <div class="benefit">
            <CheckCircle size={20} />
            <span>Tu roadmap para dominar la sala en cualquier idioma</span>
          </div>
        </div>

        <Button
          href="/es/quiz/executives/question/1"
          variant="primary"
          size="lg"
          class="cta-button gold-cta"
        >
          Comenzar Evaluación Gratis →
        </Button>

        <p class="trust-line">
          Breve. Práctico. Con la confianza de más de 200 profesionales buscando
          fluidez y seguridad.
        </p>
      </div>
    </div>
  </section>

  <!-- SECCIÓN 1: El Caso de Negocio (SEO + Conversión) -->
  <section class="business-case-section">
    <div class="container">
      <h2>Tu Inglés Ejecutivo: El Activo de $500K que Nadie Te Enseñó</h2>
      <p class="section-intro">
        Tu expertise técnico te trajo hasta aquí. Tu inglés define qué tan lejos
        llegas.
      </p>

      <div class="cost-grid">
        <div class="cost-item">
          <div class="cost-icon"><TrendingUp size={32} /></div>
          <h3>Ascensos que No Llegan</h3>
          <p>
            El 67% de ejecutivos dice que el inglés es la barrera #1 para
            promover a profesionales no nativos en EE.UU.
          </p>
        </div>
        <div class="cost-item">
          <div class="cost-icon"><Scale size={32} /></div>
          <h3>Negocios que Se Pierden</h3>
          <p>
            Las negociaciones importantes fracasan cuando no sabes disentir con
            diplomacia o cerrar con autoridad.
          </p>
        </div>
        <div class="cost-item">
          <div class="cost-icon"><Mic size={32} /></div>
          <h3>Influencia Diluida</h3>
          <p>
            Presentaciones largas o sin claridad estratégica te cuestan
            credibilidad—y aliados clave.
          </p>
        </div>
        <div class="cost-item">
          <div class="cost-icon"><Clock size={32} /></div>
          <h3>Carrera en Cámara Lenta</h3>
          <p>
            ¿La diferencia entre director y VP? Muchas veces son 60 segundos de
            presencia ejecutiva.
          </p>
        </div>
      </div>

      <div class="monetary-reality">
        <p>
          <strong>Hablemos de dinero:</strong> La diferencia entre VP y C-suite en
          EE.UU. es de <strong>$200K-$500K al año.</strong> Si tus brechas de comunicación
          retrasan tu ascenso 2 años, estamos hablando de <strong
            >$1M en oportunidad perdida.</strong
          >
        </p>
      </div>

      <div class="section-cta">
        <Button
          href="/es/quiz/executives/question/1"
          variant="primary"
          size="lg"
          class="gold-cta"
        >
          Descubre Tus Brechas en 90 Segundos →
        </Button>
      </div>
    </div>
  </section>

  <!-- SECCIÓN 2: Las 3 Brechas Ejecutivas (Rico en Palabras Clave) -->
  <section class="gaps-section">
    <div class="container">
      <h2>Las 3 Brechas que Separan a los Gerentes de los Líderes C-Suite</h2>
      <p class="section-intro">
        Esta evaluación mide exactamente lo que juntas, inversionistas y
        ejecutivos en EE.UU. evalúan para decidir si estás listo para el
        siguiente nivel.
      </p>

      <div class="gap-cards">
        <div class="gap-card">
          <div class="gap-header">
            <Target size={40} class="gap-icon" />
            <h3>Brecha #1: Claridad Estratégica</h3>
            <span class="gap-subtitle">¿Puedes ir al grano en 60 segundos?</span
            >
          </div>
          <p class="gap-description">
            Comunicar como ejecutivo no es decir más—es decir menos, con
            precisión quirúrgica.
          </p>
          <div class="what-we-measure">
            <h4>Lo que medimos:</h4>
            <ul>
              <li>
                Tu capacidad de resumir estrategias complejas en 60 segundos
              </li>
              <li>Si lideras con la conclusión o con el contexto</li>
              <li>Cuánto "relleno" usas que delata inseguridad</li>
            </ul>
          </div>
          <p class="why-matters">
            <strong>Por qué importa:</strong> Un CEO te da 7 minutos de atención
            en tu revisión trimestral. Si empiezas con antecedentes en vez de impacto,
            ya perdiste la sala.
          </p>
        </div>

        <div class="gap-card">
          <div class="gap-header">
            <Mic size={40} class="gap-icon" />
            <h3>Brecha #2: Presencia Ejecutiva</h3>
            <span class="gap-subtitle">Autoridad, no disculpas</span>
          </div>
          <p class="gap-description">
            Tu tono, tu ritmo y las palabras que eliges revelan si perteneces al
            C-suite—o si "aún te falta desarrollo."
          </p>
          <div class="what-we-measure">
            <h4>Lo que medimos:</h4>
            <ul>
              <li>
                Lenguaje dubitativo ("creo que," "tal vez," "solo quería")
              </li>
              <li>Autoridad vocal y uso de pausas intencionales</li>
              <li>Patrones de sobre-explicación vs. confianza</li>
            </ul>
          </div>
          <p class="why-matters">
            <strong>Por qué importa:</strong> Los estudios muestran que los no nativos
            sobre-explican 40% más que los nativos—y eso se lee como inseguridad,
            no como minuciosidad.
          </p>
        </div>

        <div class="gap-card">
          <div class="gap-header">
            <Scale size={40} class="gap-icon" />
            <h3>Brecha #3: Poder de Negociación</h3>
            <span class="gap-subtitle">Cerrar sin ceder terreno</span>
          </div>
          <p class="gap-description">
            Las negociaciones importantes requieren que puedas disentir con
            elegancia, manejar objeciones y mantener tu posición—sin quemar
            puentes.
          </p>
          <div class="what-we-measure">
            <h4>Lo que medimos:</h4>
            <ul>
              <li>Tu habilidad para interrumpir o redirigir con suavidad</li>
              <li>Lenguaje asertivo que mantiene la calidez</li>
              <li>Técnicas de cierre que crean urgencia sin presionar</li>
            </ul>
          </div>
          <p class="why-matters">
            <strong>Por qué importa:</strong> En la cultura de negocios de EE.UU.,
            "educado" puede confundirse con "fácil de manipular." Los que cierran
            tratos de 8 cifras saben ser firmes sin ser agresivos.
          </p>
        </div>
      </div>

      <div class="section-cta">
        <Button
          href="/es/quiz/executives/question/1"
          variant="primary"
          size="lg"
          class="gold-cta"
        >
          Tomar la Evaluación de 90 Segundos →
        </Button>
      </div>
    </div>
  </section>

  <!-- SECCIÓN 3: Para Quién Es (SEO + Calificación) -->
  <section class="who-section">
    <div class="container">
      <h2>¿Esta Evaluación Es Para Ti?</h2>

      <div class="who-grid">
        <div class="who-card designed-for">
          <h3>Diseñada para:</h3>
          <ul>
            <li>
              <strong>Ejecutivos latinoamericanos</strong> que trabajan con clientes,
              juntas o inversionistas en EE.UU.
            </li>
            <li>
              <strong>VPs y Directores</strong> que van por un puesto C-suite
            </li>
            <li>
              <strong>Empresarios y founders</strong> negociando alianzas o levantando
              capital
            </li>
            <li>
              <strong>Expertos técnicos</strong> (ingenieros, científicos, financieros)
              dando el salto a liderazgo
            </li>
            <li>
              <strong>Profesionales bilingües</strong> que dominan el inglés pero
              quieren el nivel ejecutivo
            </li>
          </ul>
        </div>

        <div class="who-card ready-if">
          <h3>Es para ti si:</h3>
          <ul class="checkmark-list">
            <li>
              Hablas bien inglés pero sientes que tu acento o forma de
              expresarte a veces te resta autoridad
            </li>
            <li>
              Te han dicho que "das muchos detalles" o que "necesitas ir más al
              grano"
            </li>
            <li>
              Te defiendes en inglés casual pero batallas en negociaciones de
              alto nivel o presentaciones a la junta
            </li>
            <li>
              Vas por un ascenso que te pondrá frente a más stakeholders en
              EE.UU.
            </li>
            <li>
              Ya tomaste cursos de inglés de negocios pero necesitas algo
              específico para ejecutivos
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- SECCIÓN 4: Tabla de Comparación -->
  <section class="comparison-section">
    <div class="container">
      <h2>
        Gerentes vs. Líderes C-Suite: La Diferencia Está en Cómo Comunican
      </h2>
      <p class="section-intro">
        Los ejecutivos que dominan salas de juntas no solo hablan inglés—lo usan
        como herramienta estratégica.
      </p>

      <div class="comparison-table-wrapper">
        <table class="comparison-table">
          <thead>
            <tr>
              <th>Lo que hacen los gerentes</th>
              <th>Lo que hacen los ejecutivos</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>Sobre-explican para compensar su acento o inseguridad</td>
              <td>Dan updates de 60 segundos sin relleno</td>
            </tr>
            <tr>
              <td>Usan lenguaje dubitativo ("tal vez," "creo," "quizás")</td>
              <td>Capturan atención con afirmaciones directas</td>
            </tr>
            <tr>
              <td>Les cuesta interrumpir o redirigir a stakeholders senior</td>
              <td>Redirigen conversaciones con autoridad y tacto</td>
            </tr>
            <tr>
              <td>Ceden terreno rápido para evitar conflicto</td>
              <td>Negocian firme sin dañar relaciones</td>
            </tr>
            <tr>
              <td>Pierden ascensos a pesar de su expertise</td>
              <td>Construyen influencia intercultural al instante</td>
            </tr>
          </tbody>
        </table>
      </div>

      <p class="comparison-conclusion">
        <strong>¿La diferencia?</strong> Entrenamiento de comunicación ejecutiva
        diseñado para los retos específicos que enfrentamos los no nativos en la
        cultura de negocios de EE.UU.
      </p>

      <div class="section-cta">
        <Button
          href="/es/quiz/executives/question/1"
          variant="primary"
          size="lg"
          class="gold-cta"
        >
          Encuentra Tus Brechas. Corrígelas. Lidera. →
        </Button>
      </div>
    </div>
  </section>

  <!-- SECCIÓN 5: Prueba Social / Testimonios -->
  <section class="testimonials-section">
    <div class="container">
      <h2>+200 Ejecutivos Ya Dieron el Paso</h2>

      <div class="testimonials-grid">
        {
          testimonials.map((testimonial) => (
            <div class="testimonial-card">
              <blockquote>"{testimonial.quote}"</blockquote>
              <div class="testimonial-author">
                <strong>{testimonial.name}</strong>
                <span>{testimonial.title}</span>
                <span class="location">{testimonial.location}</span>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- SECCIÓN 6: FAQ (Mina de Oro SEO) -->
  <section class="faq-section">
    <div class="container">
      <h2>Preguntas Frecuentes</h2>
      {
        faqs.map((faq) => (
          <details class="faq-item">
            <summary>
              <h3>{faq.question}</h3>
              <ChevronDown size={20} class="chevron" />
            </summary>
            <div class="faq-answer">
              <p>{faq.answer}</p>
            </div>
          </details>
        ))
      }
    </div>
  </section>

  <!-- SECCIÓN 7: CTA Final (Cierre Fuerte) -->
  <section class="final-cta-section">
    <div class="container">
      <h2>No Dejes que Tu Comunicación Te Cueste el Próximo Ascenso</h2>
      <p class="final-cta-text">
        Los ejecutivos que lideran con claridad, negocian con autoridad y
        dominan salas de juntas no llegaron ahí por casualidad. Dominaron las
        habilidades de comunicación que la cultura de negocios en EE.UU. exige.
      </p>
      <p class="final-cta-highlight">
        Tu evaluación de 90 segundos empieza ahora.
      </p>
      <div class="cta-center">
        <Button
          href="/es/quiz/executives/question/1"
          variant="primary"
          size="lg"
          class="gold-cta"
        >
          Tomar la Evaluación →
        </Button>
      </div>
      <p class="trust-final">
        90 segundos. Resultados al instante. Sin riesgo. +200 ejecutivos ya la
        tomaron.
      </p>
    </div>
  </section>

  <style>
    /* Hero Section with Background Image */
    .hero {
      position: relative;
      padding: 10rem 1.5rem 6rem;
      min-height: 100vh;
      display: flex;
      align-items: center;
      overflow: hidden;
    }

    .hero-bg-image {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: center;
      z-index: 0;
    }

    /* Mobile: shift image right to show Empire State Building */
    @media (max-width: 767px) {
      .hero-bg-image {
        object-position: 75% center;
      }
    }

    .hero-overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(
        135deg,
        rgba(15, 23, 42, 0.5) 0%,
        rgba(30, 41, 59, 0.4) 100%
      );
      z-index: 1;
    }

    @media (min-width: 768px) {
      .hero-overlay {
        background: linear-gradient(
          to right,
          rgba(15, 23, 42, 0.65) 0%,
          rgba(15, 23, 42, 0.55) 50%,
          rgba(30, 41, 59, 0.45) 100%
        );
      }
    }

    .container {
      max-width: 1200px;
      margin: 0 auto;
      width: 100%;
      position: relative;
      z-index: 2;
    }

    .hero-content {
      max-width: 650px;
      display: flex;
      flex-direction: column;
      gap: 1.5rem;
    }

    @media (min-width: 1024px) {
      .hero-content {
        max-width: 700px;
      }
    }

    .eyebrow {
      display: inline-block;
      font-size: 0.875rem;
      font-weight: 700;
      color: #0f172a;
      background: rgba(251, 191, 36, 0.95);
      padding: 0.625rem 1.25rem;
      border-radius: 9999px;
      width: fit-content;
      box-shadow: 0 4px 12px rgba(251, 191, 36, 0.3);
      letter-spacing: 0.025em;
      text-transform: uppercase;
    }

    h1 {
      font-size: 2.5rem;
      font-weight: 900;
      line-height: 1.1;
      color: #ffffff;
      margin: 0;
      text-shadow: 0 2px 8px rgba(0, 0, 0, 0.3);
    }

    @media (min-width: 768px) {
      h1 {
        font-size: 3.5rem;
      }
    }

    @media (min-width: 1024px) {
      h1 {
        font-size: 4rem;
      }
    }

    .discover-label {
      font-size: 1.125rem;
      color: #f1f5f9;
      margin: 0 0 0.5rem 0;
      font-weight: 500;
      text-shadow: 0px 1px 3px rgba(0, 0, 0, 0.8);
    }

    .benefits {
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
      margin: 1rem 0;
    }

    .benefit {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      font-size: 1.0625rem;
      color: #ffffff;
      font-weight: 500;
      text-shadow: 0px 1px 3px rgba(0, 0, 0, 0.8);
    }

    .benefit :global(svg) {
      color: #10b981;
      flex-shrink: 0;
      filter: drop-shadow(0 2px 4px rgba(16, 185, 129, 0.5));
    }

    .trust-line {
      font-size: 0.9375rem;
      color: #cbd5e1;
      text-align: center;
      margin-top: 1rem;
      font-weight: 500;
      text-shadow: 0px 1px 2px rgba(0, 0, 0, 0.6);
    }

    /* Gold CTA Button Override */
    :global(.gold-cta) {
      background: linear-gradient(135deg, #fbbf24 0%, #f59e0b 100%) !important;
      color: #0f172a !important;
      font-weight: 700 !important;
      box-shadow: 0 4px 16px rgba(251, 191, 36, 0.4) !important;
      border: none !important;
    }

    :global(.gold-cta:hover) {
      background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%) !important;
      transform: translateY(-2px);
      box-shadow: 0 6px 20px rgba(251, 191, 36, 0.5) !important;
    }

    /* Shared Section Styles */
    .section-intro {
      font-size: 1.125rem;
      color: #475569;
      text-align: center;
      max-width: 800px;
      margin: 0 auto 2.5rem;
      line-height: 1.7;
    }

    .section-cta {
      text-align: center;
      margin-top: 2.5rem;
    }

    .cta-center {
      text-align: center;
      margin-top: 2rem;
    }

    /* SECTION 1: Business Case */
    .business-case-section {
      padding: 4rem 1.5rem;
      background: white;
    }

    .business-case-section h2 {
      font-size: 2rem;
      font-weight: 700;
      color: #1e293b;
      text-align: center;
      margin-bottom: 1rem;
    }

    .cost-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 1.5rem;
      max-width: 1000px;
      margin: 0 auto 2.5rem;
    }

    @media (min-width: 768px) {
      .cost-grid {
        grid-template-columns: repeat(2, 1fr);
      }
    }

    @media (min-width: 1024px) {
      .cost-grid {
        grid-template-columns: repeat(4, 1fr);
      }
    }

    .cost-item {
      background: #f8fafc;
      border: 1px solid #e2e8f0;
      border-radius: 1rem;
      padding: 1.5rem;
      text-align: center;
    }

    .cost-icon {
      margin-bottom: 1rem;
      color: #ef4444;
    }

    .cost-item h3 {
      font-size: 1.125rem;
      font-weight: 600;
      color: #1e293b;
      margin-bottom: 0.5rem;
    }

    .cost-item p {
      font-size: 0.9375rem;
      color: #475569;
      line-height: 1.5;
      margin: 0;
    }

    .monetary-reality {
      background: linear-gradient(135deg, #fef3c7 0%, #fde68a 100%);
      border: 2px solid #f59e0b;
      border-radius: 1rem;
      padding: 1.5rem 2rem;
      max-width: 800px;
      margin: 0 auto;
