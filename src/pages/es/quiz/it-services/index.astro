---
/**
 * IT English Assessment Landing Page - Spanish
 * URL: /es/quiz/it-services/
 * Target Keyword: Inglés para Profesionales de TI / Comunicación Técnica
 */
export const prerender = true;

import Base from "@layouts/Base.astro";
import Button from "@components/ui/Button.astro";
import QuizSchema from "@components/seo/QuizSchema.astro";
import {
  CheckCircle,
  Clock,
  TrendingUp,
  ChevronDown,
  MessageSquare,
  Zap,
  Globe,
  GitPullRequest,
  Users,
} from "lucide-astro";
import heroSkyline from "@assets/images/home/new-york-city-skyline.webp";

// SEO metadata
const title =
  "Puntaje de Autoridad Técnica | Evaluación para Senior Developers";
const description =
  "Tu código es nivel Senior. Tu inglés suena Junior. ¿Una barrera de idioma está limitando tu crecimiento a Staff Engineer? Mide tu Puntaje de Persuasión Técnica en 90 segundos.";

// FAQ data
const faqs = [
  {
    question: "¿Cuánto tiempo toma la evaluación?",
    answer:
      "90 segundos. Responderás 6 preguntas específicas y recibirás tu Puntaje de Autoridad Técnica (0-100) junto con un análisis personalizado de tus brechas inmediatamente después.",
  },
  {
    question: "¿Esto es otro examen de gramática o acento?",
    answer:
      "No. Esta evaluación mide los patrones de comunicación que determinan la velocidad de tu promoción—cómo explicas decisiones de arquitectura, lideras code reviews, e influyes en la dirección técnica. La gramática y el acento son irrelevantes si tus ideas consistentemente quedan en segundo plano.",
  },
  {
    question: "¿Qué voy a recibir después de completar la evaluación?",
    answer:
      "Tu Puntaje de Autoridad Técnica (0-100), análisis de tus fortalezas y brechas en tres dimensiones (Traducción Técnica, Velocidad de Procesamiento, y Calibración Cultural), más un roadmap personalizado de 30 días con ejercicios específicos para acelerar tu dominio de comunicación.",
  },
  {
    question: "¿Para quién es esta evaluación?",
    answer:
      "Senior developers, ingenieros de software y tech leads que trabajan con equipos de Norteamérica—ya sea en FAANG, startups, o empresas remote-first. Si eres técnicamente fuerte pero tus ideas no tienen la tracción que merecen, esta evaluación es para ti.",
  },
  {
    question: "¿Me va a ayudar a pasar entrevistas de FAANG?",
    answer:
      "Sí. Las entrevistas de Big Tech no son solo sobre algoritmos—evalúan tu capacidad de pensar en voz alta, explicar trade-offs, y colaborar bajo presión. Esta evaluación identifica tus brechas de 'velocidad de procesamiento' y te da un roadmap para mejorar tu desempeño en entrevistas.",
  },
  {
    question: "¿Qué pasa después de obtener mis resultados?",
    answer:
      "Recibirás un email con tu scorecard detallado y la opción de agendar una consulta gratuita de 20 minutos para discutir tu roadmap personalizado hacia la comunicación de liderazgo técnico.",
  },
];

// Testimonials data
const testimonials = [
  {
    quote:
      "Pasé de ser 'el senior callado' a liderar discusiones de arquitectura en 3 meses. Los ejercicios de velocidad de procesamiento cambiaron todo.",
    name: "Miguel S.",
    title: "Staff Engineer, Fintech Startup",
    location: "CDMX → Remoto (EE.UU.)",
  },
  {
    quote:
      "Fallé 3 entrevistas de FAANG antes de esto. Por fin entendí por qué—mis explicaciones eran técnicamente correctas pero 2x más largas de lo necesario. Entré a Google en el siguiente intento.",
    name: "Ana R.",
    title: "Software Engineer, Google",
    location: "São Paulo → Bay Area",
  },
  {
    quote:
      "Mis PRs se quedaban enterrados. Ahora soy yo quien los aprueba. El módulo de calibración cultural fue un game-changer para la comunicación async.",
    name: "Carlos M.",
    title: "Tech Lead, SaaS Serie B",
    location: "Guadalajara",
  },
];
---

<Base
  title={title}
  description={description}
  lang="es"
  tkey="quiz/it-services"
  hideCta={true}
  hideNav={true}
>
  <QuizSchema lang="es" slot="head" />

  <!-- Hero Section -->
  <section class="hero">
    <img
      src={heroSkyline.src}
      alt="Evaluación de Comunicación Técnica"
      class="hero-bg-image"
      loading="eager"
    />
    <div class="hero-overlay"></div>
    <div class="container">
      <div class="hero-content">
        <span class="eyebrow"
          >Tu código es nivel Senior. Tu inglés suena Junior.</span
        >

        <h1>
          La Evaluación de 90 Segundos: ¿Una Barrera de Idioma Está Limitando tu
          Crecimiento a Staff Engineer?
        </h1>

        <p class="discover-label">Tres cosas que vas a descubrir:</p>

        <div class="benefits">
          <div class="benefit">
            <CheckCircle size={20} />
            <span>Tu Puntaje de Persuasión Técnica (0-100)</span>
          </div>
          <div class="benefit">
            <CheckCircle size={20} />
            <span
              >Por qué tus propuestas de arquitectura mueren en la traducción</span
            >
          </div>
          <div class="benefit">
            <CheckCircle size={20} />
            <span
              >El roadmap para explicar tecnología compleja a ejecutivos no
              técnicos</span
            >
          </div>
        </div>

        <Button
          href="/es/quiz/it-services/question/1"
          variant="primary"
          size="lg"
          class="cta-button gold-cta"
        >
          Comenzar Evaluación Gratis →
        </Button>

        <p class="trust-line">
          Breve. Práctico. Con la confianza de más de 200 profesionales buscando
          fluidez y seguridad.
        </p>
      </div>
    </div>
  </section>

  <!-- SECTION 1: The Business Case -->
  <section class="business-case-section">
    <div class="container">
      <h2>Tu Autoridad Técnica: El Activo de $150K que Nadie Te Enseñó</h2>
      <p class="section-intro">
        Tu LeetCode está afilado. Tu system design es sólido. Pero los
        ingenieros que ascienden no siempre son los mejores programadores—son
        los que logran que sus ideas se escuchen.
      </p>

      <div class="cost-grid">
        <div class="cost-item">
          <div class="cost-icon"><TrendingUp size={32} /></div>
          <h3>Atorado en Senior</h3>
          <p>
            La promoción IC5 → Staff tiene 70% de tasa de fallo. La habilidad
            técnica es el mínimo—la comunicación es lo que te diferencia.
          </p>
        </div>
        <div class="cost-item">
          <div class="cost-icon"><GitPullRequest size={32} /></div>
          <h3>PRs Enterrados</h3>
          <p>
            Tus pull requests se aprueban, pero tus RFCs y propuestas de
            arquitectura quedan "depriorizados" o en bikeshedding eterno.
          </p>
        </div>
        <div class="cost-item">
          <div class="cost-icon"><Users size={32} /></div>
          <h3>Invisible en Juntas</h3>
          <p>
            Para cuando formulas tu punto en inglés, alguien más ya dijo algo
            similar—y se lleva el crédito.
          </p>
        </div>
        <div class="cost-item">
          <div class="cost-icon"><Clock size={32} /></div>
          <h3>Techo en Entrevistas</h3>
          <p>
            Pasas las rondas de código pero te rechazan por "comunicación" en
            system design y entrevistas de comportamiento.
          </p>
        </div>
      </div>

      <div class="monetary-reality">
        <p>
          <strong>Haz las cuentas:</strong> La diferencia entre Senior y Staff en
          FAANG es de <strong>$150K-$300K al año</strong> en compensación total.
          Si tus brechas de comunicación retrasan tu promoción 2 años, estamos hablando
          de <strong>$500K en oportunidad perdida.</strong>
        </p>
      </div>

      <div class="section-cta">
        <Button
          href="/es/quiz/it-services/question/1"
          variant="primary"
          size="lg"
          class="gold-cta"
        >
          Descubre Tus Brechas de Comunicación en 90 Segundos →
        </Button>
      </div>
    </div>
  </section>

  <!-- SECTION 2: The 3 Gaps -->
  <section class="gaps-section">
    <div class="container">
      <h2>
        Las 3 Dimensiones de Comunicación que Separan a los Senior Devs de los
        Staff Engineers
      </h2>
      <p class="section-intro">
        Esta evaluación mide las habilidades exactas que distinguen a los
        ingenieros que ascienden de los que solo reciben "más scope."
      </p>

      <div class="gap-cards">
        <div class="gap-card">
          <div class="gap-header">
            <MessageSquare size={40} class="gap-icon" />
            <h3>Brecha #1: Traducción Técnica</h3>
            <span class="gap-subtitle"
              >Complejidad → Claridad en 60 Segundos</span
            >
          </div>
          <p class="gap-description">
            Los Staff engineers no solo entienden sistemas—traducen la
            complejidad para PMs, ejecutivos, y stakeholders de otras áreas sin
            perder precisión técnica.
          </p>
          <div class="what-we-measure">
            <h4>Lo que medimos:</h4>
            <ul>
              <li>
                Capacidad de explicar deuda técnica a un CFO en términos de
                negocio
              </li>
              <li>
                Resumir decisiones de arquitectura en actualizaciones de 60
                segundos
              </li>
              <li>
                Escribir RFCs que se aprueban, no hilos interminables de
                comentarios
              </li>
            </ul>
          </div>
          <p class="why-matters">
            <strong>Por qué importa:</strong> Tu director tiene 5 minutos para tu
            revisión trimestral. Si empiezas con detalles de implementación en vez
            de impacto de negocio, ya perdiste la conversación de promoción.
          </p>
        </div>

        <div class="gap-card">
          <div class="gap-header">
            <Zap size={40} class="gap-icon" />
            <h3>Brecha #2: Velocidad de Procesamiento</h3>
            <span class="gap-subtitle">Autoridad Técnica en Tiempo Real</span>
          </div>
          <p class="gap-description">
            En code reviews, respuesta a incidentes, y discusiones de
            arquitectura, la duda se lee como incertidumbre. Tu velocidad de
            "pensar en inglés" impacta directamente tu autoridad técnica
            percibida.
          </p>
          <div class="what-we-measure">
            <h4>Lo que medimos:</h4>
            <ul>
              <li>
                Latencia de respuesta en discusiones técnicas de alta presión
              </li>
              <li>
                Capacidad de pensar en voz alta durante entrevistas de system
                design
              </li>
              <li>Patrones de confianza en sesiones de debugging en vivo</li>
            </ul>
          </div>
          <p class="why-matters">
            <strong>Por qué importa:</strong> En un incidente de producción, el ingeniero
            que habla primero moldea la respuesta. Si todavía estás traduciendo mientras
            otros deciden, no estás liderando.
          </p>
        </div>

        <div class="gap-card">
          <div class="gap-header">
            <Globe size={40} class="gap-icon" />
            <h3>Brecha #3: Calibración Cultural</h3>
            <span class="gap-subtitle">Navegando las Reglas No Escritas</span>
          </div>
          <p class="gap-description">
            La cultura tech de Norteamérica tiene reglas no escritas: ser
            directo sin ser agresivo, "disagree and commit," comunicación
            async-first. Estos patrones no se enseñan—se absorben.
          </p>
          <div class="what-we-measure">
            <h4>Lo que medimos:</h4>
            <ul>
              <li>
                Tono en comentarios de PR (constructivo vs. percibido como duro
                o pasivo)
              </li>
              <li>
                Capacidad de hacer pushback a ingenieros senior diplomáticamente
              </li>
              <li>
                Patrones de comunicación en Slack/async que construyen
                influencia
              </li>
            </ul>
          </div>
          <p class="why-matters">
            <strong>Por qué importa:</strong> Un comentario de code review técnicamente
            correcto puede dañar tu reputación si el tono se siente fuera de lugar.
            Los ingenieros que ascienden saben ser directos sin ser ignorados.
          </p>
        </div>
      </div>

      <div class="section-cta">
        <Button
          href="/es/quiz/it-services/question/1"
          variant="primary"
          size="lg"
          class="gold-cta"
        >
          Tomar la Evaluación de 90 Segundos →
        </Button>
      </div>
    </div>
  </section>

  <!-- SECTION 3: Who This Is For -->
  <section class="who-section">
    <div class="container">
      <h2>¿Esta Evaluación Es Para Ti?</h2>

      <div class="who-grid">
        <div class="who-card designed-for">
          <h3>Esta evaluación está diseñada para:</h3>
          <ul>
            <li>
              <strong>Senior developers (IC4-IC5)</strong> en FAANG, Big Tech, o
              startups de alto crecimiento
            </li>
            <li>
              <strong>Tech leads y engineering managers</strong> que lideran equipos
              distribuidos o multiculturales
            </li>
            <li>
              <strong>Ingenieros remotos</strong> trabajando async-first con empresas
              de Norteamérica
            </li>
            <li>
              <strong
                >Ingenieros preparándose para entrevistas de Big Tech</strong
              >
              que quieren dominar la barra de comunicación
            </li>
            <li>
              <strong>Desarrolladores internacionales</strong> con fuertes habilidades
              técnicas pero inglés como segundo idioma
            </li>
          </ul>
        </div>

        <div class="who-card ready-if">
          <h3>Estás listo para esta evaluación si:</h3>
          <ul class="checkmark-list">
            <li>
              Eres técnicamente fuerte pero tus ideas no tienen la tracción que
              merecen
            </li>
            <li>
              Te han dicho que eres "muy callado" en juntas o que necesitas
              "participar más"
            </li>
            <li>
              Puedes debuggear cualquier cosa pero batallas para explicar tu
              enfoque en tiempo real
            </li>
            <li>
              Tu inglés escrito es sólido, pero te trabas en discusiones en vivo
            </li>
            <li>
              Te han pasado por alto para Staff o Tech Lead a pesar de tu fuerte
              output técnico
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- SECTION 4: Comparison Table -->
  <section class="comparison-section">
    <div class="container">
      <h2>La Brecha de Comunicación Entre Senior Devs y Staff Engineers</h2>
      <p class="section-intro">
        Los ingenieros que llegan a Staff+ no solo escriben mejor código—se
        comunican con un sistema operativo diferente.
      </p>

      <div class="comparison-table-wrapper">
        <table class="comparison-table">
          <thead>
            <tr>
              <th>Patrones de Senior Developer</th>
              <th>Comunicación de Staff Engineer</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>Sobre-explicar para demostrar profundidad técnica</td>
              <td>Liderar con el "y qué" y dejar que otros pidan detalles</td>
            </tr>
            <tr>
              <td>Esperar el "momento correcto" para hablar (nunca llega)</td>
              <td>Intervenir temprano con puntos estructurados y concisos</td>
            </tr>
            <tr>
              <td>Escribir RFCs técnicamente exhaustivos pero ignorados</td>
              <td>Escribir RFCs que construyen consenso antes de publicarse</td>
            </tr>
            <tr>
              <td>Ponerse a la defensiva cuando cuestionan tu arquitectura</td>
              <td>Disagree and commit con framing explícito de trade-offs</td>
            </tr>
            <tr>
              <td>Pasar rondas de código pero fallar en "comunicación"</td>
              <td>Pensar en voz alta de manera que demuestra liderazgo</td>
            </tr>
          </tbody>
        </table>
      </div>

      <p class="comparison-conclusion">
        <strong>¿La diferencia?</strong> Los Staff engineers aprendieron a comunicarse
        como líderes. Es una habilidad que se puede entrenar—si conoces tus brechas.
      </p>

      <div class="section-cta">
        <Button
          href="/es/quiz/it-services/question/1"
          variant="primary"
          size="lg"
          class="gold-cta"
        >
          Encuentra Tus Brechas. Arreglálas. Asciende. →
        </Button>
      </div>
    </div>
  </section>

  <!-- SECTION 5: Testimonials -->
  <section class="testimonials-section">
    <div class="container">
      <h2>+200 Senior Engineers Ya Dieron el Paso</h2>

      <div class="testimonials-grid">
        {
          testimonials.map((testimonial) => (
            <div class="testimonial-card">
              <blockquote>"{testimonial.quote}"</blockquote>
              <div class="testimonial-author">
                <strong>{testimonial.name}</strong>
                <span>{testimonial.title}</span>
                <span class="location">{testimonial.location}</span>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- SECTION 6: FAQ -->
  <section class="faq-section">
    <div class="container">
      <h2>Preguntas Frecuentes</h2>
      {
        faqs.map((faq) => (
          <details class="faq-item">
            <summary>
              <h3>{faq.question}</h3>
              <ChevronDown size={20} class="chevron" />
            </summary>
            <div class="faq-answer">
              <p>{faq.answer}</p>
            </div>
          </details>
        ))
      }
    </div>
  </section>

  <!-- SECTION 7: Final CTA -->
  <section class="final-cta-section">
    <div class="container">
      <h2>Tu Código Ya Es Suficientemente Bueno para Staff</h2>
      <p class="final-cta-text">
        Los ingenieros que ascienden a Staff, Principal, y más allá no siempre
        son los mejores programadores. Son los que aprendieron a traducir
        excelencia técnica en influencia organizacional. Los que logran que sus
        ideas no solo se implementen—moldeen la dirección.
      </p>
      <p class="final-cta-highlight">
        Tu evaluación de 90 segundos empieza ahora.
      </p>
      <div class="cta-center">
        <Button
          href="/es/quiz/it-services/question/1"
          variant="primary"
          size="lg"
          class="gold-cta"
        >
          Tomar la Evaluación →
        </Button>
      </div>
      <p class="trust-final">
        90 segundos. Resultados instantáneos. Cero riesgo. Ingenieros de Google,
        Meta, Amazon, y más de 50 startups confían en nosotros.
      </p>
    </div>
  </section>

  <style>
    /* Hero Section with Background Image */
    .hero {
      position: relative;
      padding: 10rem 1.5rem 6rem;
      min-height: 100vh;
      display: flex;
      align-items: center;
      overflow: hidden;
    }

    .hero-bg-image {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: center;
      z-index: 0;
    }

    /* Mobile: shift image right to show Empire State Building */
    @media (max-width: 767px) {
      .hero-bg-image {
        object-position: 75% center;
      }
    }

    .hero-overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(
        135deg,
        rgba(15, 23, 42, 0.5) 0%,
        rgba(30, 41, 59, 0.4) 100%
      );
      z-index: 1;
    }

    @media (min-width: 768px) {
      .hero-overlay {
        background: linear-gradient(
          to right,
          rgba(15, 23, 42, 0.65) 0%,
          rgba(15, 23, 42, 0.55) 50%,
          rgba(30, 41, 59, 0.45) 100%
        );
      }
    }

    .container {
      max-width: 1200px;
      margin: 0 auto;
      width: 100%;
      position: relative;
      z-index: 2;
    }

    .hero-content {
      max-width: 650px;
      display: flex;
      flex-direction: column;
      gap: 1.5rem;
    }

    @media (min-width: 1024px) {
      .hero-content {
        max-width: 700px;
      }
    }

    .eyebrow {
      display: inline-block;
      font-size: 0.875rem;
      font-weight: 700;
      color: #0f172a;
      background: rgba(251, 191, 36, 0.95);
      padding: 0.625rem 1.25rem;
      border-radius: 9999px;
      width: fit-content;
      box-shadow: 0 4px 12px rgba(251, 191, 36, 0.3);
      letter-spacing: 0.025em;
      text-transform: uppercase;
    }

    h1 {
      font-size: 2.5rem;
      font-weight: 900;
      line-height: 1.1;
      color: #ffffff;
      margin: 0;
      text-shadow: 0 2px 8px rgba(0, 0, 0, 0.3);
    }

    @media (min-width: 768px) {
      h1 {
        font-size: 3.5rem;
      }
    }

    @media (min-width: 1024px) {
      h1 {
        font-size: 4rem;
      }
    }

    .discover-label {
      font-size: 1.125rem;
      color: #f1f5f9;
      margin: 0 0 0.5rem 0;
      font-weight: 500;
      text-shadow: 0px 1px 3px rgba(0, 0, 0, 0.8);
    }

    .benefits {
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
      margin: 1rem 0;
    }

    .benefit {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      font-size: 1.0625rem;
      color: #ffffff;
      font-weight: 500;
      text-shadow: 0px 1px 3px rgba(0, 0, 0, 0.8);
    }

    .benefit :global(svg) {
      color: #10b981;
      flex-shrink: 0;
      filter: drop-shadow(0 2px 4px rgba(16, 185, 129, 0.5));
    }

    .trust-line {
      font-size: 0.9375rem;
      color: #cbd5e1;
      text-align: center;
      margin-top: 1rem;
      font-weight: 500;
      text-shadow: 0px 1px 2px rgba(0, 0, 0, 0.6);
    }

    /* Gold CTA Button Override */
    :global(.gold-cta) {
      background: linear-gradient(135deg, #fbbf24 0%, #f59e0b 100%) !important;
      color: #0f172a !important;
      font-weight: 700 !important;
      box-shadow: 0 4px 16px rgba(251, 191, 36, 0.4) !important;
      border: none !important;
    }

    :global(.gold-cta:hover) {
      background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%) !important;
      transform: translateY(-2px);
      box-shadow: 0 6px 20px rgba(251, 191, 36, 0.5) !important;
    }

    /* Shared Section Styles */
    .section-intro {
      font-size: 1.125rem;
      color: #475569;
      text-align: center;
      max-width: 800px;
      margin: 0 auto 2.5rem;
      line-height: 1.7;
    }

    .section-cta {
      text-align: center;
      margin-top: 2.5rem;
    }

    .cta-center {
      text-align: center;
      margin-top: 2rem;
    }

    /* SECTION 1: Business Case */
    .business-case-section {
      padding: 4rem 1.5rem;
      background: white;
    }

    .business-case-section h2 {
      font-size: 2rem;
      font-weight: 700;
      color: #1e293b;
      text-align: center;
      margin-bottom: 1rem;
    }

    .cost-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 1.5rem;
      max-width: 1000px;
      margin: 0 auto 2.5rem;
    }

