---
import Base from '@layouts/Base.astro';
import Button from '@components/ui/Button.astro';
import { Mail, Download, Calendar } from 'lucide-astro';

const title = "Tus Resultados de Confianza al Hablar | NY English";
const description = "Obtén tu Puntuación de Confianza en Comunicación personalizada y hoja de ruta de mejora.";
---

<Base 
  title={title} 
  description={description}
  lang="es"
  customCanonical="https://www.nyenglishteacher.com/es/quiz/results/"
  customHreflangs={[
    { lang: "en-US", href: "https://www.nyenglishteacher.com/en/quiz/results/" },
    { lang: "es-MX", href: "https://www.nyenglishteacher.com/es/quiz/results/" }
  ]}
  hideCta={true}
>

<section class="quiz-results pt-28 pb-16 md:pt-32 md:pb-20">
  <div class="container-narrow">
    
    <!-- Lead Capture Form (shown first) -->
    <div class="lead-capture-card" id="lead-capture">
      <div class="capture-header">
        <h1>¡Ya Casi Estás!</h1>
        <p class="capture-subtext">
          Ingresa tu correo para recibir tu Puntuación de Confianza en Comunicación 
          personalizada y hoja de ruta de mejora detallada.
        </p>
      </div>

      <form class="capture-form" id="email-form">
        <div class="form-group">
          <label for="name" class="form-label">Tu Nombre</label>
          <input 
            type="text" 
            id="name" 
            name="name" 
            class="form-input"
            placeholder="Juan Pérez"
            required
          />
        </div>

        <div class="form-group">
          <label for="email" class="form-label">Correo Electrónico</label>
          <input 
            type="email" 
            id="email" 
            name="email" 
            class="form-input"
            placeholder="juan@empresa.com"
            required
          />
        </div>

        <div class="form-group">
          <label for="company" class="form-label">Empresa (Opcional)</label>
          <input 
            type="text" 
            id="company" 
            name="company" 
            class="form-input"
            placeholder="Nombre de Tu Empresa"
          />
        </div>

        <div class="form-group">
          <label for="phone" class="form-label">Número de Teléfono (Opcional)</label>
          <input 
            type="tel" 
            id="phone" 
            name="phone" 
            class="form-input"
            placeholder="+52 (555) 123-4567"
          />
        </div>

        <Button 
          type="submit"
          variant="primary" 
          size="lg"
          class="submit-button"
        >
          <Mail size={20} />
          Obtener Mis Resultados →
        </Button>

        <p class="privacy-text">
          Al enviar este formulario, aceptas nuestra <a href="/es/legal/privacy-policy" target="_blank" class="privacy-link">Política de Privacidad</a>. 
          Respetamos tu privacidad y nunca venderemos tu información.
        </p>
      </form>
    </div>

    <!-- Results Display (shown after email submission) -->
    <div class="results-display" id="results-display" style="display: none;">
      
      <!-- Score Card -->
      <div class="score-card">
        <div class="score-header">
          <h2>Tu Puntuación de Confianza en Comunicación</h2>
          <p class="score-subtitle">Basado en tus respuestas</p>
        </div>

        <div class="score-circle">
          <div class="score-number" id="final-score">0</div>
          <div class="score-max">/ 100</div>
        </div>

        <div class="score-label" id="score-label">Calculando...</div>
        
        <div class="score-description" id="score-description">
          <!-- Dynamically populated based on score -->
        </div>
      </div>

      <!-- Key Findings -->
      <div class="findings-card">
        <h3>Hallazgos Clave</h3>
        <div id="findings-content">
          <!-- Dynamically populated -->
        </div>
      </div>

      <!-- Recommendations -->
      <div class="recommendations-card">
        <h3>Tu Hoja de Ruta Personalizada</h3>
        <div id="recommendations-content">
          <!-- Dynamically populated -->
        </div>
      </div>

      <!-- CTA Section -->
      <div class="results-cta">
        <h3>¿Listo Para Transformar la Comunicación de Tu Equipo?</h3>
        <p>
          Agenda una llamada estratégica gratuita de 30 minutos para discutir tus resultados 
          y crear un plan personalizado para tu equipo.
        </p>
        
        <div class="cta-buttons">
          <Button 
            href="/es/book" 
            variant="primary" 
            size="lg"
          >
            <Calendar size={20} />
            Agendar Llamada Estratégica Gratuita
          </Button>
          
          <Button 
            href="#" 
            variant="secondary" 
            size="lg"
            id="download-pdf"
          >
            <Download size={20} />
            Descargar Reporte Completo
          </Button>
        </div>
      </div>
    </div>

  </div>
</section>

</Base>

<style>
.container-narrow {
  max-width: 900px;
  margin: 0 auto;
  padding: 0 1.5rem;
}

.quiz-results {
  background: linear-gradient(135deg, #f0f9ff 0%, #e0e7ff 100%);
  min-height: calc(100vh - 80px);
}

/* Lead Capture Card */
.lead-capture-card {
  background: white;
  padding: 3rem;
  border-radius: 16px;
  box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
}

.capture-header {
  text-align: center;
  margin-bottom: 2.5rem;
}

.capture-header h1 {
  font-size: 2.5rem;
  font-weight: 700;
  color: #0f172a;
  margin-bottom: 1rem;
}

.capture-subtext {
  font-size: 1.125rem;
  color: #475569;
  line-height: 1.6;
}

.capture-form {
  max-width: 500px;
  margin: 0 auto;
}

.form-group {
  margin-bottom: 1.5rem;
}

.form-label {
  display: block;
  font-size: 0.875rem;
  font-weight: 600;
  color: #334155;
  margin-bottom: 0.5rem;
}

.form-input {
  width: 100%;
  padding: 0.75rem 1rem;
  border: 2px solid #e2e8f0;
  border-radius: 8px;
  font-size: 1rem;
  transition: border-color 0.2s ease;
}

.form-input:focus {
  outline: none;
  border-color: #3b82f6;
  box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.1);
}

.submit-button {
  width: 100%;
  margin-top: 1rem;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 0.5rem;
}

.privacy-text {
  text-align: center;
  font-size: 0.875rem;
  color: #64748b;
  margin-top: 1rem;
  line-height: 1.5;
}

.privacy-link {
  color: #3b82f6;
  text-decoration: underline;
  transition: color 0.2s ease;
}

.privacy-link:hover {
  color: #2563eb;
}

/* Results Display */
.results-display {
  display: flex;
  flex-direction: column;
  gap: 2rem;
}

/* Score Card */
.score-card {
  background: white;
  padding: 3rem;
  border-radius: 16px;
  box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
  text-align: center;
}

.score-header h2 {
  font-size: 1.75rem;
  font-weight: 700;
  color: #0f172a;
  margin-bottom: 0.5rem;
}

.score-subtitle {
  font-size: 1rem;
  color: #64748b;
}

.score-circle {
  margin: 2rem 0;
  display: flex;
  align-items: baseline;
  justify-content: center;
  gap: 0.5rem;
}

.score-number {
  font-size: 5rem;
  font-weight: 700;
  color: #3b82f6;
  line-height: 1;
}

.score-max {
  font-size: 2rem;
  color: #94a3b8;
  font-weight: 600;
}

.score-label {
  font-size: 1.5rem;
  font-weight: 600;
  color: #0f172a;
  margin-bottom: 1rem;
}

.score-description {
  font-size: 1rem;
  color: #475569;
  line-height: 1.6;
  max-width: 600px;
  margin: 0 auto;
}

/* Findings & Recommendations Cards */
.findings-card,
.recommendations-card {
  background: white;
  padding: 2.5rem;
  border-radius: 16px;
  box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
}

.findings-card h3,
.recommendations-card h3 {
  font-size: 1.5rem;
  font-weight: 700;
  color: #0f172a;
  margin-bottom: 1.5rem;
}

/* Results CTA */
.results-cta {
  background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%);
  color: white;
  padding: 3rem;
  border-radius: 16px;
  text-align: center;
}

.results-cta h3 {
  font-size: 2rem;
  font-weight: 700;
  margin-bottom: 1rem;
}

.results-cta p {
  font-size: 1.125rem;
  margin-bottom: 2rem;
  opacity: 0.95;
}

.cta-buttons {
  display: flex;
  gap: 1rem;
  justify-content: center;
  flex-wrap: wrap;
}

@media (max-width: 768px) {
  .lead-capture-card,
  .score-card {
    padding: 2rem 1.5rem;
  }

  .capture-header h1 {
    font-size: 2rem;
  }

  .score-number {
    font-size: 4rem;
  }

  .cta-buttons {
    flex-direction: column;
  }
}
</style>

<script>
// Calculate score and display results
function calculateScore() {
  const answersJson = sessionStorage.getItem('quizAnswers');
  if (!answersJson) {
    // Redirect back to start if no answers
    window.location.href = '/es/quiz/start';
    return;
  }

  const answers = JSON.parse(answersJson);
  const totalPoints = Object.values(answers).reduce((sum: number, val) => sum + (val as number), 0);
  const maxPoints = 100; // 10 questions × 10 points each
  const score = Math.round((totalPoints / maxPoints) * 100);

  return { score, totalPoints };
}

// Handle email form submission
const emailForm = document.getElementById('email-form');
const leadCapture = document.getElementById('lead-capture');
const resultsDisplay = document.getElementById('results-display');

if (emailForm) {
  emailForm.addEventListener('submit', async (e) => {
    e.preventDefault();
    
    const formData = new FormData(emailForm as HTMLFormElement);
    const name = formData.get('name');
    const email = formData.get('email');
    const company = formData.get('company');
    const phone = formData.get('phone');
    
    // Calculate score
    const result = calculateScore();
    if (!result) return;
    
    const { score, totalPoints } = result;
    
    // Store lead data (you'll want to send this to your backend/CRM)
    const leadData = {
      name,
      email,
      company,
      phone,
      score,
      totalPoints,
      timestamp: new Date().toISOString()
    };
    
    console.log('Lead captured:', leadData);
    // TODO: Send to your backend/CRM
    
    // Show results
    if (leadCapture && resultsDisplay) {
      leadCapture.style.display = 'none';
      resultsDisplay.style.display = 'flex';
    }
    
    // Animate score counter
    animateScore(score);
    
    // Display personalized content
    displayResults(score);
  });
}

function animateScore(targetScore: number) {
  const scoreElement = document.getElementById('final-score');
  if (!scoreElement) return;
  
  let current = 0;
  const duration = 2000;
  const startTime = performance.now();
  
  function update(currentTime: number) {
    const elapsed = currentTime - startTime;
    const progress = Math.min(elapsed / duration, 1);
    
    current = Math.floor(progress * targetScore);
    scoreElement.textContent = current.toString();
    
    if (progress < 1) {
      requestAnimationFrame(update);
    } else {
      scoreElement.textContent = targetScore.toString();
    }
  }
  
  requestAnimationFrame(update);
}

function displayResults(score: number) {
  const labelEl = document.getElementById('score-label');
  const descEl = document.getElementById('score-description');
  const findingsEl = document.getElementById('findings-content');
  const recsEl = document.getElementById('recommendations-content');
  
  let label, description, findings, recommendations;
  
  if (score >= 80) {
    label = "Base Sólida";
    description = "Tu equipo tiene habilidades sólidas de comunicación en inglés. Enfócate en refinar técnicas avanzadas para cerrar negocios más grandes y comandar precios premium.";
    findings = `
      <ul style="list-style: none; padding: 0; display: flex; flex-direction: column; gap: 1rem;">
        <li style="padding-left: 1.5rem; position: relative; color: #475569;">
          <span style="position: absolute; left: 0; color: #10b981;">✓</span>
          Tu equipo se comunica claramente en la mayoría de las situaciones
        </li>
        <li style="padding-left: 1.5rem; position: relative; color: #475569;">
          <span style="position: absolute; left: 0; color: #f59e0b;">⚠</span>
          Brechas menores en negociaciones de alta presión o explicaciones complejas
        </li>
        <li style="padding-left: 1.5rem; position: relative; color: #475569;">
          <span style="position: absolute; left: 0; color: #10b981;">✓</span>
          Buena base para escalar tu negocio
        </li>
      </ul>
    `;
    recommendations = `
      <ol style="list-style: decimal; padding-left: 1.5rem; display: flex; flex-direction: column; gap: 1rem; color: #475569;">
        <li>Dominar comunicación de nivel ejecutivo para conversaciones con C-suite</li>
        <li>Refinar lenguaje de negociación para defender precios premium</li>
        <li>Practicar comunicación improvisada para desafíos inesperados de clientes</li>
      </ol>
    `;
  } else if (score >= 60) {
    label = "Espacio para Crecer";
    description = "Tu equipo puede comunicarse, pero la duda e incertidumbre te están costando contratos. La mejora estratégica desbloqueará ingresos significativos.";
    findings = `
      <ul style="list-style: none; padding: 0; display: flex; flex-direction: column; gap: 1rem;">
        <li style="padding-left: 1.5rem; position: relative; color: #475569;">
          <span style="position: absolute; left: 0; color: #f59e0b;">⚠</span>
          El equipo a menudo delega al correo en lugar de responder en vivo
        </li>
        <li style="padding-left: 1.5rem; position: relative; color: #475569;">
          <span style="position: absolute; left: 0; color: #ef4444;">✗</span>
          Lucha con discusiones de precios y manejo de objeciones
        </li>
        <li style="padding-left: 1.5rem; position: relative; color: #475569;">
          <span style="position: absolute; left: 0; color: #f59e0b;">⚠</span>
          Malentendidos ocasionales con clientes norteamericanos
        </li>
      </ul>
    `;
    recommendations = `
      <ol style="list-style: decimal; padding-left: 1.5rem; display: flex; flex-direction: column; gap: 1rem; color: #475569;">
        <li>Construir confianza respondiendo a desafíos en tiempo real</li>
        <li>Practicar defender valor y precios sin dudar</li>
        <li>Desarrollar explicaciones claras y concisas de soluciones complejas</li>
        <li>Dominar small talk y conversaciones de construcción de relaciones</li>
      </ol>
    `;
  } else {
    label = "Oportunidad Crítica";
    description = "Las brechas de comunicación están limitando significativamente tu crecimiento. La mejora inmediata impactará directamente tu resultado final.";
    findings = `
      <ul style="list-style: none; padding: 0; display: flex; flex-direction: column; gap: 1rem;">
        <li style="padding-left: 1.5rem; position: relative; color: #475569;">
          <span style="position: absolute; left: 0; color: #ef4444;">✗</span>
          Eres el cuello de botella—el equipo no puede manejar llamadas con clientes independientemente
        </li>
        <li style="padding-left: 1.5rem; position: relative; color: #475569;">
          <span style="position: absolute; left: 0; color: #ef4444;">✗</span>
          Malentendidos frecuentes que llevan a contratos perdidos
        </li>
        <li style="padding-left: 1.5rem; position: relative; color: #475569;">
          <span style="position: absolute; left: 0; color: #ef4444;">✗</span>
          El equipo evita situaciones de cara al cliente debido a ansiedad por el idioma
        </li>
      </ul>
    `;
    recommendations = `
      <ol style="list-style: decimal; padding-left: 1.5rem; display: flex; flex-direction: column; gap: 1rem; color: #475569;">
        <li><strong>Prioridad:</strong> Construir confianza fundamental en conversaciones con clientes</li>
        <li>Practicar escenarios comunes con clientes hasta que las respuestas sean automáticas</li>
        <li>Desarrollar un marco para explicar tu propuesta de valor claramente</li>
        <li>Comenzar con llamadas de bajo riesgo y gradualmente aumentar la complejidad</li>
      </ol>
    `;
  }
  
  if (labelEl) labelEl.textContent = label;
  if (descEl) descEl.innerHTML = description;
  if (findingsEl) findingsEl.innerHTML = findings;
  if (recsEl) recsEl.innerHTML = recommendations;
}

// Check if coming directly to results page
if (window.location.pathname.includes('/results')) {
  const answersJson = sessionStorage.getItem('quizAnswers');
  if (!answersJson) {
    // Redirect to start if no quiz data
    window.location.href = '/es/quiz/start';
  }
}
</script>
