      gap: 1rem !important;
    }
  }

  @media (max-width: 480px) {
    .question-grid {
      grid-template-columns: 1fr !important;
    }
  }

  /* Recomendaciones */
  .recommendation-paths {
    margin-bottom: 2.5rem;
    margin-top: 1.5rem;
  }

  .path-card {
    background: #f8fafc;
    padding: 1.5rem;
    border-radius: 12px;
    border: 2px solid #e2e8f0;
  }

  .path-card h4 {
    font-size: 1.125rem;
    color: #0f172a;
    margin-bottom: 0.75rem;
    margin-top: 0.5rem;
  }

  .path-card p {
    font-size: 0.9rem;
    margin-bottom: 1rem;
  }

  .path-card ul {
    font-size: 0.9rem;
  }

  .path-list {
    list-style: none;
    padding-left: 0;
    margin-top: 1rem;
  }

  .path-list li {
    position: relative;
    padding-left: 1.5rem;
    margin-bottom: 0.5rem;
    color: #475569;
    line-height: 1.6;
  }

  .path-list li::before {
    content: "•";
    position: absolute;
    left: 0.5rem;
    color: #64748b;
    font-weight: 700;
  }

  .path-card.recommended {
    border-color: #3b82f6;
    background: linear-gradient(135deg, #dbeafe 0%, #bfdbfe 100%);
    box-shadow: 0 4px 12px rgba(59, 130, 246, 0.15);
  }

  .recommended-badge {
    display: inline-block;
    background: transparent;
    color: #3b82f6;
    padding: 0;
    border-radius: 0;
    font-size: 0.75rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  /* CTA Final */
  .final-cta {
    text-align: center;
    padding: 4rem 3rem;
    background: linear-gradient(135deg, #dbeafe 0%, #e0e7ff 100%);
