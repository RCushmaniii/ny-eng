---
/**
 * High-Stakes English Assessment Landing Page - Spanish
 * URL: /es/quiz/high-stakes/
 * Target Keyword: Inglés para Entrevistas de Trabajo / Coaching de Presentaciones
 */
export const prerender = true;

import Base from "@layouts/Base.astro";
import Button from "@components/ui/Button.astro";
import QuizSchema from "@components/seo/QuizSchema.astro";
import {
  Presentation,
  CheckCircle,
  Clock,
  TrendingUp,
  ChevronDown,
  Theater,
  Zap,
  Target,
  XCircle,
} from "lucide-astro";
import heroSkyline from "@assets/images/home/new-york-city-skyline.webp";

// SEO metadata
const title =
  "Puntaje de Desempeño Bajo Presión | Comunicación de Alto Impacto";
const description =
  "Eres brillante en tu idioma nativo. Te congelas en inglés. Mide tu Puntaje de Presión en Inglés de Negocios en 90 segundos. Para hablantes no nativos enfrentando momentos de alto impacto.";

// FAQ data
const faqs = [
  {
    question: "¿Cuánto tiempo toma la evaluación?",
    answer:
      "90 segundos. Responderás 6 preguntas basadas en escenarios y recibirás tu Puntaje de Desempeño Bajo Presión (0-100) junto con un análisis personalizado de tus brechas inmediatamente después.",
  },
  {
    question: "¿Qué es el 'Language Gap' que mide esta evaluación?",
    answer:
      "El Language Gap es la diferencia entre tu inteligencia en tu idioma nativo y cómo te perciben en situaciones de alta presión en inglés. Puedes ser brillante en conversaciones casuales pero congelarte en entrevistas o presentaciones. Esta evaluación cuantifica esa brecha y te da un roadmap para cerrarla.",
  },
  {
    question: "¿Qué voy a recibir después de completar la evaluación?",
    answer:
      "Tu Puntaje de Desempeño Bajo Presión (0-100), análisis de tus fortalezas y brechas en tres dimensiones (Presencia Escénica, Velocidad de Procesamiento, e Impacto Persuasivo), más un roadmap personalizado de 30 días con ejercicios específicos para construir confianza en momentos de alto impacto.",
  },
  {
    question: "¿Para quién es esta evaluación?",
    answer:
      "Profesionales preparándose para entrevistas de trabajo, presentaciones keynote, pitches a inversionistas, o cualquier momento que defina tu carrera donde el desempeño en inglés importa. Si eres fluido en situaciones casuales pero tu mente se pone en blanco bajo presión, esta evaluación es para ti.",
  },
  {
    question: "¿Me va a ayudar con la ansiedad de hablar en público?",
    answer:
      "Sí. La mayoría de la ansiedad de hablar en público para hablantes no nativos viene de la incertidumbre con el idioma—el miedo a congelarse, olvidar palabras, o ser malinterpretado. Esta evaluación identifica la causa raíz (velocidad de procesamiento, brechas de vocabulario, o fluidez cultural) y te da estrategias específicas para construir confianza.",
  },
  {
    question: "¿Qué pasa después de obtener mis resultados?",
    answer:
      "Recibirás un email con tu scorecard detallado y la opción de agendar una consulta gratuita de 20 minutos para discutir tu roadmap personalizado hacia el dominio de comunicación de alto impacto.",
  },
];

// Testimonials data
const testimonials = [
  {
    quote:
      "Fallé 2 entrevistas de ronda final en Amazon antes de esto. Los ejercicios de velocidad de procesamiento lo cambiaron todo—conseguí la oferta en mi tercer intento.",
    name: "Ricardo M.",
    title: "Senior Product Manager, Amazon",
    location: "CDMX → Seattle",
  },
  {
    quote:
      "Me bloqueaba en pitches con inversionistas. Ahora los disfruto. Levantamos $4M en nuestra Serie A—el entrenamiento de presencia valió 100x la inversión.",
    name: "Sofia L.",
    title: "CEO, Startup Fintech",
    location: "Bogotá",
  },
  {
    quote:
      "Di un keynote para 2,000 personas en inglés. Hace seis meses, hubiera dicho que no. El framework de 'congelado a fluido' lo hizo posible.",
    name: "Dr. Marco V.",
    title: "Director de Investigación en IA",
    location: "São Paulo → Austin",
  },
];
---

<Base
  title={title}
  description={description}
  lang="es"
  tkey="quiz/high-stakes"
  hideCta={true}
  hideNav={true}
>
  <QuizSchema lang="es" slot="head" />

  <!-- Hero Section -->
  <section class="hero">
    <img
      src={heroSkyline.src}
      alt="Evaluación de Comunicación de Alto Impacto"
      class="hero-bg-image"
      loading="eager"
    />
    <div class="hero-overlay"></div>
    <div class="container">
      <div class="hero-content">
        <span class="eyebrow"
          >Eres brillante en tu idioma nativo. Te congelas en inglés.</span
        >

        <h1>
          La Evaluación de 90 Segundos que Mide tu Puntaje de Presión en Inglés
          de Negocios
        </h1>

        <p class="discover-label">Tres cosas que vas a descubrir:</p>

        <div class="benefits">
          <div class="benefit">
            <CheckCircle size={20} />
            <span>Tu Puntaje de Presión en Inglés (0-100)</span>
          </div>
          <div class="benefit">
            <CheckCircle size={20} />
            <span>Por qué te congelas cuando el inglés está en juego</span>
          </div>
          <div class="benefit">
            <CheckCircle size={20} />
            <span
              >Tu roadmap de 30 días hacia confianza fluida en momentos críticos</span
            >
          </div>
        </div>

        <Button
          href="/es/quiz/high-stakes/question/1"
          variant="primary"
          size="lg"
          class="cta-button gold-cta"
        >
          Comenzar Evaluación Gratis →
        </Button>

        <p class="trust-line">
          Breve. Práctico. Con la confianza de más de 200 profesionales buscando
          fluidez y seguridad.
        </p>
      </div>
    </div>
  </section>

  <!-- SECTION 1: The Business Case -->
  <section class="business-case-section">
    <div class="container">
      <h2>Por Qué Tu "Yo de Entrevista" Te Está Costando Ofertas de $100K+</h2>
      <p class="section-intro">
        Eres elocuente en juntas. Seguro con colegas. Pero cuando hay mucho en
        juego—entrevistas de ronda final, pitches a inversionistas,
        keynotes—algo se rompe. Esa brecha tiene un precio.
      </p>

      <div class="cost-grid">
        <div class="cost-item">
          <div class="cost-icon"><XCircle size={32} /></div>
          <h3>Ofertas Perdidas</h3>
          <p>
            Llegaste a la ronda final. Tus habilidades fueron suficientes para
            llegar ahí. Pero la oferta se fue con alguien que "entrevistó
            mejor."
          </p>
        </div>
        <div class="cost-item">
          <div class="cost-icon"><TrendingUp size={32} /></div>
          <h3>Menor Compensación</h3>
          <p>
            La duda en negociaciones salariales cuesta 10-20% de tu paquete. Eso
            es $15K-$50K al año que estás dejando en la mesa.
          </p>
        </div>
        <div class="cost-item">
          <div class="cost-icon"><Presentation size={32} /></div>
          <h3>Oportunidades Evitadas</h3>
          <p>
            El keynote que rechazaste. La presentación al board que delegaste.
            Cada "no" a visibilidad es un "no" a acelerar tu carrera.
          </p>
        </div>
        <div class="cost-item">
          <div class="cost-icon"><Clock size={32} /></div>
          <h3>Búsquedas Extendidas</h3>
          <p>
            La ansiedad de entrevista extiende las búsquedas de trabajo 3-6
            meses. Eso es $50K-$150K en ingresos perdidos mientras "te preparas
            más."
          </p>
        </div>
      </div>

      <div class="monetary-reality">
        <p>
          <strong>La verdad incómoda:</strong> La diferencia entre tú y el candidato
          que consiguió la oferta no es habilidad—es desempeño bajo presión. Una
          mala entrevista puede costarte <strong>$100K+ en compensación</strong>
          y atrasar tu carrera años.
        </p>
      </div>

      <div class="section-cta">
        <Button
          href="/es/quiz/high-stakes/question/1"
          variant="primary"
          size="lg"
          class="gold-cta"
        >
          Descubre Tus Brechas de Presión en 90 Segundos →
        </Button>
      </div>
    </div>
  </section>

  <!-- SECTION 2: The 3 Gaps -->
  <section class="gaps-section">
    <div class="container">
      <h2>
        Las 3 Dimensiones de Desempeño que Separan "Casi Contratado" de "Eres
        Nuestra Primera Opción"
      </h2>
      <p class="section-intro">
        Esta evaluación mide las habilidades exactas que determinan si te
        congelas o fluyes cuando llegan los momentos que definen tu carrera.
      </p>

      <div class="gap-cards">
        <div class="gap-card">
          <div class="gap-header">
            <Theater size={40} class="gap-icon" />
            <h3>Brecha #1: Presencia Escénica</h3>
            <span class="gap-subtitle"
              >Comandar el Espacio o Pedir Perdón por Existir</span
            >
          </div>
          <p class="gap-description">
            Los primeros 30 segundos de una entrevista o presentación determinan
            el 80% del resultado. La presencia no es carisma—es proyectar
            autoridad aunque tu corazón esté acelerado.
          </p>
          <div class="what-we-measure">
            <h4>Lo que medimos:</h4>
            <ul>
              <li>
                Fuerza de apertura (entrada segura vs. disculpas y rodeos)
              </li>
              <li>Autoridad vocal bajo presión (ritmo, pausas, proyección)</li>
              <li>Patrones de recuperación cuando pierdes el hilo</li>
            </ul>
          </div>
          <p class="why-matters">
            <strong>Por qué importa:</strong> Los entrevistadores deciden "contratar"
            o "pasar" en los primeros minutos. Si empiezas con "Perdón, estoy un
            poco nervioso" o hablas muy rápido, ya perdiste terreno que nunca recuperarás.
          </p>
        </div>

        <div class="gap-card">
          <div class="gap-header">
            <Zap size={40} class="gap-icon" />
            <h3>Brecha #2: Velocidad de Procesamiento</h3>
            <span class="gap-subtitle">El Factor Congelado/Fluido</span>
          </div>
          <p class="gap-description">
            Cuando un entrevistador lanza una pregunta inesperada, tu cerebro
            tiene 2 segundos para responder antes de que la pausa se vuelva
            incómoda. Si todavía estás traduciendo de tu idioma nativo, ya
            perdiste.
          </p>
          <div class="what-we-measure">
            <h4>Lo que medimos:</h4>
            <ul>
              <li>Latencia de respuesta en preguntas inesperadas</li>
              <li>Capacidad de pensar en voz alta sin congelarte</li>
              <li>Velocidad de recuperación después de un bloqueo mental</li>
            </ul>
          </div>
          <p class="why-matters">
            <strong>Por qué importa:</strong> La velocidad de procesamiento es el
            predictor #1 de éxito en entrevistas para hablantes no nativos. No se
            trata de tener respuestas perfectas—se trata de tener <em>alguna</em
            >
            respuesta sin un silencio de 10 segundos.
          </p>
        </div>

        <div class="gap-card">
          <div class="gap-header">
            <Target size={40} class="gap-icon" />
            <h3>Brecha #3: Impacto Persuasivo</h3>
            <span class="gap-subtitle">Información vs. Inspiración</span>
          </div>
          <p class="gap-description">
            La mayoría de los candidatos responden preguntas. Los mejores
            candidatos mueven al cuarto. El impacto persuasivo es la diferencia
            entre "candidato sólido" y "tenemos que contratar a esta persona
            antes de que alguien más lo haga."
          </p>
          <div class="what-we-measure">
            <h4>Lo que medimos:</h4>
            <ul>
              <li>Estructura de storytelling (ejecución del método STAR)</li>
              <li>Resonancia emocional y framing estratégico</li>
              <li>Fuerza de cierre (aterrizar con impacto)</li>
            </ul>
          </div>
          <p class="why-matters">
            <strong>Por qué importa:</strong> En una ronda final con 3 candidatos
            calificados, la oferta va para quien hace que los entrevistadores <em
              >sientan</em
            > algo. La información se olvida. Las historias se recuerdan.
          </p>
        </div>
      </div>

      <div class="section-cta">
        <Button
          href="/es/quiz/high-stakes/question/1"
          variant="primary"
          size="lg"
          class="gold-cta"
        >
          Tomar la Evaluación de 90 Segundos →
        </Button>
      </div>
    </div>
  </section>

  <!-- SECTION 3: Who This Is For -->
  <section class="who-section">
    <div class="container">
      <h2>¿Esta Evaluación de Alto Impacto Es Para Ti?</h2>

      <div class="who-grid">
        <div class="who-card designed-for">
          <h3>Esta evaluación está diseñada para:</h3>
          <ul>
            <li>
              <strong>Buscadores de empleo</strong> preparándose para entrevistas
              de ronda final en empresas top
            </li>
            <li>
              <strong>Ejecutivos y fundadores</strong> haciendo pitches a inversionistas,
              boards, o clientes enterprise
            </li>
            <li>
              <strong>Profesionales</strong> preparándose para keynotes, conferencias,
              o presentaciones de alta visibilidad
            </li>
            <li>
              <strong>Profesionales en transición</strong> entrando a mercados dominados
              por inglés por primera vez
            </li>
            <li>
              <strong>Cualquiera</strong> cuyo inglés está bien en situaciones casuales
              pero se rompe bajo presión
            </li>
          </ul>
        </div>

        <div class="who-card ready-if">
          <h3>Estás listo para esta evaluación si:</h3>
          <ul class="checkmark-list">
            <li>
              Has perdido ofertas de trabajo a pesar de estar calificado porque
              "no entrevistaste bien"
            </li>
            <li>
              Evitas oportunidades de alta visibilidad porque tienes miedo de
              congelarte
            </li>
            <li>
              Te sobre-preparas con guiones y luego suenas robótico e
              inauténtico
            </li>
            <li>
              Tu mente se pone en blanco cuando te hacen preguntas inesperadas
            </li>
            <li>
              Sabes que eres más inteligente de cómo te perciben en inglés bajo
              presión
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- SECTION 4: Comparison Table -->
  <section class="comparison-section">
    <div class="container">
      <h2>La Brecha de Desempeño Entre "Casi" y "Contratado"</h2>
      <p class="section-intro">
        Los candidatos que consiguen ofertas no tienen mejores habilidades—se
        desempeñan mejor cuando cuenta.
      </p>

      <div class="comparison-table-wrapper">
        <table class="comparison-table">
          <thead>
            <tr>
              <th>Congelado Bajo Presión</th>
              <th>Fluido Bajo Presión</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>Pausas largas mientras traduces internamente</td>
              <td>Pensar en voz alta en inglés sin dudar</td>
            </tr>
            <tr>
              <td>Sobre-preparar guiones, sonar robótico</td>
              <td>Preparar frameworks, sonar natural y adaptable</td>
            </tr>
            <tr>
              <td>Divagar cuando estás nervioso, perder el hilo</td>
              <td
                >Entregar historias estructuradas de 60 segundos con impacto</td
              >
            </tr>
            <tr>
              <td>Disculparte por tu acento o nerviosismo</td>
              <td>Proyectar autoridad desde la primera oración</td>
            </tr>
            <tr>
              <td
                >Salir de entrevistas esperando que "vieron más allá" de los
                nervios</td
              >
              <td>Salir de entrevistas sabiendo que comandaste el espacio</td>
            </tr>
          </tbody>
        </table>
      </div>

      <p class="comparison-conclusion">
        <strong>¿La diferencia?</strong> Los que se desempeñan bien bajo presión
        entrenaron su respuesta a la presión. Es una habilidad—y se puede aprender.
      </p>

      <div class="section-cta">
        <Button
          href="/es/quiz/high-stakes/question/1"
          variant="primary"
          size="lg"
          class="gold-cta"
        >
          Encuentra Tus Brechas. Arreglálas. Desempeña. →
        </Button>
      </div>
    </div>
  </section>

  <!-- SECTION 5: Testimonials -->
  <section class="testimonials-section">
    <div class="container">
      <h2>
        Más de 200 Profesionales Que Dejaron de Congelarse Confían en Nosotros
      </h2>

      <div class="testimonials-grid">
        {
          testimonials.map((testimonial) => (
            <div class="testimonial-card">
              <blockquote>"{testimonial.quote}"</blockquote>
              <div class="testimonial-author">
                <strong>{testimonial.name}</strong>
                <span>{testimonial.title}</span>
                <span class="location">{testimonial.location}</span>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- SECTION 6: FAQ -->
  <section class="faq-section">
    <div class="container">
      <h2>Preguntas Frecuentes</h2>
      {
        faqs.map((faq) => (
          <details class="faq-item">
            <summary>
              <h3>{faq.question}</h3>
              <ChevronDown size={20} class="chevron" />
            </summary>
            <div class="faq-answer">
              <p>{faq.answer}</p>
            </div>
          </details>
        ))
      }
    </div>
  </section>

  <!-- SECTION 7: Final CTA -->
  <section class="final-cta-section">
    <div class="container">
      <h2>
        Tu Próxima Entrevista No Tiene Que Sentirse Como Una Situación de Rehén
      </h2>
      <p class="final-cta-text">
        Los profesionales que consiguen trabajos soñados y comandas escenarios
        de keynote no son más talentosos que tú. Entrenaron su respuesta a la
        presión. Aprendieron a fluir en vez de congelarse. Dejaron de permitir
        que la ansiedad les robara oportunidades que se habían ganado.
      </p>
      <p class="final-cta-highlight">
        Tu evaluación de 90 segundos empieza ahora.
      </p>
      <div class="cta-center">
        <Button
          href="/es/quiz/high-stakes/question/1"
          variant="primary"
          size="lg"
          class="gold-cta"
        >
          Tomar la Evaluación →
        </Button>
      </div>
      <p class="trust-final">
        90 segundos. Resultados instantáneos. Cero riesgo. Únete a más de 200
        profesionales que dejaron de congelarse.
      </p>
    </div>
  </section>

  <style>
    /* Hero Section with Background Image */
    .hero {
      position: relative;
      padding: 10rem 1.5rem 6rem;
      min-height: 100vh;
      display: flex;
      align-items: center;
      overflow: hidden;
    }

    .hero-bg-image {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: center;
      z-index: 0;
    }

    /* Mobile: shift image right to show Empire State Building */
    @media (max-width: 767px) {
      .hero-bg-image {
        object-position: 75% center;
      }
    }

    .hero-overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(
        135deg,
        rgba(15, 23, 42, 0.5) 0%,
        rgba(30, 41, 59, 0.4) 100%
      );
      z-index: 1;
    }

    @media (min-width: 768px) {
      .hero-overlay {
        background: linear-gradient(
          to right,
          rgba(15, 23, 42, 0.65) 0%,
          rgba(15, 23, 42, 0.55) 50%,
          rgba(30, 41, 59, 0.45) 100%
        );
      }
    }

    .container {
      max-width: 1200px;
      margin: 0 auto;
      width: 100%;
      position: relative;
      z-index: 2;
    }

    .hero-content {
      max-width: 650px;
      display: flex;
      flex-direction: column;
      gap: 1.5rem;
    }

    @media (min-width: 1024px) {
      .hero-content {
        max-width: 700px;
      }
    }

    .eyebrow {
      display: inline-block;
      font-size: 0.875rem;
      font-weight: 700;
      color: #0f172a;
      background: rgba(251, 191, 36, 0.95);
      padding: 0.625rem 1.25rem;
      border-radius: 9999px;
      width: fit-content;
      box-shadow: 0 4px 12px rgba(251, 191, 36, 0.3);
      letter-spacing: 0.025em;
      text-transform: uppercase;
    }

    h1 {
      font-size: 2.5rem;
      font-weight: 900;
      line-height: 1.1;
      color: #ffffff;
      margin: 0;
      text-shadow: 0 2px 8px rgba(0, 0, 0, 0.3);
    }

    @media (min-width: 768px) {
      h1 {
        font-size: 3.5rem;
      }
    }

    @media (min-width: 1024px) {
      h1 {
        font-size: 4rem;
      }
    }

    .discover-label {
      font-size: 1.125rem;
      color: #f1f5f9;
      margin: 0 0 0.5rem 0;
      font-weight: 500;
      text-shadow: 0px 1px 3px rgba(0, 0, 0, 0.8);
    }

    .benefits {
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
      margin: 1rem 0;
    }

    .benefit {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      font-size: 1.0625rem;
      color: #ffffff;
      font-weight: 500;
      text-shadow: 0px 1px 3px rgba(0, 0, 0, 0.8);
    }

    .benefit :global(svg) {
      color: #10b981;
      flex-shrink: 0;
      filter: drop-shadow(0 2px 4px rgba(16, 185, 129, 0.5));
    }

    .trust-line {
      font-size: 0.9375rem;
      color: #cbd5e1;
      text-align: center;
      margin-top: 1rem;
      font-weight: 500;
      text-shadow: 0px 1px 2px rgba(0, 0, 0, 0.6);
    }

    /* Gold CTA Button Override */
    :global(.gold-cta) {
      background: linear-gradient(135deg, #fbbf24 0%, #f59e0b 100%) !important;
      color: #0f172a !important;
      font-weight: 700 !important;
      box-shadow: 0 4px 16px rgba(251, 191, 36, 0.4) !important;
      border: none !important;
    }

    :global(.gold-cta:hover) {
      background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%) !important;
      transform: translateY(-2px);
      box-shadow: 0 6px 20px rgba(251, 191, 36, 0.5) !important;
    }

    /* Shared Section Styles */
    .section-intro {
      font-size: 1.125rem;
      color: #475569;
      text-align: center;
      max-width: 800px;
      margin: 0 auto 2.5rem;
      line-height: 1.7;
    }

    .section-cta {
      text-align: center;
      margin-top: 2.5rem;
    }

    .cta-center {
      text-align: center;
      margin-top: 2rem;
    }

    /* SECTION 1: Business Case */
    .business-case-section {
      padding: 4rem 1.5rem;
      background: white;
    }

    .business-case-section h2 {
      font-size: 2rem;
      font-weight: 700;
