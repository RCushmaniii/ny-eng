---
export const prerender = true;

import Base from "@layouts/Base.astro";
import InnerHero from "@components/sections/InnerHero.astro";
import BookingFormSteps from "@components/booking/BookingFormSteps.astro";
import bookingHero from "@assets/images/contact/book-hero.jpg";

const metadata = {
  title: "Sesión de Estrategia Ejecutiva | NY English",
  description:
    "Agenda tu análisis de 15 minutos. Sin rollos de ventas—solo una plática directa sobre tu presencia técnica y ejecutiva en inglés.",
};

const heroContent = {
  title: "Vamos a Depurar Tu Comunicación en Inglés",
  description:
    "Sin rollos de ventas. Solo un análisis de 15 minutos de tu presencia técnica y ejecutiva actual.",
  backgroundImage: bookingHero,
  overlayOpacity: 0.6,
};
---

<Base
  lang="es"
  tkey="book"
  title={metadata.title}
  description={metadata.description}
  ogImage={{ src: "/images/logos/new-york-english-sq-og.jpg" }}
>
  <main>
    <InnerHero content={heroContent} />

    <section class="py-16 md:py-24 bg-background-light">
      <div class="site-container px-4">
        <!-- Booking Form with Steps -->
        <BookingFormSteps lang="es" />
      </div>
    </section>
  </main>
</Base>
