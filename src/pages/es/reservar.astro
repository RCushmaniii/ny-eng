---
import Base from "@layouts/Base.astro";
import InnerHero from "@components/sections/InnerHero.astro";
import BookingFormSteps from "@components/booking/BookingFormSteps.astro";
import bookingHero from "@assets/images/contact/nyc-statue-of-liberty.jpg";

const metadata = {
  title: "Reserva Tu Consulta Gratuita de Inglés | NY English",
  description: "Agenda tu consulta gratuita de 30 minutos. Obtén consejos personalizados para mejorar tu inglés laboral y descubre cómo el coaching puede acelerar tu confianza.",
};

const heroContent = {
  title: "Reserva Tu Consulta Gratuita de Inglés",
  description: "Desbloquea la Comunicación Segura en el Trabajo",
  backgroundImage: bookingHero,
  overlayOpacity: 0.5,
};
---

<Base
  lang="es"
  tkey="book"
  title={metadata.title}
  description={metadata.description}
  ogImage={{ src: "/images/logos/new-york-english-sq-og.jpg" }}
>
  <main>
    <InnerHero content={heroContent} />
    
    <section class="py-16 md:py-24 bg-background-light">
      <div class="site-container px-4">
        <!-- Booking Form with Steps -->
        <BookingFormSteps lang="es" />
      </div>
    </section>
  </main>
</Base>
