---
import { getCollection, type CollectionEntry } from "astro:content";
import { categories } from "@data/categories";
import { routeFor, type TKey } from "../../../lib/i18n";
import { siteConfig } from "@data/config";
import Base from "@layouts/Base.astro";
import BlogList from "@components/blog/BlogList.astro";
import InnerHero from "@components/sections/InnerHero.astro";
import blogHeroImage from "../../../content/blog/images/blog-hero.jpg";

export async function getStaticPaths() {
  // Generate paths for Spanish categories using i18n system
  return categories.map((category) => {
    const tkey = `category/${category.slug}` as TKey;
    const esPath = routeFor.es[tkey];

    // Handle both English and Spanish slugs
    return [
      // English slug -> Spanish URL
      {
        params: { category: category.slug },
        props: { category, tkey },
      },
      // Spanish slug -> Spanish URL
      {
        params: { category: category.esSlug || category.slug },
        props: { category, tkey },
      },
    ];
  }).flat();
}

interface Props {
  category: typeof categories[number];
  tkey: TKey;
}

const { category, tkey } = Astro.props;

// Get canonical paths from i18n system
const canonicalEnPath = routeFor.en[tkey];
const canonicalEsPath = routeFor.es[tkey];

// If current URL doesn't match the canonical Spanish URL, redirect
if (Astro.url.pathname !== canonicalEsPath) {
  return Astro.redirect(canonicalEsPath, 301);
}

// Get Spanish blog posts for this category
const allPosts = await getCollection("blog");
const categoryPosts = allPosts
  .filter((post: CollectionEntry<"blog">) => {
    // Only Spanish posts that are published
    if (!post.id.startsWith("es/") || post.data.publish === false) return false;

    // Check if post categories include this category name
    const categoryNames = post.data.categories || [];
    return categoryNames.includes(category.name_es || category.name);
  })
  .sort(
    (a: CollectionEntry<"blog">, b: CollectionEntry<"blog">) =>
      new Date(b.data.publishDate).getTime() -
      new Date(a.data.publishDate).getTime()
  );

// SEO content
const seoTitle = `${category.name_es || category.name} | ${siteConfig.companyName}`;
const seoDescription = category.description_es || category.description;

// Create custom hreflangs for this specific category
const customHreflangs = [
  { lang: 'en-US', href: canonicalEnPath },
  { lang: 'es-MX', href: canonicalEsPath }
];

// Hero content
const heroContent = {
  title: category.name_es || category.name,
  description: category.description_es || category.description,
  backgroundImage: blogHeroImage,
  overlayOpacity: 0.7
};
---

<Base lang="es" tkey={tkey} title={seoTitle} description={seoDescription} customHreflangs={customHreflangs}>
  <main role="main">
    <InnerHero content={heroContent} />
    <BlogList
      posts={categoryPosts}
      currentCategory={category.name_es || category.name}
      currentCategorySlug={category.esSlug || category.slug}
      lang="es"
    />
  </main>
</Base>
