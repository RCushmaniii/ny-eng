---
import Layout from '@layouts/Layout.astro';
import Button from '@components/ui/Button.astro';

const seoTitle = "Página desaparecida";
const seoDescription = "Esta página se fue a tomar un café y nunca regresó.";
const footerCta = {
  eyebrow: "",
  title: "Transforma tu inglés profesional hoy",
  description: "Reserva tu consulta gratuita para ganar claridad, confianza e impacto en tu rol profesional.",
  hideCta: false,
  button: {
    text: "Reservar mi consulta gratuita",
    link: "https://ny-english-teacher.odoo.com/book/7ceefa20",
    target: "_blank",
    variant: "primary"
  }
};
---

<Layout title={seoTitle} description={seoDescription} footerCta={footerCta}>
    <div class="w-full min-h-[80vh] flex items-center">
        <div class="site-container mx-auto px-4 py-base text-center">
            <div class="max-w-2xl mx-auto">
                <h1 class="mb-4 text-9xl font-bold text-primary" data-aos="fade-up">404</h1>
                <h2 class="mb-8" data-aos="fade-up" data-aos-delay="100">Página no encontrada</h2>
                <p class="text-body-base mb-12" data-aos="fade-up" data-aos-delay="200">
                    La página que buscas no existe o ha sido movida. 
                    Por favor revisa la URL o navega de regreso a nuestra página principal.
                </p>
                <div data-aos="fade-up" data-aos-delay="300">
                    <Button 
                        href="/es/" 
                        variant="primary"
                        size="lg"
                    >
                        Volver al inicio
                    </Button>
                </div>
            </div>
        </div>
    </div>
</Layout>
