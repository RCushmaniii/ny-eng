---
export const prerender = true;

import Base from "@layouts/Base.astro";
import InnerHero from "@components/sections/InnerHero.astro";
import Challenge from "@components/sections/Challenge.astro";
import MethodologySection from "@components/sections/MethodologySection.astro";
import FeaturedTestimonial from "@components/sections/FeaturedTestimonial.astro";
import CtaSection from "@components/sections/CtaSection.astro";
import ServiceFAQ from "@components/sections/ServiceFAQ.astro";
import BreadcrumbSchema from "@components/seo/BreadcrumbSchema.astro";
import Breadcrumbs from "@components/ui/Breadcrumbs.astro";
import { serviceFaqs } from "@data/service-faqs";

// Import services data
import { services } from "@data/services";

// Get the startup founders service data
const startupFoundersService = services.find(
  (s) => s.slug === "startup-founders"
);

// Import methodology content
import type { Methodology } from "@data/methodology";

// Define Spanish methodology content directly
const metodologiaEs: Methodology = {
  title: "Cómo funciona",
  subtitle: "",
  steps: [
    {
      icon: "lucide:search-check",
      title: "Primero hablamos.",
      description:
        "Una llamada introductoria corta. Tu startup, tu próxima ronda, lo que está en juego—sin presión, sin discurso de ventas.",
    },
    {
      icon: "lucide:map",
      title: "Construyo tu plan.",
      description:
        "Desde tu etapa de startup, tu industria y tus momentos de presión. Sesiones diseñadas para tu realidad de fundador, no genéricas.",
    },
    {
      icon: "lucide:settings",
      title: "Practicas bajo presión.",
      description:
        "Pitches a inversionistas, llamadas con board members, reclutamiento cross-border. Retroalimentación sobre claridad, convicción y presencia. Comete errores conmigo, no frente a los VCs.",
    },
    {
      icon: "lucide:message-square-text",
      title: "Refino conforme creces.",
      description:
        "¿Tu comunicación mejora? Yo ajusto—nuevos desafíos, escenarios más complejos. Evoluciona con tu startup.",
    },
  ],
};

// Import testimonials and select Julio testimonial
import { testimonials } from "@data/testimonials/es";
const featuredTestimonial = testimonials[0]; // Julio Aldana testimonial

// SEO metadata
const title = "Coaching para Fundadores | Perfecciona tu Pitch | NY";
const seoDescription =
  "Coaching de inglés para fundadores de startups. Perfecciona tu pitch, comunica tu visión y destaca en reuniones con inversores.";

// Hero content
const heroContent = {
  title: "Tu visión es clara. Tu pitch no está aterrizando.",
  description:
    "Coaching para fundadores que necesitan hacer pitch a inversionistas de EE.UU., reclutar cross-border y liderar su equipo en inglés — con la confianza que cierra rondas.",
  backgroundImage: startupFoundersService?.backgroundImage,
  overlayOpacity: 0.7,
};

// Challenge section content
const challengeContent = {
  headline: "¿Te suena familiar?",
  painPoints: [
    "Conoces tu producto al derecho y al revés — pero cuando haces pitch en inglés, la convicción no se transmite igual.",
    "Las llamadas con inversionistas se sienten como exámenes de idioma en vez de conversaciones de negocios.",
    "Lideras a tu equipo en español con autoridad. En inglés, suenas como si leyeras de un guión.",
  ],
  icon: "😰",
  image: startupFoundersService?.squareImage,
  quizCta: {
    text: "Descubre tu Puntuación de Comunicación para Fundadores en 60 segundos.",
    link: "/es/quiz/executives/question/1",
    linkLabel: "Iniciar la Evaluación →",
  },
};

// Final CTA content
const ctaContent = {
  eyebrow: "",
  title: "Ya lideras. Ahora suena así — en inglés.",
  description:
    "Reserva una sesión estratégica privada. 30 minutos: identificaré las brechas entre tu inglés y la presencia ejecutiva que tu rol de fundador exige.",
  buttonText: "Reservar Mi Sesión Estratégica",
  buttonLink: "/es/reservar/",
  whatToExpectTitle: "En Tu Sesión Gratuita, Haremos:",
  whatToExpectList: [
    "Evaluar cómo tu inglés impacta conversaciones con inversionistas y socios",
    "Identificar los momentos específicos donde tu pitch pierde fuerza",
    "Crear un plan para cerrar la brecha entre tu visión y tu entrega",
  ],
};

const faqs = serviceFaqs["startup-founders"]?.es || [];
---

<Base
  title={title}
  description={seoDescription}
  lang="es"
  tkey="services/startup-founders"
  ogImage={{
    src:
      typeof startupFoundersService?.backgroundImage === "string"
        ? startupFoundersService.backgroundImage
        : "/images/logos/new-york-english-og.jpg",
  }}
  customHreflangs={[
    {
      lang: "en-US",
      href: "https://www.nyenglishteacher.com/en/services/startup-founders/",
    },
    {
      lang: "es-MX",
      href: "https://www.nyenglishteacher.com/es/servicios/ingles-para-fundadores-de-startups/",
    },
  ]}
  customCanonical="https://www.nyenglishteacher.com/es/servicios/ingles-para-fundadores-de-startups/"
>
  <!-- Hero Section -->
  <InnerHero content={heroContent} />

  <!-- Challenge Section -->
  <Challenge content={challengeContent} background="white" padding="lg" />

  <!-- Methodology Section -->
  <MethodologySection content={metodologiaEs} background="light" padding="lg" />

  <!-- Featured Testimonial -->
  {
    featuredTestimonial && (
      <FeaturedTestimonial testimonial={featuredTestimonial} />
    )
  }

  <!-- Final CTA -->
  <CtaSection content={ctaContent} />

  <BreadcrumbSchema items={[
    { name: "Inicio", url: "https://www.nyenglishteacher.com/es/" },
    { name: "Servicios", url: "https://www.nyenglishteacher.com/es/servicios/" },
    { name: "Inglés para Startups", url: "https://www.nyenglishteacher.com/es/servicios/ingles-para-fundadores-de-startups/" }
  ]} />
  <ServiceFAQ faqs={faqs} lang="es" />
</Base>
