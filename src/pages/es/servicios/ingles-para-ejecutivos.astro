---
import Base from "@layouts/Base.astro";
import InnerHero from "@components/sections/InnerHero.astro";
import Challenge from "@components/sections/Challenge.astro";
import MethodologySection from "@components/sections/MethodologySection.astro";
import FeaturedTestimonial from "@components/sections/FeaturedTestimonial.astro";
import CtaSection from "@components/sections/CtaSection.astro";

// Import services data
import { services } from "@data/services";

// Get the executive English service data
const executiveService = services.find((s) => s.slug === "executive-english");
if (!executiveService) {
  throw new Error("Executive English service data not found");
}

// Import methodology content
import type { Methodology } from "@data/methodology";

// Define Spanish methodology content directly
const metodologiaEs: Methodology = {
  title: "Tu Método de Coaching Personalizado",
  subtitle:
    "Una metodología probada de cuatro pasos diseñada para entender tus desafíos únicos y desarrollar las habilidades específicas que necesitas para tener éxito.",
  steps: [
    {
      icon: "lucide:search-check",
      title: "Descubrimiento y Evaluación",
      description:
        "Evaluamos tu perfil ejecutivo y comunicación en inglés para identificar fortalezas y diseñar un plan personalizado hacia tus objetivos de liderazgo.",
    },
    {
      icon: "lucide:map",
      title: "Mapeo Estratégico de Objetivos",
      description:
        "Juntos, definimos objetivos claros y medibles directamente vinculados con tu éxito profesional, creando un plan estratégico enfocado en tus metas específicas.",
    },
    {
      icon: "lucide:settings",
      title: "Currículum Personalizado y Práctica",
      description:
        "Tu programa está construido para ti, enfocándose en el vocabulario específico, frases y matices culturales relevantes para tu industria y tareas diarias.",
    },
    {
      icon: "lucide:message-square-text",
      title: "Simulación del Mundo Real y Retroalimentación",
      description:
        "Aquí es donde la teoría se convierte en instinto. Realizamos presentaciones simuladas y juegos de rol de negociaciones difíciles, proporcionando retroalimentación directa y accionable para que estés confiado y preparado.",
    },
  ],
};

// Import testimonials and select featured one
import { testimonials } from "@data/testimonials/es";
const featuredTestimonial = testimonials[1]; // Hugo Blum testimonial
if (!featuredTestimonial) {
  throw new Error('Featured testimonial not found');
}

// SEO metadata
const title = "Coaching de Inglés para Ejecutivos | NY English";
const seoDescription =
  "Coaching de inglés personalizado para ejecutivos. Mejora tu liderazgo y comunicación estratégica para destacar en entornos globales.";

// Hero content
const heroContent = {
  title: "Lidera con Autoridad en Entornos Globales",
  description:
    "Domina el inglés ejecutivo para comunicarte con el impacto y la presencia que tu posición requiere.",
  backgroundImage: executiveService.backgroundImage,
  overlayOpacity: 0.7,
};

// Challenge section content
const challengeContent = {
  headline: "¿Enfrentas Estos Desafíos?",
  painPoints: [
    "Te cuesta proyectar autoridad y confianza durante reuniones ejecutivas en inglés.",
    "Tienes dificultades para comunicar estrategias complejas a equipos internacionales.",
    "Te sientes limitado al negociar acuerdos importantes o presentar a la junta directiva en inglés.",
  ],
  icon: "😰",
  image: executiveService.squareImage,
};

// Final CTA content
const ctaContent = {
  eyebrow: "¿Listo para Liderar con Mayor Impacto?",
  title: "Domina el Inglés Ejecutivo",
  description:
    "Una sesión de estrategia personalizada te mostrará exactamente cómo desarrollar la presencia ejecutiva y las habilidades de comunicación necesarias para liderar con autoridad en entornos globales.",
  buttonText: "Reserva Mi Sesión de Estrategia Ejecutiva",
  buttonLink: "/es/book/",
  whatToExpectTitle: "En Tu Sesión Gratuita, Haremos:",
  whatToExpectList: [
    "Evaluar tu estilo de liderazgo actual y presencia ejecutiva",
    "Identificar oportunidades para aumentar tu impacto en comunicaciones estratégicas",
    "Crear una hoja de ruta para desarrollar tu voz de liderazgo global",
  ],
};
---

<Base
  title={title}
  description={seoDescription}
  lang="es"
  tkey="services/executive-english"
  ogImage={{
    src:
      typeof executiveService.backgroundImage === "string"
        ? executiveService.backgroundImage
        : "/images/logos/new-york-english-og.jpg",
  }}
  hideCta={true}
  customHreflangs={[
    { lang: 'en-US', href: 'https://www.nyenglishteacher.com/en/services/executive-english/' },
    { lang: 'es-MX', href: 'https://www.nyenglishteacher.com/es/servicios/ingles-para-ejecutivos/' }
  ]}
  customCanonical="https://www.nyenglishteacher.com/es/servicios/ingles-para-ejecutivos/"
>
  <!-- Hero Section -->
  <InnerHero content={heroContent} />

  <!-- Challenge Section -->
  <Challenge content={challengeContent} background="white" padding="lg" />

  <!-- Methodology Section -->
  <MethodologySection content={metodologiaEs} background="light" padding="lg" />

  <!-- Featured Testimonial -->
  {
    featuredTestimonial && (
      <FeaturedTestimonial testimonial={featuredTestimonial} />
    )
  }

  <!-- Final CTA -->
  <CtaSection content={ctaContent} />
</Base>
