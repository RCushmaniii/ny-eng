---
export const prerender = true;

import Base from "@layouts/Base.astro";
import InnerHero from "@components/sections/InnerHero.astro";
import Challenge from "@components/sections/Challenge.astro";
import MethodologySection from "@components/sections/MethodologySection.astro";
import FeaturedTestimonial from "@components/sections/FeaturedTestimonial.astro";
import CtaSection from "@components/sections/CtaSection.astro";
import ServiceFAQ from "@components/sections/ServiceFAQ.astro";
import BreadcrumbSchema from "@components/seo/BreadcrumbSchema.astro";
import { serviceFaqs } from "@data/service-faqs";

// Import services data
import { services } from "@data/services";

// Get the logistics service data
const logisticsService = services.find((s) => s.slug === "logistics-english");

// Import methodology content
import type { Methodology } from "@data/methodology";

// Define Spanish methodology content directly
const metodologiaEs: Methodology = {
  title: "Cómo funciona",
  subtitle: "",
  steps: [
    {
      icon: "lucide:search-check",
      title: "Primero hablamos.",
      description:
        "Una llamada introductoria corta. Tu rol en la cadena de suministro, tus interacciones en inglés, lo que te frena—sin presión.",
    },
    {
      icon: "lucide:map",
      title: "Construyo tu plan.",
      description:
        "Desde tu operación real: aduanas, freight forwarding, negociaciones con carriers. Sesiones diseñadas para tu día a día, no genéricas.",
    },
    {
      icon: "lucide:settings",
      title: "Practicas bajo presión.",
      description:
        "Llamadas con clientes, reportes de disrupciones, negociación de tarifas. Retroalimentación directa sobre precisión y tono. Comete errores conmigo, no con tu cliente.",
    },
    {
      icon: "lucide:message-square-text",
      title: "Refino conforme creces.",
      description:
        "¿Tu comunicación mejora? Yo ajusto—nuevos escenarios, mayor complejidad. Evoluciona con tu carrera.",
    },
  ],
};

// Import testimonials and select Humberto testimonial
import { testimonials } from "@data/testimonials/es";
const featuredTestimonial = testimonials[11]; // Humberto Grimaldo testimonial

// SEO metadata
const title = "Inglés para Logística | Cadena de Suministro | NY";
const seoDescription =
  "Optimiza la comunicación en logística internacional. Domina terminología de cadena de suministro, aduanas y negociaciones en inglés.";

// Hero content
const heroContent = {
  title: "Tu operación corre perfecto. Tu comunicación con socios en EE.UU. no.",
  description:
    "Coaching para profesionales de logística que necesitan navegar aduanas, freight forwarding y operaciones transfronterizas en inglés — con precisión.",
  backgroundImage: logisticsService?.backgroundImage,
  overlayOpacity: 0.7,
};

// Challenge section content
const challengeContent = {
  headline: "¿Te suena familiar?",
  painPoints: [
    "Una mala comunicación sobre BOLs o incoterms ya te ha costado tiempo, dinero o una relación con un cliente.",
    "Puedes manejar la operación — pero explicar una disrupción de envío a un cliente en EE.UU. en tiempo real es otra clase de presión.",
    "Negociar tarifas y términos con freight forwarders internacionales se siente más difícil de lo que debería porque el idioma se interpone.",
  ],
  icon: "😰",
  image: logisticsService?.squareImage,
  quizCta: {
    text: "Descubre tu Puntuación de Comunicación en Logística en 60 segundos.",
    link: "/es/quiz/executives/question/1",
    linkLabel: "Iniciar la Evaluación →",
  },
};

// Final CTA content
const ctaContent = {
  eyebrow: "",
  title: "Ya lideras. Ahora suena así — en inglés.",
  description:
    "Reserva una sesión estratégica privada. 30 minutos: identificaré las brechas entre tu inglés y la precisión que tu rol en logística exige.",
  buttonText: "Reservar Mi Sesión Estratégica",
  buttonLink: "/es/reservar/",
  whatToExpectTitle: "En Tu Sesión Gratuita, Haremos:",
  whatToExpectList: [
    "Evaluar cómo tu inglés impacta tus interacciones con brokers, carriers y clientes",
    "Identificar las brechas de comunicación que frenan tus operaciones",
    "Crear un plan basado en tus escenarios reales de operación transfronteriza",
  ],
};

const faqs = serviceFaqs["logistics-english"]?.es || [];
---

<Base
  title={title}
  description={seoDescription}
  lang="es"
  tkey="services/logistics-english"
  ogImage={{
    src:
      typeof logisticsService?.backgroundImage === "string"
        ? logisticsService.backgroundImage
        : "/images/logos/new-york-english-sq-og.jpg",
  }}
  customHreflangs={[
    {
      lang: "en-US",
      href: "https://www.nyenglishteacher.com/en/services/logistics-english/",
    },
    {
      lang: "es-MX",
      href: "https://www.nyenglishteacher.com/es/servicios/ingles-para-logistica/",
    },
  ]}
  customCanonical="https://www.nyenglishteacher.com/es/servicios/ingles-para-logistica/"
>
  <!-- Hero Section -->
  <InnerHero content={heroContent} />

  <!-- Challenge Section -->
  <Challenge content={challengeContent} background="white" padding="lg" />

  <!-- Methodology Section -->
  <MethodologySection content={metodologiaEs} background="light" padding="lg" />

  <!-- Featured Testimonial -->
  {
    featuredTestimonial && (
      <FeaturedTestimonial testimonial={featuredTestimonial} />
    )
  }

  <!-- Final CTA -->
  <CtaSection content={ctaContent} />

  <BreadcrumbSchema items={[
    { name: "Inicio", url: "https://www.nyenglishteacher.com/es/" },
    { name: "Servicios", url: "https://www.nyenglishteacher.com/es/servicios/" },
    { name: "Inglés para Logística", url: "https://www.nyenglishteacher.com/es/servicios/ingles-para-logistica/" }
  ]} />
  <ServiceFAQ faqs={faqs} lang="es" />
</Base>
