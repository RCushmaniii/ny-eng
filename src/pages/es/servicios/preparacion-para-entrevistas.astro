---
export const prerender = true;

import Base from "@layouts/Base.astro";
import InnerHero from "@components/sections/InnerHero.astro";
import Challenge from "@components/sections/Challenge.astro";
import MethodologySection from "@components/sections/MethodologySection.astro";
import FeaturedTestimonial from "@components/sections/FeaturedTestimonial.astro";
import CtaSection from "@components/sections/CtaSection.astro";
import ServiceFAQ from "@components/sections/ServiceFAQ.astro";
import BreadcrumbSchema from "@components/seo/BreadcrumbSchema.astro";
import Breadcrumbs from "@components/ui/Breadcrumbs.astro";
import { serviceFaqs } from "@data/service-faqs";

// Import services data
import { services } from "@data/services";

// Get the interview prep service data
const interviewPrepService = services.find((s) => s.slug === "interview-prep");

// Import methodology content
import type { Methodology } from "@data/methodology";

// Define Spanish methodology content directly
const metodologiaEs: Methodology = {
  title: "Tu Método de Coaching Personalizado",
  subtitle:
    "Una metodología probada de cuatro pasos diseñada para entender tus desafíos únicos y desarrollar las habilidades específicas que necesitas para tener éxito.",
  steps: [
    {
      icon: "lucide:search-check",
      title: "Descubrimiento y Evaluación",
      description:
        "Inglés para entrevistas: prepárate para destacar y conseguir el empleo que deseas en empresas globales.",
    },
    {
      icon: "lucide:map",
      title: "Mapeo Estratégico de Objetivos",
      description:
        "Juntos, definimos objetivos claros y medibles directamente vinculados con tu éxito profesional, creando un plan estratégico enfocado en tus metas específicas.",
    },
    {
      icon: "lucide:settings",
      title: "Programa Personalizado y Práctica",
      description:
        "Tu programa está construido para ti, enfocándose en el vocabulario específico, frases y matices culturales relevantes para tu industria y tareas diarias.",
    },
    {
      icon: "lucide:message-square-text",
      title: "Simulación del Mundo Real y Retroalimentación",
      description:
        "Aquí es donde la teoría se convierte en instinto. Realizamos presentaciones simuladas y juegos de rol de negociaciones difíciles, proporcionando retroalimentación directa y práctica para que estés confiado y preparado.",
    },
  ],
};

// Import testimonials and select featured one
import { testimonials } from "@data/testimonials/es";
const featuredTestimonialSlug = "carolina-martinez-interview-success";
const featuredTestimonial = testimonials.find(
  (t) => t.slug === featuredTestimonialSlug
);

// SEO metadata
const title = "Preparación para Entrevistas en Inglés | NY English";
const seoDescription =
  "Domina las entrevistas en inglés. Aprende a contar tu historia, responder preguntas difíciles y proyectar confianza en cada entrevista.";

// Hero content
const heroContent = {
  title: "Asegura tu Próximo Rol con Confianza",
  description:
    "Domina el arte de las entrevistas en inglés y destaca entre los candidatos.",
  backgroundImage: interviewPrepService?.backgroundImage,
  overlayOpacity: 0.7,
};

// Challenge section content
const challengeContent = {
  headline: "¿Enfrentas Estos Desafíos?",
  painPoints: [
    "Te pones nervioso y pierdes fluidez cuando te hacen preguntas inesperadas en inglés.",
    "Te cuesta explicar tus logros de manera convincente y estructurada.",
    "No sabes cómo manejar preguntas sobre debilidades o situaciones difíciles en el trabajo.",
  ],
  icon: "😰",
  image: interviewPrepService?.squareImage,
  quizCta: {
    text: "Descubre tu Puntuación de Preparación para Entrevistas en 60 segundos.",
    link: "/es/quiz/high-stakes/question/1",
    linkLabel: "Iniciar la Evaluación →",
  },
};

// Final CTA content
const ctaContent = {
  eyebrow: "¿Listo para Destacar en tu Próxima Entrevista?",
  title: "Domina las Entrevistas en Inglés",
  description:
    "Una sesión de estrategia personalizada te mostrará exactamente cómo prepararte para entrevistas en inglés y proyectar la confianza que necesitas para conseguir el trabajo que deseas.",
  buttonText: "Reserva Mi Sesión de Estrategia de Entrevistas",
  buttonLink: "/es/reservar/",
  whatToExpectTitle: "En Tu Sesión Gratuita, Haremos:",
  whatToExpectList: [
    "Evaluar tu estilo de comunicación actual en entrevistas",
    "Identificar áreas clave donde mejorar tu presentación personal impulsará tus resultados",
    "Crear una hoja de ruta para desarrollar respuestas convincentes y técnicas de narrativa profesional",
  ],
};

// Translation slug for English version
const translationSlug = "interview-prep";

const faqs = serviceFaqs["interview-prep"]?.es || [];
---

<Base
  title={title}
  description={seoDescription}
  lang="es"
  tkey="services/interview-prep"
  ogImage={{
    src:
      typeof interviewPrepService?.backgroundImage === "string"
        ? interviewPrepService.backgroundImage
        : "/images/logos/new-york-english-og.jpg",
  }}
  customHreflangs={[
    {
      lang: "en-US",
      href: "https://www.nyenglishteacher.com/en/services/interview-prep/",
    },
    {
      lang: "es-MX",
      href: "https://www.nyenglishteacher.com/es/servicios/preparacion-para-entrevistas/",
    },
  ]}
  customCanonical="https://www.nyenglishteacher.com/es/servicios/preparacion-para-entrevistas/"
>
  <!-- Hero Section -->
  <InnerHero content={heroContent} />

  <!-- Challenge Section -->
  <Challenge content={challengeContent} background="white" padding="lg" />

  <!-- Methodology Section -->
  <MethodologySection content={metodologiaEs} background="light" padding="lg" />

  <!-- Featured Testimonial -->
  {
    featuredTestimonial && (
      <FeaturedTestimonial testimonial={featuredTestimonial} />
    )
  }

  <!-- Final CTA -->
  <CtaSection content={ctaContent} />

  <BreadcrumbSchema items={[
    { name: "Inicio", url: "https://www.nyenglishteacher.com/es/" },
    { name: "Servicios", url: "https://www.nyenglishteacher.com/es/servicios/" },
    { name: "Preparación para Entrevistas", url: "https://www.nyenglishteacher.com/es/servicios/preparacion-para-entrevistas/" }
  ]} />
  <ServiceFAQ faqs={faqs} lang="es" />
</Base>
