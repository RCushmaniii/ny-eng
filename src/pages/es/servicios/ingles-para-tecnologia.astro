---
export const prerender = true;

import Base from "@layouts/Base.astro";
import InnerHero from "@components/sections/InnerHero.astro";
import Challenge from "@components/sections/Challenge.astro";
import MethodologySection from "@components/sections/MethodologySection.astro";
import FeaturedTestimonial from "@components/sections/FeaturedTestimonial.astro";
import CtaSection from "@components/sections/CtaSection.astro";
import ServiceFAQ from "@components/sections/ServiceFAQ.astro";
import BreadcrumbSchema from "@components/seo/BreadcrumbSchema.astro";
import { serviceFaqs } from "@data/service-faqs";

// Import services data
import { services } from "@data/services";

// Get the tech service data
const techService = services.find((s) => s.slug === "tech-english");

// Import methodology content
import type { Methodology } from "@data/methodology";

// Define Spanish methodology content directly
const metodologiaEs: Methodology = {
  title: "Cómo funciona",
  subtitle: "",
  steps: [
    {
      icon: "lucide:search-check",
      title: "Primero hablamos.",
      description:
        "Una llamada introductoria corta. Tu stack, tu equipo, tus interacciones en inglés—sin presión, sin discurso de ventas.",
    },
    {
      icon: "lucide:map",
      title: "Construyo tu plan.",
      description:
        "Desde tu rol técnico, tus ceremonias de sprint y tus reuniones con stakeholders. Sesiones diseñadas para tu día a día en tech, no genéricas.",
    },
    {
      icon: "lucide:settings",
      title: "Practicas bajo presión.",
      description:
        "Code reviews, demos de arquitectura, reuniones cross-team. Retroalimentación sobre claridad, estructura y presencia técnica. Comete errores conmigo, no en la daily.",
    },
    {
      icon: "lucide:message-square-text",
      title: "Refino conforme creces.",
      description:
        "¿Tu comunicación mejora? Yo ajusto—nuevos desafíos, escenarios más complejos. Evoluciona con tu carrera en tech.",
    },
  ],
};

// Import testimonials and select Julio testimonial
import { testimonials } from "@data/testimonials/es";
const featuredTestimonial = testimonials[0]; // Julio Aldana testimonial

// SEO metadata
const title = "Coaching de Inglés para Tecnología | NY English";
const seoDescription =
  "Domina el inglés técnico para comunicar conceptos complejos con claridad. Code reviews, arquitectura y colaboración global en tecnología.";

// Hero content
const heroContent = {
  title: "Tu código es impecable. Tu explicación pierde a la sala.",
  description:
    "Coaching para líderes técnicos que necesitan convertir complejidad técnica en valor de negocio claro — sin perder precisión ni credibilidad.",
  backgroundImage: techService?.backgroundImage,
  overlayOpacity: 0.7,
};

// Challenge section content
const challengeContent = {
  headline: "¿Te suena familiar?",
  painPoints: [
    "Entiendes la arquitectura perfecto — pero cuando la explicas en inglés, los stakeholders no-técnicos se desconectan.",
    "En ceremonias de sprint, tus ideas se pasan por alto porque alguien más las articula mejor — no porque sean mejores ideas.",
    "Evitas hablar en reuniones cross-team. No porque no tengas la respuesta, sino porque construirla en inglés tarda demasiado.",
  ],
  icon: "😰",
  image: techService?.squareImage,
  quizCta: {
    text: "Obtén tu Puntuación de Comunicación Técnica en 60 segundos.",
    link: "/es/quiz/it-services/question/1",
    linkLabel: "Iniciar la Evaluación →",
  },
};

// Final CTA content
const ctaContent = {
  eyebrow: "",
  title: "Ya lideras. Ahora suena así — en inglés.",
  description:
    "Reserva una sesión estratégica privada. 30 minutos: identificaré las brechas entre tu inglés y el liderazgo técnico que tu rol exige.",
  buttonText: "Reservar Mi Sesión Estratégica",
  buttonLink: "/es/reservar/",
  whatToExpectTitle: "En Tu Sesión Gratuita, Haremos:",
  whatToExpectList: [
    "Evaluar cómo tu inglés impacta discusiones técnicas y confianza con stakeholders",
    "Identificar los escenarios donde la comunicación te cuesta influencia",
    "Crear un plan para explicar ideas complejas con claridad — en cualquier sala",
  ],
};

const faqs = serviceFaqs["tech-english"]?.es || [];
---

<Base
  title={title}
  description={seoDescription}
  lang="es"
  tkey="services/tech-english"
  ogImage={{
    src:
      typeof techService?.backgroundImage === "string"
        ? techService.backgroundImage
        : "/images/logos/new-york-english-sq-og.jpg",
  }}
  customHreflangs={[
    {
      lang: "en-US",
      href: "https://www.nyenglishteacher.com/en/services/tech-english/",
    },
    {
      lang: "es-MX",
      href: "https://www.nyenglishteacher.com/es/servicios/ingles-para-tecnologia/",
    },
  ]}
  customCanonical="https://www.nyenglishteacher.com/es/servicios/ingles-para-tecnologia/"
>
  <!-- Hero Section -->
  <InnerHero content={heroContent} />

  <!-- Challenge Section -->
  <Challenge content={challengeContent} background="white" padding="lg" />

  <!-- Methodology Section -->
  <MethodologySection content={metodologiaEs} background="light" padding="lg" />

  <!-- Featured Testimonial -->
  {
    featuredTestimonial && (
      <FeaturedTestimonial testimonial={featuredTestimonial} />
    )
  }

  <!-- More testimonials link -->
  <div class="text-center py-4 -mt-8 bg-slate-900">
    <a href="/es/testimonios/tech-english/" class="text-blue-400 hover:text-blue-300 font-medium transition-colors">
      Lee m&aacute;s historias de &eacute;xito de ingenieros y l&iacute;deres tech &rarr;
    </a>
  </div>

  <!-- Final CTA -->
  <CtaSection content={ctaContent} />

  <BreadcrumbSchema items={[
    { name: "Inicio", url: "https://www.nyenglishteacher.com/es/" },
    { name: "Servicios", url: "https://www.nyenglishteacher.com/es/servicios/" },
    { name: "Inglés para Tecnología", url: "https://www.nyenglishteacher.com/es/servicios/ingles-para-tecnologia/" }
  ]} />
  <ServiceFAQ faqs={faqs} lang="es" />
</Base>
