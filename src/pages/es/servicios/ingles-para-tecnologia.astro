---
import Base from "@layouts/Base.astro";
import InnerHero from "@components/sections/InnerHero.astro";
import Challenge from "@components/sections/Challenge.astro";
import MethodologySection from "@components/sections/MethodologySection.astro";
import FeaturedTestimonial from "@components/sections/FeaturedTestimonial.astro";
import CtaSection from "@components/sections/CtaSection.astro";

// Import services data
import { services } from "@data/services";

// Get the tech service data
const techService = services.find(s => s.slug === 'tech-english');

// Import methodology content
import type { Methodology } from "@data/methodology";

// Define Spanish methodology content directly
const metodologiaEs: Methodology = {
  title: "Tu Método de Coaching Personalizado",
  subtitle: "Una metodología probada de cuatro pasos diseñada para entender tus desafíos únicos y desarrollar las habilidades específicas que necesitas para tener éxito.",
  steps: [
    {
      icon: "lucide:search-check",
      title: "Descubrimiento y Evaluación",
      description: "Identificamos tus retos técnicos en inglés y tus fortalezas para crear un plan personalizado y enfocado en tus objetivos profesionales."
    },
    {
      icon: "lucide:map",
      title: "Mapeo Estratégico de Objetivos",
      description: "Juntos, definimos objetivos claros y medibles directamente vinculados con tu éxito profesional, creando un plan estratégico enfocado en tus metas específicas."
    },
    {
      icon: "lucide:settings",
      title: "Currículum Personalizado y Práctica",
      description: "Tu programa está construido para ti, enfocándose en el vocabulario específico, frases y matices culturales relevantes para tu industria y tareas diarias."
    },
    {
      icon: "lucide:message-square-text",
      title: "Simulación del Mundo Real y Retroalimentación",
      description: "Aquí es donde la teoría se convierte en instinto. Realizamos presentaciones simuladas y juegos de rol de negociaciones difíciles, proporcionando retroalimentación directa y accionable para que estés confiado y preparado."
    }
  ]
};

// Import testimonials and select Julio testimonial
import { testimonials } from "@data/testimonials/es";
const featuredTestimonial = testimonials[0]; // Julio Aldana testimonial

// SEO metadata
const title = "Coaching de Inglés para Tecnología | NY English";
const seoDescription = "Domina el inglés técnico para comunicar conceptos complejos con claridad. Code reviews, arquitectura y colaboración global en tecnología.";

// Hero content
const heroContent = {
  title: "Domina el Inglés Técnico para Impacto Global",
  description: "Comunica conceptos técnicos complejos con claridad y precisión en entornos tecnológicos internacionales.",
  backgroundImage: techService?.backgroundImage,
  overlayOpacity: 0.7
};

// Challenge section content
const challengeContent = {
  headline: "¿Enfrentas Estos Desafíos?",
  painPoints: [
    "Te cuesta explicar conceptos técnicos complejos claramente en inglés durante reuniones.",
    "Las revisiones de código y discusiones técnicas se sienten abrumadoras en un segundo idioma.",
    "Evitas participar en reuniones de arquitectura debido a barreras del idioma."
  ],
  icon: "😰",
  image: techService?.squareImage
};

// Final CTA content
const ctaContent = {
  eyebrow: "¿Listo para Transformar tu Comunicación Técnica?",
  title: "Domina el Inglés para Tecnología",
  description: "Inglés para tecnología: explica conceptos técnicos y colabora eficazmente en equipos globales de IT.",
  buttonText: "Reserva Mi Sesión de Estrategia Técnica",
  buttonLink: "/es/book/",
  whatToExpectTitle: "En Tu Sesión Gratuita, Haremos:",
  whatToExpectList: [
    "Evaluar tus fortalezas y brechas actuales en comunicación técnica",
    "Practicar explicando conceptos técnicos complejos con claridad",
    "Crear un plan personalizado para aumentar tu confianza en discusiones técnicas"
  ]
};

---

<Base
  title={title}
  description={seoDescription}
  lang="es"
  tkey="services/tech-english"
  ogImage={{ src: typeof techService?.backgroundImage === 'string' ? techService.backgroundImage : "/images/logos/new-york-english-og.jpg" }}
  customHreflangs={[
    { lang: 'en-US', href: 'https://www.nyenglishteacher.com/en/services/tech-english/' },
    { lang: 'es-MX', href: 'https://www.nyenglishteacher.com/es/servicios/ingles-para-tecnologia/' }
  ]}
  customCanonical="https://www.nyenglishteacher.com/es/servicios/ingles-para-tecnologia/"
>
  <!-- Hero Section -->
  <InnerHero content={heroContent} />
  
  <!-- Challenge Section -->
  <Challenge content={challengeContent} background="white" padding="lg" />
  
  <!-- Methodology Section -->
  <MethodologySection content={metodologiaEs} background="light" padding="lg" />
  
  <!-- Featured Testimonial -->
  {featuredTestimonial && (
    <FeaturedTestimonial testimonial={featuredTestimonial} />
  )}
  
  <!-- Final CTA -->
  <CtaSection content={ctaContent} />
</Base>
