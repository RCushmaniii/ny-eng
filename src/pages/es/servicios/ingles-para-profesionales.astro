---
export const prerender = true;

import Base from "@layouts/Base.astro";
import InnerHero from "@components/sections/InnerHero.astro";
import Challenge from "@components/sections/Challenge.astro";
import MethodologySection from "@components/sections/MethodologySection.astro";
import FeaturedTestimonial from "@components/sections/FeaturedTestimonial.astro";
import CtaSection from "@components/sections/CtaSection.astro";
import ServiceFAQ from "@components/sections/ServiceFAQ.astro";
import BreadcrumbSchema from "@components/seo/BreadcrumbSchema.astro";
import Breadcrumbs from "@components/ui/Breadcrumbs.astro";
import { serviceFaqs } from "@data/service-faqs";

// Import services data
import { services } from "@data/services";

// Get the professional service data
const professionalService = services.find(
  (s) => s.slug === "professional-english"
);

// Import methodology content
import type { Methodology } from "@data/methodology";

// Define Spanish methodology content directly
const metodologiaEs: Methodology = {
  title: "Tu Método de Coaching Personalizado",
  subtitle:
    "Una metodología probada de cuatro pasos diseñada para entender tus desafíos únicos y desarrollar las habilidades específicas que necesitas para tener éxito.",
  steps: [
    {
      icon: "lucide:search-check",
      title: "Descubrimiento y Evaluación",
      description:
        "Inglés para profesionales: avanza en tu carrera con clases enfocadas en comunicación efectiva y relaciones profesionales internacionales.",
    },
    {
      icon: "lucide:map",
      title: "Mapeo Estratégico de Objetivos",
      description:
        "Juntos, definimos objetivos claros y medibles directamente vinculados con tu éxito profesional, creando un plan estratégico enfocado en tus metas específicas.",
    },
    {
      icon: "lucide:settings",
      title: "Programa Personalizado y Práctica",
      description:
        "Tu programa está construido para ti, enfocándose en el vocabulario específico, frases y matices culturales relevantes para tu industria y tareas diarias.",
    },
    {
      icon: "lucide:message-square-text",
      title: "Simulación del Mundo Real y Retroalimentación",
      description:
        "Aquí es donde la teoría se convierte en instinto. Realizamos presentaciones simuladas y juegos de rol de negociaciones difíciles, proporcionando retroalimentación directa y práctica para que estés confiado y preparado.",
    },
  ],
};

// Import testimonials and select Erika testimonial (medical professional)
import { testimonials } from "@data/testimonials/es";
const featuredTestimonial = testimonials[7]; // Dra. Erika Itzel testimonial

// SEO metadata
const title = "Inglés para Profesionales | Médicos y Abogados";
const seoDescription =
  "Mejora tu comunicación profesional en inglés. Coaching para interacciones con clientes, reuniones ejecutivas y relaciones profesionales internacionales.";

// Hero content
const heroContent = {
  title: "Inglés para Campos Profesionales",
  description:
    "Domina la terminología especializada y comunícate con claridad en cada interacción con clientes y entornos profesionales.",
  backgroundImage: professionalService?.backgroundImage,
  overlayOpacity: 0.7,
};

// Challenge section content
const challengeContent = {
  headline: "¿Enfrentas Estos Desafíos?",
  painPoints: [
    "Te sientes menos seguro al explicar temas complejos a clientes o pacientes de habla inglesa.",
    "La terminología especializada y la pronunciación crean barreras durante las interacciones profesionales.",
    "Te preocupa que la falta de comunicación afecte las relaciones con los clientes y la confianza.",
  ],
  icon: "😰",
  image: professionalService?.squareImage,
  quizCta: {
    text: "¿Quieres saber exactamente dónde están tus brechas de comunicación profesional?",
    link: "/es/quiz/professional-services/question/1",
    linkLabel: "Toma la evaluación gratuita de 90 segundos →",
  },
};

// Final CTA content
const ctaContent = {
  eyebrow: "¿Listo para Transformar tu Comunicación Profesional?",
  title: "Comunícate con Confianza y Precisión",
  description:
    "Una sesión de estrategia gratuita y sin compromiso es la mejor manera de entender cómo el coaching personalizado puede mejorar tus interacciones con clientes y aumentar tu confianza.",
  buttonText: "Reserva Mi Sesión de Estrategia Gratuita",
  buttonLink: "/es/reservar/",
  whatToExpectTitle: "En Tu Sesión Gratuita, Haremos:",
  whatToExpectList: [
    "Evaluar tus habilidades actuales de comunicación en inglés profesional",
    "Identificar áreas específicas de mejora en las interacciones con clientes",
    "Crear un plan de aprendizaje personalizado para tu campo profesional",
  ],
};

const faqs = serviceFaqs["professional-english"]?.es || [];
---

<Base
  title={title}
  description={seoDescription}
  lang="es"
  tkey="services/professional-english"
  ogImage={{
    src:
      typeof professionalService?.backgroundImage === "string"
        ? professionalService.backgroundImage
        : "/images/logos/new-york-english-og.jpg",
  }}
  customHreflangs={[
    {
      lang: "en-US",
      href: "https://www.nyenglishteacher.com/en/services/professional-english/",
    },
    {
      lang: "es-MX",
      href: "https://www.nyenglishteacher.com/es/servicios/ingles-para-profesionales/",
    },
  ]}
  customCanonical="https://www.nyenglishteacher.com/es/servicios/ingles-para-profesionales/"
>
  <!-- Hero Section -->
  <InnerHero content={heroContent} />

  <!-- Challenge Section -->
  <Challenge content={challengeContent} background="white" padding="lg" />

  <!-- Methodology Section -->
  <MethodologySection content={metodologiaEs} background="light" padding="lg" />

  <!-- Featured Testimonial -->
  {
    featuredTestimonial && (
      <FeaturedTestimonial testimonial={featuredTestimonial} />
    )
  }

  <!-- Final CTA -->
  <CtaSection content={ctaContent} />

  <BreadcrumbSchema items={[
    { name: "Inicio", url: "https://www.nyenglishteacher.com/es/" },
    { name: "Servicios", url: "https://www.nyenglishteacher.com/es/servicios/" },
    { name: "Inglés para Profesionales", url: "https://www.nyenglishteacher.com/es/servicios/ingles-para-profesionales/" }
  ]} />
  <ServiceFAQ faqs={faqs} lang="es" />
</Base>
