---
import Layout from "@layouts/Layout.astro";
import InnerHero from "@components/sections/InnerHero.astro";
import Challenge from "@components/sections/Challenge.astro";
import MethodologySection from "@components/sections/MethodologySection.astro";
import FeaturedTestimonial from "@components/sections/FeaturedTestimonial.astro";
import CtaSection from "@components/sections/CtaSection.astro";

// Import services data
import { services } from "@data/services";

// Get the professional service data
const professionalService = services.find(s => s.slug === 'professional-english');

// Import methodology content
import type { Methodology } from "@data/methodology";

// Define Spanish methodology content directly
const metodologiaEs: Methodology = {
  title: "Tu Método de Coaching Personalizado",
  subtitle: "Una metodología probada de cuatro pasos diseñada para entender tus desafíos únicos y desarrollar las habilidades específicas que necesitas para tener éxito.",
  steps: [
    {
      icon: "lucide:search-check",
      title: "Descubrimiento y Evaluación",
      description: "Inglés para profesionales: avanza en tu carrera con clases enfocadas en comunicación efectiva y networking internacional."
    },
    {
      icon: "lucide:map",
      title: "Mapeo Estratégico de Objetivos",
      description: "Juntos, definimos objetivos claros y medibles directamente vinculados con tu éxito profesional, creando un plan estratégico enfocado en tus metas específicas."
    },
    {
      icon: "lucide:settings",
      title: "Currículum Personalizado y Práctica",
      description: "Tu programa está construido para ti, enfocándose en el vocabulario específico, frases y matices culturales relevantes para tu industria y tareas diarias."
    },
    {
      icon: "lucide:message-square-text",
      title: "Simulación del Mundo Real y Retroalimentación",
      description: "Aquí es donde la teoría se convierte en instinto. Realizamos presentaciones simuladas y juegos de rol de negociaciones difíciles, proporcionando retroalimentación directa y accionable para que estés confiado y preparado."
    }
  ]
};

// Import testimonials and select an appropriate testimonial
import { testimonials } from "@data/testimonials/es";
const featuredTestimonialSlug = 'ricardo-fernandez-hospital-angeles'; // Use a medical testimonial since it's related
const featuredTestimonial = testimonials.find(t => t.slug === featuredTestimonialSlug);

// SEO metadata
const title = "Coaching de Inglés Profesional | Médicos y Abogados | NY English";
const seoDescription = "Comunícate claramente con pacientes, clientes, colegas y en conferencias de la industria. Domina la terminología especializada para profesionales médicos y legales.";

// Hero content
const heroContent = {
  title: "Inglés para Campos Profesionales",
  description: "Domina la terminología especializada y comunícate con claridad en cada interacción con clientes y entornos profesionales.",
  backgroundImage: professionalService?.backgroundImage,
  overlayOpacity: 0.7
};

// Challenge section content
const challengeContent = {
  headline: "¿Enfrentas Estos Desafíos?",
  painPoints: [
    "Te sientes menos seguro al explicar temas complejos a clientes o pacientes de habla inglesa.",
    "La terminología especializada y la pronunciación crean barreras durante las interacciones profesionales.",
    "Te preocupa que la falta de comunicación afecte las relaciones con los clientes y la confianza."
  ],
  icon: "😰",
  image: professionalService?.squareImage
};

// Final CTA content
const ctaContent = {
  eyebrow: "¿Listo para Transformar tu Comunicación Profesional?",
  title: "Comunícate con Confianza y Precisión",
  description: "Una sesión de estrategia gratuita y sin compromiso es la mejor manera de entender cómo el coaching personalizado puede mejorar tus interacciones con clientes y aumentar tu confianza.",
  buttonText: "Reserva Mi Sesión de Estrategia Gratuita",
  buttonLink: "https://ny-english-teacher.odoo.com/book/7ceefa20",
  whatToExpectTitle: "En Tu Sesión Gratuita, Haremos:",
  whatToExpectList: [
    "Evaluar tus habilidades actuales de comunicación en inglés profesional",
    "Identificar áreas específicas de mejora en las interacciones con clientes",
    "Crear un plan de aprendizaje personalizado para tu campo profesional"
  ]
};

// Translation slug for English version
const translationSlug = "professional-english";
---

<Layout
  title={title}
  description={seoDescription}
  lang="es"
  translationSlugEn={`/en/services/${translationSlug}`}
  image={professionalService?.backgroundImage || "/images/logos/new-york-english-og-wide.jpg"}
  hideCta={true}
>
  <!-- Hero Section -->
  <InnerHero content={heroContent} />
  
  <!-- Challenge Section -->
  <Challenge content={challengeContent} background="white" padding="lg" />
  
  <!-- Methodology Section -->
  <MethodologySection content={metodologiaEs} background="light" padding="lg" />
  
  <!-- Featured Testimonial -->
  {featuredTestimonial && (
    <FeaturedTestimonial testimonial={featuredTestimonial} />
  )}
  
  <!-- Final CTA -->
  <CtaSection content={ctaContent} />
</Layout>
