---
export const prerender = true;

import Base from "@layouts/Base.astro";
import InnerHero from "@components/sections/InnerHero.astro";
import Challenge from "@components/sections/Challenge.astro";
import MethodologySection from "@components/sections/MethodologySection.astro";
import FeaturedTestimonial from "@components/sections/FeaturedTestimonial.astro";
import CtaSection from "@components/sections/CtaSection.astro";
import ServiceFAQ from "@components/sections/ServiceFAQ.astro";
import BreadcrumbSchema from "@components/seo/BreadcrumbSchema.astro";
import Breadcrumbs from "@components/ui/Breadcrumbs.astro";
import { serviceFaqs } from "@data/service-faqs";

// Import services data
import { services } from "@data/services";

// Get the professional service data
const professionalService = services.find(
  (s) => s.slug === "professional-english"
);

// Import methodology content
import type { Methodology } from "@data/methodology";

// Define Spanish methodology content directly
const metodologiaEs: Methodology = {
  title: "Cómo funciona",
  subtitle: "",
  steps: [
    {
      icon: "lucide:search-check",
      title: "Primero hablamos.",
      description:
        "Una llamada introductoria corta. Tu especialidad, tus interacciones en inglés, lo que está en juego—sin presión, sin discurso de ventas.",
    },
    {
      icon: "lucide:map",
      title: "Construyo tu plan.",
      description:
        "Desde tu campo profesional, tu terminología y tus escenarios reales. Sesiones diseñadas para tu práctica, no genéricas.",
    },
    {
      icon: "lucide:settings",
      title: "Practicas bajo presión.",
      description:
        "Consultas con pacientes, casos legales, interacciones con clientes internacionales. Retroalimentación sobre precisión, tono y confianza. Comete errores conmigo, no con tus clientes.",
    },
    {
      icon: "lucide:message-square-text",
      title: "Refino conforme creces.",
      description:
        "¿Tu comunicación mejora? Yo ajusto—nuevos desafíos, escenarios más complejos. Evoluciona con tu carrera.",
    },
  ],
};

// Import testimonials and select Erika testimonial (medical professional)
import { testimonials } from "@data/testimonials/es";
const featuredTestimonial = testimonials[7]; // Dra. Erika Itzel testimonial

// SEO metadata
const title = "Inglés para Profesionales | Médicos y Abogados";
const seoDescription =
  "Mejora tu comunicación profesional en inglés. Coaching para interacciones con clientes, reuniones ejecutivas y relaciones profesionales internacionales.";

// Hero content
const heroContent = {
  title: "Una palabra incorrecta puede costar más que tus honorarios.",
  description:
    "Inglés de precisión para profesionales médicos y legales que necesitan claridad absoluta cuando lo que está en juego es real.",
  backgroundImage: professionalService?.backgroundImage,
  overlayOpacity: 0.7,
};

// Challenge section content
const challengeContent = {
  headline: "¿Te suena familiar?",
  painPoints: [
    "Eres experto en tu campo — pero explicar un diagnóstico o una posición legal en inglés te hace sonar menos seguro de lo que eres.",
    "Pacientes o clientes internacionales perciben tu vacilación. No es tu competencia — es el idioma creando distancia.",
    "Evitas conferencias, casos transfronterizos o referidos internacionales porque el inglés se siente como un riesgo que no puedes asumir.",
  ],
  icon: "😰",
  image: professionalService?.squareImage,
  quizCta: {
    text: "Obtén tu Puntuación de Comunicación Profesional en 60 segundos.",
    link: "/es/quiz/professional-services/question/1",
    linkLabel: "Iniciar la Evaluación →",
  },
};

// Final CTA content
const ctaContent = {
  eyebrow: "",
  title: "Ya lideras. Ahora suena así — en inglés.",
  description:
    "Reserva una sesión estratégica privada. 30 minutos: identificaré las brechas entre tu inglés y la precisión que tu rol profesional exige.",
  buttonText: "Reservar Mi Sesión Estratégica",
  buttonLink: "/es/reservar/",
  whatToExpectTitle: "En Tu Sesión Gratuita, Haremos:",
  whatToExpectList: [
    "Evaluar cómo tu inglés impacta la confianza de tus pacientes o clientes",
    "Identificar las interacciones específicas donde la precisión importa más",
    "Crear un plan basado en tus escenarios profesionales reales",
  ],
};

const faqs = serviceFaqs["professional-english"]?.es || [];
---

<Base
  title={title}
  description={seoDescription}
  lang="es"
  tkey="services/professional-english"
  ogImage={{
    src:
      typeof professionalService?.backgroundImage === "string"
        ? professionalService.backgroundImage
        : "/images/logos/new-york-english-og.jpg",
  }}
  customHreflangs={[
    {
      lang: "en-US",
      href: "https://www.nyenglishteacher.com/en/services/professional-english/",
    },
    {
      lang: "es-MX",
      href: "https://www.nyenglishteacher.com/es/servicios/ingles-para-profesionales/",
    },
  ]}
  customCanonical="https://www.nyenglishteacher.com/es/servicios/ingles-para-profesionales/"
>
  <!-- Hero Section -->
  <InnerHero content={heroContent} />

  <!-- Challenge Section -->
  <Challenge content={challengeContent} background="white" padding="lg" />

  <!-- Methodology Section -->
  <MethodologySection content={metodologiaEs} background="light" padding="lg" />

  <!-- Featured Testimonial -->
  {
    featuredTestimonial && (
      <FeaturedTestimonial testimonial={featuredTestimonial} />
    )
  }

  <!-- Final CTA -->
  <CtaSection content={ctaContent} />

  <BreadcrumbSchema items={[
    { name: "Inicio", url: "https://www.nyenglishteacher.com/es/" },
    { name: "Servicios", url: "https://www.nyenglishteacher.com/es/servicios/" },
    { name: "Inglés para Profesionales", url: "https://www.nyenglishteacher.com/es/servicios/ingles-para-profesionales/" }
  ]} />
  <ServiceFAQ faqs={faqs} lang="es" />
</Base>
