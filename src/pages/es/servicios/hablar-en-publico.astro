---
export const prerender = true;

import Base from "@layouts/Base.astro";
import InnerHero from "@components/sections/InnerHero.astro";
import Challenge from "@components/sections/Challenge.astro";
import MethodologySection from "@components/sections/MethodologySection.astro";
import FeaturedTestimonial from "@components/sections/FeaturedTestimonial.astro";
import CtaSection from "@components/sections/CtaSection.astro";
import ServiceFAQ from "@components/sections/ServiceFAQ.astro";
import BreadcrumbSchema from "@components/seo/BreadcrumbSchema.astro";
import Breadcrumbs from "@components/ui/Breadcrumbs.astro";
import { serviceFaqs } from "@data/service-faqs";

// Import services data
import { services, serviciosEs } from "@data/services";

// Get the public speaking service data
const publicSpeakingService = serviciosEs.find(
  (s) => s.slug === "ingles-para-presentaciones"
);

// Import methodology content
import type { Methodology } from "@data/methodology";

// Define Spanish methodology content directly
const metodologiaEs: Methodology = {
  title: "Tu Método de Coaching Personalizado",
  subtitle:
    "Una metodología probada de cuatro pasos diseñada para entender tus desafíos únicos y desarrollar las habilidades específicas que necesitas para tener éxito.",
  steps: [
    {
      icon: "lucide:search-check",
      title: "Descubrimiento y Evaluación",
      description:
        "Inglés para presentaciones: domina el arte de hablar en público y comunica tus ideas con seguridad y claridad ante cualquier audiencia.",
    },
    {
      icon: "lucide:map",
      title: "Mapeo Estratégico de Objetivos",
      description:
        "Juntos, definimos objetivos claros y medibles directamente vinculados con tu éxito profesional, creando un plan estratégico enfocado en tus metas específicas.",
    },
    {
      icon: "lucide:settings",
      title: "Programa Personalizado y Práctica",
      description:
        "Tu programa está construido para ti, enfocándose en el vocabulario específico, frases y matices culturales relevantes para tu industria y tareas diarias.",
    },
    {
      icon: "lucide:message-square-text",
      title: "Simulación del Mundo Real y Retroalimentación",
      description:
        "Aquí es donde la teoría se convierte en instinto. Realizamos presentaciones simuladas y juegos de rol de negociaciones difíciles, proporcionando retroalimentación directa y práctica para que estés confiado y preparado.",
    },
  ],
};

// Import testimonials and select featured one
import { testimonials } from "@data/testimonials/es";
const featuredTestimonialSlug = "maria-gonzalez-presentation-success";
const featuredTestimonial = testimonials.find(
  (t) => t.slug === featuredTestimonialSlug
);

// SEO metadata
const title = "Hablar en Público | Presenta con Confianza | NY English";
const seoDescription =
  "Domina el arte de hablar en público en inglés. Supera la ansiedad, cautiva a tu audiencia y proyecta autoridad en presentaciones.";

// Hero content
const heroContent = {
  title: "Cautiva a Cualquier Audiencia",
  description:
    "Domina el arte de hablar en público en inglés, desde reuniones de equipo hasta conferencias internacionales.",
  backgroundImage: publicSpeakingService?.backgroundImage,
  overlayOpacity: 0.7,
};

// Challenge section content
const challengeContent = {
  headline: "¿Enfrentas Estos Desafíos?",
  painPoints: [
    "Te pones nervioso al presentar en inglés frente a audiencias internacionales.",
    "Te cuesta estructurar tus ideas de manera clara y convincente durante presentaciones.",
    "Pierdes la atención de tu audiencia porque no sabes cómo mantener el interés y la conexión en inglés.",
  ],
  icon: "😰",
  image: publicSpeakingService?.squareImage,
  quizCta: {
    text: "¿Quieres saber exactamente dónde están tus brechas de comunicación de alto impacto?",
    link: "/es/quiz/high-stakes/question/1",
    linkLabel: "Toma la evaluación gratuita de 90 segundos →",
  },
};

// Final CTA content
const ctaContent = {
  eyebrow: "¿Listo para Cautivar a tu Audiencia?",
  title: "Domina el Arte de Hablar en Público",
  description:
    "Una sesión de estrategia personalizada te mostrará exactamente cómo desarrollar la confianza y las técnicas necesarias para presentar con impacto en inglés ante cualquier audiencia.",
  buttonText: "Reserva Mi Sesión de Estrategia de Presentaciones",
  buttonLink: "/es/reservar/",
  whatToExpectTitle: "En Tu Sesión Gratuita, Haremos:",
  whatToExpectList: [
    "Evaluar tu estilo actual de presentación y nivel de confianza",
    "Identificar técnicas específicas para mejorar tu presencia e interacción con la audiencia",
    "Crear una hoja de ruta para desarrollar habilidades de narrativa persuasiva y manejo de audiencias",
  ],
};

// Translation slug for English version
const translationSlug = "public-speaking-english";

const faqs = serviceFaqs["public-speaking-english"]?.es || [];
---

<Base
  title={title}
  description={seoDescription}
  lang="es"
  tkey="services/public-speaking-english"
  ogImage={{
    src:
      publicSpeakingService?.backgroundImage?.src ||
      "/images/logos/new-york-english-sq-og.jpg",
    alt: `${title} - Featured Image`,
    width: publicSpeakingService?.backgroundImage?.width,
    height: publicSpeakingService?.backgroundImage?.height,
  }}
  customHreflangs={[
    {
      lang: "en-US",
      href: "https://www.nyenglishteacher.com/en/services/public-speaking-english/",
    },
    {
      lang: "es-MX",
      href: "https://www.nyenglishteacher.com/es/servicios/hablar-en-publico/",
    },
  ]}
  customCanonical="https://www.nyenglishteacher.com/es/servicios/hablar-en-publico/"
>
  <!-- Hero Section -->
  <InnerHero content={heroContent} />

  <!-- Challenge Section -->
  <Challenge content={challengeContent} background="white" padding="lg" />

  <!-- Methodology Section -->
  <MethodologySection content={metodologiaEs} background="light" padding="lg" />

  <!-- Featured Testimonial -->
  {
    featuredTestimonial && (
      <FeaturedTestimonial testimonial={featuredTestimonial} />
    )
  }

  <!-- Final CTA -->
  <CtaSection content={ctaContent} />

  <BreadcrumbSchema items={[
    { name: "Inicio", url: "https://www.nyenglishteacher.com/es/" },
    { name: "Servicios", url: "https://www.nyenglishteacher.com/es/servicios/" },
    { name: "Hablar en Público", url: "https://www.nyenglishteacher.com/es/servicios/hablar-en-publico/" }
  ]} />
  <ServiceFAQ faqs={faqs} lang="es" />
</Base>
