---
export const prerender = true;

// src/pages/es/servicios/index.astro
import Base from "@layouts/Base.astro";
import Hero from "@components/sections/Hero.astro";
import ServicesGrid from "@components/sections/ServicesGrid.astro";
import ProfessionalProfiles from "@components/sections/ProfessionalProfiles.astro";
import CtaBanner from "@components/sections/CtaBanner.astro";
import { serviciosEs, professionalProfilesEs } from "@data/services";
import servicesHeroImage from "@assets/images/services/services-hero.jpg";

// i18n configuration
const lang = "es";
const tkey = "services";

// SEO metadata
const seoTitle = "Servicios de Coaching de Inglés de Negocios | NY English";
const seoDescription =
  "Explora coaching personalizado de inglés para ejecutivos, tecnología y médicos. Mejora tu fluidez y confianza en entornos empresariales.";

// Hero content in Spanish
const heroContent = {
  title: "Ya lideras. Ahora suena así — en inglés.",
  description:
    "Coaching privado para los momentos específicos donde tu inglés importa más.",
  buttons: [
    {
      text: "Reserva Tu Consulta Gratuita",
      link: "/es/reservar/",
      variant: "primary" as const,
    },
  ],
  backgroundImage: servicesHeroImage,
  backgroundImageMobile: servicesHeroImage,
  backgroundImageAlt:
    "Servicios profesionales de coaching de inglés de negocios",
  overlayOpacity: 0.3,
};

// CTA Banner content in Spanish
const ctaContent = {
  eyebrow: "",
  title: "Ya lideras. Ahora suena así — en inglés.",
  description:
    "Reserva una sesión estratégica privada. 30 minutos: identificaré las brechas entre tu inglés y la presencia ejecutiva que tu rol exige.",
  button: {
    text: "Reservar Mi Sesión Estratégica",
    link: "/es/reservar/",
    variant: "primary" as const,
  },
} as const;

// Professional profiles content in Spanish
const professionalProfilesContent = {
  title: "Encuentra coaching para tu rol",
  description:
    "Cada rol tiene puntos de presión diferentes. Elige el tuyo.",
};
---

<Base
  title={seoTitle}
  description={seoDescription}
  lang={lang}
  tkey={tkey}
  ogImage={{ src: "/images/logos/new-york-english-og-wide.jpg" }}
  heroImage={servicesHeroImage}
  hideCta={true}
>
  <!-- Hero Section -->
  <Hero content={heroContent} />

  <!-- Services Grid -->
  <ServicesGrid
    services={serviciosEs}
    title=""
    description=""
  />

  <!-- Professional Profiles Section -->
  <ProfessionalProfiles
    profiles={professionalProfilesEs}
    content={professionalProfilesContent}
  />

  <!-- Final CTA -->
  <CtaBanner content={ctaContent} />
</Base>
