---
// src/pages/es/servicios/index.astro
import Layout from "@layouts/Layout.astro";
import Hero from "@components/sections/Hero.astro";
import ServicesGrid from "@components/sections/ServicesGrid.astro";
import ProfessionalProfiles from "@components/sections/ProfessionalProfiles.astro";
import CtaBanner from "@components/sections/CtaBanner.astro";
import { serviciosEs, professionalProfilesEs } from "@data/services";
import servicesHeroImage from "@assets/images/services/services-hero.jpg";

// SEO metadata
const seoTitle = "Servicios de Coaching de Inglés de Negocios | NY English";
const seoDescription =
  "Explora coaching personalizado de inglés para ejecutivos, profesionales de tecnología, médicos y más. Mejora tu fluidez y confianza en entornos empresariales reales.";

// Hero content in Spanish
const heroContent = {
  title: "Coaching Especializado de Inglés de Negocios para Tu Éxito",
  description:
    "Programas dirigidos para perfeccionar tus habilidades de comunicación y acelerar tu carrera.",
  buttons: [
    {
      text: "Reserva Tu Consulta Gratuita",
      link: "https://ny-english-teacher.odoo.com/book/7ceefa20",
      variant: "primary" as const,
      target: "_blank",
    },
  ],
  backgroundImage: servicesHeroImage,
  backgroundImageMobile: servicesHeroImage,
  backgroundImageAlt:
    "Servicios profesionales de coaching de inglés de negocios",
  overlayOpacity: 0.3,
};

// CTA Banner content in Spanish
const ctaContent = {
  eyebrow: "¿No Estás Seguro Cuál Servicio Es El Adecuado Para Ti?",
  title:
    "Hablemos de tus objetivos y encontremos el camino perfecto hacia adelante.",
  description:
    "Reserva una consulta gratuita para descubrir cómo puedo ayudarte a lograr tus objetivos de comunicación en inglés.",
  button: {
    text: "Reserva Tu Consulta Gratuita",
    link: "https://ny-english-teacher.odoo.com/book/7ceefa20",
    variant: "primary" as const,
    target: "_blank",
  },
} as const;

// Professional profiles content in Spanish
const professionalProfilesContent = {
  title: "Diseñado para Profesionales Ambiciosos",
  description:
    "Mi coaching no es de talla única. Me asocio con innovadores, líderes y especialistas que necesitan comunicarse con precisión y autoridad. Tengo éxito comprobado con:",
};

// Translation slug for English version
const translationSlug = "services";
---

<Layout
  title={seoTitle}
  description={seoDescription}
  lang="es"
  translationSlugEn="/en/services"
  image="/images/logos/new-york-english-og-wide.jpg"
  hideCta={true}
>
  <!-- Hero Section -->
  <Hero content={heroContent} />

  <!-- Services Grid -->
  <ServicesGrid
    services={serviciosEs}
    title="Domina el Inglés de Negocios para el Crecimiento Profesional y la Comunicación Global"
    description="Desbloquea tu máximo potencial con coaching personalizado de inglés para profesionales. Ya sea que lideres equipos, vendas soluciones técnicas, te prepares para entrevistas o te expandes internacionalmente—nuestros programas están diseñados para resultados reales."
  />

  <!-- Professional Profiles Section -->
  <ProfessionalProfiles
    profiles={professionalProfilesEs}
    content={professionalProfilesContent}
  />

  <!-- Final CTA -->
  <CtaBanner content={ctaContent} />
</Layout>
