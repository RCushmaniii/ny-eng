---
export const prerender = true;

import Base from "@layouts/Base.astro";
import InnerHero from "@components/sections/InnerHero.astro";
import Challenge from "@components/sections/Challenge.astro";
import MethodologySection from "@components/sections/MethodologySection.astro";
import FeaturedTestimonial from "@components/sections/FeaturedTestimonial.astro";
import CtaSection from "@components/sections/CtaSection.astro";

// Import services data
import { services } from "@data/services";

// Get the high-stakes service data
const highStakesService = services.find(
  (s) => s.slug === "high-stakes-english"
);

// Import methodology content
import type { Methodology } from "@data/methodology";

// Define Spanish methodology content directly
const metodologiaEs: Methodology = {
  title: "Tu Método de Coaching Personalizado",
  subtitle:
    "Una metodología probada de cuatro pasos diseñada para entender tus desafíos únicos y desarrollar las habilidades específicas que necesitas para tener éxito.",
  steps: [
    {
      icon: "lucide:search-check",
      title: "Descubrimiento y Evaluación",
      description:
        "Inglés para presentaciones: comunica tus ideas con impacto y claridad en reuniones y conferencias.",
    },
    {
      icon: "lucide:map",
      title: "Mapeo Estratégico de Objetivos",
      description:
        "Juntos, definimos objetivos claros y medibles directamente vinculados con tu éxito profesional, creando un plan estratégico enfocado en tus metas específicas.",
    },
    {
      icon: "lucide:settings",
      title: "Programa Personalizado y Práctica",
      description:
        "Tu programa está construido para ti, enfocándose en el vocabulario específico, frases y matices culturales relevantes para tu industria y tareas diarias.",
    },
    {
      icon: "lucide:message-square-text",
      title: "Simulación del Mundo Real y Retroalimentación",
      description:
        "Aquí es donde la teoría se convierte en instinto. Realizamos presentaciones simuladas y juegos de rol de negociaciones difíciles, proporcionando retroalimentación directa y práctica para que estés confiado y preparado.",
    },
  ],
};

// Import testimonials and select Hugo Lopez testimonial
import { testimonials } from "@data/testimonials/es";
const featuredTestimonial = testimonials[9]; // Hugo Lopez testimonial

// SEO metadata
const title = "Coaching de Inglés para Presentaciones | NY English";
const seoDescription =
  "Domina presentaciones de alto impacto en inglés. Comunica ideas complejas, maneja preguntas difíciles y cautiva audiencias globales.";

// Hero content
const heroContent = {
  title: "Inglés para Situaciones Importantes",
  description:
    "Cautiva a cualquier audiencia, supera entrevistas y realiza presentaciones poderosas con confianza.",
  backgroundImage: highStakesService?.backgroundImage,
  overlayOpacity: 0.7,
};

// Challenge section content
const challengeContent = {
  headline: "¿Enfrentas Estos Desafíos?",
  painPoints: [
    "Te sientes nervioso y pierdes confianza al presentar ante audiencias de habla inglesa.",
    "Las situaciones de entrevista en inglés te generan ansiedad y no puedes mostrar tus verdaderas habilidades.",
    "Tienes dificultades para mantener el interés de tu audiencia y transmitir tu mensaje con impacto y autoridad.",
  ],
  icon: "😰",
  image: highStakesService?.squareImage,
  quizCta: {
    text: "¿Quieres saber exactamente dónde están tus brechas de comunicación de alto impacto?",
    link: "/es/quiz/high-stakes/question/1",
    linkLabel: "Toma nuestra evaluación gratuita de 90 segundos →",
  },
};

// Final CTA content
const ctaContent = {
  eyebrow: "¿Listo para Dominar la Comunicación de Alto Impacto?",
  title: "Destaca en Situaciones de Alta Presión",
  description:
    "Una sesión de estrategia gratuita y sin compromiso es la mejor manera de entender cómo el coaching personalizado puede aumentar tu confianza y efectividad en la comunicación.",
  buttonText: "Reserva Mi Sesión de Estrategia Gratuita",
  buttonLink: "/es/reservar/",
  whatToExpectTitle: "En Tu Sesión Gratuita, Haremos:",
  whatToExpectList: [
    "Evaluar tus habilidades actuales de presentación y entrevista",
    "Identificar áreas específicas de mejora en escenarios de alta presión",
    "Crear un plan personalizado para superar la ansiedad al hablar y desarrollar confianza",
  ],
};
---

<Base
  title={title}
  description={seoDescription}
  lang="es"
  tkey="services/high-stakes-english"
  ogImage={{
    src:
      typeof highStakesService?.backgroundImage === "string"
        ? highStakesService.backgroundImage
        : "/images/logos/new-york-english-og.jpg",
  }}
  customHreflangs={[
    {
      lang: "en-US",
      href: "https://www.nyenglishteacher.com/en/services/high-stakes-english/",
    },
    {
      lang: "es-MX",
      href: "https://www.nyenglishteacher.com/es/servicios/ingles-para-presentaciones/",
    },
  ]}
  customCanonical="https://www.nyenglishteacher.com/es/servicios/ingles-para-presentaciones/"
>
  <!-- Hero Section -->
  <InnerHero content={heroContent} />

  <!-- Challenge Section -->
  <Challenge content={challengeContent} background="white" padding="lg" />

  <!-- Methodology Section -->
  <MethodologySection content={metodologiaEs} background="light" padding="lg" />

  <!-- Featured Testimonial -->
  {
    featuredTestimonial && (
      <FeaturedTestimonial testimonial={featuredTestimonial} />
    )
  }

  <!-- Final CTA -->
  <CtaSection content={ctaContent} />
</Base>
