---
export const prerender = true;

import Base from "@layouts/Base.astro";
import InnerHero from "@components/sections/InnerHero.astro";
import Challenge from "@components/sections/Challenge.astro";
import MethodologySection from "@components/sections/MethodologySection.astro";
import FeaturedTestimonial from "@components/sections/FeaturedTestimonial.astro";
import CtaSection from "@components/sections/CtaSection.astro";
import ServiceFAQ from "@components/sections/ServiceFAQ.astro";
import BreadcrumbSchema from "@components/seo/BreadcrumbSchema.astro";
import Breadcrumbs from "@components/ui/Breadcrumbs.astro";
import { serviceFaqs } from "@data/service-faqs";

// Import services data
import { services } from "@data/services";

// Get the high-stakes service data
const highStakesService = services.find(
  (s) => s.slug === "high-stakes-english"
);

// Import methodology content
import type { Methodology } from "@data/methodology";

// Define Spanish methodology content directly
const metodologiaEs: Methodology = {
  title: "Cómo funciona",
  subtitle: "",
  steps: [
    {
      icon: "lucide:search-check",
      title: "Primero hablamos.",
      description:
        "Una llamada introductoria corta. Tu rol, tu próxima presentación, lo que está en juego—sin presión, sin discurso de ventas.",
    },
    {
      icon: "lucide:map",
      title: "Construyo tu plan.",
      description:
        "Desde tu nivel, tu industria y el momento específico que viene. Sesiones diseñadas para tu realidad, no genéricas.",
    },
    {
      icon: "lucide:settings",
      title: "Practicas bajo presión.",
      description:
        "Presentaciones, entrevistas, pitches. Retroalimentación sobre estructura, tono y presencia. Comete errores conmigo, no cuando cuenta.",
    },
    {
      icon: "lucide:message-square-text",
      title: "Refino conforme creces.",
      description:
        "¿Tu comunicación mejora? Yo ajusto—nuevos desafíos, escenarios más difíciles. Evoluciona con tu carrera.",
    },
  ],
};

// Import testimonials and select Hugo Lopez testimonial
import { testimonials } from "@data/testimonials/es";
const featuredTestimonial = testimonials[9]; // Hugo Lopez testimonial

// SEO metadata
const title = "Coaching de Inglés para Presentaciones | NY English";
const seoDescription =
  "Domina presentaciones de alto impacto en inglés. Comunica ideas complejas, maneja preguntas difíciles y cautiva audiencias globales.";

// Hero content
const heroContent = {
  title: "Tienes una oportunidad. Que suene a que estás listo.",
  description:
    "Preparación enfocada para la entrevista, el pitch o la presentación que no te puedes permitir improvisar.",
  backgroundImage: highStakesService?.backgroundImage,
  overlayOpacity: 0.7,
};

// Challenge section content
const challengeContent = {
  headline: "¿Te suena familiar?",
  painPoints: [
    "Has ensayado el contenido mil veces — pero en cuanto presentas en inglés, tu confianza baja y tu entrega se aplana.",
    "En entrevistas, sabes que estás calificado. Pero tu inglés te hace sonar menos experimentado de lo que eres.",
    "La presentación salió 'bien'. Pero 'bien' no te da el trabajo, el deal ni la promoción.",
  ],
  icon: "😰",
  image: highStakesService?.squareImage,
  quizCta: {
    text: "Descubre tu Puntuación de Preparación para Presentaciones en 60 segundos.",
    link: "/es/quiz/high-stakes/question/1",
    linkLabel: "Iniciar la Evaluación →",
  },
};

// Final CTA content
const ctaContent = {
  eyebrow: "",
  title: "Ya lideras. Ahora suena así — en inglés.",
  description:
    "Reserva una sesión estratégica privada. 30 minutos: identificaré las brechas entre tu inglés y el impacto que tu próxima presentación exige.",
  buttonText: "Reservar Mi Sesión Estratégica",
  buttonLink: "/es/reservar/",
  whatToExpectTitle: "En Tu Sesión Gratuita, Haremos:",
  whatToExpectList: [
    "Evaluar cómo tu inglés impacta tu entrega bajo presión",
    "Identificar los momentos específicos donde tu confianza baja",
    "Crear un plan de preparación para tu próximo momento de alto impacto",
  ],
};

const faqs = serviceFaqs["high-stakes-english"]?.es || [];
---

<Base
  title={title}
  description={seoDescription}
  lang="es"
  tkey="services/high-stakes-english"
  ogImage={{
    src:
      typeof highStakesService?.backgroundImage === "string"
        ? highStakesService.backgroundImage
        : "/images/logos/new-york-english-og.jpg",
  }}
  customHreflangs={[
    {
      lang: "en-US",
      href: "https://www.nyenglishteacher.com/en/services/high-stakes-english/",
    },
    {
      lang: "es-MX",
      href: "https://www.nyenglishteacher.com/es/servicios/ingles-para-presentaciones/",
    },
  ]}
  customCanonical="https://www.nyenglishteacher.com/es/servicios/ingles-para-presentaciones/"
>
  <!-- Hero Section -->
  <InnerHero content={heroContent} />

  <!-- Challenge Section -->
  <Challenge content={challengeContent} background="white" padding="lg" />

  <!-- Methodology Section -->
  <MethodologySection content={metodologiaEs} background="light" padding="lg" />

  <!-- Featured Testimonial -->
  {
    featuredTestimonial && (
      <FeaturedTestimonial testimonial={featuredTestimonial} />
    )
  }

  <!-- Final CTA -->
  <CtaSection content={ctaContent} />

  <BreadcrumbSchema items={[
    { name: "Inicio", url: "https://www.nyenglishteacher.com/es/" },
    { name: "Servicios", url: "https://www.nyenglishteacher.com/es/servicios/" },
    { name: "Inglés para Presentaciones", url: "https://www.nyenglishteacher.com/es/servicios/ingles-para-presentaciones/" }
  ]} />
  <ServiceFAQ faqs={faqs} lang="es" />
</Base>
