---
export const prerender = true;

import Base from "@layouts/Base.astro";
import FaqsSegmented from "@components/sections/FaqsSegmented.astro";
import FAQSchema from "@components/seo/FAQSchema.astro";
import { segmentedFaqLists } from "@data/faqs";
import faqHeroImage from "@assets/images/faq/faq-hero.jpg";

const seoTitle = "Obtén Respuestas a Tus Preguntas | New York English Teacher";
const seoDescription =
  "Todo lo que necesitas saber sobre cerrar tu brecha de comunicación y escalar tu carrera con coaching premium de inglés para profesionales.";

const faqData = segmentedFaqLists.premium_es;
const allFaqs = faqData.sections.flatMap((section) => section.faqs);
---

<Base
  title={seoTitle}
  description={seoDescription}
  lang="es"
  tkey="faqs"
  hideCta={true}
>
  <FAQSchema faqs={allFaqs} />

  <!-- Premium Hero Section -->
  <section
    class="faq-hero"
    style={`background-image: url(${faqHeroImage.src})`}
  >
    <img
      src={faqHeroImage.src}
      alt="FAQ Hero Background"
      class="hero-bg-image"
    />
    <div class="hero-overlay"></div>
    <div class="hero-content">
      <p class="hero-eyebrow">// DEPURA TU COMUNICACIÓN</p>
      <h1 class="hero-title">Obtén Respuestas a Tus Preguntas</h1>
      <p class="hero-subtitle">
        Todo lo que necesitas saber sobre optimizar tu inglés para momentos de
        carrera de alto riesgo.
      </p>
    </div>
  </section>

  <!-- Segmented FAQ Sections -->
  <FaqsSegmented
    sections={faqData.sections}
    showCta={true}
    ctaHeading="¿Listo para convertir fluidez en influencia?"
    ctaButtonText="Agenda Tu Llamada de Descubrimiento Gratis"
    ctaButtonLink="/es/reservar/"
  />
</Base>

<style>
  .faq-hero {
    position: relative;
    min-height: 500px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .hero-bg-image {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    z-index: 0;
  }

  .hero-overlay {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: linear-gradient(
      135deg,
      rgba(0, 0, 50, 0.75) 0%,
      rgba(30, 64, 175, 0.65) 100%
    );
    z-index: 1;
  }

  .hero-content {
    position: relative;
    z-index: 2;
    max-width: 900px;
    padding: 100px 5% 100px 5%;
    color: white;
    text-align: left;
  }

  .hero-eyebrow {
    font-size: 0.875rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #fbbf24;
    margin-bottom: 1rem;
    font-family: "Courier New", monospace;
  }

  .hero-title {
    font-size: 3.5rem;
    font-weight: 800;
    line-height: 1.1;
    margin-bottom: 1.5rem;
    color: white;
    text-shadow: 0 2px 8px rgba(0, 0, 0, 0.3);
  }

  .hero-subtitle {
    font-size: 1.375rem;
    line-height: 1.6;
    color: #e2e8f0;
    max-width: 700px;
    text-shadow: 0 1px 4px rgba(0, 0, 0, 0.2);
  }

  @media (max-width: 768px) {
    .faq-hero {
      min-height: 400px;
    }

    .hero-content {
      padding: 60px 20px 60px 20px;
    }

    .hero-eyebrow {
      font-size: 0.75rem;
    }

    .hero-title {
      font-size: 2.25rem;
    }

    .hero-subtitle {
      font-size: 1.125rem;
    }
  }
</style>
