---
import Layout from "@layouts/Layout.astro";
import InnerHero from "@components/sections/InnerHero.astro";
import ContactInfo from "@components/sections/ContactInfo.astro";
import nycStatueOfLiberty from "@assets/images/contact/nyc-statue-of-liberty.jpg";

const heroContent = {
    title: "Contáctame",
    description: "Si tu inglés pudiera hablar… ¿sería merecedor de un ascenso?",
};

const footerCta = {
  eyebrow: "",
  title: "Transforma tu inglés profesional hoy",
  description: "Reserva tu consulta gratuita para obtener la claridad, la confianza y el impacto que tu puesto exige.",
  hideCta: false,
  button: {
    text: "Reservar mi consulta gratuita",
    link: "https://ny-english-teacher.odoo.com/book/7ceefa20",
    target: "_blank",
    variant: "primary"
  }
};

// Page-specific metadata
const metadata = {
    title: "Contáctame",
    description: "Contáctame mediante este formulario o WhatsApp."
};
---

<Layout 
    lang="es" 
    translationSlugEn="/en/contact" 
    title={metadata.title} 
    description={metadata.description} 
    footerCta={footerCta}
    image="/images/logos/new-york-english-og-wide.jpg"
    whatsappImage="/images/logos/new-york-english-og.jpg"
    linkedinImage="/images/logos/new-york-english-og-wide.jpg"
>
    <InnerHero 
        content={{
            ...heroContent,
            backgroundImage: nycStatueOfLiberty,
            overlayOpacity: 0.3
        }} 
    />
    <ContactInfo background="base" padding="base" lang="es" />
</Layout>
