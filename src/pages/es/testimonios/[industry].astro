---
import Base from "@layouts/Base.astro";
import TestimonialsGrid from "@components/sections/TestimonialsGrid.astro";
import { testimonialsByIndustry, industryLabels } from "@data/testimonials/es";
import type { Testimonial } from "@data/testimonials/es";

type ValidIndustry = keyof typeof testimonialsByIndustry;

export async function getStaticPaths() {
  // Get all valid industries that have testimonials
  const validIndustries = Object.keys(testimonialsByIndustry).filter(
    (industry) => testimonialsByIndustry[industry as ValidIndustry]?.length > 0
  );

  return validIndustries.map((industry) => ({
    params: { industry }
  }));
}

// Get industry from URL parameter
const { industry } = Astro.params;

// Validate industry parameter
const validIndustries = Object.keys(testimonialsByIndustry).filter(
  (ind) => testimonialsByIndustry[ind as ValidIndustry]?.length > 0
);

// Default to "all" if industry is invalid
const currentIndustry = industry && validIndustries.includes(industry) ? industry : "all";

// Filter testimonials based on selected industry
const filteredTestimonials: Testimonial[] = testimonialsByIndustry[currentIndustry as ValidIndustry] || [];

// SEO metadata
const industryLabel = industryLabels[currentIndustry as keyof typeof industryLabels];
const title = currentIndustry === "all" 
  ? "Historias de Éxito de Clientes | NY English Teacher"
  : `Historias de Éxito de ${industryLabel} | NY English Teacher`;
const description = currentIndustry === "all"
  ? "Lee historias de éxito de ejecutivos, fundadores y profesionales que transformaron su comunicación en inglés con coaching personalizado."
  : `Lee historias de éxito de ${industryLabel.toLowerCase()} que transformaron su comunicación en inglés con coaching personalizado.`;
---

<Base
  title={title}
  description={description}
  lang="es"
  tkey="testimonials"
  hideCta={true}
>
  <TestimonialsGrid
    testimonials={filteredTestimonials}
    title={currentIndustry === "all" ? "Testimonios de Clientes" : `Testimonios de ${industryLabel}`}
    description={currentIndustry === "all" 
      ? "Descubre cómo profesionales de diversas industrias han transformado sus habilidades de comunicación en inglés y alcanzado sus metas profesionales."
      : `Descubre cómo ${industryLabel.toLowerCase()} han transformado sus habilidades de comunicación en inglés y alcanzado sus metas profesionales.`}
    showFilters={true}
    selectedIndustry={currentIndustry}
    lang="es"
  />
</Base>
