---
import Base from "@layouts/Base.astro";
import TestimonialsGrid from "@components/sections/TestimonialsGrid.astro";
import { publishedTestimonials } from "@data/testimonials/es";

const title = "Historias de Éxito | Coaching de Inglés Ejecutivo";
const description = "Historias de éxito de ejecutivos y profesionales que transformaron su comunicación en inglés con coaching personalizado y efectivo.";
---

<Base
  lang="es"
  tkey="testimonials"
  title={title}
  description={description}
>
  <TestimonialsGrid
    testimonials={publishedTestimonials}
    title="Historias de Éxito"
    description="Descubre cómo ejecutivos, fundadores y profesionales transformaron su comunicación en inglés para situaciones importantes."
    lang="es"
  />
</Base>
