---
export const prerender = true;

import Base from "@layouts/Base.astro";
import { Image } from "astro:assets";
import Button from "@components/ui/Button.astro";
import meImage from "@assets/images/about/me-blue-shirt.jpg";
import ceoImage from "@assets/images/about/working-with-client-1200.jpg";
import { testimonialsAboutEs as testimonials } from "@data/testimonials-about-es";

const metadata = {
  title: "Sobre Robert Cushman | Coach de Inglés Ejecutivo",
  description:
    "Robert Cushman pasó 20 años en TI — 17 en una Fortune 500. Ahora entrena a profesionales internacionales para sonar como los líderes que ya son, en inglés.",
};

const FooterCta = {
  Eyebrow: "",
  title: "Ya lideras. Ahora suena así — en inglés.",
  description:
    "Reserva una sesión estratégica privada. En 30 minutos, identificaré las brechas específicas entre tu inglés actual y la presencia ejecutiva que tu rol exige.",
  hideCta: false,
  button: {
    text: "Reservar Mi Sesión Estratégica",
    link: "/es/reservar/",
    variant: "primary",
  },
};
---

<Base
  {...metadata}
  lang="es"
  tkey="about"
  hideCta={true}
  ogImage={{
    src: "/images/logos/new-york-english-sq-og.jpg",
    alt: "New York English Teacher - Coach de Comunicación en Inglés de Negocios",
    width: 1200,
    height: 630,
  }}
>
  {/* ── Hero / Intro ── */}
  <section
    id="about-me"
    class="relative pt-28 pb-8 md:pt-32 md:pb-12 overflow-hidden"
  >
    <div class="container mx-auto px-4 max-w-6xl">
      <div class="grid md:grid-cols-12 grid-cols-1 items-start gap-12">
        {/* Left column — Photo */}
        <div class="md:col-span-4 order-2 md:order-1">
          <div class="relative">
            <Image
              src={meImage}
              alt="Robert Cushman – Coach de Comunicación Ejecutiva"
              class="rounded-lg shadow-lg w-full"
              width={400}
              height={533}
              loading="eager"
            />
          </div>
        </div>

        {/* Right column — Copy */}
        <div class="md:col-span-8 order-1 md:order-2">
          <div class="lg:ml-8">
            <h1 class="font-heading text-4xl md:text-5xl font-bold mb-4">
              Robert Cushman
            </h1>
            <p class="text-2xl text-primary font-semibold mb-8">
              Coach de Comunicación Ejecutiva
            </p>

            <div class="space-y-6 text-lg">
              <p class="text-xl leading-relaxed font-medium">
                Pasé 20 años en TI—17 de ellos en una Fortune 500, ascendiendo
                de desarrollador a Senior Manager. He liderado equipos globales,
                presentado ante juntas directivas y navegado la política del
                liderazgo corporativo a escala.
              </p>

              <p>
                Ahora entreno a profesionales internacionales para hacer lo
                mismo—en inglés.
              </p>

              <p>
                Vivo en Guadalajara. Me casé con una mexicana. Sé lo que se
                siente operar en un idioma y una cultura que no son los tuyos.
                ¿Esa perspectiva? Moldea cada sesión que diseño.
              </p>

              <div class="mt-8">
                <Button href="/es/reservar/" variant="primary" size="lg">
                  Reserva Tu Sesión Gratuita
                </Button>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  {/* ── Por Qué Entreno Diferente ── */}
  <section
    id="about-why"
    class="relative py-16 md:py-24 bg-gray-50 dark:bg-gray-800/50"
  >
    <div class="container mx-auto px-4 max-w-6xl">
      <div class="grid md:grid-cols-12 gap-12 items-center">
        {/* Left Column — Content */}
        <div class="md:col-span-7 order-2 md:order-1">
          <div class="lg:pr-8">
            <h2 class="font-heading text-3xl md:text-4xl font-bold mb-8">
              Por qué entreno diferente
            </h2>

            <div class="space-y-6 text-lg text-gray-600 dark:text-gray-300 leading-relaxed">
              <p>
                La mayoría de los profesores de inglés enseñan inglés.
              </p>

              <p class="text-xl font-medium text-gray-900 dark:text-white">
                Yo enseño a profesionales a sonar como los líderes que ya
                son—en un segundo idioma.
              </p>

              <p>
                La diferencia importa. He estado sentado en las reuniones para
                las que te estás preparando. Sé cómo suena un VP cuando está
                perdiendo la sala... y lo que se necesita para mantenerla. Eso
                no se aprende de un libro de texto o un ejercicio de gramática.
              </p>

              <p>
                Cada sesión parte de tu realidad—tu próxima presentación,
                negociación o apretón de agenda. ¿Junta directiva el jueves?
                Lo trabajamos el miércoles.
              </p>

              <p class="text-xl font-semibold text-primary">
                Autoridad, no disculpas. Ese es el estándar.
              </p>
            </div>
          </div>
        </div>

        {/* Right Column — Image */}
        <div class="md:col-span-5 order-1 md:order-2">
          <div class="relative">
            <Image
              src={ceoImage}
              alt="Sesión de coaching ejecutivo en progreso"
              class="rounded-lg shadow-lg w-full object-cover"
              width={600}
              height={400}
              loading="lazy"
            />
          </div>
        </div>
      </div>
    </div>
  </section>

  {/* ── Cómo Funciona ── */}
  <section id="about-methodology" class="relative py-16 md:py-24">
    <div class="container mx-auto px-4 max-w-6xl">
      <div class="max-w-3xl mx-auto text-center mb-16">
        <h2 class="font-heading text-4xl md:text-5xl font-bold mb-6">
          Cómo funciona
        </h2>
      </div>

      <div class="grid md:grid-cols-2 gap-8 md:gap-12 max-w-5xl mx-auto">
        {/* Step 1 */}
        <div class="bg-white dark:bg-gray-800 p-8 rounded-xl shadow-lg border border-gray-100 dark:border-gray-700">
          <div class="flex items-center gap-4 mb-6">
            <span class="flex items-center justify-center w-12 h-12 rounded-full bg-primary text-white font-bold text-lg">
              1
            </span>
            <h3 class="font-heading text-xl font-bold">
              Primero hablamos.
            </h3>
          </div>
          <p class="text-gray-600 dark:text-gray-300">
            Una llamada introductoria corta. Tu rol, objetivos, compatibilidad—sin
            presión, sin discurso de ventas.
          </p>
        </div>

        {/* Step 2 */}
        <div class="bg-white dark:bg-gray-800 p-8 rounded-xl shadow-lg border border-gray-100 dark:border-gray-700">
          <div class="flex items-center gap-4 mb-6">
            <span class="flex items-center justify-center w-12 h-12 rounded-full bg-primary text-white font-bold text-lg">
              2
            </span>
            <h3 class="font-heading text-xl font-bold">
              Construyo tu plan.
            </h3>
          </div>
          <p class="text-gray-600 dark:text-gray-300">
            Desde tu nivel, industria y momentos de presión. Sesiones
            personalizadas, no prefabricadas.
          </p>
        </div>

        {/* Step 3 */}
        <div class="bg-white dark:bg-gray-800 p-8 rounded-xl shadow-lg border border-gray-100 dark:border-gray-700">
          <div class="flex items-center gap-4 mb-6">
            <span class="flex items-center justify-center w-12 h-12 rounded-full bg-primary text-white font-bold text-lg">
              3
            </span>
            <h3 class="font-heading text-xl font-bold">
              Practicas bajo presión.
            </h3>
          </div>
          <p class="text-gray-600 dark:text-gray-300">
            Pitches, negociaciones, llamadas con clientes. Retroalimentación
            sobre tono, pronunciación y esas señales sutiles que convierten
            "fluido" en contundente. Comete errores conmigo, no cuando cuenta.
          </p>
        </div>

        {/* Step 4 */}
        <div class="bg-white dark:bg-gray-800 p-8 rounded-xl shadow-lg border border-gray-100 dark:border-gray-700">
          <div class="flex items-center gap-4 mb-6">
            <span class="flex items-center justify-center w-12 h-12 rounded-full bg-primary text-white font-bold text-lg">
              4
            </span>
            <h3 class="font-heading text-xl font-bold">
              Refino conforme creces.
            </h3>
          </div>
          <p class="text-gray-600 dark:text-gray-300">
            ¿Tu comunicación mejora? Yo ajusto—nuevos desafíos, escenarios,
            metas. Evoluciona con tu carrera.
          </p>
        </div>
      </div>
    </div>
  </section>

  {/* ── Con Quién Trabajo ── */}
  <section class="relative py-16 md:py-24 bg-gray-50 dark:bg-gray-800/50">
    <div class="container mx-auto px-4 max-w-4xl">
      <h2 class="font-heading text-3xl md:text-4xl font-bold mb-8 text-center">
        Con quién trabajo
      </h2>

      <div class="space-y-6 text-lg text-gray-600 dark:text-gray-300 leading-relaxed text-center max-w-3xl mx-auto">
        <p>
          COOs preparando juntas internacionales. Fundadores presentando ante
          inversionistas en EE. UU. Líderes tech explicando arquitectura a
          gente no técnica. Abogados, médicos—donde una palabra cambia todo.
        </p>

        <p class="text-xl font-medium text-gray-900 dark:text-white">
          Si te va increíble en tu campo pero te sientes raro, menos
          contundente en inglés? Esa es la brecha que cierro.
        </p>
      </div>
    </div>
  </section>

  {/* ── Lo Que Dicen Mis Clientes ── */}
  <section class="relative py-16 md:py-24">
    <div class="container mx-auto px-4 max-w-6xl">
      <div class="max-w-3xl mx-auto text-center mb-16">
        <h2 class="font-heading text-4xl md:text-5xl font-bold mb-6">
          Lo que dicen mis clientes
        </h2>
      </div>

      <div class="grid md:grid-cols-2 gap-8 md:gap-12 max-w-5xl mx-auto">
        {
          testimonials.map((t, idx) => (
            <div
              class:list={[
                "bg-white dark:bg-gray-700/50 rounded-xl p-8 shadow-lg fade-in-up border border-gray-100 dark:border-gray-600",
                `delay-${idx + 1}`,
              ]}
            >
              <div class="flex items-center mb-6">
                <Image
                  src={t.avatar}
                  alt={t.author}
                  class="w-14 h-14 rounded-full object-cover mr-4 border-2 border-primary"
                  loading="lazy"
                  width={56}
                  height={56}
                />
                <div>
                  <div class="font-heading text-lg font-semibold">
                    {t.author}
                  </div>
                  <div class="text-sm text-gray-500 dark:text-gray-400">
                    {t.position}, {t.company}
                  </div>
                </div>
              </div>
              <blockquote class="mb-2">
                <p class="text-lg text-gray-600 dark:text-gray-300 italic">
                  "<span set:html={t.content} />"
                </p>
              </blockquote>
            </div>
          ))
        }
      </div>

      {/* Bottom CTA */}
      <div
        class="mt-16 bg-gradient-to-r from-primary to-gray-100 dark:from-primary dark:to-gray-800 rounded-2xl p-8 md:p-12 text-center"
      >
        <h3 class="text-2xl font-bold text-white mb-4">
          Ya lideras. Ahora suena así — en inglés.
        </h3>
        <p class="text-white mb-6">
          Reserva una sesión estratégica privada. 30 minutos: identificaré las
          brechas entre tu inglés y la presencia ejecutiva que tu rol exige.
        </p>
        <Button
          href="/es/reservar/"
          variant="ghostLight"
          size="lg"
        >
          Reservar Mi Sesión Estratégica
        </Button>
      </div>
    </div>
  </section>
</Base>

<style>
  .leading-relaxed {
    line-height: 1.75;
  }
</style>
