---
import Layout from "@layouts/Layout.astro";
import Hero from "@components/sections/Hero.astro";
import SplitPanel from "@components/sections/SplitPanel.astro";
import Features from "@components/sections/Features.astro";
import Stats from "@components/sections/Stats.astro";
import Logos from "@components/sections/Logos.astro";
import CtaBanner from "@components/sections/CtaBanner.astro";
import Faqs from "@components/sections/Faqs.astro";
import RecentPosts from "@components/sections/RecentPosts.astro";
import Testimonials from "@components/sections/Testimonials-titan.astro";

import { statsLists } from "@data/stats-es";
import { logoLists } from "@data/logos";
import { faqLists } from "@data/faqs";
import { testimonials } from "@data/testimonials";

import newHeroImage from "@assets/images/home/new-york-city-skyline.webp";
import newHeroImageMobile from "@assets/images/home/new-york-city-skyline-mob.webp";
import styleGuideImage from "@assets/images/home/developer.jpg";
import { GraduationCap, Briefcase, Presentation, Users } from "lucide-astro";

// Structured data for Google SEO (Organization, WhatsApp contact)
const organizationJsonLd = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: "New York English Teacher",
  url: "https://www.nyenglishteacher.com/",
  logo: "https://www.nyenglishteacher.com/images/logos/new-york-english-og-wide.jpg",
  sameAs: [
    "https://www.linkedin.com/in/robert-cushman/",
    "https://www.facebook.com/nyenglishteacher",
  ],
  contactPoint: {
    "@type": "ContactPoint",
    url: "https://wa.link/pk4f97",
    contactType: "Customer Service",
    areaServed: "MX, US, CA",
    availableLanguage: ["English", "Spanish"],
  },
} as const;

// This is the Spanish homepage, so we define the path to its English counterpart.
const englishHomepageUrl = "/en/";

const testimonialsBlock = {
  eyebrow: "Resultados Reales",
  title: "Coaching de Inglés para Profesionales | Robert Cushman",
  description:
    "Ejecutivos, emprendedores y expertos de diversas industrias confían en New York English para elevar su fluidez, confianza e impacto global.",
  testimonials,
  cta: {
    heading: "Para Ejecutivos que Lideran en Inglés",
    description:
      "Comienza con una sesión de coaching gratuita de 30 minutos para mejorar tu claridad, confianza y autoridad.",
    text: "Reservar Mi Llamada Estratégica Gratuita",
    link: "https://ny-english-teacher.odoo.com/book/7ceefa20",
    target: "_blank",
    rel: "noopener noreferrer",
  },
} as const;

const seoTitle = "Coaching de Inglés Profesional";
const seoDescription =
  "Mejora tu fluidez y confianza en inglés con coaching personalizado para profesionales y empresas.";

const heroContent = {
  title: "Domina el Inglés de Negocios y Avanza en tu Carrera",
  description:
    "Coaching de inglés personalizado para desarrollar confianza, fluidez e impacto profesional.",
  buttons: [
    {
      text: "Clase Gratis",
      link: "https://ny-english-teacher.odoo.com/book/7ceefa20",
      target: "_blank",
      variant: "primary" as const,
    },
    {
      text: "Contáctame por WhatsApp",
      link: "https://wa.link/pk4f97",
      target: "_blank",
      variant: "whatsapp" as const,
    },
  ],
  backgroundImage: newHeroImage,
  backgroundImageMobile: newHeroImageMobile,
  overlayOpacity: 0.3,
} as const;

const featuresSection = {
  eyebrow: "NY ENGLISH OFRECE",
  title: "Coaching de Inglés Personalizado para Profesionales",
  description:
    "Ya sea que necesites mejorar tu fluidez, destacar en una entrevista o comunicarte más eficazmente en reuniones de negocios, te ayudaré a lograrlo.",
  features: [
    {
      title: "Coaching Personalizado 1 a 1",
      description:
        "Lecciones personalizadas y alineadas con tu rol y los desafíos del mundo real que enfrentas, para que cada sesión agregue valor inmediato.",
      icon: GraduationCap,
    },
    {
      title: "Capacitación Corporativa",
      description:
        "Coaching individual que prepara a tus equipos y ejecutivos con un inglés claro y persuasivo.",
      icon: Users,
    },
    {
      title: "Preparación para Entrevistas",
      description:
        "Ambiente simulado de entrevistas y retroalimentación para que estés 100% preparado.",
      icon: Briefcase,
    },
    {
      title: "Presentaciones de Negocios",
      description:
        "Práctica intensiva con slides estructuradas para exponer con confianza.",
      icon: Presentation,
    },
  ],
} as const;

const FooterCta = {
  eyebrow: "",
  title: "Transforma tu Inglés Profesional Hoy",
  description:
    "Reserva tu consulta gratuita para obtener la claridad, confianza e impacto que tu rol exige.",
  hideCta: false,
  button: {
    text: "Reservar mi Consulta Gratuita",
    link: "https://ny-english-teacher.odoo.com/book/7ceefa20",
    target: "_blank",
    rel: "noopener noreferrer",
  },
} as const;

const styleGuideSection = {
  eyebrow: "Mi Enfoque de Enseñanza",
  headline: "Coaching de Inglés Personalizado y Orientado a Objetivos",
  description:
    "Utilizo un enfoque estructurado pero flexible, adaptado a tus necesidades profesionales. Ya sea que estés preparando una entrevista, liderando una reunión o mejorando tu fluidez, mi coaching está diseñado para el éxito en el mundo real.",
  descriptionPoints: [
    "Lecciones construidas en torno a tu propio trabajo y metas",
    "Retroalimentación clara e instantánea sobre pronunciación, fraseo y tono",
    "Práctica de tareas reales (presentaciones, llamadas a clientes, informes) tal como las haces en el trabajo",
  ],
  image: {
    src: styleGuideImage,
    alt: "Sesión de coaching de inglés profesional",
  },
  buttons: [
    {
      text: "Explora Mi Enfoque de Coaching",
      link: "/es/about",
      variant: "primary" as const,
    },
  ],
} as const;

const sideBySideStats = {
  eyebrow: "ESTADÍSTICAS",
  title: "Habla y Escribe Inglés con Claridad, Confianza y Facilidad",
  description:
    "Ayudo a profesionales a hablar y escribir inglés con claridad, propósito y confianza. Ya sea que te prepares para entrevistas, presentaciones o conversaciones de negocios diarias, te brindaré el apoyo que necesitas.",
  variant: "side-by-side" as const,
  stats: statsLists.withContent.stats,
  content: {
    title: "Habla y Escribe Inglés con Claridad, Confianza y Facilidad",
    description:
      "Ayudo a profesionales a hablar y escribir inglés con claridad, propósito y confianza. Ya sea que te prepares para entrevistas, presentaciones o conversaciones de negocios diarias, te brindaré el apoyo que necesitas.",
    button: {
      text: "Trabajemos Juntos",
      link: "/es/contact",
    },
  },
} as const;

const logosSection = {
  eyebrow: "Nuestros Clientes",
  logos: logoLists.main.logos,
} as const;

const faqsSection = {
  eyebrow: "PREGUNTAS FRECUENTES",
  title: "Preguntas Frecuentes",
  description: "Encuentra respuestas a preguntas comunes.",
  faqs: faqLists.main_es.faqs,
} as const;

const recentPostsSection = {
  eyebrow: "ÚLTIMAS ENTRADAS DEL BLOG",
  title: "Perspectivas para Profesionales de Negocios",
  description:
    "Consejos prácticos sobre Inglés de Negocios, crecimiento profesional y comunicación efectiva.",
  button: {
    text: "Ver Todos los Artículos",
    link: "/es/blog",
  },
} as const;
---

<script type="application/ld+json">
  {JSON.stringify(organizationJsonLd)}
</script>

<Layout
  translationSlugEs="/es/"
  translationSlugEn={englishHomepageUrl}
  footerCta={FooterCta}
  lang="es"
  title={seoTitle}
  description={seoDescription}
  heroImage={heroContent.backgroundImage}
  heroImageMobile={heroContent.backgroundImageMobile}
  image="/images/logos/new-york-english-og-wide.jpg"
>
  <div class="relative bg-background-light">
    <Hero content={heroContent} />
    <Features content={featuresSection} padding="small" background="light" />
    <div class="mb-16 pb-0">
      <Testimonials
        content={testimonialsBlock}
        background="base"
        padding="small"
      />
    </div>

    <div
      class="pt-10 border-t border-gray-200 dark:border-gray-700"
      style="padding-bottom: var(--spacing-small);"
    >
      <RecentPosts
        content={recentPostsSection}
        background="base"
        postsToShow={3}
      />
    </div>

    <SplitPanel
      content={styleGuideSection}
      imagePosition="right"
      background="light"
      padding="base"
      lang="es"
    />

    <Stats content={sideBySideStats} background="dark" padding="base" />
    <Faqs content={faqsSection} background="base" padding="base" />
  </div>
</Layout>
