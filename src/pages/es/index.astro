import { GraduationCap, Briefcase, Presentation, Users } from "lucide-astro";
import Testimonials from "@components/sections/Testimonials-titan.astro";
import { testimonials } from "@data/testimonials"; // User to ensure this data source provides Spanish testimonials or update path

// This is the Spanish homepage, so we define the path to its English counterpart.
const englishHomepageUrl = "/en/";

const testimonialsBlock = {
  eyebrow: "Resultados Reales",
