---
export const prerender = true;

import Base from "@layouts/Base.astro";
import Hero from "@components/sections/Hero.astro";
import SplitPanel from "@components/sections/SplitPanel.astro";
import Features from "@components/sections/Features.astro";
import RecentPosts from "@components/sections/RecentPosts.astro";
import Testimonials from "@components/sections/Testimonials-titan.astro";
import QuizPromotion from "@components/sections/QuizPromotion.astro";
import HomepageFAQ from "@components/HomepageFAQ";
import FAQSchema from "@components/seo/FAQSchema.astro";
import { homepageFAQs } from "@data/homepage-faqs";

// Define language and tkey for i18n
const lang = "es";
const tkey = "home";

import { statsLists } from "@data/stats-es";
import { logoLists } from "@data/logos";
import { testimonials } from "@data/testimonials-es";

import heroSkyline from "@assets/images/home/new-york-city-skyline.webp";
import styleGuideImage from "@assets/images/home/developer.jpg";
import { GraduationCap, Briefcase, Presentation, Users } from "lucide-astro";

const testimonialsBlock = {
  eyebrow: "Resultados Reales",
  title: "Coaching de Inglés para Profesionales | Robert Cushman",
  description:
    "Ejecutivos, emprendedores y expertos de diversas industrias confían en New York English para elevar su fluidez, confianza e impacto global.",
  testimonials,
  cta: {
    heading: "Para Ejecutivos que Lideran en Inglés",
    description:
      "Comienza con una sesión estratégica de cortesía para identificar tus brechas de comunicación y trazar tus objetivos.",
    text: "Reservar Mi Sesión Estratégica",
    link: "/es/reservar/",
    rel: "noopener noreferrer",
  },
};

const seoTitle = "Coaching de Inglés Profesional";
const seoDescription =
  "Mejora tu fluidez y confianza en inglés con coaching personalizado para ejecutivos y profesionales. Clases 1-a-1 adaptadas a tu industria.";

const heroContent = {
  eyebrow: "Coaching Privado de Inglés para Profesionales Senior",
  title: "Eres líder en español. Suena como uno en inglés.",
  description:
    "Lidera reuniones globales con autoridad tranquila. Coaching privado que hace que tu inglés esté a la altura de tu experiencia.",
  trustLine: "Confiado por líderes en empresas Fortune 500 y startups globales",
  trustLineLink: "/es/testimonios/",
  buttons: [
    {
      text: "Reserva una Consulta Privada",
      link: "/es/reservar/",
      variant: "primary" as const,
    },
    // Single CTA for higher conversion - matches EN page
  ],
  backgroundImage: heroSkyline,
  backgroundImageMobile: heroSkyline,
  overlayOpacity: 0.9,
  fullHeight: true,
} as const;

const featuresSection = {
  eyebrow: "NY ENGLISH OFRECE",
  title: "Elige Tu Ruta Especializada",
  description:
    "Selecciona el camino enfocado que se alinea con tus objetivos profesionales específicos.",
  features: [
    {
      tag: "Líderes Ejecutivos",
      title: "Tu estrategia es sólida. Tu inglés no está a la altura.",
      description:
        "Domina la sala de juntas, lidera negociaciones y habla con la claridad que el liderazgo global exige — sin traducir en tu cabeza.",
      icon: Briefcase,
      link: "/es/quiz/executives/",
    },
    {
      tag: "Líderes en Tecnología",
      title: "Tu código es impecable. Tu explicación pierde a la audiencia.",
      description:
        "Convierte la complejidad técnica en valor de negocio claro que ejecutivos, clientes y grupos de interés entienden de inmediato.",
      icon: Presentation,
      link: "/es/quiz/it-services/",
    },
    {
      tag: "Servicios Profesionales",
      title: "Una palabra mal elegida puede costar más que tus honorarios.",
      description:
        "Inglés de precisión para profesionales médicos y legales que deben comunicarse con claridad absoluta cuando lo que está en juego es real.",
      icon: Users,
      link: "/es/quiz/professional-services/",
    },
    {
      tag: "Entrevistas y Presentaciones",
      title: "Tienes una oportunidad. Suena preparado.",
      description:
        "Preparación enfocada para entrevistas, pitches a inversionistas y las presentaciones que cambian carreras.",
      icon: GraduationCap,
      link: "/es/quiz/high-stakes/",
    },
  ],
} as const;

const FooterCta = {
  eyebrow: "",
  title: "Ya lideras. Ahora suena así — en inglés.",
  description:
    "Reserva una sesión estratégica privada. En 30 minutos, identificaré las brechas específicas entre tu inglés actual y la presencia ejecutiva que tu rol exige.",
  hideCta: false,
  button: {
    text: "Reservar Mi Sesión Estratégica",
    link: "/es/reservar/",
  },
} as const;

const styleGuideSection = {
  eyebrow: "Mi Metodología",
  headline: "Cada clase se construye a partir de tu próxima reunión, no de un libro de texto.",
  description:
    "Diseño cada sesión en torno a tu rol real, tu industria y tus plazos. Si tienes una presentación ante la junta el jueves, eso es lo que trabajamos el miércoles. Nada genérico. Nada teórico.",
  descriptionPoints: [
    "Tu plan de estudios, no un catálogo de cursos — sesiones construidas a partir de tus escenarios reales, el vocabulario de tu industria, tus próximos momentos de presión.",
    "Tu voz, afinada — retroalimentación táctica sobre tono, pronunciación y las señales sutiles que separan \"fluido\" de \"contundente.\"",
    "Tu espacio de ensayo — simula el pitch, la negociación o la llamada con el cliente antes de que cuente. Comete errores aquí, no allá.",
  ],
  image: {
    src: styleGuideImage,
    alt: "Sesión de coaching ejecutivo en progreso",
  },
  buttons: [
    {
      text: "Explorar El Marco",
      link: "/es/about",
      variant: "primary" as const,
    },
  ],
};

const sideBySideStats = {
  eyebrow: "ESTADÍSTICAS",
  title: "Habla y Escribe Inglés con Claridad, Confianza y Facilidad",
  description:
    "Ayudo a profesionales a hablar y escribir inglés con claridad, propósito y confianza. Ya sea que te prepares para entrevistas, presentaciones o conversaciones de negocios diarias, te brindaré el apoyo que necesitas.",
  variant: "side-by-side" as const,
  stats: statsLists.withContent.stats,
  content: {
    title: "Habla y Escribe Inglés con Claridad, Confianza y Facilidad",
    description:
      "Ayudo a profesionales a hablar y escribir inglés con claridad, propósito y confianza. Ya sea que te prepares para entrevistas, presentaciones o conversaciones de negocios diarias, te brindaré el apoyo que necesitas.",
    button: {
      text: "Trabajemos Juntos",
      link: "/es/contact",
    },
  },
} as const;

const logosSection = {
  eyebrow: "Nuestros Clientes",
  logos: logoLists.main.logos,
} as const;

const recentPostsSection = {
  eyebrow: "ÚLTIMOS ARTÍCULOS",
  title: "Perspectivas de Comunicación Ejecutiva",
  description:
    "Estrategias prácticas para liderar reuniones, refinar tu presentación y hablar con confianza absoluta.",
  button: {
    text: "Leer el Blog",
    link: "/es/blog",
  },
} as const;
---

<Base
  lang="es"
  tkey={tkey}
  title={seoTitle}
  description={seoDescription}
  heroImage={heroContent.backgroundImage}
  heroImageMobile={heroContent.backgroundImageMobile}
  ogImage={{ src: "/images/logos/new-york-english-sq-og.jpg" }}
  transparentHeader={true}
>
  <div class="relative bg-background-light">
    <Hero content={heroContent} />

    {/* ARCS — CALL OUT: "¿Te identificas?" — espejo de identidad */}
    <section class="bg-gray-950 py-16 sm:py-20 border-t border-gray-800">
      <div class="site-container mx-auto px-4 max-w-3xl text-center">
        <p class="text-sm font-bold uppercase tracking-wider mb-6" style="color: #FFC107; letter-spacing: 0.1em;">
          ¿Te identificas?
        </p>
        <p class="text-xl sm:text-2xl leading-relaxed text-white font-normal">
          Si diriges juntas, cierras acuerdos y gestionas equipos en tu idioma nativo — pero te sientes menos preciso, menos contundente, <em class="font-semibold not-italic" style="color: #FFC107;">menos tú mismo</em> cuando cambias al inglés — esto fue creado para ti.
        </p>
      </div>
    </section>

    <Features content={featuresSection} padding="small" background="light" />
    <QuizPromotion lang="es" />
    <div class="mb-15 pb-0">
      <Testimonials
        content={testimonialsBlock}
        background="base"
        padding="small"
      />
    </div>

    <div
      class="pt-10 border-t border-gray-200 dark:border-gray-700"
      style="padding-bottom: var(--spacing-small);"
    >
      <RecentPosts
        content={recentPostsSection}
        background="base"
        postsToShow={3}
      />
    </div>

    <SplitPanel
      content={styleGuideSection}
      imagePosition="right"
      background="light"
      padding="base"
      lang="es"
    />

    <!-- Homepage FAQ Section -->
    <FAQSchema faqs={homepageFAQs.es.faqs} />
    <HomepageFAQ client:load lang="es" />

    <!-- Stats temporarily removed -->
    <!-- <Stats content={sideBySideStats} background="dark" padding="base" /> -->
  </div>
</Base>
