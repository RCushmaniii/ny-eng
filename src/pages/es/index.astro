      icon: Users,
    },
    {
      title: "Preparación para Entrevistas", // Translated
      description: "Ambiente simulado de entrevistas y retroalimentación para que estés 100% preparado.", // Translated
      icon: Briefcase,
    },
    {
      title: "Presentaciones de Negocios", // Translated
      description: "Práctica intensiva con slides estructuradas para exponer con confianza.", // Translated
      icon: Presentation,
    },
  ],
  // Note: The button from your provided ES featuresSection ("Ver Información del Tema") seems specific to "Titan Core".
  // I'm omitting it here to match the structure of the EN featuresSection which doesn't have a main button.
  // If you need a button here, you can add it:
  // button: {
  //   text: "Ver Más Servicios", // Example text
  //   link: "/es/servicios",    // Example link
  //   variant: "primary"
  // }
};

const FooterCta = {
  eyebrow: "",
  title: "Transforma tu Inglés Profesional Hoy",
  description: "Reserva tu consulta gratuita para obtener la claridad, confianza e impacto que tu rol exige.",
  hideCta: false,
  button: {
    text: "Reservar mi Consulta Gratuita",
    link: "https://ny-english-teacher.odoo.com/book/7ceefa20", // External link
    target: "_blank",
    rel: "noopener noreferrer"
  },
};

const styleGuideSection = {
  eyebrow: "Mi Enfoque de Enseñanza",
  headline: "Coaching de Inglés Personalizado y Orientado a Objetivos",
  description:
    "Utilizo un enfoque estructurado pero flexible, adaptado a tus necesidades profesionales. Ya sea que estés preparando una entrevista, liderando una reunión o mejorando tu fluidez, mi coaching está diseñado para el éxito en el mundo real.",
  descriptionPoints: [
    "Lecciones construidas en torno a tu propio trabajo y metas",
    "Retroalimentación clara e instantánea sobre pronunciación, fraseo y tono",
    "Práctica de tareas reales (presentaciones, llamadas a clientes, informes) tal como las haces en el trabajo",
  ],
  image: {
    src: styleGuideImage, // Assuming same image
    alt: "Sesión de coaching de inglés profesional", // Translated alt text
  },
  buttons: [
    {
      text: "Saber Más",
      link: "/es/about", // Link to Spanish about page
      variant: "primary",
    },
  ],
};

const sideBySideStats = {
  eyebrow: "ESTADÍSTICAS",
  title: "Habla y Escribe Inglés con Claridad, Confianza y Facilidad",
  description:
    "Ayudo a profesionales a hablar y escribir inglés con claridad, propósito y confianza. Ya sea que te prepares para entrevistas, presentaciones o conversaciones de negocios diarias, te brindaré el apoyo que necesitas.",
  variant: "side-by-side",
  stats: statsLists.withContent.stats,
  content: {
    title: "Habla y Escribe Inglés con Claridad, Confianza y Facilidad",
    description:
      "Ayudo a profesionales a hablar y escribir inglés con claridad, propósito y confianza. Ya sea que te prepares para entrevistas, presentaciones o conversaciones de negocios diarias, te brindaré el apoyo que necesitas.",
    button: {
      text: "Trabajemos Juntos",
      link: "/es/contact"
    },
  },
};

// The 'mainCta' section was present in your EN file but not clearly in your ES snippet.
// If you need it, translate its content and uncomment. For now, it's omitted for cleaner parity.
/*
const mainCta = {
  eyebrow: "Bloques de Construcción", // Example Translation
  title: "Componentes Listos para Usar", // Example Translation
  description:
    "Ahorra tiempo de desarrollo con nuestros componentes pre-construidos y accesibles. Cada uno está diseñado para integrarse sin problemas con tus proyectos manteniendo un rendimiento excelente.", // Example Translation
  button: {
    text: "Ver Todos los Componentes", // Example Translation
    link: "/es/components", // Prefixed with /es/ (if this page exists)
    variant: "primary",
  },
};
*/

const logosSection = {
  eyebrow: "Nuestros Clientes", // Translated
  logos: logoLists.main.logos, // Assuming logos are universal
};

const faqsSection = {
  eyebrow: "PREGUNTAS FRECUENTES", // Translated
  title: "Preguntas Frecuentes", // Translated
  description: "Encuentra respuestas a preguntas comunes.", // Translated
  faqs: faqLists.main_es.faqs, // Using your specified Spanish FAQ data
};

const recentPostsSection = {
  eyebrow: "ÚLTIMAS ENTRADAS DEL BLOG", // Translated
  title: "Perspectivas para Profesionales de Negocios", // Translated
  description:
    "Consejos prácticos sobre Inglés de Negocios, crecimiento profesional y comunicación efectiva.", // Translated
  button: {
    text: "Ver Todos los Artículos",
    link: "/es/blog", // Prefixed with /es/
  },
};
---

<Layout
  translationSlugEs="/es/"
  translationSlugEn="/en/"
  footerCta={FooterCta}
  title={seoTitle}
  description={seoDescription}
  heroImage={heroContent.backgroundImage}
  heroImageMobile={heroContent.backgroundImageMobile}
  translationSlugEn={englishHomepageUrl} {/* ✅ Pass the English homepage URL */}
>
  <div class="relative bg-background-light">
    <Hero content={heroContent} />
    <Features content={featuresSection} padding="small" background="light" />
    <div class="mb-16 pb-0"> {/* Changed mb-15 to mb-16 (Tailwind standard) */}
      <Testimonials content={testimonialsBlock} background="base" padding="small" />
    </div>

    <div class="pt-10 border-t border-gray-200 dark:border-gray-700" style="padding-bottom: var(--spacing-small);"> {/* Consider Tailwind for padding */}
      <RecentPosts
        content={recentPostsSection}
        background="base"
        postsToShow={3}
      />
    </div>

    <SplitPanel
      content={styleGuideSection}
      imagePosition="right"
      background="light"
      padding="base"
      lang="es"
    />

  <!-- SplitPanel already included above -->

  {/* <CtaBanner content={mainCta} variant="contained" background="light" paddingBottom="base" /> */} {/* mainCta commented out as discussed */}
  {/* <Logos content={logosSection} background="base" padding="small" /> */} {/* Logos section can be added if needed */}

  <Stats content={sideBySideStats} background="dark" padding="base" />
  <Faqs content={faqsSection} background="base" padding="base" />
  
  {/* Removed duplicated sections from the end to match a cleaner structure */}
  </div>
</Layout>