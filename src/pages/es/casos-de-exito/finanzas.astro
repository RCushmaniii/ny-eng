---
import Layout from "@layouts/Layout.astro";
import { Image } from "astro:assets";
import Eyebrow from "@components/ui/Eyebrow.astro";
import Button from "@components/ui/Button.astro";
import { testimonialsByIndustry } from "@data/testimonials/es";

// Get finance industry testimonials (using c-level-executives as most relevant)
const industryTestimonials = testimonialsByIndustry["c-level-executives"] || [];

// SEO metadata
const title = "Caso de Éxito: Sector Financiero | NY English Teacher";
const description = "Cómo los profesionales de finanzas mejoraron sus habilidades de comunicación en inglés y lograron crecimiento profesional con coaching personalizado.";

// English counterpart for language switcher
const translationSlugEn = "/en/case-studies/finance";

// Set language to Spanish
const lang = "es";
---

<Layout 
  title={title}
  description={description}
  translationSlugEn={translationSlugEn}
  lang={lang}
>
  <section class="bg-gradient-to-b from-light to-white py-16 md:py-24">
    <div class="site-container px-4 sm:px-6 md:px-8">
      <div class="text-center mb-12 pt-8">
        <Eyebrow text="Caso de Éxito" background="light" />
        <h1 class="text-h1 text-[--color-headline] mb-4">Historias de Éxito en el Sector Financiero</h1>
        <p class="text-lg text-[--color-body-base] max-w-2xl mx-auto">
          Cómo los profesionales financieros mejoraron sus habilidades de comunicación en inglés y lograron crecimiento profesional a través de coaching personalizado.
        </p>
      </div>

      <!-- Case Study Content -->
      <div class="max-w-4xl mx-auto">
        <div class="bg-white rounded-xl shadow-md p-8 mb-12">
          <h2 class="text-2xl font-bold text-[--color-headline] mb-4">El Desafío</h2>
          <p class="mb-6">
            Los profesionales financieros a menudo enfrentan desafíos lingüísticos únicos al comunicarse con clientes internacionales, presentar datos financieros complejos o participar en reuniones de alto nivel. Muchos luchan con vocabulario específico de la industria, explicaciones precisas de conceptos financieros y la transmisión de confianza durante negociaciones o presentaciones críticas.
          </p>
          
          <h2 class="text-2xl font-bold text-[--color-headline] mb-4">La Solución</h2>
          <p class="mb-6">
            Nuestro programa de coaching personalizado para profesionales financieros se enfoca en:
          </p>
          <ul class="list-disc pl-6 mb-6 space-y-2">
            <li>Dominio de vocabulario específico de la industria y terminología financiera</li>
            <li>Comunicación clara de conceptos y datos financieros complejos</li>
            <li>Desarrollo de confianza para presentaciones y reuniones de alto nivel</li>
            <li>Matices culturales en comunicaciones financieras internacionales</li>
            <li>Precisión y claridad en informes financieros escritos y correos electrónicos</li>
          </ul>
          
          <h2 class="text-2xl font-bold text-[--color-headline] mb-4">Los Resultados</h2>
          <p class="mb-6">
            Los profesionales financieros que completaron nuestro programa de coaching reportaron mejoras significativas en sus habilidades de comunicación, lo que llevó a avances profesionales, mayor confianza en las interacciones con clientes y un liderazgo de equipo más efectivo.
          </p>
        </div>
        
        <!-- Testimonials Section -->
        <h2 class="text-2xl font-bold text-center text-[--color-headline] mb-8">Historias de Éxito de Profesionales Financieros</h2>
        <div class="grid gap-8 md:grid-cols-2">
          {industryTestimonials.map((testimonial) => (
            <div class="bg-white p-6 rounded-lg shadow-md">
              <div class="flex items-center mb-4">
                {testimonial.avatar && (
                  <div class="mr-4">
                    <Image 
                      src={testimonial.avatar} 
                      alt={`Avatar de ${testimonial.author}`} 
                      width={64} 
                      height={64}
                      class="rounded-full object-cover w-16 h-16" 
                    />
                  </div>
                )}
                <div>
                  <h3 class="font-bold text-[--color-headline]">{testimonial.author}</h3>
                  <p class="text-sm text-[--color-body-muted]">{testimonial.position}, {testimonial.company}</p>
                </div>
              </div>
              {testimonial.headline && (
                <p class="font-medium text-[--color-headline] mb-2">{testimonial.headline}</p>
              )}
              <p class="text-[--color-body-base] mb-2">{testimonial.content}</p>
              <div class="flex text-yellow-400 mb-2">
                {Array.from({ length: testimonial.stars || 5 }).map(() => (
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                  </svg>
                ))}
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- CTA Section -->
      <div class="mt-16 bg-gradient-to-r from-primary-500 to-secondary-500 rounded-2xl p-8 md:p-12 relative overflow-hidden">
        <div class="absolute inset-0 bg-gradient-to-r from-primary-600/30 to-secondary-600/30 backdrop-blur-sm"></div>
        <div class="relative z-10 text-center md:text-left md:flex items-center justify-between">
          <div class="mb-6 md:mb-0 md:mr-8">
            <h3 class="text-2xl md:text-3xl font-bold text-[--color-headline-dark] mb-4">
              ¿Listo para transformar tu inglés financiero?
            </h3>
            <p class="text-[--color-body-dark] max-w-2xl">
              Reserva tu consulta gratuita para obtener la claridad, confianza e impacto que tu rol exige.
            </p>
          </div>
          <Button 
            href="https://ny-english-teacher.odoo.com/book/7ceefa20" 
            variant="primary"
            target="_blank"
            rel="noopener noreferrer"
          >
            Reserva Mi Consulta Gratuita
          </Button>
        </div>
      </div>
    </div>
  </section>
</Layout>
