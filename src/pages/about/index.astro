---
import Layout from "@layouts/Layout.astro";
import { Image } from "astro:assets";
import meImage from "@assets/images/about/me-blue-shirt.jpg";
import ceoImage from "@assets/images/about/ceo-taking-class.jpg";
import {
    Waves,
    Calendar,
    Target,
    FileText,
    CheckCircle,
    LineChart,
} from "lucide-astro";

const metadata = {
    title: "About Me | Robert Cushman - Business English Communication Coach",
    description:
        "With 20+ years of corporate leadership and 7 years of business English coaching, I help professionals and executives communicate with clarity and confidence.",
};

const FooterCta = {
    eyebrow: "",
    title: "Ready to Elevate Your Communication?",
    description:
        "Speak with the clarity and confidence your role demands—book a no-pressure introduction call today.",
    hideCta: false,
    button: {
        text: "Book Your Introduction Call",
        link: "/contact",
        target: "_self",
    },
};
---

<Layout {...metadata} footerCta={FooterCta}>
    <section class="relative py-20 md:py-32 overflow-hidden">
        <div class="container mx-auto px-4 max-w-6xl">
            <div class="grid md:grid-cols-12 grid-cols-1 items-start gap-12">
                {/* Left column - Image */}
                <div class="md:col-span-4 order-2 md:order-1">
                    <div class="relative">
                        <Image
                            src={meImage}
                            alt="Robert Cushman - Business English Communication Coach"
                            class="rounded-lg shadow-lg w-full"
                            width={400}
                            height={533}
                            loading="eager"
                        />
                    </div>
                </div>

                {/* Right column - Content */}
                <div class="md:col-span-8 order-1 md:order-2">
                    <div class="lg:ml-8">
                        <h1
                            class="font-heading text-4xl md:text-5xl font-bold mb-8"
                        >
                            Hi, I'm <span class="text-primary">Robert</span>.
                        </h1>

                        <div class="space-y-8 text-lg">
                            <p class="text-xl leading-relaxed">
                                I help professionals, executives, and business
                                leaders speak English with clarity and
                                confidence.
                            </p>

                            <p class="text-lg">
                                With over 20 years in corporate
                                leadership—including 15 years at a Fortune 100
                                company—and 7 years of business English
                                coaching, I'm the unique resource to elevate
                                intermediate and advanced speakers to the next
                                level in high-stakes communication.
                            </p>

                            <div
                                class="my-12 border-t border-b border-gray-200 dark:border-gray-700 py-12"
                            >
                                <h2
                                    class="font-heading text-2xl font-semibold mb-6"
                                >
                                    My clients share two priorities:
                                </h2>
                                <ul class="space-y-4">
                                    <li class="flex items-start">
                                        <span
                                            class="text-primary font-semibold mr-3"
                                            >1.</span
                                        >
                                        They want their English to reflect their
                                        professional expertise and authority.
                                    </li>
                                    <li class="flex items-start">
                                        <span
                                            class="text-primary font-semibold mr-3"
                                            >2.</span
                                        >
                                        They expect a professional, efficient learning
                                        experience that respects their time.
                                    </li>
                                </ul>
                            </div>

                            <p class="text-xl text-primary font-semibold">
                                Ready to Elevate Your Communication?
                            </p>

                            <p class="text-lg mt-4">
                                Speak with the clarity and confidence your role
                                demands—book a no-pressure introduction call
                                today.
                            </p>

                            <div class="mt-6">
                                <a
                                    href="#contact"
                                    class="inline-block bg-primary hover:bg-primary-dark text-white font-semibold py-4 px-8 rounded-lg transition-colors duration-200"
                                >
                                    Book Your Introduction Call
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    {/* Values Section */}
    <section class="relative py-16 md:py-24 bg-gray-50 dark:bg-gray-800/50">
        <div class="container mx-auto px-4 max-w-6xl">
            <div class="max-w-3xl mx-auto text-center mb-16">
                <h2 class="font-heading text-4xl md:text-5xl font-bold mb-6">
                    My Values
                </h2>
                <p class="text-lg text-gray-600 dark:text-gray-300">
                    Professional growth starts with clear, confident
                    communication. These values guide every lesson, session, and
                    client relationship:
                </p>
            </div>

            <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8 md:gap-12">
                {/* Value 1 */}
                <div class="relative">
                    <div class="mb-6">
                        <span
                            class="flex items-center justify-center w-12 h-12 rounded-full bg-primary/10 text-primary font-bold text-xl"
                        >
                            1
                        </span>
                    </div>
                    <h3 class="font-heading text-2xl font-semibold mb-4">
                        Client-Centered Coaching
                    </h3>
                    <p class="text-gray-600 dark:text-gray-300">
                        Your goals drive the process—I adapt to your real-world
                        needs, from executive meetings to cross-cultural
                        communication.
                    </p>
                </div>

                {/* Value 2 */}
                <div class="relative">
                    <div class="mb-6">
                        <span
                            class="flex items-center justify-center w-12 h-12 rounded-full bg-primary/10 text-primary font-bold text-xl"
                        >
                            2
                        </span>
                    </div>
                    <h3 class="font-heading text-2xl font-semibold mb-4">
                        Empowered Expression
                    </h3>
                    <p class="text-gray-600 dark:text-gray-300">
                        I help you speak your second language authentically,
                        ensuring you project authority and impact to elevate
                        your personal brand and business performance.
                    </p>
                </div>

                {/* Value 3 */}
                <div class="relative">
                    <div class="mb-6">
                        <span
                            class="flex items-center justify-center w-12 h-12 rounded-full bg-primary/10 text-primary font-bold text-xl"
                        >
                            3
                        </span>
                    </div>
                    <h3 class="font-heading text-2xl font-semibold mb-4">
                        Integrity & Professionalism
                    </h3>
                    <p class="text-gray-600 dark:text-gray-300">
                        Your time, goals, and privacy are sacred. My coaching is
                        built on trust and transparency for long-term success.
                    </p>
                </div>
            </div>
        </div>
    </section>

    {/* Why Work with Me Section */}
    <section class="relative py-16 md:py-24">
        <div class="container mx-auto px-4 max-w-6xl">
            <div class="max-w-3xl mx-auto text-center mb-16">
                <h2 class="font-heading text-4xl md:text-5xl font-bold mb-6">
                    Why Work with Me?
                </h2>
                <p class="text-xl text-primary font-semibold">
                    Tailored Coaching Built on Real-World Experience
                </p>
            </div>

            <div class="grid md:grid-cols-12 gap-12 items-center">
                {/* Left Column - Content */}
                <div class="md:col-span-7 order-2 md:order-1">
                    <div class="lg:pr-8">
                        <h3 class="font-heading text-3xl font-bold mb-6">
                            What Sets Me Apart: Personalized Expertise
                        </h3>
                        <p
                            class="text-lg text-gray-600 dark:text-gray-300 leading-relaxed"
                        >
                            I'm not just another English coach—I'm a corporate
                            strategist who's navigated the same challenges
                            you're facing. My sessions are laser-focused on your
                            professional goals, from nailing that high-stakes
                            interview to delivering impactful presentations. No
                            generic templates, no fluff—just practical,
                            personalized coaching that gets results.
                        </p>
                    </div>
                </div>

                {/* Right Column - Image */}
                <div class="md:col-span-5 order-1 md:order-2">
                    <div class="relative">
                        <Image
                            src={ceoImage}
                            alt="Business executive taking an English coaching class"
                            class="rounded-lg shadow-lg w-full object-cover"
                            width={600}
                            height={400}
                            loading="lazy"
                        />
                    </div>
                </div>
            </div>
        </div>
    </section>

    {/* Testimonials Section */}
    <section class="relative py-16 md:py-24 bg-gray-50 dark:bg-gray-800/50">
        <div class="container mx-auto px-4 max-w-6xl">
            <div class="max-w-3xl mx-auto text-center mb-16">
                <p class="text-primary font-semibold mb-4">
                    Real Impact: Success Stories from My Clients
                </p>
                <h2 class="font-heading text-4xl md:text-5xl font-bold mb-6">
                    Results That Speak for Themselves
                </h2>
                <p class="text-lg text-gray-600 dark:text-gray-300">
                    I've coached COOs, CEOs, and founders to communicate with
                    clarity and confidence, driving career-defining wins—from
                    streamlining global operations to securing investor funding.
                    Here's what they say:
                </p>
            </div>

            <div class="grid md:grid-cols-2 gap-8 md:gap-12 max-w-5xl mx-auto">
                {/* Testimonial 1 */}
                <div
                    class="bg-white dark:bg-gray-700/50 rounded-xl p-8 shadow-lg"
                >
                    <div class="flex text-yellow-400 mb-6">
                        <svg class="w-5 h-5 fill-current" viewBox="0 0 20 20">
                            <path
                                d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"
                            ></path>
                        </svg>
                        <svg class="w-5 h-5 fill-current" viewBox="0 0 20 20">
                            <path
                                d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"
                            ></path>
                        </svg>
                        <svg class="w-5 h-5 fill-current" viewBox="0 0 20 20">
                            <path
                                d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"
                            ></path>
                        </svg>
                        <svg class="w-5 h-5 fill-current" viewBox="0 0 20 20">
                            <path
                                d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"
                            ></path>
                        </svg>
                        <svg class="w-5 h-5 fill-current" viewBox="0 0 20 20">
                            <path
                                d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"
                            ></path>
                        </svg>
                    </div>
                    <blockquote class="mb-8">
                        <p
                            class="text-lg text-gray-600 dark:text-gray-300 italic mb-6"
                        >
                            "After my promotion to COO, Robert's coaching gave
                            me the confidence and clarity to lead global
                            operations meetings effectively in my new role."
                        </p>
                        <footer class="flex items-center">
                            <div>
                                <cite
                                    class="font-heading text-lg font-semibold not-italic block"
                                >
                                    Andres Guzman
                                </cite>
                                <span
                                    class="text-sm text-gray-500 dark:text-gray-400"
                                >
                                    COO, Driscoll's Mexico
                                </span>
                            </div>
                        </footer>
                    </blockquote>
                </div>

                {/* Testimonial 2 */}
                <div
                    class="bg-white dark:bg-gray-700/50 rounded-xl p-8 shadow-lg"
                >
                    <div class="flex text-yellow-400 mb-6">
                        <svg class="w-5 h-5 fill-current" viewBox="0 0 20 20">
                            <path
                                d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"
                            ></path>
                        </svg>
                        <svg class="w-5 h-5 fill-current" viewBox="0 0 20 20">
                            <path
                                d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"
                            ></path>
                        </svg>
                        <svg class="w-5 h-5 fill-current" viewBox="0 0 20 20">
                            <path
                                d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"
                            ></path>
                        </svg>
                        <svg class="w-5 h-5 fill-current" viewBox="0 0 20 20">
                            <path
                                d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"
                            ></path>
                        </svg>
                        <svg class="w-5 h-5 fill-current" viewBox="0 0 20 20">
                            <path
                                d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"
                            ></path>
                        </svg>
                    </div>
                    <blockquote class="mb-8">
                        <p
                            class="text-lg text-gray-600 dark:text-gray-300 italic mb-6"
                        >
                            "Before Robert, I struggled to pitch to
                            English-speaking VCs. His coaching made me a
                            powerhouse in my second language—I secured funding
                            for my startup in just months."
                        </p>
                        <footer class="flex items-center">
                            <div>
                                <cite
                                    class="font-heading text-lg font-semibold not-italic block"
                                >
                                    Julio Aldana
                                </cite>
                                <span
                                    class="text-sm text-gray-500 dark:text-gray-400"
                                >
                                    Founder, LUMI
                                </span>
                            </div>
                        </footer>
                    </blockquote>
                </div>
            </div>
        </div>
    </section>

    {/* How I Work Section */}
    <section class="relative py-16 md:py-24 bg-white dark:bg-gray-900">
        <div class="container mx-auto px-4">
            <div class="grid md:grid-cols-12 gap-8 md:gap-12">
                {/* Left Column - Static */}
                <div class="md:col-span-5 md:sticky md:top-24 md:self-start">
                    <div
                        class="bg-gray-50 dark:bg-gray-800 rounded-xl p-8 md:p-12"
                    >
                        <h2
                            class="font-heading text-3xl md:text-4xl font-bold mb-6"
                        >
                            How I Work with Clients
                        </h2>
                        <h3
                            class="text-xl md:text-2xl text-gray-600 dark:text-gray-300 font-medium mb-6"
                        >
                            A Proven Process to Elevate Your Communication
                        </h3>
                        <p
                            class="text-lg text-gray-600 dark:text-gray-300 leading-relaxed"
                        >
                            I guide professionals like you through a tailored
                            journey to speak English with clarity and confidence
                            in high-stakes settings. Here's how we'll achieve
                            your goals:
                        </p>
                    </div>
                </div>

                {/* Right Column - Timeline */}
                <div class="md:col-span-7">
                    <div class="relative pl-8 md:pl-12">
                        {/* Timeline Line */}
                        <div
                            class="absolute left-6 top-0 h-full w-px bg-gray-200 dark:bg-gray-700"
                        >
                        </div>

                        {/* Step 1 */}
                        <div class="relative mb-16 flex items-start">
                            <div
                                class="absolute left-0 flex h-12 w-12 items-center justify-center rounded-full bg-blue-600 text-white"
                            >
                                <Waves size={24} />
                            </div>
                            <div class="pl-16">
                                <h3 class="font-heading text-xl font-bold mb-4">
                                    Connect and Confirm We're a Match
                                </h3>
                                <p
                                    class="text-gray-600 dark:text-gray-300 text-lg"
                                >
                                    We start with a brief online introduction to
                                    discuss your needs and ensure we're the
                                    right fit. This no-pressure call sets the
                                    stage for a successful partnership.
                                </p>
                            </div>
                        </div>

                        {/* Step 2 */}
                        <div class="relative mb-16 flex items-start">
                            <div
                                class="absolute left-0 flex h-12 w-12 items-center justify-center rounded-full bg-blue-600 text-white"
                            >
                                <Calendar size={24} />
                            </div>
                            <div class="pl-16">
                                <h3 class="font-heading text-xl font-bold mb-4">
                                    Schedule Your First Session
                                </h3>
                                <p
                                    class="text-gray-600 dark:text-gray-300 text-lg"
                                >
                                    Once we're aligned, we'll book your first
                                    session at a time that works for you,
                                    kicking off your journey to confident
                                    communication.
                                </p>
                            </div>
                        </div>

                        {/* Step 3 */}
                        <div class="relative mb-16 flex items-start">
                            <div
                                class="absolute left-0 flex h-12 w-12 items-center justify-center rounded-full bg-blue-600 text-white"
                            >
                                <Target size={24} />
                            </div>
                            <div class="pl-16">
                                <h3 class="font-heading text-xl font-bold mb-4">
                                    Identify Your Goals and Gaps
                                </h3>
                                <p
                                    class="text-gray-600 dark:text-gray-300 text-lg"
                                >
                                    In our first session, we'll pinpoint your
                                    immediate goals—whether it's leading a board
                                    meeting or pitching to investors—and
                                    identify any gaps in your English skills to
                                    create a focused plan.
                                </p>
                            </div>
                        </div>

                        {/* Step 4 */}
                        <div class="relative mb-16 flex items-start">
                            <div
                                class="absolute left-0 flex h-12 w-12 items-center justify-center rounded-full bg-blue-600 text-white"
                            >
                                <FileText size={24} />
                            </div>
                            <div class="pl-16">
                                <h3 class="font-heading text-xl font-bold mb-4">
                                    Plan Tailored Sessions with Custom Content
                                </h3>
                                <p
                                    class="text-gray-600 dark:text-gray-300 text-lg"
                                >
                                    I design the first few sessions specifically
                                    for you, crafting custom content that
                                    addresses your unique challenges and goals,
                                    from vocabulary to delivery, ensuring every
                                    lesson drives impact.
                                </p>
                            </div>
                        </div>

                        {/* Step 5 */}
                        <div class="relative mb-16 flex items-start">
                            <div
                                class="absolute left-0 flex h-12 w-12 items-center justify-center rounded-full bg-blue-600 text-white"
                            >
                                <CheckCircle size={24} />
                            </div>
                            <div class="pl-16">
                                <h3 class="font-heading text-xl font-bold mb-4">
                                    Review Your Progress
                                </h3>
                                <p
                                    class="text-gray-600 dark:text-gray-300 text-lg"
                                >
                                    After a few sessions, we'll assess your
                                    growth, reflecting on how your communication
                                    has improved and adjusting our approach to
                                    keep you on track.
                                </p>
                            </div>
                        </div>

                        {/* Step 6 */}
                        <div class="relative mb-16 flex items-start">
                            <div
                                class="absolute left-0 flex h-12 w-12 items-center justify-center rounded-full bg-blue-600 text-white"
                            >
                                <LineChart size={24} />
                            </div>
                            <div class="pl-16">
                                <h3 class="font-heading text-xl font-bold mb-4">
                                    Monitor and Refine for Lasting Results
                                </h3>
                                <p
                                    class="text-gray-600 dark:text-gray-300 text-lg"
                                >
                                    I'll continuously monitor your progress,
