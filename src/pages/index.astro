---
export const prerender = true;

import Base from "@layouts/Base.astro";

// This is a redirect page - should not be indexed (redirects to /en/)
const lang = "en";
const tkey = "home";
---
<Base
  title="Redirecting... | NY English Teacher"
  description="Redirecting to the English homepage."
  lang={lang}
  tkey={tkey}
  noindex={true}
>
  <noscript>
    <meta http-equiv="refresh" content="0; url=/en/">
    <p>If you're not redirected, <a href="/en/">go to English</a>.</p>
  </noscript>
  <script is:inline>
    // Replace so / doesn't stick in the history
    window.location.replace("/en/");
  </script>
</Base>