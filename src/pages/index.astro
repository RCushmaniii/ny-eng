---
import Base from "@layouts/Base.astro";

// This is a redirect page - minimal SEO needed
const lang = "en";
const tkey = "home";
---
<Base 
  title="New York English Teacher" 
  description="Professional Business English Coaching"
  lang={lang}
  tkey={tkey}
>
  <noscript>
    <meta http-equiv="refresh" content="0; url=/en/">
    <p>If you're not redirected, <a href="/en/">go to English</a>.</p>
  </noscript>
  <script is:inline>
    // Replace so / doesn't stick in the history
    window.location.replace("/en/");
  </script>
</Base>