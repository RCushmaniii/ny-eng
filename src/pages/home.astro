---
import Layout from "@layouts/Layout.astro";
import Hero from "@components/sections/Hero.astro";
import SplitPanel from "@components/sections/SplitPanel.astro";
import Features from "@components/sections/Features.astro";
import Stats from "@components/sections/Stats.astro";
import { featureLists } from "@data/features";
import { statsLists } from "@data/stats";
import Logos from "@components/sections/Logos.astro";
import { logoLists } from "@data/logos";
import CtaBanner from "@components/sections/CtaBanner.astro";
import Faqs from "@components/sections/Faqs.astro";
import { faqLists } from "@data/faqs";
import RecentPosts from "@components/sections/RecentPosts.astro";
import newHeroImage from "../assets/images/home/new-york-city-skyline.webp";
import styleGuideImage from "../assets/images/home/developer.jpg";
import { GraduationCap, Briefcase, Presentation, Users } from "lucide-astro";
import Testimonials from "@components/sections/Testimonials-titan.astro";
import { testimonials } from "@data/testimonials";

const testimonialsBlock = {
  eyebrow: "Real Results",
  title: "What Our Clients Say About Coaching with Robert",
  description:
    "Professionals across industries—from logistics to tech—have gained confidence, fluency, and new opportunities by working with New York English.",
  testimonials, // ✅ <-- This is the missing key
  cta: {
    heading: "Ready to Elevate Your English?",
    description:
      "Join a growing community of business professionals who’ve improved their fluency and performance through personalized English coaching.",
    text: "Book a Free Strategy Call",
    link: "#contact",
    variant: "primary",
  },
};

const seoTitle = "Professional English Coaching for Business Success";
const seoDescription =
  "Boost your English fluency and confidence with personalized coaching tailored for professionals and companies.";

const heroContent = {
  title: "Master Business English & Advance Your Career",
  description:
    "Personalized English coaching designed to boost your confidence, fluency, and success in professional settings.",
  buttons: [
    {
      text: "Book a Free Consultation",
      link: "/contact",
      target: "_self",
      variant: "primary", // Using design system button variant
    },
    {
      text: "WhatsApp Me",
      link: "https://wa.me/YOUR_WHATSAPP_NUMBER", // Replace with actual number
      target: "_blank",
      variant: "whatsapp", // Our custom WhatsApp button
    },
  ],
  backgroundImage: newHeroImage, // This assumes you've imported or defined `newHeroImage` elsewhere
  overlayOpacity: 0.3,
};

const featuresSection = {
  eyebrow: "WHAT WE OFFER",
  title: "Personalized English Coaching for Professionals",
  description:
    "Whether you need to improve your fluency, ace an interview, or communicate more effectively in business meetings, we’ve got you covered.",
  features: [
    {
      title: "1-on-1 Coaching",
      description: "Tailored lessons to match your career goals.",
      icon: GraduationCap,
    },
    {
      title: "Corporate Training",
      description: "Workshops for teams and executives.",
      icon: Users,
    },
    {
      title: "Interview Preparation",
      description: "Master your next job interview in English.",
      icon: Briefcase,
    },
    {
      title: "Business Presentations",
      description: "Communicate your ideas with confidence.",
      icon: Presentation,
    },
  ],
  button: {
    text: "Explore Services",
    link: "/services",
    variant: "primary" as const,
  },
};

const FooterCta = {
  eyebrow: "Let’s Improve Your English",
  title: "Start Your Learning Journey Today",
  description:
    "Book a free consultation and take the first step toward fluent, confident English communication.",
  hideCta: false,
  button: {
    text: "Schedule a Free Consultation",
    link: "/contact",
    target: "_self",
  },
};

const styleGuideSection = {
  eyebrow: "My Teaching Approach",
  headline: "Personalized & Goal-Oriented English Coaching",
  description:
    "I use a structured yet flexible approach tailored to your professional needs. Whether you're preparing for an interview, leading a meeting, or improving fluency, my coaching is designed for real-world success.",
  image: {
    src: styleGuideImage,
    alt: "Professional English coaching session",
  },
  buttons: [
    {
      text: "Learn More",
      link: "/methodology",
      variant: "primary" as const,
    },
  ],
};

const sideBySideStats = {
  eyebrow: "STATS",
  title: "Build Real Confidence in Your Communication",
  description:
    "I help professionals speak and write English with clarity, purpose, and ease. Whether you're preparing for interviews, presentations, or daily business conversations — you're covered.",
  variant: "side-by-side" as const,
  stats: statsLists.withContent.stats,
  content: {
    title: "Build Real Confidence in Your Communication",
    description:
      "I help professionals speak and write English with clarity, purpose, and ease. Whether you're preparing for interviews, presentations, or daily business conversations — you're covered.",
    button: {
      text: "Let's Work Together",
      link: "/contact",
      variant: "primary" as const,
    },
  },
};

const mainCta = {
  eyebrow: "Build Blocks",
  title: "Ready-to-Use Components",
  description:
    "Save development time with our pre-built, accessible components. Each one is designed to integrate seamlessly with your projects while maintaining excellent performance.",
  button: {
    text: "View All Components",
    link: "/components",
    variant: "primary" as const,
    target: "_self" as const,
  },
};

const logosSection = {
  eyebrow: "Our Clients",
  logos: logoLists.main.logos,
};

const faqsSection = {
  eyebrow: "FAQs",
  title: "Frequently Asked Questions",
  description: "Find answers to common questions.",
  faqs: faqLists.main.faqs,
};

const recentPostsSection = {
  eyebrow: "RECENT BLOG POSTS", // <-- Updated smoke title
  title: "Insights for Business Professionals", // <-- Updated main title
  description:
    "Practical tips on Business English, career growth, and effective communication.", // <-- Updated description
  button: {
    text: "See All Articles", // <-- Updated button text
    link: "/blog", // Keep the link destination
  },
};
---

<Layout footerCta={FooterCta} title={seoTitle} description={seoDescription}>
  <Hero content={heroContent} />
  <Features content={featuresSection} padding="base" background="light" />
  <Testimonials content={testimonialsBlock} background="light" padding="base" />

  <RecentPosts
    content={recentPostsSection}
    background="base"
    padding="base"
    postsToShow={3}
  />

  <SplitPanel
    content={styleGuideSection}
    imagePosition="right"
    background="light"
    padding="base"
  />
  {
    /* <CtaBanner
    content={mainCta}
    variant="contained"
    background="light"
    paddingBottom="base"
  />/}
  {/* <Logos content={logosSection} background="base" padding="small" /> */
  }

  <Stats content={sideBySideStats} background="dark" padding="base" />
  <Faqs content={faqsSection} background="base" padding="base" />
</Layout>
