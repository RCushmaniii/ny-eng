---
/**
 * Documentation Library - Main index page with links to all documentation
 */

import DocsLayout from '@layouts/DocsLayout.astro';

// Create a mapping for all available documentation
function getAvailableDocuments() {
  return [
    { 
      filename: 'INDEX.md', 
      name: 'Documentation Index', 
      category: 'Main', 
      icon: '🏠',
      route: '/dev/docs/index/',
      description: 'Main documentation overview and navigation'
    },
    { 
      filename: 'DEPLOYMENT-CHECKLIST.md', 
      name: 'Deployment Checklist', 
      category: 'Operations', 
      icon: '🚀',
      route: '/dev/docs/deployment-checklist/',
      description: 'Complete pre-deployment verification checklist'
    },
    { 
      filename: 'BILINGUAL-SYSTEM-GUIDE.md', 
      name: 'Bilingual System Guide', 
      category: 'i18n', 
      icon: '🌍',
      route: '/dev/docs/bilingual-system-guide/',
      description: 'Comprehensive guide to the bilingual architecture'
    },
    { 
      filename: 'BLOG-I18N-EDGE-CASES.md', 
      name: 'Blog i18n Edge Cases', 
      category: 'Blog', 
      icon: '📝',
      route: '/dev/docs/blog-i18n-edge-cases/',
      description: 'Edge cases and solutions for blog internationalization'
    },
    { 
      filename: 'HREFLANG-FIX-SUMMARY.md', 
      name: 'Hreflang Fix Summary', 
      category: 'SEO', 
      icon: '🔗',
      route: '/dev/docs/hreflang-fix-summary/',
      description: 'Summary of hreflang implementation and SEO fixes'
    },
    { 
      filename: 'IMAGE-OPTIMIZATION-PRIORITIES.md', 
      name: 'Image Optimization', 
      category: 'Performance', 
      icon: '🖼️',
      route: '/dev/docs/image-optimization-priorities/',
      description: 'Image optimization strategies and priorities'
    },
    { 
      filename: 'WINDSURF-RULES.md', 
      name: 'Windsurf Rules', 
      category: 'Development', 
      icon: '⚙️',
      route: '/dev/docs/windsurf-rules/',
      description: 'Development rules and coding standards'
    },
    { 
      filename: 'REDIRECT-ANALYSIS-SUMMARY.md', 
      name: 'Redirect Analysis', 
      category: 'SEO', 
      icon: '🔄',
      route: '/dev/docs/redirect-analysis-summary/',
      description: 'Analysis of redirect chains and URL optimization'
    }
  ];
}

const availableDocs = getAvailableDocuments();
const totalDocs = availableDocs.length;
const pageTitle = 'Documentation Library';
---

<DocsLayout title={pageTitle} description="NY English Teacher project documentation library">
  <!-- Document Navigation -->
  <div class="mb-8 bg-gradient-to-r from-blue-50 to-indigo-50 rounded-xl shadow-lg border border-blue-100 overflow-hidden">
    <div class="bg-gradient-to-r from-blue-600 to-indigo-600 px-6 py-4">
      <h2 class="text-xl font-bold text-white flex items-center">
        <span class="text-2xl mr-3">📚</span>
        Documentation Library
      </h2>
      <p class="text-blue-100 text-sm mt-1">{totalDocs} documents available</p>
    </div>
    
    <div class="p-6">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
        {availableDocs.map(doc => (
          <a 
            href={doc.route}
            class="group block p-4 rounded-lg border-2 transition-all duration-200 transform hover:scale-105 hover:shadow-md bg-white border-gray-200 hover:border-blue-300 hover:bg-blue-50"
          >
            <div class="flex items-start justify-between">
              <div class="flex-1">
                <div class="font-semibold text-sm mb-2 text-gray-900 group-hover:text-blue-700">
                  <span class="text-lg mr-2">{doc.icon}</span>
                  {doc.name}
                </div>
                <div class="text-xs text-gray-600 mb-2 line-clamp-2">
                  {doc.description}
                </div>
                <div class="text-xs inline-flex items-center px-2 py-1 rounded-full bg-gray-100 text-gray-600 group-hover:bg-blue-100 group-hover:text-blue-700">
                  {doc.category}
                </div>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </div>

  <!-- Getting Started Section -->
  <div class="mt-8 bg-white rounded-xl shadow-lg border border-gray-200 overflow-hidden">
    <div class="bg-gradient-to-r from-green-50 to-emerald-50 px-8 py-6 border-b border-gray-200">
      <h2 class="text-2xl font-bold text-gray-900 flex items-center">
        <span class="text-3xl mr-3">🚀</span>
        Getting Started
      </h2>
      <p class="text-gray-600 mt-2">Quick navigation to key documentation sections</p>
    </div>
    
    <div class="p-8">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="text-center">
          <div class="text-4xl mb-3">👨‍💻</div>
          <h3 class="font-semibold text-gray-900 mb-2">For Developers</h3>
          <p class="text-sm text-gray-600 mb-4">Start with system architecture and coding standards</p>
          <div class="space-y-2">
            <a href="/dev/docs/index/" class="block text-blue-600 hover:text-blue-800 text-sm">📚 Documentation Index</a>
            <a href="/dev/docs/bilingual-system-guide/" class="block text-blue-600 hover:text-blue-800 text-sm">🌍 Bilingual System Guide</a>
            <a href="/dev/docs/windsurf-rules/" class="block text-blue-600 hover:text-blue-800 text-sm">⚙️ Windsurf Rules</a>
          </div>
        </div>
        
        <div class="text-center">
          <div class="text-4xl mb-3">📈</div>
          <h3 class="font-semibold text-gray-900 mb-2">For SEO/Content</h3>
          <p class="text-sm text-gray-600 mb-4">SEO implementation and content guidelines</p>
          <div class="space-y-2">
            <a href="/dev/docs/hreflang-fix-summary/" class="block text-blue-600 hover:text-blue-800 text-sm">🔗 Hreflang Fix Summary</a>
            <a href="/dev/docs/blog-i18n-edge-cases/" class="block text-blue-600 hover:text-blue-800 text-sm">📝 Blog i18n Edge Cases</a>
            <a href="/dev/docs/redirect-analysis-summary/" class="block text-blue-600 hover:text-blue-800 text-sm">🔄 Redirect Analysis</a>
          </div>
        </div>
        
        <div class="text-center">
          <div class="text-4xl mb-3">🛠️</div>
          <h3 class="font-semibold text-gray-900 mb-2">For DevOps</h3>
          <p class="text-sm text-gray-600 mb-4">Deployment and performance optimization</p>
          <div class="space-y-2">
            <a href="/dev/docs/deployment-checklist/" class="block text-blue-600 hover:text-blue-800 text-sm">🚀 Deployment Checklist</a>
            <a href="/dev/docs/image-optimization-priorities/" class="block text-blue-600 hover:text-blue-800 text-sm">🖼️ Image Optimization</a>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Development Info -->
  <div class="mt-8 bg-gradient-to-r from-indigo-50 to-purple-50 rounded-xl border border-indigo-200 overflow-hidden">
    <div class="bg-gradient-to-r from-indigo-600 to-purple-600 px-6 py-3">
      <h3 class="font-bold text-white flex items-center">
        <span class="text-xl mr-2">🛠️</span>
        Development Information
      </h3>
    </div>
    <div class="p-6">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4 text-sm">
        <div class="space-y-3">
          <div class="flex items-center">
            <span class="w-3 h-3 bg-green-500 rounded-full mr-3"></span>
            <span class="font-medium text-gray-700">Documentation System:</span>
            <code class="ml-2 px-2 py-1 bg-gray-100 rounded text-xs">Astro + MarkdownLayout</code>
          </div>
          <div class="flex items-center">
            <span class="w-3 h-3 bg-blue-500 rounded-full mr-3"></span>
            <span class="font-medium text-gray-700">Total Documents:</span>
            <span class="ml-2 px-2 py-1 bg-blue-100 text-blue-800 rounded text-xs font-semibold">{totalDocs}</span>
          </div>
        </div>
        <div class="space-y-3">
          <div class="flex items-center">
            <span class="w-3 h-3 bg-purple-500 rounded-full mr-3"></span>
            <span class="font-medium text-gray-700">Source Directory:</span>
            <code class="ml-2 px-2 py-1 bg-gray-100 rounded text-xs">/docs/</code>
          </div>
          <div class="flex items-center">
            <span class="w-3 h-3 bg-orange-500 rounded-full mr-3"></span>
            <span class="font-medium text-gray-700">Layout Component:</span>
            <code class="ml-2 px-2 py-1 bg-gray-100 rounded text-xs">MarkdownLayout.astro</code>
          </div>
        </div>
      </div>
    </div>
  </div>
</DocsLayout>
