---
import Layout from "@layouts/Layout.astro";
import InnerHero from "@components/sections/InnerHero.astro";
import ContactInfo from "@components/sections/ContactInfo.astro";

const heroContent = {
    title: "Contact Me",
    description: "Get in touch to discuss your communication goals",
};
const footerCta = {
  eyebrow: "",
  title: "Transform Your Professional English Today",
  description: "Book your free consultation to gain the clarity, confidence, and impact your role demands.",
  hideCta: false,
  button: {
    text: "Reserve My Free Consultation",
    link: "https://ny-english-teacher.odoo.com/book/7ceefa20",
    target: "_blank",
    variant: "primary"
  }
};
---

<Layout title="Contact Us" description="Reach me via this form or WhatsApp." footerCta={footerCta}>
    <InnerHero content={{
    ...heroContent,
    backgroundImage: '/src/assets/images/contact/nyc-statue-of-liberty.jpg',
    overlayOpacity: 0.3
}} />
    <ContactInfo background="base" padding="base" />
</Layout>
