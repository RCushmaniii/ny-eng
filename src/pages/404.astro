---
// src/pages/404.astro (ROOT 404 - for redirection)
const { url } = Astro;
const pathSegments = url.pathname.split('/').filter(segment => segment.length > 0);

let targetLang = 'en'; // Default to English for 404 page if no specific lang prefix

// Check if the first significant path segment indicates a language
if (pathSegments.length > 0) {
  if (pathSegments[0] === 'es') {
    targetLang = 'es';
  } else if (pathSegments[0] === 'en') {
    targetLang = 'en';
  }
  // If pathSegments[0] is neither 'en' nor 'es' (e.g., /somepage), targetLang remains 'en'.
}

const redirectPath = `/${targetLang}/404`;

// Prevent redirect loop if this page is hit AFTER a redirect
// or if /en/404 or /es/404 themselves don't exist (which they should).
// This also handles the case where someone directly navigates to /404.
if (url.pathname !== redirectPath && url.pathname !== `/${targetLang}/404.html`) { // .html for built sites
  return Astro.redirect(redirectPath, 302); // 302 for temporary redirect to the correct handler
}

// Fallback content - This should ideally never be shown if redirection works.
// This is a safety net if someone lands directly on /404.astro AND the redirect above fails
// OR if the target /en/404 or /es/404 itself is missing.
let fallbackTitle = "Page Not Found";
let fallbackMessage = "The page you are looking for cannot be found. Please check the URL or return to the homepage.";
let homeLink = "/en/";
let homeButtonText = "Back to Homepage";

if (targetLang === 'es') {
  fallbackTitle = "Página No Encontrada";
  fallbackMessage = "La página que buscas no se puede encontrar. Por favor, verifica la URL o regresa a la página principal.";
  homeLink = "/es/";
  homeButtonText = "Volver a la Página Principal";
}
---
<!doctype html>
<html lang={targetLang}>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{fallbackTitle}</title>
  <meta name="robots" content="noindex, nofollow">
  <style>
    body { font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, 'Open Sans', 'Helvetica Neue', sans-serif; text-align: center; padding: 40px; background-color: #f8f9fa; color: #343a40; margin:0; display:flex; justify-content:center; align-items:center; min-height: 100vh; }
    .container { max-width: 600px; margin: auto; background: white; padding: 30px; border-radius: 8px; box-shadow: 0 4px 6px rgba(0,0,0,0.1); }
    h1 { font-size: 2.5em; color: #007bff; margin-bottom: 0.5em; }
    p { font-size: 1.1em; line-height: 1.6; margin-bottom: 1.5em;}
    a.button { color: white; background-color: #007bff; text-decoration: none; padding: 12px 25px; border-radius: 5px; display: inline-block; font-weight: bold; transition: background-color 0.2s ease-in-out; }
    a.button:hover { background-color: #0056b3; }
  </style>
</head>
<body>
  <div class="container">
    <h1>{fallbackTitle}</h1>
    <p>{fallbackMessage}</p>
    <a href={homeLink} class="button">{homeButtonText}</a>
  </div>
</body>
</html>