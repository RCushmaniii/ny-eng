---
import Layout from '@layouts/Layout.astro';
import BlogList from './BlogList.astro';
import InnerHero from '../sections/InnerHero.astro';
import Button from '../ui/Button.astro';
import { ChevronLeft, ChevronRight } from 'lucide-astro';
import { getLanguage, useTranslations, getLangFromUrl } from '../../i18n/utils';

export interface Props {
  posts: Array<any>;
  currentPage: number;
  totalPages: number;
  baseUrl: string;
  title: string;
  subtitle?: string;
  heroImage: ImageMetadata;
  heroImageAlt?: string;
  hasMultiplePages?: boolean;
  translationSlugEn?: string;
  translationSlugEs?: string;
  currentCategory?: string;
  currentCategorySlug?: string;
  lang?: string;
}

const {
  posts,
  currentPage,
  totalPages,
  baseUrl,
  title,
  subtitle,
  heroImage,
  heroImageAlt = "Blog image",
  currentCategory = "",
  currentCategorySlug = "",
  hasMultiplePages = false,
  translationSlugEn,
  translationSlugEs,
  lang = "en"
} = Astro.props;

// Determine language based on multiple approaches for better resilience
const urlLang = Astro.url.pathname.startsWith('/es/') ? 'es' : 'en';
const propLang = lang || 'en';
// Use URL-based language detection as primary, prop as backup
const detectedLang = urlLang || propLang;

// Set up language for translations
const typedLang = getLanguage(detectedLang);
const t = useTranslations(typedLang);

// Generate pagination URLs
const cleanBaseUrl = baseUrl ? baseUrl.replace(/\/\/+/g, '\/').replace(/\/$/, '') : '';
const prevUrl = currentPage > 1 ? (currentPage === 2 ? cleanBaseUrl : `${cleanBaseUrl}/${currentPage - 1}`) : null;
const nextUrl = currentPage < totalPages ? `${cleanBaseUrl}/${currentPage + 1}` : null;

const shouldShowPagination = hasMultiplePages && totalPages > 1 && posts.length > 0;
const nextPage = shouldShowPagination && currentPage < totalPages ? `${cleanBaseUrl}/${currentPage + 1}` : null;
const prevPage = shouldShowPagination && currentPage > 1 
  ? currentPage - 1 === 1 
    ? cleanBaseUrl
    : `${cleanBaseUrl}/${currentPage - 1}`
  : null;

const seoTitle = title;
const seoDescription = subtitle;

const heroContent = {
  title: title,
  description: subtitle,
  backgroundImage: heroImage,
  overlayOpacity: 0.2,
  alt: heroImageAlt
};
---
<Layout 
    title={seoTitle} 
    description={seoDescription} 
    translationSlugEn={translationSlugEn} 
    translationSlugEs={translationSlugEs}
    image="/images/logos/new-york-english-og-wide.jpg"
    whatsappImage="/images/logos/new-york-english-og.jpg"
    linkedinImage="/images/logos/new-york-english-og-wide.jpg"
    isPaginated={shouldShowPagination}
    paginationData={{
      currentPage,
      totalPages,
      canonicalUrl: cleanBaseUrl,
      prevPageUrl: prevPage,
      nextPageUrl: nextPage
    }}>
    <main>
    <InnerHero content={{
      title: title,
      description: subtitle || '',
      backgroundImage: heroImage,
      overlayOpacity: 0.2
    }}/>
    <BlogList posts={posts} currentCategory={currentCategory} currentCategorySlug={currentCategorySlug} />

    {shouldShowPagination && (
        <nav class="pagination-nav" aria-label={t('pagination.aria')} data-aos="fade-in">
            <div class="container mx-auto px-4 py-12">
                <div class="flex items-center justify-center gap-6">
                    {prevPage && (
                        <Button href={prevPage} variant="primary" class="flex items-center gap-2">
                            <ChevronLeft size={20} />
                            {t('pagination.previous')}
                        </Button>
                    )}
                    
                    <div class="flex items-center gap-2">
                        {Array.from({ length: totalPages }, (_, i) => i + 1).map((pageNum) => (
                            <a
                                href={pageNum === 1 ? cleanBaseUrl : `${cleanBaseUrl}/${pageNum}`}
                                class={`w-10 h-10 flex items-center justify-center rounded-full transition-colors ${
                                    currentPage === pageNum
                                        ? 'bg-primary text-white'
                                        : 'hover:bg-white hover:text-body-base'
                                }`}
                                aria-current={currentPage === pageNum ? 'page' : undefined}
                            >
                                {pageNum}
                            </a>
                        ))}
                    </div>

                    {nextPage && (
                        <Button href={nextPage} variant="primary" class="flex items-center gap-2">
                            {t('pagination.next')}
                            <ChevronRight size={20} />
                        </Button>
                    )}
                </div>
            </div>
        </nav>
    )}
    </main>
</Layout> 