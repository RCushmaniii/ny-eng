---
import Base from '@layouts/Base.astro';
import BlogList from './BlogList.astro';
import InnerHero from '../sections/InnerHero.astro';
import Button from '../ui/Button.astro';
import { ChevronLeft, ChevronRight } from 'lucide-astro';
import { getLanguage, useTranslations } from '../../i18n/utils';
import type { TKey } from '../../lib/i18n';
import type { CollectionEntry } from 'astro:content';
import type { ImageMetadata } from 'astro';

type BlogPost = CollectionEntry<'blog'>;

export interface Props {
  posts: BlogPost[];
  currentPage: number;
  totalPages: number;
  baseUrl: string;
  title: string;
  heroTitle?: string;
  subtitle?: string;
  description?: string;
  heroImage: ImageMetadata | string;
  heroImageAlt?: string;
  hasMultiplePages?: boolean;
  translationSlugEn?: string;
  translationSlugEs?: string;
  currentCategory?: string;
  currentCategorySlug?: string;
  lang?: string;
  languageAlternates?: Array<{ hreflang: string; href: string }>;
  tkey?: TKey;
}

const {
  posts,
  currentPage,
  totalPages,
  baseUrl,
  title,
  heroTitle,
  subtitle,
  description,
  heroImage,
  heroImageAlt = "Blog image",
  currentCategory = "",
  currentCategorySlug = "",
  hasMultiplePages = false,
  translationSlugEn,
  translationSlugEs,
  lang = "en",
  languageAlternates,
  tkey
} = Astro.props;

// Determine language based on multiple approaches for better resilience
const urlLang = Astro.url.pathname.startsWith('/es/') ? 'es' : 'en';
const propLang = lang || 'en';
// Use URL-based language detection as primary, prop as backup
const detectedLang = urlLang || propLang;

// Set up language for translations
const typedLang = getLanguage(detectedLang);
const t = useTranslations(typedLang);

// Generate pagination URLs (always trailing slash)
// Accept baseUrl like "/en/blog/" and normalize to base without trailing slash
const base = (baseUrl ?? '').endsWith('/') ? (baseUrl ?? '').slice(0, -1) : (baseUrl ?? '');
const lastPage = totalPages; // compatibility with callers using totalPages
const pagePath = (n: number) => (n === 1 ? `${base}/` : `${base}/${n}/`);

const shouldShowPagination = hasMultiplePages && lastPage > 1 && posts.length > 0;
const canonicalUrl = pagePath(currentPage);
const prevPage = shouldShowPagination && currentPage > 1 ? pagePath(currentPage - 1) : null;
const nextPage = shouldShowPagination && currentPage < lastPage ? pagePath(currentPage + 1) : null;

const seoTitle = title;
const seoDescription = description || subtitle || "";

// Convert hreflang format to lang format for Base layout
const convertedHreflangs = languageAlternates?.map(alt => ({
  lang: alt.hreflang,
  href: alt.href
}));

---
<Base 
    lang={detectedLang}
    tkey={tkey || 'blog'}
    title={seoTitle} 
    description={seoDescription}
    customHreflangs={convertedHreflangs}
    customCanonical={canonicalUrl}
>
    <main>
    <InnerHero content={{
      title: heroTitle || title,
      description: subtitle || '',
      backgroundImage: heroImage,
      overlayOpacity: 0.2
    }}/>
    <BlogList posts={posts} currentCategory={currentCategory} currentCategorySlug={currentCategorySlug} />

    {shouldShowPagination && (
        <nav class="pagination-nav" aria-label={t('pagination.aria')} data-aos="fade-in">
            <div class="container mx-auto px-4 py-12">
                <div class="flex items-center justify-center gap-6">
                    {prevPage && (
                        <Button href={prevPage} variant="primary" class="flex items-center gap-2">
                            <ChevronLeft size={20} />
                            {t('pagination.previous')}
                        </Button>
                    )}
                    
                    <div class="flex items-center gap-2">
                        {Array.from({ length: totalPages }, (_, i) => i + 1).map((pageNum) => (
                            <a
                                href={pagePath(pageNum)}
                                class:list={`w-10 h-10 flex items-center justify-center rounded-full transition-colors ${
                                    currentPage === pageNum
                                        ? 'bg-primary text-white'
                                        : 'hover:bg-white hover:text-body-base'
                                }`}
                                aria-current={currentPage === pageNum ? 'page' : undefined}
                            >
                                {pageNum}
                            </a>
                        ))}
                    </div>

                    {nextPage && (
                        <Button href={nextPage} variant="primary" class="flex items-center gap-2">
                            {t('pagination.next')}
                            <ChevronRight size={20} />
                        </Button>
                    )}
                </div>
            </div>
        </nav>
    )}
    </main>
</Base> 