---
import Layout from '../../layouts/Layout.astro';
import BlogList from './BlogList.astro';
import InnerHero from '../sections/InnerHero.astro';
import Button from '../ui/Button.astro';
import { ChevronLeft, ChevronRight } from 'lucide-astro';


const seoTitle = "Blog";
const seoDescription = "Our blog is where we share our thoughts and ideas about the latest trends in the web development industry.";

interface Props {
    posts: any[];
    currentPage: number;
    totalPages: number;
    baseUrl: string;  // e.g., '/blog' or '/category/some-category'
    title: string;
    subtitle: string;
    currentCategory?: string;
    heroImage?: any; // processed Astro image object
    heroImageAlt?: string;
    translationSlugEn?: string;
    translationSlugEs?: string;
    hasMultiplePages?: boolean; // Added to explicitly control pagination visibility
}

const { 
    posts: paginatedPosts, 
    currentPage, 
    totalPages, 
    baseUrl,
    title,
    subtitle,
    currentCategory,
    heroImage,
    heroImageAlt,
    translationSlugEn,
    translationSlugEs,
    hasMultiplePages = false // Default to false if not provided
} = Astro.props;

    // Generate pagination URLs
const cleanBaseUrl = baseUrl ? baseUrl.replace(/\/\/+/g, '\/').replace(/\/$/, '') : '';

// Only generate pagination if explicitly told there are multiple pages AND we have posts
const shouldShowPagination = hasMultiplePages && totalPages > 1 && paginatedPosts.length > 0;

// Conditionally create pagination URLs based on whether we should show pagination
const nextPage = shouldShowPagination && currentPage < totalPages ? `${cleanBaseUrl}/${currentPage + 1}` : null;
const prevPage = shouldShowPagination && currentPage > 1 
  ? currentPage - 1 === 1 
    ? cleanBaseUrl
    : `${cleanBaseUrl}/${currentPage - 1}`
  : null;

const heroContent = {
    title: title,
    description: subtitle,
    backgroundImage: heroImage,
    overlayOpacity: 0.2,
    alt: heroImageAlt
}
---
<Layout title={seoTitle} description={seoDescription} 
    translationSlugEn={translationSlugEn} 
    translationSlugEs={translationSlugEs}
    image="/images/logos/new-york-english-og-wide.jpg"
    whatsappImage="/images/logos/new-york-english-og.jpg"
    linkedinImage="/images/logos/new-york-english-og-wide.jpg">
    <main>
    <InnerHero content={heroContent}/>
    <BlogList posts={paginatedPosts} currentCategory={currentCategory} />

    {shouldShowPagination && (
        <nav class="pagination-nav" aria-label="Blog pagination" data-aos="fade-in">
            <div class="container mx-auto px-4 py-12">
                <div class="flex items-center justify-center gap-6">
                    {prevPage && (
                        <Button href={prevPage} variant="primary" class="flex items-center gap-2">
                            <ChevronLeft size={20} />
                            Previous
                        </Button>
                    )}
                    
                    <div class="flex items-center gap-2">
                        {Array.from({ length: totalPages }, (_, i) => i + 1).map((pageNum) => (
                            <a
                                href={pageNum === 1 ? cleanBaseUrl : `${cleanBaseUrl}/${pageNum}`}
                                class={`w-10 h-10 flex items-center justify-center rounded-full transition-colors ${
                                    currentPage === pageNum
                                        ? 'bg-primary text-white'
                                        : 'hover:bg-white hover:text-body-base'
                                }`}
                                aria-current={currentPage === pageNum ? 'page' : undefined}
                            >
                                {pageNum}
                            </a>
                        ))}
                    </div>

                    {nextPage && (
                        <Button href={nextPage} variant="primary">
                            Next
                            <ChevronRight size={20} />
                        </Button>
                    )}
                </div>
            </div>
        </nav>
    )}
    </main>
</Layout> 