---
/**
 * SpeakEnglish.astro
 *
 * Adds text-to-speech buttons to any element with class="speak-en".
 * Uses Azure Neural TTS via /api/tts/synthesize for high-quality pronunciation.
 * Falls back to browser Web Speech API if the API call fails.
 * Only activates if .speak-en elements exist on the page.
 *
 * Usage in markdown:
 *   <span class="speak-en">The shipment is pending customs clearance.</span>
 */
---

<style is:global>
  .speak-en {
    position: relative;
  }
  .speak-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.5rem;
    height: 1.5rem;
    margin-left: 0.35rem;
    padding: 0;
    border: none;
    border-radius: 50%;
    background: #e8ecff;
    color: #4f46e5;
    cursor: pointer;
    vertical-align: middle;
    transition: background 0.15s, transform 0.15s;
    flex-shrink: 0;
  }
  .speak-btn:hover {
    background: #4f46e5;
    color: #fff;
    transform: scale(1.1);
  }
  .speak-btn.speaking {
    background: #4f46e5;
    color: #fff;
    animation: pulse-speak 1s infinite;
  }
  @keyframes pulse-speak {
    0%, 100% { transform: scale(1); }
    50% { transform: scale(1.15); }
  }
  .speak-btn svg {
    width: 0.85rem;
    height: 0.85rem;
    fill: currentColor;
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const speakables = document.querySelectorAll('.speak-en');
    if (!speakables.length) return;

    // Audio cache to avoid re-fetching the same text
    const audioCache = new Map<string, string>();
    let currentAudio: HTMLAudioElement | null = null;
    let currentBtn: HTMLButtonElement | null = null;

    const API_BASE = '/api/tts/synthesize';

    const speakerSVG = `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path d="M3 9v6h4l5 5V4L7 9H3zm13.5 3c0-1.77-1.02-3.29-2.5-4.03v8.05c1.48-.73 2.5-2.25 2.5-4.02zM14 3.23v2.06c2.89.86 5 3.54 5 6.71s-2.11 5.85-5 6.71v2.06c4.01-.91 7-4.49 7-8.77s-2.99-7.86-7-8.77z"/></svg>`;

    speakables.forEach(el => {
      // Store the original text BEFORE adding the button
      const originalText = (el.textContent || '').replace(/[""'']/g, '').trim();

      const btn = document.createElement('button');
      btn.className = 'speak-btn';
      btn.innerHTML = speakerSVG;
      btn.title = 'Listen to pronunciation';
      btn.type = 'button';

      btn.addEventListener('click', async (e) => {
        e.preventDefault();
        e.stopPropagation();

        // Stop any currently playing audio or browser speech
        if (currentAudio) {
          currentAudio.pause();
          currentAudio.currentTime = 0;
          currentBtn?.classList.remove('speaking');
        }
        if ('speechSynthesis' in window) {
          speechSynthesis.cancel();
        }

        const text = originalText;
        if (!text) return;

        btn.classList.add('speaking');
        currentBtn = btn;

        try {
          // Check cache first
          let audioUrl = audioCache.get(text);

          if (!audioUrl) {
            console.log('[TTS] Fetching Azure Neural TTS for:', text.substring(0, 50) + '...');

            const response = await fetch(API_BASE, {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ text, lang: 'en' }),
            });

            console.log('[TTS] Response status:', response.status, 'Content-Type:', response.headers.get('content-type'));

            if (!response.ok) {
              const errorText = await response.text();
              throw new Error(`TTS API error: ${response.status} — ${errorText}`);
            }

            const contentType = response.headers.get('content-type') || '';
            if (!contentType.includes('audio')) {
              const body = await response.text();
              throw new Error(`Expected audio, got ${contentType}: ${body}`);
            }

            const blob = await response.blob();
            console.log('[TTS] Received audio blob:', blob.size, 'bytes, type:', blob.type);

            if (blob.size < 100) {
              throw new Error(`Audio blob too small: ${blob.size} bytes`);
            }

            audioUrl = URL.createObjectURL(blob);
            audioCache.set(text, audioUrl);
          } else {
            console.log('[TTS] Using cached audio for:', text.substring(0, 50) + '...');
          }

          // Play the audio
          const audio = new Audio(audioUrl);
          currentAudio = audio;

          audio.addEventListener('ended', () => {
            console.log('[TTS] Audio playback completed (Azure Neural TTS)');
            btn.classList.remove('speaking');
            currentAudio = null;
            currentBtn = null;
          });

          audio.addEventListener('error', (err) => {
            console.error('[TTS] Audio element error:', err);
            btn.classList.remove('speaking');
            currentAudio = null;
            currentBtn = null;
          });

          await audio.play();
          console.log('[TTS] Playing Azure Neural TTS audio');

        } catch (err) {
          console.error('[TTS] Azure TTS failed, falling back to browser speech:', err);
          fallbackSpeak(text, btn);
        }
      });

      el.appendChild(btn);
    });

    /** Fallback to browser Web Speech API if Azure TTS is unavailable */
    function fallbackSpeak(text: string, btn: HTMLButtonElement) {
      console.warn('[TTS] FALLBACK: Using browser SpeechSynthesis (not Azure)');
      if (!('speechSynthesis' in window)) {
        btn.classList.remove('speaking');
        return;
      }

      speechSynthesis.cancel();
      const utterance = new SpeechSynthesisUtterance(text);
      utterance.lang = 'en-US';
      utterance.rate = 0.85;

      const voices = speechSynthesis.getVoices();
      const usVoice = voices.find(v => v.lang === 'en-US') || voices.find(v => v.lang.startsWith('en'));
      if (usVoice) utterance.voice = usVoice;

      utterance.onend = () => btn.classList.remove('speaking');
      utterance.onerror = () => btn.classList.remove('speaking');
      speechSynthesis.speak(utterance);
    }
  });
</script>
