---
export interface Props {
  name: string;
  description: string;
  steps: Array<{ name: string; text: string }>;
  totalTime?: string; // ISO 8601 duration, e.g. "PT30M"
}

const { name, description, steps, totalTime } = Astro.props;

const howToSchema: Record<string, unknown> = {
  "@context": "https://schema.org",
  "@type": "HowTo",
  "name": name,
  "description": description,
  "step": steps.map((step, index) => ({
    "@type": "HowToStep",
    "position": index + 1,
    "name": step.name,
    "text": step.text,
  })),
};

if (totalTime) {
  howToSchema.totalTime = totalTime;
}
---
<script type="application/ld+json" is:inline set:html={JSON.stringify(howToSchema)}></script>
