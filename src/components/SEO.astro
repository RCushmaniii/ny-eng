---
import { defaultSEO } from '../data/seo';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  whatsappImage?: string; // Specific image for WhatsApp sharing
  linkedinImage?: string; // Specific image for LinkedIn sharing
  type?: string;
  url?: string;
  locale?: string;
  alternateUrls?: {
    hreflang: string;
    href: string;
  }[];
}

const {
  title = defaultSEO.title,
  description = defaultSEO.description,
  image = defaultSEO.image,
  whatsappImage = defaultSEO.whatsappImage || defaultSEO.image,
  linkedinImage = defaultSEO.linkedinImage || defaultSEO.image,
  type = defaultSEO.type,
  url = defaultSEO.siteUrl,
  locale = defaultSEO.locale,
  alternateUrls = []
} = Astro.props;

// Ensure we always use the www version as canonical
const canonicalDomain = defaultSEO.siteUrl.replace(/^(https?:\/\/)/, '$1www.');

const fullImage = new URL(image.startsWith('/') ? image : `/${image}`, canonicalDomain).toString();
const fullWhatsappImage = new URL(whatsappImage.startsWith('/') ? whatsappImage : `/${whatsappImage}`, canonicalDomain).toString();
const fullLinkedinImage = new URL(linkedinImage.startsWith('/') ? linkedinImage : `/${linkedinImage}`, canonicalDomain).toString();

// Ensure the URL always uses the canonical domain (with www)
let fullUrl = new URL(url, canonicalDomain).toString();
// Clean up any potential double slashes in the path
fullUrl = fullUrl.replace(/([^:]\/)\/+/g, '$1');
---

<title>{title}</title>
<meta name="description" content={description} />
<meta name="image" content={fullImage} />

<!-- Primary Open Graph tags -->
<meta property="og:type" content={type} />
<meta property="og:url" content={fullUrl} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={fullImage} />
<meta property="og:image:secure_url" content={fullImage} />
<meta property="og:image:alt" content={title} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />

<!-- WhatsApp specific (square format) -->
<meta property="og:image:width" content="400" />
<meta property="og:image:height" content="400" />
<meta property="og:image" content={fullWhatsappImage} />

<!-- LinkedIn specific -->
<meta name="image" content={fullLinkedinImage} />
<meta property="og:image:type" content="image/jpeg" />

<!-- Additional tags for better platform-specific sharing -->
<meta property="og:locale" content={locale} />

<!-- Twitter -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:site" content={defaultSEO.twitterHandle} />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={fullImage} />
<meta name="twitter:image:alt" content={title} />

<!-- WhatsApp-optimized Twitter card (used when shared on mobile) -->
<meta name="twitter:image" content={fullWhatsappImage} media="(max-width: 600px)" />

<!-- Hreflang tags for multilingual SEO -->
{alternateUrls.map((alt) => {
  // Ensure URLs are properly formatted without double slashes in paths
  const cleanHref = alt.href.replace(/([^:]\/)\/+/g, '$1');
  return <link rel="alternate" hreflang={alt.hreflang} href={cleanHref} />;
})}
<!-- Canonical URL tag to reinforce the correct URL -->
<link rel="canonical" href={fullUrl.replace(/([^:]\/)\/+/g, '$1')} />
