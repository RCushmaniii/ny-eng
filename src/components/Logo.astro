---
import { Image } from "astro:assets";

// CORRECT MAPPING per user specification:
// ny-english-logo-150-dark.webp = for DARK backgrounds (transparent hero)
// ny-english-logo-150.webp = for WHITE backgrounds (scrolled navbar, other pages)
import logoForDarkBg from "../assets/images/logos/ny-english-logo-150-dark.webp";
import logoForWhiteBg from "../assets/images/logos/ny-english-logo-150.webp";

interface Props {
  variant?: "header" | "footer";
  transparentMode?: boolean;
}

const { variant = "header", transparentMode = false } = Astro.props;

const altText = "NY English Logo";
---

{
  variant === "footer" ? (
    <Image src={logoForDarkBg} alt={altText} class="h-10 w-auto" />
  ) : transparentMode ? (
    <div class="logo-container relative h-10" style="width: 150px;">
      <Image
        src={logoForDarkBg}
        alt={altText}
        class="h-10 w-auto logo-light absolute top-0 left-0"
      />
      <Image
        src={logoForWhiteBg}
        alt={altText}
        class="h-10 w-auto logo-dark hidden absolute top-0 left-0"
      />
      <span class="sr-only">NY English</span>
    </div>
  ) : (
    <Image src={logoForWhiteBg} alt={altText} class="h-10 w-auto" />
  )
}

<style>
  .logo-container {
    position: relative;
    display: inline-block;
  }

  .logo-light,
  .logo-dark {
    transition: opacity 0.3s ease;
  }
</style>
