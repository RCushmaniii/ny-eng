---
import { Image } from "astro:assets";
import logo from "../assets/images/logos/ny-english-logo-150.webp";
import logoDark from "../assets/images/logos/ny-english-logo-150 Dark.webp"; // Assuming you might use this

interface Props {
  variant?: "header" | "footer" | "dark"; // Keep variants if they affect styling of the image/span only
}

const { variant = "header" } = Astro.props;

// Choose the logo image based on context (e.g. if header is dark/light theme aware)
// For now, defaulting to the standard logo for the header.
// You might have more complex logic here if the header variant implies a different logo image.
const logoToUse = logo; // Simplified for now, adjust if logoDark is needed for header based on theme
---

<Image src={logoToUse} alt="NY English Logo" class="h-10 w-auto" /> {/* Adjust height/width as needed */}
<span class="sr-only">NY English</span>