---
import Button from '@components/ui/Button.astro';
import Eyebrow from '@components/ui/Eyebrow.astro';
import { getPaddingClass, getBackgroundColor } from '@utils/styleUtils';
import type { PaddingSize, ThemeColor } from '@utils/styleUtils';
import { Image } from 'astro:assets';

interface Content {
    eyebrow?: string;
    headline: string;
    subheadline?: string;
    description?: string;
    descriptionPoints?: string[];
    image: {
        src: string | any;
        alt: string;
    };
    buttons?: {
        text: string;
        link: string;
        variant?: 'primary' | 'secondary' | 'ghostLight' | 'ghostDark';
        target?: string;
    }[];
}

export interface Props {
    content: Content;
    imagePosition?: 'left' | 'right';
    background?: ThemeColor;
    paddingTop?: PaddingSize;
    lang?: 'en' | 'es';
    paddingBottom?: PaddingSize;
    padding?: PaddingSize;
}

const {
    content,
    imagePosition = 'right',
    background = 'base',
    paddingTop,
    paddingBottom,
    padding,
    lang = 'en',
} = Astro.props;

const { eyebrow, headline, subheadline, description, descriptionPoints, image, buttons = [] } = content;

const paddingClass = getPaddingClass({ padding, paddingTop, paddingBottom });
const bgColor = getBackgroundColor(background);

// Define text colors explicitly based on background
const textColorClass = background === 'dark' ? 'text-white' : 'text-neutral-900';

// Localized strings
const localizedText = {
    en: {
        expectText: "Here's what you can expect:"
    },
    es: {
        expectText: "Esto es lo que puedes esperar:"
    }
};

// Get the correct localized text based on language
const L = localizedText[lang] || localizedText.en; // Fallback to English if language not supported
---
<section class:list={["relative", bgColor, paddingClass]}>
    <div class="site-container px-4">
        <div class="grid gap-16 items-center md:grid-cols-2">
            {imagePosition === 'left' && (
                <div class="relative aspect-[4/3] overflow-hidden rounded-[var(--border-radius-base)] border border-black">
                    <Image
                        src={image.src}
                        alt={image.alt}
                        width={800}
                        height={600}
                        class="w-full h-full object-cover"
                        quality={80}
                        format="webp"
                     />
                </div>
            )}

            <div>
                {eyebrow && (
                    <Eyebrow
                        text={eyebrow}
                        background={background}
                    />
                )}
                <h2 class={`fade-in-up ${textColorClass}`} style="font-family: 'Noto Sans KR', sans-serif;">{headline}</h2>
                {subheadline && <h3 class={`fade-in-up delay-1 mt-4 text-h5 ${textColorClass}`} style="font-family: 'Noto Sans KR', sans-serif;">{subheadline}</h3>}

                {description && <p class={`fade-in-up delay-2 mt-6 text-base opacity-90 ${textColorClass}`} style="font-family: 'Noto Sans KR', sans-serif;">{description}</p>}

                {descriptionPoints && descriptionPoints.length > 0 && (
                    <div class="fade-in-up delay-3 mt-4 space-y-2" style="font-family: 'Noto Sans KR', sans-serif;">
                        <strong class={textColorClass} style="font-family: 'Noto Sans KR', sans-serif;">{L.expectText}</strong>
                        <ul class="list-disc list-inside space-y-1">
                            {descriptionPoints.map((point: string) => (
                                <li class={textColorClass} style="font-family: 'Noto Sans KR', sans-serif;">{point}</li>
                            ))}
                        </ul>
                    </div>
                )}

                {buttons && buttons.length > 0 && (
                    <div class="flex flex-wrap gap-4 mt-8">
                        {buttons.map((button) => (
                            <Button 
                                href={button.link} 
                                variant={button.variant || 'primary'} 
                                target={button.target}
                            >
                                {button.text}
                            </Button>
                        ))}
                    </div>
                )}
            </div>

            {imagePosition === 'right' && (
                 <div class="relative aspect-[4/3] overflow-hidden rounded-[var(--border-radius-base)] border border-black" data-aos="fade-up" data-aos-delay="100">
                    {/* ... Image component ... */}
                     <Image
                        src={image.src}
                        alt={image.alt}
                        width={800}
                        height={600}
                        class="w-full h-full object-cover"
                        quality={80}
                        format="webp"
                     />
                </div>
            )}
        </div>
    </div>
</section>