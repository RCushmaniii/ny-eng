---
import type { Meme, MemeRole } from "@data/memes/en";
import { roleLabels as roleLabelsEn, memesByRole as memesByRoleEn } from "@data/memes/en";
import { roleLabels as roleLabelsEs, memesByRole as memesByRoleEs } from "@data/memes/es";

interface Props {
  memes: Meme[];
  title: string;
  description: string;
  showFilters?: boolean;
  selectedRole?: string;
  lang: "en" | "es";
}

const {
  memes,
  title,
  description,
  showFilters = false,
  selectedRole = "all",
  lang = "en",
} = Astro.props;

// Get labels based on language
const labels = lang === "en" ? roleLabelsEn : roleLabelsEs;

// Get base URL for role filter links
const baseUrl = lang === "en" ? "/en/meme-portfolio/" : "/es/meme-portfolio/";
---

<section class="meme-gallery py-16 bg-gray-50">
  <div class="container mx-auto px-4">
    <div class="text-center mb-12 pt-16">
      <h1 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">
        {title}
      </h1>
      {description && (
        <p class="text-lg text-gray-600 max-w-3xl mx-auto">
          {description}
        </p>
      )}
    </div>

    {showFilters && (
      <div class="mb-10 flex flex-col sm:flex-row justify-center items-center gap-4">
        <label for="role-filter" class="font-medium text-gray-900">
          {lang === "en" ? "Filter by role:" : "Filtrar por rol:"}
        </label>
        <div class="relative">
          <select
            id="role-filter"
            class="bg-white border border-gray-300 rounded-md px-4 py-2 focus:outline-none focus:ring-2 focus:ring-primary-500 font-sans"
            style="font-family: NotoSansKR, ui-sans-serif, system-ui, sans-serif;"
          >
            {Object.entries(labels).map(([key, label]) => (
              <option value={key} selected={selectedRole === key}>
                {label}
              </option>
            ))}
          </select>
          <script define:vars={{ baseUrl }}>
            const roleFilter = document.getElementById("role-filter");
            if (roleFilter instanceof HTMLSelectElement) {
              roleFilter.addEventListener("change", function () {
                const selectedRole = this.value;
                window.location.href = `${baseUrl}${selectedRole}/`;
              });
            }
          </script>
        </div>
      </div>
    )}

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 max-w-7xl mx-auto">
      {memes.map((meme) => (
        <div class="meme-card bg-white rounded-xl shadow-md overflow-hidden transition-transform duration-200 hover:-translate-y-1 hover:shadow-lg">
          <div class="aspect-square overflow-hidden bg-gray-100">
            <img
              src={meme.image}
              alt={meme.alt}
              class="w-full h-full object-cover"
              loading="lazy"
              decoding="async"
            />
          </div>
          <div class="p-4">
            <h2 class="text-lg font-semibold text-gray-900 mb-2">
              {meme.title}
            </h2>
            <p class="text-sm text-gray-600 leading-relaxed mb-3">
              {meme.caption}
            </p>
            {(meme.beforePhrase || meme.afterPhrase) && (
              <div class="border-t border-gray-100 pt-3 space-y-2">
                {meme.beforePhrase && (
                  <div class="text-xs">
                    <span class="inline-block px-1.5 py-0.5 bg-red-50 text-red-600 font-semibold rounded mr-1">
                      {lang === "en" ? "Before" : "Antes"}
                    </span>
                    <span class="text-gray-500 italic">"{meme.beforePhrase}"</span>
                  </div>
                )}
                {meme.afterPhrase && (
                  <div class="text-xs">
                    <span class="inline-block px-1.5 py-0.5 bg-green-50 text-green-700 font-semibold rounded mr-1">
                      {lang === "en" ? "After" : "Despues"}
                    </span>
                    <span class="text-gray-700 font-medium">"{meme.afterPhrase}"</span>
                  </div>
                )}
              </div>
            )}
          </div>
        </div>
      ))}
    </div>

    {memes.length === 0 && (
      <div class="text-center py-16">
        <div class="text-5xl mb-6">🎬</div>
        <h2 class="text-2xl font-bold text-gray-900 mb-3">
          {lang === "en"
            ? "Coming Soon!"
            : "Proximamente!"}
        </h2>
        <p class="text-lg text-gray-600 mb-6 max-w-lg mx-auto">
          {lang === "en"
            ? "We're creating executive communication memes for this category. Check back soon or explore other roles!"
            : "Estamos creando memes de comunicacion ejecutiva para esta categoria. Vuelve pronto o explora otros roles!"}
        </p>
        <a
          href={`${baseUrl}all/`}
          class="inline-block px-6 py-3 bg-primary-600 text-white font-medium rounded-lg hover:bg-primary-700 transition-colors"
        >
          {lang === "en" ? "View All Memes" : "Ver Todos los Memes"}
        </a>
      </div>
    )}
  </div>
</section>
