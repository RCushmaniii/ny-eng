---
import { getCollection } from "astro:content";
import BlogPost from "@components/blog/BlogPost.astro";
import Button from "@components/ui/Button.astro";
import Eyebrow from "@components/ui/Eyebrow.astro";
import {
  getPaddingClass,
  getBackgroundColor,
  getTextColor,
} from "@utils/styleUtils";
import type { PaddingSize, ThemeColor } from "@utils/styleUtils";

export interface Props {
  content?: {
    eyebrow?: string;
    title?: string;
    description?: string;
    button?: {
      text: string;
      link: string;
      variant?: "primary" | "secondary" | "ghostLight" | "ghostDark";
    };
  };
  background?: ThemeColor;
  padding?: PaddingSize;
  paddingTop?: PaddingSize;
  paddingBottom?: PaddingSize;
  postsToShow?: number;
  category?: string;
}

const {
  content,
  background = "base",
  padding,
  paddingTop,
  paddingBottom,
  postsToShow = 3,
  category,
} = Astro.props;

const bgColor = getBackgroundColor(background);
const textColor = getTextColor(background);
const paddingClass = getPaddingClass({ padding, paddingTop, paddingBottom });

const allPosts = await getCollection(
  "blog",
  ({ data }: { data: { publish?: boolean } }) => {
    return import.meta.env.DEV || data.publish !== false;
  }
);

// Language filtering logic
const isSpanish = Astro.url.pathname.startsWith("/es");
const lang = isSpanish ? "es" : "en";
const filteredPosts = allPosts
  .filter(
    (post: {
      id: string;
      data: { categories?: string[]; publishDate: Date | string };
    }) => {
      // Filter by directory: show only posts in 'es/' for Spanish, 'en/' for English
      const isEs = post.id.startsWith("es/");
      const isEn = post.id.startsWith("en/");
      return isSpanish ? isEs : isEn;
    }
  )
  .filter(
    (post: { data: { categories?: string[] } }) =>
      !category || post.data.categories?.includes(category)
  )
  .sort(
    (
      a: { data: { publishDate: Date | string } },
      b: { data: { publishDate: Date | string } }
    ) => {
      // Handle publishDate as either Date object or string
      const dateA =
        a.data.publishDate instanceof Date
          ? a.data.publishDate
          : new Date(a.data.publishDate);
      const dateB =
        b.data.publishDate instanceof Date
          ? b.data.publishDate
          : new Date(b.data.publishDate);
      return dateB.getTime() - dateA.getTime();
    }
  )
  .slice(0, postsToShow);
---

<section class:list={["relative", bgColor, paddingClass]}>
  <div class="site-container px-4">
    {
      (content?.title || content?.description) && (
        <div class="max-w-2xl mb-12">
          {content?.eyebrow && (
            <Eyebrow text={content.eyebrow} background={background} />
          )}

          {content?.title && (
            <h2 class:list={`fade-in-up ${textColor} text-3xl font-bold`}>
              {content.title}
            </h2>
          )}

          {content?.description && (
            <p class:list={`fade-in-up delay-1 mt-4 ${textColor} opacity-90`}>
              {content.description}
            </p>
          )}

          {content?.button && (
            <div class="fade-in-up delay-2 mt-8">
              <Button
                href={content.button.link}
                variant={content.button.variant ?? "primary"}
              >
                {content.button.text}
              </Button>
            </div>
          )}
        </div>
      )
    }

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-12 sm:gap-8">
      {
        filteredPosts.map(
          (
            post: {
              data: {
                title: string;
                excerpt?: string;
                featuredImage?: string;
                imageAlt?: string;
                publishDate: Date | string;
                categories?: string[];
              };
              body: string;
              slug: string;
            },
            index: number
          ) => (
            <BlogPost
              title={post.data.title}
              excerpt={post.data.excerpt ?? undefined}
              featuredImage={post.data.featuredImage}
              imageAlt={post.data.imageAlt || post.data.title}
              publishDate={
                post.data.publishDate instanceof Date
                  ? post.data.publishDate
                  : new Date(post.data.publishDate)
              }
              categories={post.data.categories || []}
              content={post.body}
              slug={post.slug.replace(/^(en|es)\//, "")}
              index={index}
              lang={lang}
            />
          )
        )
      }
    </div>

    {
      filteredPosts.length === 0 && (
        <p class="text-center text-gray-500 py-8">No posts found.</p>
      )
    }
  </div>
</section>
