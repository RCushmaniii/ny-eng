---
import { getCollection } from "astro:content";
import BlogPost from "@components/blog/BlogPost.astro";
import Button from "@components/ui/Button.astro";
import Eyebrow from "@components/ui/Eyebrow.astro";
import {
    getPaddingClass,
    getBackgroundColor,
    getTextColor,
} from "@utils/styleUtils";
import type { PaddingSize, ThemeColor } from "@utils/styleUtils";

export interface Props {
    content?: {
        eyebrow?: string;
        title?: string;
        description?: string;
        button?: {
            text: string;
            link: string;
            variant?: "primary" | "secondary" | "ghostLight" | "ghostDark";
        };
    };
    background?: ThemeColor;
    padding?: PaddingSize;
    paddingTop?: PaddingSize;
    paddingBottom?: PaddingSize;
    postsToShow?: number;
    category?: string;
}

const {
    content,
    background = "base",
    padding,
    paddingTop,
    paddingBottom,
    postsToShow = 3,
    category,
} = Astro.props;

const bgColor = getBackgroundColor(background);
const textColor = getTextColor(background);
const paddingClass = getPaddingClass({ padding, paddingTop, paddingBottom });

const allPosts = await getCollection("blog", ({ data }) => {
    return import.meta.env.DEV || data.publish !== false;
});

// Language filtering logic
const isSpanish = Astro.url.pathname.startsWith('/es');
const filteredPosts = allPosts
    .filter((post) => {
        // Only show .es.md files on /es pages, only show English posts elsewhere
        const isEs = post.id.endsWith('.es.md');
        return isSpanish ? isEs : !isEs;
    })
    .filter((post) => !category || post.data.categories?.includes(category))
    .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime())
    .slice(0, postsToShow);
---

<section class:list={["relative", bgColor, paddingClass]}>
    <div class="site-container px-4">
        {
            (content?.title || content?.description) && (
                <div class="max-w-2xl mb-12">
                    {content?.eyebrow && (
                        <Eyebrow
                            text={content.eyebrow}
                            background={background}
                        />
                    )}

                    {content?.title && (
                        <h2
                            class={`fade-in-up ${textColor} text-3xl font-bold`}
                        >
                            {content.title}
                        </h2>
                    )}

                    {content?.description && (
                        <p
                            class={`fade-in-up delay-1 mt-4 ${textColor} opacity-90`}
                        >
                            {content.description}
                        </p>
                    )}

                    {content?.button && (
                        <div
                            class="fade-in-up delay-2 mt-8"
                        >
                            <Button
                                href={content.button.link}
                                variant={content.button.variant ?? "primary"}
                            >
                                {content.button.text}
                            </Button>
                        </div>
                    )}
                </div>
            )
        }

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
            {
                filteredPosts.map((post, index) => (
                    <BlogPost
                        title={post.data.title}
                        excerpt={post.data.excerpt}
                        featuredImage={post.data.featuredImage}
                        imageAlt={post.data.imageAlt || post.data.title}
                        publishDate={post.data.publishDate}
                        categories={post.data.categories || []}
                        content={post.body}
                        slug={post.slug}
                        index={index}
                    />
                ))
            }
        </div>

        {
            filteredPosts.length === 0 && (
                <p class="text-center text-gray-500 py-8">No posts found.</p>
            )
        }
    </div>
</section>
