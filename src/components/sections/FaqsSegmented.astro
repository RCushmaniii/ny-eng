---
import type { FaqSection } from "@data/faqs";

interface Props {
  sections: FaqSection[];
  showCta?: boolean;
  ctaHeading?: string;
  ctaButtonText?: string;
  ctaButtonLink?: string;
}

const {
  sections,
  showCta = true,
  ctaHeading = "Ready to turn fluency into influence?",
  ctaButtonText = "Book Your Free Discovery Call",
  ctaButtonLink = "/en/book/",
} = Astro.props;
---

<div class="faqs-segmented">
  {
    sections.map((section, index) => (
      <section class={`faq-section ${index % 2 === 1 ? "bg-alt" : "bg-base"}`}>
        <div class="container">
          <div class="section-header">
            <h2 class="section-title">{section.title}</h2>
            {section.description && (
              <p class="section-description">{section.description}</p>
            )}
          </div>

          <div class="faqs-list">
            {section.faqs.map((faq) => (
              <details class="faq-item">
                <summary class="faq-question">
                  {faq.question}
                  <span class="faq-icon" aria-hidden="true">
                    +
                  </span>
                </summary>
                <div class="faq-answer">
                  <p>{faq.answer}</p>
                </div>
              </details>
            ))}
          </div>

          {/* Show CTA after first section (Pain Points) */}
          {index === 0 && showCta && (
            <div class="cta-section">
              <h3 class="cta-heading">{ctaHeading}</h3>
              <a href={ctaButtonLink} class="cta-button">
                {ctaButtonText}
              </a>
            </div>
          )}
        </div>
      </section>
    ))
  }
</div>

<style>
  .faqs-segmented {
    width: 100%;
  }

  .faq-section {
    padding: 4rem 0;
  }

  .faq-section.bg-base {
    background: #ffffff;
  }

  .faq-section.bg-alt {
    background: #f8fafc;
  }

  .container {
    max-width: 900px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .section-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .section-title {
    font-size: 2.25rem;
    font-weight: 700;
    color: #0f172a;
    margin-bottom: 1rem;
  }

  .section-description {
    font-size: 1.125rem;
    color: #64748b;
    max-width: 700px;
    margin: 0 auto;
  }

  .faqs-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .faq-item {
    background: white;
    border: 1px solid #e2e8f0;
    border-radius: 12px;
    overflow: hidden;
    transition: all 0.2s ease;
  }

  .faq-item:hover {
    border-color: #3b82f6;
    box-shadow: 0 4px 12px rgba(59, 130, 246, 0.1);
  }

  .faq-item[open] {
    border-color: #3b82f6;
  }

  .faq-question {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1.5rem;
    font-size: 1.125rem;
    font-weight: 600;
    color: #0f172a;
    cursor: pointer;
    user-select: none;
    list-style: none;
  }

  .faq-question::-webkit-details-marker {
    display: none;
  }

  .faq-icon {
    font-size: 1.5rem;
    font-weight: 300;
    color: #3b82f6;
    transition: transform 0.2s ease;
    flex-shrink: 0;
    margin-left: 1rem;
  }

  .faq-item[open] .faq-icon {
    transform: rotate(45deg);
  }

  .faq-answer {
    padding: 0 1.5rem 1.5rem 1.5rem;
    color: #475569;
    font-size: 1rem;
    line-height: 1.7;
  }

  .faq-answer p {
    margin: 0;
  }

  /* CTA Section */
  .cta-section {
    margin-top: 3rem;
    padding: 3rem 2rem;
    background: linear-gradient(135deg, #1e40af 0%, #3b82f6 100%);
    border-radius: 16px;
    text-align: center;
  }

  .cta-heading {
    font-size: 1.75rem;
    font-weight: 700;
    color: white;
    margin-bottom: 1.5rem;
  }

  .cta-button {
    display: inline-block;
    padding: 1rem 2rem;
    background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%);
    color: white;
    font-size: 1.125rem;
    font-weight: 600;
    border-radius: 8px;
    text-decoration: none;
    transition: all 0.2s ease;
    box-shadow: 0 4px 12px rgba(245, 158, 11, 0.3);
  }

  .cta-button:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 16px rgba(245, 158, 11, 0.4);
  }

  @media (max-width: 768px) {
    .faq-section {
      padding: 3rem 0;
    }

    .section-title {
      font-size: 1.75rem;
    }

    .section-description {
      font-size: 1rem;
    }

    .faq-question {
      font-size: 1rem;
      padding: 1.25rem;
    }

    .faq-answer {
      padding: 0 1.25rem 1.25rem 1.25rem;
      font-size: 0.9375rem;
    }

    .cta-heading {
      font-size: 1.5rem;
    }

    .cta-button {
      font-size: 1rem;
      padding: 0.875rem 1.75rem;
    }
  }
</style>
