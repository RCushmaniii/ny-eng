---
import Button from '@components/ui/Button.astro';
import { Image } from 'astro:assets';

type HeroButton = {
  text: string;
  link: string;
  variant?: 'primary' | 'secondary' | 'ghostLight' | 'ghostDark' | 'whatsapp';
  target?: string;
};


interface HeroContent {
  title: string;
  description: string;
  buttons?: {
    text: string;
    link: string;
    variant?: 'primary' | 'secondary' | 'ghostLight' | 'ghostDark' | 'whatsapp';
    target?: string;
  }[];
  /*  NEW  */
  backgroundImage: any;         // desktop (imported via astro:assets)
  backgroundImageMobile?: any;  // mobile portrait crop (optional)
  overlayOpacity?: number;
}

const { content } = Astro.props;
const opacity = content.overlayOpacity ?? 1;
---

<section class="header-offset relative">
  {content.backgroundImage && (
    <picture class="absolute inset-0 w-full h-full overflow-hidden">
      {content.backgroundImageMobile && (
        /*  <source> fires on screens ≤768 px */
        <>
          <source
            srcset={content.backgroundImageMobile.src}
            media="(max-width: 768px)"
            type="image/webp"
          />
          {/* Mobile fallback for browsers that don't support <picture>/<source> */}
          <Image
            src={content.backgroundImageMobile}
            alt="Background image"
            width={800}
            height={1000}
            sizes="100vw"
            quality={60}
            format="webp"
            decoding="async"
            loading="eager"
            fetchpriority="high"
            class="w-full h-full object-cover md:hidden"
            style="display: none;"
            style:media="(max-width: 768px)"
          />
        </>
      )}

      {/* Desktop / fallback */}
      <Image
        src={content.backgroundImage}
        alt="Background image"
        width={1920}
        height={1080}
        sizes="100vw"
        quality={60}
        format="webp"
        decoding="async"
        loading="eager"
        fetchpriority="high"
        class="w-full h-full object-cover hidden md:block"
      />
    </picture>
  )}

  <!-- translucent colour wash -->
  <div
    class="hero-background absolute inset-0 w-full h-full"
    style={`opacity:${opacity};`}
  />

  <!-- copy & CTA -->
  <div class="site-container relative z-10 mx-auto px-4 py-large flex flex-col md:items-center md:justify-center md:text-center">
    <h1 class="text-white text-balance" data-aos="fade-up">{content.title}</h1>
    <p class="text-white mt-2 text-balance" data-aos="fade-up" data-aos-delay="100">
      {content.description}
    </p>

    {content.buttons?.length && (
      <div class="flex flex-wrap gap-4 mt-8" data-aos="fade-up">
        {content.buttons.map((b: HeroButton) => (
          <Button href={b.link} target={b.target ?? '_self'} variant={b.variant ?? 'primary'}>
            {b.text}
          </Button>
        ))}
      </div>
    )}
  </div>
</section>
