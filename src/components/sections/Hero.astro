---
// Unchanged front-matter
import Button from '@components/ui/Button.astro';

type HeroButton = {
  text: string;
  link: string;
  variant?: 'primary' | 'secondary' | 'ghostLight' | 'ghostDark' | 'whatsapp';
  target?: string;
};

interface HeroContent {
  title: string;
  description: string;
  buttons?: {
    text: string;
    link: string;
    variant?: 'primary' | 'secondary' | 'ghostLight' | 'ghostDark' | 'whatsapp';
    target?: string;
  }[];
  backgroundImage: any;
  backgroundImageMobile?: any;
  overlayOpacity?: number;
}

const { content } = Astro.props;
const opacity = content.overlayOpacity ?? 1;
---

<section class="header-offset relative">
  {content.backgroundImage && (
    <picture class="absolute inset-0 w-full h-full overflow-hidden">
      {content.backgroundImageMobile && (
        <>
          <source
            srcset={content.backgroundImageMobile.src}
            media="(max-width: 768px)"
            type="image/webp"
          />
        </>
      )}
      <source
        srcset={content.backgroundImage.src}
        media="(min-width: 769px)"
        type="image/webp"
      />
      <img
        src={content.backgroundImageMobile?.src ?? content.backgroundImage.src}
        alt="Background image"
        width={content.backgroundImageMobile ? 800 : 1920}
        height={content.backgroundImageMobile ? 1000 : 1080}
        sizes="(max-width: 768px) 100vw, 100vw"
        loading="eager"
        decoding="async"
        fetchpriority="high"
        class="w-full h-full object-cover"
      />
    </picture>
  )}

  <div
    class="hero-background absolute inset-0 w-full h-full"
    style={`opacity:${opacity};`}
  />

  <div class="site-container relative z-10 mx-auto px-4 py-large flex flex-col md:items-center md:justify-center md:text-center">
    <h1 class="text-white text-balance" data-aos="fade-up">{content.title}</h1>
    <p class="text-white mt-2 text-balance" data-aos="fade-up" data-aos-delay="100">
      {content.description}
    </p>

    {content.buttons?.length && (
      <div class="flex flex-wrap gap-4 mt-8" data-aos="fade-up">
        {content.buttons.map((b: HeroButton) => (
          <Button href={b.link} target={b.target ?? '_self'} variant={b.variant ?? 'primary'}>
            {b.text}
          </Button>
        ))}
      </div>
    )}
  </div>
</section>
