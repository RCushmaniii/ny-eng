---
import type { Testimonial } from "@data/testimonials/en";
import TestimonialCard from "@components/ui/TestimonialCard.astro";
import ExpandableTestimonialCard from "@components/ui/ExpandableTestimonialCard.astro";
import { industryLabels as industryLabelsEn, testimonialsByIndustry as testimonialsByIndustryEn } from "@data/testimonials/en";
import { industryLabels as industryLabelsEs, testimonialsByIndustry as testimonialsByIndustryEs } from "@data/testimonials/es";

interface Props {
  testimonials: Testimonial[];
  title?: string;
  description?: string;
  showFilters?: boolean;
  selectedIndustry?: string;
  lang?: 'en' | 'es';
}

const { 
  testimonials: initialTestimonials, 
  title = "Client Success Stories", 
  description, 
  showFilters = true,
  selectedIndustry = 'all',
  lang = 'en'
} = Astro.props;

// Get labels and testimonials by industry based on language
const labels = lang === 'en' ? industryLabelsEn : industryLabelsEs;
const testimonialsByIndustry = lang === 'en' ? testimonialsByIndustryEn : testimonialsByIndustryEs;

// Get testimonials for selected industry
const testimonials = selectedIndustry === 'all' 
  ? initialTestimonials 
  : initialTestimonials.filter(t => t.industries.includes(selectedIndustry));

// Get base URL for industry links
const baseUrl = lang === 'en' ? '/en/testimonials/' : '/es/testimonios/';

// Get available industries (those that have testimonials)
const availableIndustries = Object.entries(testimonialsByIndustry)
  .filter(([_, testimonials]) => testimonials.length > 0)
  .map(([industry]) => industry);
---

<section class="testimonials-grid py-16 bg-gray-50">
  <div class="container mx-auto px-4">
    <div class="text-center mb-12 pt-16">
      <h1 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">
        {title}
      </h1>
      {description && (
        <p class="text-lg text-gray-600 max-w-3xl mx-auto">
          {description}
        </p>
      )}
    </div>

    {showFilters && (
      <div class="mb-10 flex flex-col sm:flex-row justify-center items-center gap-4">
        <label for="industry-filter" class="font-medium text-gray-900">
          {lang === 'en' ? 'Filter by industry:' : 'Filtrar por industria:'}
        </label>
        <div class="relative">
          <select
            id="industry-filter"
            class="bg-white border border-gray-300 rounded-md px-4 py-2 focus:outline-none focus:ring-2 focus:ring-primary-500 font-sans"
            style="font-family: NotoSansKR, ui-sans-serif, system-ui, sans-serif;"
          >
            {Object.entries(labels)
              .filter(([key]) => availableIndustries.includes(key))
              .map(([key, label]) => (
                <option value={key} selected={selectedIndustry === key}>{label}</option>
              ))}
          </select>
          <script define:vars={{ baseUrl }}>
            const industryFilter = document.getElementById('industry-filter');
            if (industryFilter instanceof HTMLSelectElement) {
              industryFilter.addEventListener('change', function() {
                const selectedIndustry = this.value;
                if (selectedIndustry === 'all') {
                  window.location.href = baseUrl;
                } else {
                  window.location.href = `${baseUrl}${selectedIndustry}/`;
                }
              });
            }
          </script>
        </div>
      </div>
    )}
    
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 max-w-7xl mx-auto">
      {testimonials.map((testimonial) => (
        testimonial.shortContent ? (
          <ExpandableTestimonialCard
            testimonial={testimonial}
            showHeadline={true}
          />
        ) : (
          <TestimonialCard
            testimonial={testimonial}
            showHeadline={true}
          />
        )
      ))}
    </div>

    {testimonials.length === 0 && (
      <div class="text-center py-16">
        <p class="text-lg text-gray-600 mb-4">
          {lang === 'en' 
            ? 'No testimonials found for this industry.' 
            : 'No se encontraron testimonios para esta industria.'}
        </p>
        <a 
          href={baseUrl.endsWith('/') ? baseUrl : `${baseUrl}/`}
          class="inline-block px-6 py-3 bg-primary-600 text-white font-medium rounded-lg hover:bg-primary-700 transition-colors"
        >
          {lang === 'en' ? 'View All Testimonials' : 'Ver Todos los Testimonios'}
        </a>
      </div>
    )}
  </div>
</section>
