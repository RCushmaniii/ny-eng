---
import Button from "../ui/Button.astro";

const testimonials = [
  {
    content:
      "This platform has completely transformed how we manage our projects. The intuitive interface and powerful features have increased our team's productivity by over 40%.",
    author: "Sarah Johnson",
    position: "Product Manager",
    company: "TechCorp",
    avatar: "https://randomuser.me/api/portraits/women/32.jpg",
  },
  {
    content:
      "I've tried many SaaS solutions, but this one stands out for its ease of use and comprehensive feature set. The customer support is also exceptional.",
    author: "Michael Chen",
    position: "CTO",
    company: "Innovate Inc.",
    avatar: "https://randomuser.me/api/portraits/men/46.jpg",
  },
  {
    content:
      "The analytics capabilities alone are worth the investment. We've gained valuable insights that have helped us optimize our operations and reduce costs.",
    author: "Emily Rodriguez",
    position: "Operations Director",
    company: "Global Solutions",
    avatar: "https://randomuser.me/api/portraits/women/65.jpg",
  },
];
---

<section id="testimonials" class="py-16 bg-[--color-background-light]">
  <div class="site-container text-center px-4 sm:px-6 md:px-8">
    <span
      class="inline-block px-4 py-1 rounded-full bg-secondary-100 text-secondary-600 dark:bg-secondary-900 dark:text-secondary-300 font-medium text-sm mb-4"
    >
      Customer Stories
    </span>
    <h2 class="text-3xl md:text-4xl font-bold text-[--color-headline] mb-4">
      What Our Clients Say
    </h2>
    <p class="text-[--color-body-base] mb-12 max-w-2xl mx-auto">
      Don't just take our word for it. Here's what our customers have to say
      about their experience with our platform.
    </p>

    <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
      {
        testimonials.map((testimonial, index) => (
          <div
            class="bg-white rounded-xl p-6 shadow-md hover:shadow-lg transition-shadow border border-secondary-200 dark:bg-secondary-900 dark:border-secondary-800 text-left"
            style={`animation-delay: ${index * 150}ms`}
          >
            <div class="mb-4 text-yellow-500 text-xl">★★★★★</div>

            <blockquote class="mb-6 text-[--color-body-base] italic">
              "{testimonial.content}"
            </blockquote>

            <div class="flex items-center">
              <img
                src={testimonial.avatar}
                alt={testimonial.author}
                class="w-12 h-12 rounded-full mr-4 object-cover"
                loading="lazy"
              />
              <div>
                <p class="font-semibold text-[--color-headline]">
                  {testimonial.author}
                </p>
                <p class="text-sm text-[--color-body-light]">
                  {testimonial.position}, {testimonial.company}
                </p>
              </div>
            </div>
          </div>
        ))
      }
    </div>

    <!-- CTA block -->
    <div
      class="mt-16 bg-gradient-to-r from-primary-500 to-secondary-500 rounded-2xl p-8 md:p-12 relative overflow-hidden"
    >
      <div
        class="absolute inset-0 bg-gradient-to-r from-primary-600/30 to-secondary-600/30 backdrop-blur-sm"
      >
      </div>
      <div
        class="relative z-10 text-center md:text-left md:flex items-center justify-between"
      >
        <div class="mb-6 md:mb-0 md:mr-8">
          <h3
            class="text-2xl md:text-3xl font-bold text-[--color-headline-dark] mb-4"
          >
            Ready to transform your business?
          </h3>
          <p class="text-[--color-body-dark] max-w-2xl">
            Join thousands of satisfied customers who have improved their
            workflow with our platform.
          </p>
        </div>
        <Button href="#signup" variant="primary"> Get Started Today </Button>
      </div>
    </div>
  </div>
</section>
