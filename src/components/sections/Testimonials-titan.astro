---
import { Image } from "astro:assets";
import type { Testimonial } from "@data/testimonials";
import Button from "../ui/Button.astro";
import Eyebrow from "../ui/Eyebrow.astro";
import {
  getBackgroundColor,
  getTextColor,
  getPaddingClass,
} from "@utils/styleUtils";
import type { ThemeColor, PaddingSize } from "@utils/styleUtils";

export interface Props {
  content: {
    eyebrow?: string;
    title?: string;
    description?: string;
    testimonials: Testimonial[];
    cta?: {
      heading: string;
      description?: string;
      text: string;
      link: string;
      variant?: "primary" | "secondary" | "ghostLight" | "ghostDark";
    };
  };
  background?: ThemeColor;
  padding?: PaddingSize;
  paddingTop?: PaddingSize;
  paddingBottom?: PaddingSize;
}

const {
  content: { eyebrow, title, description, cta, testimonials },
  background = "light",
  padding,
  paddingTop,
  paddingBottom,
} = Astro.props;

const bgColor = getBackgroundColor(background);
const textColor = getTextColor(background);
const paddingClass = getPaddingClass({ padding, paddingTop, paddingBottom });
---

<section id="testimonials" class:list={[bgColor, paddingClass]} style="padding-bottom:0 !important;">
  <div class="site-container text-center px-4 sm:px-6 md:px-8">
    {eyebrow && <Eyebrow text={eyebrow} background={background} />}

    {
      title && (
        <h2 class={`fade-in-up ${textColor} text-h2 mb-4`}>
          {title}
        </h2>
      )
    }

    {
      description && (
        <p
          class={`fade-in-up delay-1 ${textColor} text-base opacity-90 mb-12 max-w-2xl mx-auto`}
        >
          {description}
        </p>
      )
    }

    <div class="grid gap-8 sm:grid-cols-1 md:grid-cols-2">
      {
        testimonials.map((testimonial, index) => (
          <div
            class={`fade-in-up${index > 0 ? ` delay-${(index % 3) + 1}` : ''} bg-white rounded-xl p-6 shadow-md hover:shadow-lg transition-shadow border border-secondary-200 dark:bg-secondary-900 dark:border-secondary-800 text-left`}
          >
            <div class="mb-4 text-yellow-500 text-xl">★★★★★</div>

            <blockquote class="mb-6 italic text-[--color-body-base]">
              "{testimonial.content}"
            </blockquote>

            <div class="flex items-center">
              <Image
                src={testimonial.avatar}
                alt={testimonial.author}
                class="w-12 h-12 rounded-full mr-4 object-cover"
                width={48}
                height={48}
                loading="lazy"
              />
              <div>
                <p class="font-semibold text-[--color-headline]">
                  {testimonial.author}
                </p>
                <p class="text-sm text-[--color-body-light]">
                  {testimonial.position}, {testimonial.company}
                </p>
              </div>
            </div>
          </div>
        ))
      }
    </div>

    {
      cta && (
        <div class="mt-16 bg-gradient-to-r from-primary-500 to-secondary-500 rounded-2xl p-8 md:p-12 relative overflow-hidden">
          <div class="absolute inset-0 bg-gradient-to-r from-primary-600/30 to-secondary-600/30 backdrop-blur-sm" />
          <div class="relative z-10 text-center md:text-left md:flex items-center justify-between">
            <div class="mb-6 md:mb-0 md:mr-8">
              <h3 class="text-2xl md:text-3xl font-bold text-[--color-headline-dark] mb-4">
                {cta.heading}
              </h3>
              {cta.description && (
                <p class="text-[--color-body-dark] max-w-2xl">
                  {cta.description}
                </p>
              )}
            </div>
            <Button href={cta.link} variant={cta.variant || "primary"}>
              {cta.text}
            </Button>
          </div>
        </div>
      )
    }
  </div>
</section>
