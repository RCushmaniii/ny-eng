---
import { Image } from "astro:assets";
// Define a relaxed testimonial shape compatible with both EN/ES data
// and with avatars coming from either Astro assets or public paths
type TestimonialLite = Readonly<{
  content: string;
  author: string;
  position?: string;
  company?: string;
  avatar: any; // ImageMetadata | string
  status?: string; // allow optional status like "draft"
}>;
import Button from "../ui/Button.astro";
import Eyebrow from "../ui/Eyebrow.astro";
import {
  getBackgroundColor,
  getTextColor,
  getPaddingClass,
} from "@utils/styleUtils";
import type { ThemeColor, PaddingSize } from "@utils/styleUtils";

export interface Props {
  content: Readonly<{
    eyebrow?: string;
    title?: string;
    description?: string;
    testimonials: TestimonialLite[];
    cta?: Readonly<{
      heading: string;
      description?: string;
      text: string;
      link: string;
      variant?: "primary" | "secondary" | "ghostLight" | "ghostDark";
      target?: string;
      rel?: string;
    }>;
  }>;
  background?: ThemeColor;
  padding?: PaddingSize;
  paddingTop?: PaddingSize;
  paddingBottom?: PaddingSize;
}

const {
  content: { eyebrow, title, description, cta, testimonials },
  background = "light",
  padding,
  paddingTop,
  paddingBottom,
} = Astro.props;

const bgColor = getBackgroundColor(background);
const textColor = getTextColor(background);
const paddingClass = getPaddingClass({ padding, paddingTop, paddingBottom });
---

<section
  id="testimonials"
  class:list={[bgColor, paddingClass]}
  style="padding-bottom:0 !important;"
>
  <div class="site-container text-center px-4 sm:px-6 md:px-8">
    {eyebrow && <Eyebrow text={eyebrow} background={background} />}

    {title && <h2 class:list={`fade-in-up ${textColor} text-h2 mb-4`}>{title}</h2>}

    {
      description && (
        <p
          class:list={`fade-in-up delay-1 ${textColor} text-base opacity-90 mb-12 max-w-2xl mx-auto`}
        >
          {description}
        </p>
      )
    }

    <div class="grid gap-8 sm:grid-cols-1 md:grid-cols-2">
      {
        testimonials
          .filter(
            (testimonial) =>
              !("status" in testimonial) || testimonial.status !== "draft",
          )
          .map((testimonial, index) => (
            <div
              class:list={`fade-in-up${index > 0 ? ` delay-${(index % 3) + 1}` : ""} bg-white rounded-xl p-6 shadow-md hover:shadow-lg transition-shadow border border-secondary-200 dark:bg-secondary-900 dark:border-secondary-800 text-left`}
            >
              <div class="mb-4 text-yellow-500 text-xl">★★★★★</div>

              <blockquote class="mb-6 italic text-[--color-body-base]">
                "<span set:html={testimonial.content} />"
              </blockquote>

              <div class="flex items-center">
                {typeof testimonial.avatar === "object" ? (
                  <Image
                    src={testimonial.avatar}
                    alt={testimonial.author}
                    class="w-12 h-12 rounded-full mr-4 object-cover"
                    width={48}
                    height={48}
                    loading="lazy"
                  />
                ) : (
                  <img
                    src={testimonial.avatar as any}
                    alt={testimonial.author}
                    class="w-12 h-12 rounded-full mr-4 object-cover"
                    width="48"
                    height="48"
                    loading="lazy"
                    decoding="async"
                  />
                )}
                <div>
                  <p class="font-semibold text-[--color-headline]">
                    {testimonial.author}
                  </p>
                  <p class="text-sm text-[--color-body-light]">
                    {testimonial.position}, {testimonial.company}
                  </p>
                </div>
              </div>
            </div>
          ))
      }
    </div>

    {
      cta && (
        <div class="mt-16 bg-gradient-to-r from-primary-500 to-secondary-500 rounded-2xl p-8 md:p-12 relative overflow-hidden">
          <div class="absolute inset-0 bg-gradient-to-r from-primary-600/30 to-secondary-600/30 backdrop-blur-sm" />
          <div class="relative z-10 flex flex-col xl:flex-row xl:items-center xl:justify-between gap-4">
            <div class="text-center md:text-left">
              <h3
                class="text-2xl md:text-3xl font-bold text-[--color-headline-dark] mb-4"
                style="font-family: 'Noto Sans KR', sans-serif;"
              >
                {cta.heading}
              </h3>
              {cta.description && (
                <p
                  class="text-[--color-body-dark] max-w-2xl"
                  style="font-family: 'Noto Sans KR', sans-serif;"
                >
                  {cta.description}
                </p>
              )}
            </div>
            <div class="mt-6 xl:mt-0 md:text-left">
              {/* Responsive button with automatic language detection */}
              <Button
                href={cta.link}
                variant={cta.variant || "primary"}
                target={cta.target}
                rel={
                  cta.target === "_blank" ? "noopener noreferrer" : undefined
                }
                class="w-full md:w-auto inline-block text-sm sm:text-base leading-tight whitespace-normal px-3 sm:px-4 py-2"
              >
                <span class="text-xs sm:text-sm md:text-base leading-snug truncate block max-w-full">
                  {cta.text}
                </span>
              </Button>
            </div>
          </div>
        </div>
      )
    }
  </div>
</section>
