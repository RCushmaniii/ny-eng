---
/**
 * LeadMagnetForm — The Corporate English Training Audit PDF download form.
 *
 * Captures name, work email, and company. Submits to /api/corporate-guide/download
 * which inserts into Neon and sends a branded delivery email with the PDF link.
 *
 * Renders a success state on submit (no redirect) so the page flow is preserved.
 */

export interface Props {
  lang?: "en" | "es";
  sourcePage?: string;
}

const { lang = "en", sourcePage = "" } = Astro.props;

const copy =
  lang === "es"
    ? {
        anchorId: "descargar-guia",
        eyebrow: "Guía Gratuita para Responsables de RH",
        headline: "Descargue La Guía de Evaluación para Capacitación de Inglés Corporativo",
        subhead:
          "7 preguntas que debe hacer antes de invertir en cualquier programa de inglés para su equipo. Una guía práctica para líderes de Recursos Humanos, responsables de Capacitación y Desarrollo, y ejecutivos.",
        bullets: [
          "Las señales de alerta que revelan un programa genérico",
          "Cómo definir y medir el éxito antes de firmar un contrato",
          "Qué debe entregar un proveedor serio desde el día uno",
        ],
        formTitle: "Reciba la guía por correo",
        formSubtitle:
          "El PDF y una versión en video corta. Se los enviaré directamente a su correo. Sin spam, sin secuencias de ventas agresivas.",
        labelName: "Nombre",
        labelEmail: "Correo de trabajo",
        labelCompany: "Empresa",
        submit: "Enviar la guía a mi correo",
        submitting: "Enviando...",
        successTitle: "Listo — revise su correo",
        successBody:
          "Le acabo de enviar la guía. Debería llegar en menos de un minuto. Si no la ve, revise su carpeta de spam o promociones.",
        errorValidation: "Por favor complete todos los campos con información válida.",
        errorServer: "Hubo un problema al procesar su solicitud. Intente de nuevo.",
        errorNetwork: "Error de red. Verifique su conexión e intente de nuevo.",
      }
    : {
        anchorId: "download-the-guide",
        eyebrow: "Free Guide for HR Managers",
        headline: "Download The Corporate English Training Audit",
        subhead:
          "7 questions to ask before you invest in any English training program for your team. A practical guide for HR leaders, Learning & Development managers, and executives.",
        bullets: [
          "The warning signs that reveal a generic program",
          "How to define and measure success before signing a contract",
          "What a serious provider should deliver from day one",
        ],
        formTitle: "Send the guide to my inbox",
        formSubtitle:
          "Both the PDF and a short video version. I will email them to you directly. No spam, no aggressive sales sequences.",
        labelName: "Name",
        labelEmail: "Work email",
        labelCompany: "Company",
        submit: "Send the guide to my inbox",
        submitting: "Sending...",
        successTitle: "Done — check your inbox",
        successBody:
          "I just sent you the guide. It should arrive in under a minute. If you don't see it, check your spam or promotions folder.",
        errorValidation: "Please fill in all fields with valid information.",
        errorServer: "Something went wrong processing your request. Please try again.",
        errorNetwork: "Network error. Check your connection and try again.",
      };

const formId = `lead-magnet-form-${lang}`;
const statusId = `lead-magnet-status-${lang}`;
const successId = `lead-magnet-success-${lang}`;
---

<section
  id={copy.anchorId}
  class="bg-gradient-to-br from-blue-50 via-white to-blue-50 py-16 px-4 sm:px-8 border-t border-blue-100"
>
  <div class="site-container--small mx-auto max-w-5xl">
    <div class="grid gap-10 md:grid-cols-2 md:items-center">
      <!-- Left: Pitch -->
      <div>
        <p class="text-sm font-semibold text-blue-700 uppercase tracking-wide mb-3">
          {copy.eyebrow}
        </p>
        <h2 class="text-3xl font-bold mb-4 text-gray-900 leading-tight">
          {copy.headline}
        </h2>
        <p class="text-base text-gray-700 mb-6 leading-relaxed">
          {copy.subhead}
        </p>
        <ul class="space-y-3 mb-6">
          {
            copy.bullets.map((bullet) => (
              <li class="flex gap-3 text-sm text-gray-700">
                <span class="text-blue-600 font-bold shrink-0 mt-0.5">→</span>
                <span>{bullet}</span>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Right: Form -->
      <div
        id={`${formId}-wrapper`}
        class="bg-white rounded-2xl p-8 shadow-md border border-gray-100"
      >
        <div id={`${formId}-container`}>
          <h3 class="text-xl font-bold mb-1 text-gray-900">
            {copy.formTitle}
          </h3>
          <p class="text-sm text-gray-600 mb-6">
            {copy.formSubtitle}
          </p>

          <form id={formId} novalidate class="space-y-4">
            <input type="hidden" name="language" value={lang} />
            <input type="hidden" name="sourcePage" value={sourcePage} />
            <input
              type="text"
              name="_gotcha"
              style="display:none"
              tabindex="-1"
              autocomplete="off"
              aria-hidden="true"
            />

            <div>
              <label
                for={`${formId}-name`}
                class="block text-sm font-medium mb-1 text-gray-700"
              >
                {copy.labelName} <span class="text-red-500">*</span>
              </label>
              <input
                type="text"
                id={`${formId}-name`}
                name="name"
                required
                minlength="2"
                autocomplete="name"
                class="w-full px-4 py-2.5 bg-gray-50 text-gray-900 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 focus:bg-white transition"
              />
            </div>

            <div>
              <label
                for={`${formId}-email`}
                class="block text-sm font-medium mb-1 text-gray-700"
              >
                {copy.labelEmail} <span class="text-red-500">*</span>
              </label>
              <input
                type="email"
                id={`${formId}-email`}
                name="email"
                required
                autocomplete="email"
                class="w-full px-4 py-2.5 bg-gray-50 text-gray-900 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 focus:bg-white transition"
              />
            </div>

            <div>
              <label
                for={`${formId}-company`}
                class="block text-sm font-medium mb-1 text-gray-700"
              >
                {copy.labelCompany} <span class="text-red-500">*</span>
              </label>
              <input
                type="text"
                id={`${formId}-company`}
                name="company"
                required
                minlength="2"
                autocomplete="organization"
                class="w-full px-4 py-2.5 bg-gray-50 text-gray-900 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 focus:bg-white transition"
              />
            </div>

            <button
              type="submit"
              class="w-full bg-blue-600 hover:bg-blue-700 text-white font-semibold py-3 px-6 rounded-lg transition shadow-sm hover:shadow-md disabled:opacity-50 disabled:cursor-not-allowed"
            >
              {copy.submit}
            </button>

            <div id={statusId} class="text-sm text-center" role="status"></div>
          </form>
        </div>

        <div
          id={successId}
          class="hidden text-center py-6"
          role="status"
          aria-live="polite"
        >
          <div class="mx-auto w-14 h-14 rounded-full bg-green-100 flex items-center justify-center mb-4">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="w-7 h-7 text-green-600"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="3"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <polyline points="20 6 9 17 4 12"></polyline>
            </svg>
          </div>
          <h3 class="text-xl font-bold mb-2 text-gray-900">
            {copy.successTitle}
          </h3>
          <p class="text-sm text-gray-600 leading-relaxed">
            {copy.successBody}
          </p>
        </div>
      </div>
    </div>
  </div>
</section>

<script
  is:inline
  define:vars={{
    formId,
    statusId,
    successId,
    containerId: `${formId}-container`,
    errorValidation: copy.errorValidation,
    errorServer: copy.errorServer,
    errorNetwork: copy.errorNetwork,
    submittingText: copy.submitting,
    submitText: copy.submit,
  }}
>
  const form = document.getElementById(formId);
  const statusDiv = document.getElementById(statusId);
  const successDiv = document.getElementById(successId);
  const container = document.getElementById(containerId);

  if (
    form instanceof HTMLFormElement &&
    statusDiv &&
    successDiv &&
    container
  ) {
    const emailRegex =
      /^[a-zA-Z0-9._%+-]+@[a-zA-Z0-9](?:[a-zA-Z0-9-]*[a-zA-Z0-9])?(?:\.[a-zA-Z0-9](?:[a-zA-Z0-9-]*[a-zA-Z0-9])?)*\.[a-zA-Z]{2,}$/;

    form.addEventListener("submit", async (e) => {
      e.preventDefault();

      const fd = new FormData(form);
      const submitButton = form.querySelector("button[type='submit']");

      const name = String(fd.get("name") || "").trim();
      const email = String(fd.get("email") || "").trim();
      const company = String(fd.get("company") || "").trim();

      statusDiv.textContent = "";
      statusDiv.className = "text-sm text-center";

      if (
        name.length < 2 ||
        !emailRegex.test(email) ||
        company.length < 2
      ) {
        statusDiv.textContent = errorValidation;
        statusDiv.classList.add("text-red-600");
        return;
      }

      if (submitButton instanceof HTMLButtonElement) {
        submitButton.disabled = true;
        submitButton.textContent = submittingText;
      }

      const referrer =
        typeof document !== "undefined" ? document.referrer : "";
      const params = new URLSearchParams(window.location.search);

      const payload = {
        name,
        email,
        company,
        language: fd.get("language"),
        sourcePage: fd.get("sourcePage") || window.location.pathname,
        _gotcha: fd.get("_gotcha") || "",
        referrer,
        utmSource: params.get("utm_source") || null,
        utmMedium: params.get("utm_medium") || null,
        utmCampaign: params.get("utm_campaign") || null,
        utmContent: params.get("utm_content") || null,
        utmTerm: params.get("utm_term") || null,
      };

      try {
        const response = await fetch("/api/corporate-guide/download", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify(payload),
        });

        if (response.ok) {
          container.classList.add("hidden");
          successDiv.classList.remove("hidden");
          if (typeof window !== "undefined" && window.va) {
            try {
              window.va("event", {
                name: "corporate-guide-download",
                data: { language: String(fd.get("language") || "en") },
              });
            } catch {}
          }
        } else {
          statusDiv.textContent = errorServer;
          statusDiv.classList.add("text-red-600");
          if (submitButton instanceof HTMLButtonElement) {
            submitButton.disabled = false;
            submitButton.textContent = submitText;
          }
        }
      } catch {
        statusDiv.textContent = errorNetwork;
        statusDiv.classList.add("text-red-600");
        if (submitButton instanceof HTMLButtonElement) {
          submitButton.disabled = false;
          submitButton.textContent = submitText;
        }
      }
    });
  }
</script>
