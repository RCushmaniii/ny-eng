---
import { Image } from "astro:assets";
import type { Testimonial } from "@data/testimonials/en";
import Button from "@components/ui/Button.astro";
import { cn } from "@utils/cn";

export interface Props {
  testimonial: Testimonial;
  showHeadline?: boolean;
  showReadMore?: boolean;
  showCtaLink?: boolean;
}

const { testimonial, showHeadline = false, showReadMore = true, showCtaLink = true } = Astro.props;

// Set avatar size class based on testimonial.avatarSize
const avatarSizeClass = {
  sm: "w-10 h-10",
  md: "w-12 h-12",
  lg: "w-16 h-16"
}[testimonial.avatarSize || "md"];

// Generate stars based on rating
const stars = "★".repeat(testimonial.stars || 5);
---

<div class="bg-white rounded-xl p-6 shadow-md hover:shadow-lg transition-shadow border border-secondary-200 dark:bg-secondary-900 dark:border-secondary-800 text-left">
  {showHeadline && testimonial.headline && (
    <h3 class="text-lg font-bold mb-3 text-[--color-headline]">{testimonial.headline}</h3>
  )}
  
  <div class="mb-4 text-yellow-500 text-xl">{stars}</div>

  <blockquote class="mb-6 italic text-[--color-body-base]">
    "{testimonial.content}"
  </blockquote>

  <div class="flex items-center">
    {typeof testimonial.avatar === 'string' ? (
      <img
        src={testimonial.avatar}
        alt={testimonial.author}
        class:list={`${avatarSizeClass} rounded-full mr-4 object-cover`}
        width={testimonial.avatarSize === "lg" ? 64 : 48}
        height={testimonial.avatarSize === "lg" ? 64 : 48}
        loading="lazy"
      />
    ) : (
      <Image
        src={testimonial.avatar}
        alt={testimonial.author}
        class:list={`${avatarSizeClass} rounded-full mr-4 object-cover`}
        width={testimonial.avatarSize === "lg" ? 64 : 48}
        height={testimonial.avatarSize === "lg" ? 64 : 48}
        loading="lazy"
      />
    )}
    <div>
      <p class="font-semibold text-[--color-headline]">
        {testimonial.author}
      </p>
      <p class="text-sm text-[--color-body-light]">
        {testimonial.position}, {testimonial.company}
      </p>
    </div>
  </div>
  
  {showReadMore && showCtaLink && testimonial.link && (
    <div class="mt-4 text-right">
      <a 
        href={testimonial.link} 
        class:list={cn("text-primary-600 hover:text-primary-800 font-medium inline-flex items-center")}
        {...(testimonial.link.startsWith('http') ? {
          target: "_blank",
          rel: "noopener noreferrer"
        } : {})}
      >
        {testimonial.linkText || (testimonial.link.includes('/es/') ? 'Leer más' : 'Read more')} <span class="ml-1">→</span>
      </a>
    </div>
  )}
</div>
