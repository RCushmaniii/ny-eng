---
interface Props {
  lang: "en" | "es";
}

const { lang } = Astro.props;

const embedSrc =
  import.meta.env.PUBLIC_NY_AI_CHATBOT_EMBED_SRC ??
  "https://ny-ai-chatbot.vercel.app/api/embed";

const botId = import.meta.env.PUBLIC_NY_AI_CHATBOT_ID ?? "";

const resolvedEmbedSrc = botId
  ? embedSrc.includes("?id=")
    ? embedSrc
    : `${embedSrc}${embedSrc.includes("?") ? "&" : "?"}id=${encodeURIComponent(botId)}`
  : embedSrc;

console.log("🔧 ChatEmbed debug - resolvedEmbedSrc:", resolvedEmbedSrc);
console.log("🔧 ChatEmbed debug - botId:", botId);
console.log("🔧 ChatEmbed debug - embedSrc:", embedSrc);

const copy = {
  en: {
    heading: "Get Instant Answers from My AI English Coach",
    subheading:
      "Curious about coaching, pricing, or how to close your Communication Gap? Ask anything — get a personalized response in seconds.",
    welcomeMessage: "👋 Hey... ask your questions here!",
    placeholder: "Type your message...",
  },
  es: {
    heading: "Respuestas Instantáneas de Mi Coach de Inglés con IA",
    subheading:
      "¿Tienes preguntas sobre coaching, precios o cómo cerrar tu brecha de comunicación? Pregunta lo que quieras — recibe una respuesta personalizada en segundos.",
    welcomeMessage: "👋 Hola... haz tus preguntas aquí.",
    placeholder: "Escribe tu mensaje...",
  },
} as const;

const t = copy[lang];
---

<section class="relative pt-28 pb-8 md:pt-32 md:pb-12 overflow-hidden">
  <div class="container mx-auto px-4 max-w-6xl">
    <div class="text-center max-w-4xl mx-auto">
      <h1 class="text-4xl md:text-5xl font-bold text-slate-900 mb-6">
        {t.heading}
      </h1>
      <p class="text-xl md:text-2xl text-slate-700 leading-relaxed">
        {t.subheading}
      </p>

      {
        !botId && (
          <div class="mt-8 rounded-lg border border-amber-300 bg-amber-50 p-6 text-amber-950 max-w-md mx-auto">
            <p class="font-semibold text-lg">Chatbot not configured.</p>
            <p class="mt-2 text-sm">
              Set{" "}
              <code class="bg-amber-100 px-2 py-1 rounded">
                PUBLIC_NY_AI_CHATBOT_ID
              </code>{" "}
              in your deploy environment.
            </p>
          </div>
        )
      }
    </div>
  </div>

  {/* Embedded chat interface for page */}
  <div class="container mx-auto px-4 max-w-4xl mt-12" id="chat-embed-container">
    <div
      class="bg-white rounded-lg shadow-lg border border-slate-200 overflow-hidden"
    >
      <div class="bg-slate-900 text-white p-4">
        <h3 class="font-semibold flex items-center gap-2">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
            <path
              fill-rule="evenodd"
              d="M18 10c0 3.866-3.582 7-8 7a8.841 8.841 0 01-4.083-.98L2 17l1.338-3.123C2.493 12.767 2 11.434 2 10c0-3.866 3.582-7 8-7s8 3.134 8 7zM7 9H5v2h2V9zm8 0h-2v2h2V9zM9 9h2v2H9V9z"
              clip-rule="evenodd"></path>
          </svg>
          AI English Coach
        </h3>
        <p class="text-sm text-slate-300 mt-1">{t.welcomeMessage}</p>
      </div>
      <div class="p-0 border-t border-slate-200">
        <iframe
          id="chat-embed-iframe"
          src={resolvedEmbedSrc.replace("/api/embed", "/embed/chat") +
            "?lang=" +
            lang +
            "&placeholder=" +
            encodeURIComponent(t.placeholder)}
          style="width: 100%; height: 600px; border: none;"
          class="rounded-b-lg"
          loading="eager"
          scrolling="no"
          tabindex="-1"></iframe>
      </div>
    </div>
  </div>

  <!-- Next steps CTA below chat -->
  <div class="container mx-auto px-4 max-w-4xl mt-10 mb-8">
    <div class="text-center">
      <p class="text-lg text-slate-600 mb-4">
        {lang === 'en'
          ? 'Ready to take the next step?'
          : '¿Listo para dar el siguiente paso?'}
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <a
          href={lang === 'en' ? '/en/book/' : '/es/book/'}
          class="inline-block px-6 py-3 bg-primary-600 text-white font-medium rounded-lg hover:bg-primary-700 transition-colors"
        >
          {lang === 'en' ? 'Book a Free Strategy Session' : 'Reservar Sesión Gratuita'}
        </a>
        <a
          href={lang === 'en' ? '/en/assessments/' : '/es/assessments/'}
          class="inline-block px-6 py-3 border border-primary-600 text-primary-600 font-medium rounded-lg hover:bg-primary-50 transition-colors"
        >
          {lang === 'en' ? 'Take a Free Assessment' : 'Tomar Evaluación Gratuita'}
        </a>
      </div>
    </div>
  </div>

  <script>
    // Aggressive scroll prevention for chat embed
    (function () {
      const preventScroll = () => {
        window.scrollTo(0, 0);
      };

      // Prevent scroll on iframe load
      const iframe = document.getElementById("chat-embed-iframe");
      if (iframe) {
        iframe.addEventListener("load", preventScroll);
      }

      // Prevent scroll on any focus events
      document.addEventListener("focus", preventScroll, true);

      // Force scroll to top after a short delay
      setTimeout(preventScroll, 100);
      setTimeout(preventScroll, 300);
      setTimeout(preventScroll, 500);

      // Clean up after page is fully loaded
      window.addEventListener("load", () => {
        setTimeout(() => {
          document.removeEventListener("focus", preventScroll, true);
        }, 1000);
      });
    })();
  </script>
</section>
