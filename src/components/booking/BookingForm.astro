---
import Input from "@components/ui/form/Input.astro";
import DatePicker from "./DatePicker.astro";

interface Props {
  lang: 'en' | 'es';
}

const { lang } = Astro.props;

const translations = {
  en: {
    pickDate: 'Pick a Date',
    selectDate: 'Select your preferred appointment date',
    chooseTime: 'Choose Time',
    yourInfo: 'Your Information',
    fullName: 'Full Name',
    namePlaceholder: 'John Doe',
    email: 'Email Address',
    emailPlaceholder: 'john@example.com',
    bookingSummary: 'Booking Summary',
    reviewDetails: 'Review your appointment details',
    selectedDate: 'Selected Date',
    selectedTime: 'Selected Time',
    contactInfo: 'Contact Information',
    meetingLink: 'Google Meet Link',
    confirmButton: 'Book My Free Consultation',
    noAccount: 'No account needed – just pick and confirm a time',
  },
  es: {
    pickDate: 'Elige una Fecha',
    selectDate: 'Selecciona tu fecha de cita preferida',
    chooseTime: 'Elige Horario',
    yourInfo: 'Tu Información',
    fullName: 'Nombre Completo',
    namePlaceholder: 'Juan Pérez',
    email: 'Correo Electrónico',
    emailPlaceholder: 'juan@ejemplo.com',
    bookingSummary: 'Resumen de Reserva',
    reviewDetails: 'Revisa los detalles de tu cita',
    selectedDate: 'Fecha Seleccionada',
    selectedTime: 'Hora Seleccionada',
    contactInfo: 'Información de Contacto',
    meetingLink: 'Enlace de Google Meet',
    confirmButton: 'Reservar Mi Consulta Gratuita',
    noAccount: 'No necesitas cuenta – solo elige y confirma un horario',
  },
};

const t = translations[lang];
---

<div class="booking-form-container">
  <!-- Step 1: Date Picker -->
  <div class="bg-white dark:bg-gray-800 rounded-lg shadow-lg p-6 mb-6">
    <div class="flex items-center gap-3 mb-4">
      <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
      </svg>
      <h2 class="text-2xl font-bold text-gray-900 dark:text-white">{t.pickDate}</h2>
    </div>
    <p class="text-gray-600 dark:text-gray-400 mb-6">{t.selectDate}</p>
    
    <DatePicker lang={lang} />
  </div>

  <!-- Step 2: Time Slots -->
  <div class="bg-white dark:bg-gray-800 rounded-lg shadow-lg p-6 mb-6" id="time-slot-section">
    <div class="flex items-center gap-3 mb-4">
      <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
      </svg>
      <h2 class="text-2xl font-bold text-gray-900 dark:text-white">{t.chooseTime}</h2>
    </div>
    <p class="text-gray-600 dark:text-gray-400 mb-2" id="selected-date-display">October 05, 2025</p>
    <p class="text-sm text-gray-500 dark:text-gray-500 mb-4">
      <svg class="w-4 h-4 inline-block mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
      </svg>
      {lang === 'en' ? 'Central Standard Time (GMT-6) - Guadalajara, Mexico' : 'Hora del Centro (GMT-6) - Guadalajara, México'}
    </p>
    
    <div id="time-slots-container" class="grid grid-cols-2 sm:grid-cols-3 gap-3 mt-6">
      <!-- Time slots will be populated by JavaScript -->
    </div>
  </div>

  <!-- Step 3: Your Information -->
  <div class="bg-white dark:bg-gray-800 rounded-lg shadow-lg p-6 mb-6">
    <div class="flex items-center gap-3 mb-4">
      <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
      </svg>
      <h2 class="text-2xl font-bold text-gray-900 dark:text-white">{t.yourInfo}</h2>
    </div>
    
    <form id="booking-form" class="space-y-4">
      <Input
        type="text"
        id="full-name"
        name="fullName"
        label={t.fullName}
        placeholder={t.namePlaceholder}
        required
      />
      
      <Input
        type="email"
        id="email"
        name="email"
        label={t.email}
        placeholder={t.emailPlaceholder}
        required
      />
    </form>
  </div>

  <!-- Step 4: Booking Summary -->
  <div class="bg-white dark:bg-gray-800 rounded-lg shadow-lg border-2 border-primary border-opacity-30 p-6 mb-6" id="booking-summary">
    <div class="flex items-center gap-3 mb-4">
      <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
      </svg>
      <h2 class="text-2xl font-bold text-gray-900 dark:text-white">{t.bookingSummary}</h2>
    </div>
    <p class="text-gray-600 dark:text-gray-400 mb-6">{t.reviewDetails}</p>
    
    <div class="space-y-4">
      <div class="flex justify-between items-center py-3 border-b border-gray-200 dark:border-gray-700">
        <span class="text-gray-600 dark:text-gray-400">{t.selectedDate}</span>
        <span class="font-semibold text-gray-900 dark:text-white" id="summary-date">-</span>
      </div>
      
      <div class="flex justify-between items-center py-3 border-b border-gray-200 dark:border-gray-700">
        <span class="text-gray-600 dark:text-gray-400">{t.selectedTime}</span>
        <span class="font-semibold text-gray-900 dark:text-white" id="summary-time">-</span>
      </div>
      
      <div class="flex justify-between items-center py-3 border-b border-gray-200 dark:border-gray-700">
        <span class="text-gray-600 dark:text-gray-400">{t.contactInfo}</span>
        <div class="text-right">
          <div class="font-semibold text-gray-900 dark:text-white" id="summary-name">-</div>
          <div class="text-sm text-gray-600 dark:text-gray-400" id="summary-email">-</div>
        </div>
      </div>
      
      <div class="py-3">
        <span class="text-gray-600 dark:text-gray-400 block mb-2">{t.meetingLink}</span>
        <a 
          href="https://meet.google.com/yvp-wvqs-erf" 
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 text-primary hover:text-primary-dark font-medium transition-colors"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"></path>
          </svg>
          meet.google.com/yvp-wvqs-erf
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path>
          </svg>
        </a>
        <p class="text-xs text-gray-500 dark:text-gray-500 mt-2">
          {lang === 'en' ? 'Meeting link will be included in your confirmation email' : 'El enlace de la reunión se incluirá en tu correo de confirmación'}
        </p>
      </div>
    </div>
  </div>

  <!-- Submit Button -->
  <button
    type="submit"
    form="booking-form"
    class="w-full bg-primary hover:bg-primary-dark text-white font-bold py-4 px-6 rounded-lg transition-colors duration-200 text-lg disabled:opacity-50 disabled:cursor-not-allowed"
    id="submit-booking"
  >
    {t.confirmButton}
  </button>
</div>

<script define:vars={{ lang }}>
  // API Configuration
  const API_BASE = 'https://plain-mode-42c4.rcushmaniii.workers.dev';
  
  // Booking form interactivity
  document.addEventListener('DOMContentLoaded', () => {
    // Initialize with today's date, or tomorrow if it's late (after 6 PM)
    const now = new Date();
    const currentHour = now.getHours();
    
    let selectedDate;
    if (currentHour >= 18) {
      // After 6 PM, default to tomorrow
      selectedDate = new Date(now);
      selectedDate.setDate(now.getDate() + 1);
      selectedDate.setHours(0, 0, 0, 0);
      console.log('Late in the day - defaulting to tomorrow:', selectedDate);
    } else {
      // Before 6 PM, use today
      selectedDate = new Date(now);
      selectedDate.setHours(0, 0, 0, 0);
      console.log('Initialized with today:', selectedDate);
    }
    
    let selectedTime = null;

    // Update the date display in "Choose Time" section
    const updateDateDisplay = (date) => {
      const display = document.getElementById('selected-date-display');
      if (display && date) {
        const options = { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' };
        display.textContent = date.toLocaleDateString(lang === 'es' ? 'es-ES' : 'en-US', options);
      }
    };

    // Listen for date selection from DatePicker
    document.addEventListener('dateSelected', async (e) => {
      selectedDate = e.detail.date;
      selectedTime = null; // Reset time when date changes
      updateDateDisplay(selectedDate);
      await fetchAvailableSlots(selectedDate);
      updateSummary();
    });

    let timeSlots = [];

    // Fetch available time slots from API
    const fetchAvailableSlots = async (date) => {
      const container = document.getElementById('time-slots-container');
      if (!container) return;
      
      if (!date) {
        console.error('No date provided to fetchAvailableSlots');
        return;
      }
      
      // Show loading state
      container.innerHTML = '<p class="col-span-full text-center text-gray-500">Loading available times...</p>';
      
      try {
        const dateStr = date.toISOString().split('T')[0];
        console.log('Fetching slots for date:', dateStr);
        console.log('API URL:', `${API_BASE}/slots/${dateStr}?lang=${lang}`);
        
        // Use Cloudflare Worker API with lang parameter
        const response = await fetch(`${API_BASE}/slots/${dateStr}?lang=${lang}`);
        console.log('Response status:', response.status);
        
        const data = await response.json();
        console.log('API Response:', data);
        
        if (data.ok && data.slots && data.slots.length > 0) {
          timeSlots = data.slots;
          renderTimeSlots();
        } else {
          container.innerHTML = '<p class="col-span-full text-center text-gray-500">' + 
            (lang === 'es' ? 'No hay horarios disponibles para esta fecha.' : 'No available times for this date.') +
            '</p>';
        }
      } catch (error) {
        console.error('Error fetching slots:', error);
        // Show user-friendly "no slots available" message instead of error
        container.innerHTML = '<p class="col-span-full text-center text-gray-500">' + 
          (lang === 'es' ? 'No hay horarios disponibles para esta fecha.' : 'No available times for this date.') +
          '</p>';
      }
    };

    // Render time slots
    const renderTimeSlots = () => {
      const container = document.getElementById('time-slots-container');
      if (!container) return;

      container.innerHTML = timeSlots.map(time => `
        <button
          type="button"
          class="time-slot-btn px-4 py-3 border-2 border-gray-300 dark:border-gray-600 rounded-lg hover:border-primary transition-all duration-200 font-medium text-gray-700 dark:text-gray-300 hover:text-gray-900"
          data-time="${time}"
        >
          ${time}
        </button>
      `).join('');

      // Add click handlers
      container.querySelectorAll('.time-slot-btn').forEach(btn => {
        btn.addEventListener('click', (e) => {
          const target = e.currentTarget;
          selectedTime = target.dataset.time || null;
          
          // Update UI - make selected button blue with white text
          container.querySelectorAll('.time-slot-btn').forEach(b => {
            b.classList.remove('border-primary', 'bg-primary', 'text-white');
            b.classList.add('border-gray-300', 'dark:border-gray-600', 'text-gray-700', 'dark:text-gray-300');
          });
          target.classList.add('border-primary', 'bg-primary', 'text-white');
          target.classList.remove('border-gray-300', 'dark:border-gray-600', 'text-gray-700', 'dark:text-gray-300');
          
          updateSummary();
        });
      });
    };

    // Update summary
    const updateSummary = () => {
      const summaryDate = document.getElementById('summary-date');
      const summaryTime = document.getElementById('summary-time');
      const summaryName = document.getElementById('summary-name');
      const summaryEmail = document.getElementById('summary-email');
      const nameInput = document.getElementById('full-name');
      const emailInput = document.getElementById('email');

      if (summaryDate && selectedDate) {
        summaryDate.textContent = selectedDate.toLocaleDateString('en-US', {
          weekday: 'long',
          year: 'numeric',
          month: 'long',
          day: 'numeric'
        });
      }

      if (summaryTime && selectedTime) {
        summaryTime.textContent = selectedTime;
      }

      if (summaryName && nameInput?.value) {
        summaryName.textContent = nameInput.value;
      }

      if (summaryEmail && emailInput?.value) {
        summaryEmail.textContent = emailInput.value;
      }
    };

    // Form input listeners
    const nameInput = document.getElementById('full-name');
    const emailInput = document.getElementById('email');
    
    nameInput?.addEventListener('input', updateSummary);
    emailInput?.addEventListener('input', updateSummary);

    // Form submission
    const submitButton = document.getElementById('submit-booking');
    const bookingForm = document.getElementById('booking-form');
    
    submitButton?.addEventListener('click', async (e) => {
      e.preventDefault();
      
      // Validate all fields
      if (!selectedDate || !selectedTime) {
        alert(lang === 'es' ? 'Por favor selecciona una fecha y hora' : 'Please select a date and time');
        return;
      }
      
      if (!bookingForm.checkValidity()) {
        bookingForm.reportValidity();
        return;
      }
      
      const nameInput = document.getElementById('full-name');
      const emailInput = document.getElementById('email');
      
      // Disable button during submission
      submitButton.disabled = true;
      submitButton.textContent = lang === 'es' ? 'Procesando...' : 'Processing...';
      
      try {
        // Format date for API
        const dateStr = selectedDate.toISOString().split('T')[0];
        
        const response = await fetch(`${API_BASE}/book`, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
          },
          body: JSON.stringify({
            name: nameInput.value,
            email: emailInput.value,
            date: dateStr,
            time: selectedTime,
            lang: lang
          })
        });
        
        const data = await response.json();
        
        if (data.ok) {
          // Redirect to thank you page with booking source parameter
          window.location.href = lang === 'es' ? '/es/thank-you/?source=booking' : '/en/thank-you/?source=booking';
        } else {
          throw new Error(data.error || 'Booking failed');
        }
      } catch (error) {
        console.error('Booking error:', error);
        alert(lang === 'es' 
          ? 'Hubo un error al procesar tu reserva. Por favor intenta de nuevo.' 
          : 'There was an error processing your booking. Please try again.');
        submitButton.disabled = false;
        submitButton.textContent = lang === 'es' ? 'Reservar Mi Consulta Gratuita' : 'Book My Free Consultation';
      }
    });

    // Initialize - load today's available slots on page load
    setTimeout(() => {
      console.log('Initializing with date:', selectedDate);
      
      // Clear form fields on page load
      const nameInput = document.getElementById('full-name');
      const emailInput = document.getElementById('email');
      if (nameInput) nameInput.value = '';
      if (emailInput) emailInput.value = '';
      
      if (selectedDate) {
        updateDateDisplay(selectedDate);
        fetchAvailableSlots(selectedDate);
      }
    }, 100); // Small delay to ensure DOM is ready
    
    updateSummary();
  });
</script>

<style>
  .time-slot-btn.selected {
    @apply border-primary bg-primary bg-opacity-10 text-primary;
  }
