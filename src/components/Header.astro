---
import { normalizePath } from "@utils/url";
import Logo from "@components/Logo.astro";
import { Menu, X } from "lucide-astro";
import Button from "@components/ui/Button.astro";
import { Image } from 'astro:assets';
import mexFlag from '@assets/images/mex-flag.svg';
import usaFlag from '@assets/images/usa-flag.svg';

interface Props {
  content: {
    readonly logoLink: string;
    readonly menu: ReadonlyArray<{ readonly name: string; readonly link: string }>;
    readonly cta: { readonly text: string; readonly link: string };
  };
  translationSlugEs?: string;
  translationSlugEn?: string;
}

const { content, translationSlugEs, translationSlugEn } = Astro.props;

// Determine current page for navigation highlighting
const currentPath = Astro.url.pathname;

const isCurrentPage = (link: string) => {
  if (link === content.logoLink && (currentPath === content.logoLink || currentPath === content.logoLink + '/')) {
    return true;
  }
  if (link !== "/" && link !== "/en/" && link !== "/es/") {
    return currentPath.startsWith(link);
  }
  return currentPath === link;
};
---

<header id="site-header" class="fixed top-0 z-50 w-full left-0">
  <div class="site-container mx-auto px-4 mt-4">
    <div class="flex justify-between items-center bg-white py-4 rounded-lg px-4 shadow-md border border-gray-200 dark:bg-neutral-900 dark:border-neutral-700">
      <a href={normalizePath(content.logoLink)} aria-label="Homepage" class="flex items-center">
        <Logo />
      </a>
      <div class="flex items-center gap-x-3 sm:gap-x-4 md:gap-x-6">
        <nav class="hidden lg:flex items-center" aria-label="Primary site navigation">
          <ul class="flex items-center gap-x-4 md:gap-x-6">
            {content.menu.map((item) => (
              <li>
                <a
                  href={item.link}
                  class:list={[
                    "text-small font-medium rounded-md px-2 py-1 focus:outline-none focus:ring-2 focus:ring-primary dark:focus:ring-primary-dark",
                    isCurrentPage(item.link)
                      ? "text-primary dark:text-primary-dark font-semibold"
                      : "text-neutral-700 hover:text-primary dark:text-neutral-300 dark:hover:text-primary-dark",
                  ]}
                  aria-current={isCurrentPage(item.link) ? "page" : undefined}
                >
                  {item.name}
                </a>
              </li>
            ))}
          </ul>
        </nav>
        <div class="flex items-center" id="lang-switcher-container">
          {translationSlugEs && typeof translationSlugEs === 'string' && !currentPath.startsWith('/es') && (
            <a
              href={currentPath === '/en/blog' || currentPath === '/en/blog/' 
                ? '/es/blog'
                : currentPath.includes('/blog/') 
                  ? `/es/blog/${translationSlugEs}`.replace(/^\/+/, '/').replace(/\/\/+/g, '/').replace(/\/es\/blog\/es\/blog\//, '/es/blog/') 
                  : `/es/${translationSlugEs}`.replace(/^\/+/, '/').replace(/\/\/+/g, '/').replace(/\/es\/es\//, '/es/')}
              class="lang-flag p-1 rounded-full border border-gray-300 hover:ring-2 hover:ring-primary focus:outline-none focus:ring-2 focus:ring-primary bg-white"
              aria-label="Cambiar a Español"
              data-lang="es"
              data-astro-reload
            >
              <Image src={mexFlag} alt="Bandera de México" width={24} height={24} class="w-6 h-6" />
            </a>
          )}
          {translationSlugEn && typeof translationSlugEn === 'string' && !currentPath.startsWith('/en') && (
            <a
              href={currentPath === '/es/blog' || currentPath === '/es/blog/' 
                ? '/en/blog'
                : currentPath.includes('/blog/') 
                  ? `/en/blog/${translationSlugEn}`.replace(/^\/+/, '/').replace(/\/\/+/g, '/').replace(/\/en\/blog\/en\/blog\//, '/en/blog/') 
                  : `/en/${translationSlugEn}`.replace(/^\/+/, '/').replace(/\/\/+/g, '/').replace(/\/en\/en\//, '/en/')}
              class="lang-flag p-1 rounded-full border border-gray-300 hover:ring-2 hover:ring-primary focus:outline-none focus:ring-2 focus:ring-primary bg-white"
              aria-label="Switch to English"
              data-lang="en"
              data-astro-reload
            >
              <Image src={usaFlag} alt="USA Flag" width={24} height={24} class="w-6 h-6" />
            </a>
          )}
        </div>
        <div class="hidden lg:block">
          <Button
            href={content.cta.link}
            variant="primary"
            size="md" 
          >
            {content.cta.text}
          </Button>
        </div>
        <button
          id="mobile-menu-button"
          class="lg:hidden p-2 border-none cursor-pointer bg-transparent text-neutral-700 dark:text-neutral-300"
          aria-label="Toggle Menu"
          aria-expanded="false"
          aria-controls="mobile-menu-panel"
        >
          <span class="menu-icon block"><Menu size={24} /></span>
          <span class="close-icon hidden"><X size={24} /></span>
        </button>
      </div>
    </div>
  </div>

  <div
    id="mobile-menu-panel"
    class="fixed inset-x-0 top-0 z-40 bg-white dark:bg-neutral-950 shadow-xl lg:hidden hidden opacity-0 scale-95 transform transition-all duration-200 ease-out overflow-y-auto"
    aria-hidden="true"
  >
    <div class="site-container mx-auto px-4 sm:px-6 relative"> 
      <button
        id="mobile-panel-close-button"
        class="absolute top-4 left-4 p-2 text-neutral-700 dark:text-neutral-300 hover:text-primary dark:hover:text-primary-dark"
        aria-label="Close menu"
      >
        <X size={28} />
      </button>

      <ul class="flex flex-col gap-4 pt-20"> 
        {content.menu.map((item) => (
          <li>
            <a
              href={item.link}
              class:list={[
                "block py-2 text-base font-medium rounded-md focus:outline-none focus:ring-2 focus:ring-primary-dark",
                isCurrentPage(item.link)
                  ? "text-primary dark:text-primary-dark font-semibold"
                  : "text-neutral-700 hover:text-primary dark:text-neutral-300 dark:hover:text-primary-dark",
              ]}
              aria-current={isCurrentPage(item.link) ? "page" : undefined}
            >
              {item.name}
            </a>
          </li>
        ))}
      </ul>
      <!-- Language Switcher for Mobile Menu -->
      <div class="mt-6 mb-4 flex justify-center gap-4">
        {translationSlugEs && typeof translationSlugEs === 'string' && !currentPath.startsWith('/es') && (
          <a
            href={currentPath === '/en/blog' || currentPath === '/en/blog/' 
              ? '/es/blog'
              : currentPath.includes('/blog/') 
                ? `/es/blog/${translationSlugEs}`.replace(/^\/+/, '/').replace(/\/\/+/g, '/').replace(/\/es\/blog\/es\/blog\//, '/es/blog/') 
                : `/es/${translationSlugEs}`.replace(/^\/+/, '/').replace(/\/\/+/g, '/').replace(/\/es\/es\//, '/es/')}
            class="lang-flag p-2 rounded-full border border-gray-300 hover:ring-2 hover:ring-primary focus:outline-none focus:ring-2 focus:ring-primary bg-white flex items-center gap-2"
            aria-label="Cambiar a Español"
            data-lang="es"
            data-astro-reload
          >
            <Image src={mexFlag} alt="Bandera de México" width={24} height={24} class="w-6 h-6" />
            <span class="text-sm font-medium">Español</span>
          </a>
        )}
        {translationSlugEn && typeof translationSlugEn === 'string' && !currentPath.startsWith('/en') && (
          <a
            href={currentPath === '/es/blog' || currentPath === '/es/blog/' 
              ? '/en/blog'
              : currentPath.includes('/blog/') 
                ? `/en/blog/${translationSlugEn}`.replace(/^\/+/, '/').replace(/\/\/+/g, '/').replace(/\/en\/blog\/en\/blog\//, '/en/blog/') 
                : `/en/${translationSlugEn}`.replace(/^\/+/, '/').replace(/\/\/+/g, '/').replace(/\/en\/en\//, '/en/')}
            class="lang-flag p-2 rounded-full border border-gray-300 hover:ring-2 hover:ring-primary focus:outline-none focus:ring-2 focus:ring-primary bg-white flex items-center gap-2"
            aria-label="Switch to English"
            data-lang="en"
            data-astro-reload
          >
            <Image src={usaFlag} alt="USA Flag" width={24} height={24} class="w-6 h-6" />
            <span class="text-sm font-medium">English</span>
          </a>
        )}
      </div>
      
      <div class="mt-4 pb-4 flex flex-col gap-3">
        <Button href={normalizePath(content.cta.link)} variant="primary" size="md" class="w-full text-center">
          {content.cta.text}
        </Button>
      </div>
    </div>
  </div>
</header>

<script>
  const header = document.getElementById('site-header');
  const menuButton = document.getElementById('mobile-menu-button');
  const mobileMenuPanel = document.getElementById('mobile-menu-panel');
  const mobilePanelCloseButton = document.getElementById('mobile-panel-close-button'); 
  const menuIcon = menuButton?.querySelector('.menu-icon');
  const closeIcon = menuButton?.querySelector('.close-icon');

  function setMobileMenuPadding() {
    if (header && mobileMenuPanel) {
    }
  }

  function openMenu() {
    if (!menuButton || !mobileMenuPanel || !menuIcon || !closeIcon) return;
    menuButton.setAttribute('aria-expanded', 'true');
    mobileMenuPanel.setAttribute('aria-hidden', 'false');
    mobileMenuPanel.classList.remove('hidden', 'opacity-0', 'scale-95');
    mobileMenuPanel.classList.add('opacity-100', 'scale-100');
    menuIcon.classList.add('hidden');
    closeIcon.classList.remove('hidden');
    document.body.style.overflow = 'hidden'; 
  }

  function closeMenu() {
    if (!menuButton || !mobileMenuPanel || !menuIcon || !closeIcon) return;
    menuButton.setAttribute('aria-expanded', 'false');
    mobileMenuPanel.setAttribute('aria-hidden', 'true');
    mobileMenuPanel.classList.add('opacity-0', 'scale-95');
    setTimeout(() => {
      mobileMenuPanel.classList.add('hidden');
    }, 200); 
    menuIcon.classList.remove('hidden');
    closeIcon.classList.add('hidden');
    document.body.style.overflow = ''; 
  }

  if (menuButton) {
    menuButton.addEventListener('click', () => {
      const isExpanded = menuButton.getAttribute('aria-expanded') === 'true';
      if (!isExpanded) {
        openMenu();
      } else {
        closeMenu();
      }
    });
  }

  if (mobilePanelCloseButton) { 
    mobilePanelCloseButton.addEventListener('click', closeMenu);
  }
  
  window.addEventListener('resize', setMobileMenuPadding);
  setMobileMenuPadding();

  if (mobileMenuPanel) {
    mobileMenuPanel.querySelectorAll('a').forEach(link => {
      link.addEventListener('click', () => {
        if (menuButton && menuButton.getAttribute('aria-expanded') === 'true') {
          closeMenu(); 
        }
      });
    });
  }
</script>