---
import { normalizePath } from "@utils/url";
import {
  cleanDoubleLanguagePrefixes,
  removeLanguagePrefix,
  addLanguagePrefix,
  cleanBlogUrl,
} from "@utils/url-cleaner";
import Logo from "@components/Logo.astro";
import { Menu, X, Globe } from "lucide-astro";
import Button from "@components/ui/Button.astro";

interface MenuItem {
  readonly name: string;
  readonly link: string | undefined;
}

interface Props {
  content: {
    readonly logoLink: string;
    readonly menu: ReadonlyArray<MenuItem>;
    readonly cta: { readonly text: string; readonly link: string };
  };
  translationSlugEs?: string;
  translationSlugEn?: string;
  hideLanguageSwitcher?: boolean;
  transparentOnLoad?: boolean;
}

const {
  content,
  translationSlugEs,
  translationSlugEn,
  hideLanguageSwitcher,
  transparentOnLoad = false,
} = Astro.props;

// Import i18n helpers
import { routeFor, type TKey } from "../lib/i18n";
import { categories } from "@data/categories";

// Helpers to map section slugs between locales
function mapToEs(path: string | undefined): string {
  if (!path) return "/es/";

  // Static mapping for service pages
  const servicePages: Record<string, string> = {
    // English to Spanish
    "/en/services/executive-english/": "/es/servicios/ingles-para-ejecutivos/",
    "/en/services/high-stakes-english/":
      "/es/servicios/ingles-para-presentaciones/",
    "/en/services/interview-prep/":
      "/es/servicios/preparacion-para-entrevistas/",
    "/en/services/logistics-english/": "/es/servicios/ingles-para-logistica/",
    "/en/services/medical-english/": "/es/servicios/ingles-para-medicos/",
    "/en/services/professional-english/":
      "/es/servicios/ingles-para-profesionales/",
    "/en/services/public-speaking-english/": "/es/servicios/hablar-en-publico/",
    "/en/services/startup-founders/":
      "/es/servicios/ingles-para-fundadores-de-startups/",
    "/en/services/tech-english/": "/es/servicios/ingles-para-tecnologia/",
    "/en/services/technical-sales-english/":
      "/es/servicios/ingles-para-ventas-tecnicas/",
  };

  // Handle service pages with direct mapping
  if (path.startsWith("/en/services/")) {
    return (
      servicePages[path] || path.replace("/en/services/", "/es/servicios/")
    );
  }

  // Handle category pages using i18n mappings
  if (path.startsWith("/en/category/")) {
    const categoryPath = path.replace("/en/category/", "");
    const tkey = `category/${categoryPath.replace("/", "")}` as TKey;
    const esPath = routeFor.es[tkey];
    if (esPath) {
      return esPath;
    }
  }

  // Handle other sections
  return path
    .replace("/services/", "/servicios/")
    .replace("/testimonials/", "/testimonios/");
}

function mapToEn(path: string | undefined): string {
  if (!path) return "/en/";

  // Static mapping for service pages
  const servicePages: Record<string, string> = {
    // Spanish to English
    "/es/servicios/ingles-para-ejecutivos/": "/en/services/executive-english/",
    "/es/servicios/ingles-para-presentaciones/":
      "/en/services/high-stakes-english/",
    "/es/servicios/preparacion-para-entrevistas/":
      "/en/services/interview-prep/",
    "/es/servicios/ingles-para-logistica/": "/en/services/logistics-english/",
    "/es/servicios/ingles-para-medicos/": "/en/services/medical-english/",
    "/es/servicios/ingles-para-profesionales/":
      "/en/services/professional-english/",
    "/es/servicios/hablar-en-publico/": "/en/services/public-speaking-english/",
    "/es/servicios/ingles-para-fundadores-de-startups/":
      "/en/services/startup-founders/",
    "/es/servicios/ingles-para-tecnologia/": "/en/services/tech-english/",
    "/es/servicios/ingles-para-ventas-tecnicas/":
      "/en/services/technical-sales-english/",
  };

  // Handle service pages with direct mapping
  if (path.startsWith("/es/servicios/")) {
    return (
      servicePages[path] || path.replace("/es/servicios/", "/en/services/")
    );
  }

  // Handle category pages using i18n mappings
  if (path.startsWith("/es/categoria/")) {
    const categoryPath = path.replace("/es/categoria/", "");
    // Find the English category slug that maps to this Spanish slug
    const category = categories.find(
      (c: { esSlug?: string; slug: string }) =>
        c.esSlug === categoryPath || c.slug === categoryPath
    );
    if (category) {
      const tkey = `category/${category.slug}` as TKey;
      const enPath = routeFor.en[tkey];
      if (enPath) {
        return enPath;
      }
    }
  }

  // Handle other sections
  return path
    .replace("/servicios/", "/services/")
    .replace("/testimonios/", "/testimonials/")
    .replace("/en/services/ingles-", "/en/services/");
}
function withSlash(p: string): string {
  if (!p) return p;
  if (p.includes(".")) return p;
  return p.endsWith("/") ? p : p + "/";
}

// Determine current page for navigation highlighting
const currentPath = Astro.url.pathname;

const isCurrentPage = (link: string | undefined) => {
  if (!link) return false;
  if (
    link === content.logoLink &&
    (currentPath === content.logoLink || currentPath === content.logoLink + "/")
  ) {
    return true;
  }
  if (link !== "/" && link !== "/en/" && link !== "/es/") {
    return currentPath.startsWith(link);
  }
  return currentPath === link;
};
---

<header
  id="site-header"
  class:list={[
    "fixed top-0 z-50 w-full left-0 transition-all duration-300",
    transparentOnLoad && "header-transparent",
  ]}
>
  <div class="site-container mx-auto px-4 mt-4">
    <div
      id="header-inner"
      class="flex justify-between items-center py-4 rounded-lg px-4 transition-all duration-300 bg-white shadow-md border border-gray-200 dark:bg-neutral-900 dark:border-neutral-700"
    >
      <a
        href={normalizePath(content.logoLink)}
        aria-label="New York English Teacher — Home"
        class="flex items-center"
      >
        <Logo transparentMode={transparentOnLoad} />
      </a>
      <div class="flex items-center gap-x-3 sm:gap-x-4 md:gap-x-6">
        <nav
          class="hidden lg:flex items-center"
          aria-label="Primary site navigation"
        >
          <ul class="flex items-center gap-x-4 md:gap-x-6">
            {
              content.menu.map((item) => (
                <li>
                  <a
                    href={item.link}
                    class:list={[
                      "nav-link text-small font-medium rounded-md px-2 py-1 focus:outline-none focus:ring-2 focus:ring-primary dark:focus:ring-primary-dark transition-colors duration-300",
                      isCurrentPage(item.link)
                        ? "text-primary dark:text-primary-dark font-semibold"
                        : "text-neutral-700 hover:text-primary dark:text-neutral-300 dark:hover:text-primary-dark",
                    ]}
                    aria-current={isCurrentPage(item.link) ? "page" : undefined}
                  >
                    {item.name}
                  </a>
                </li>
              ))
            }
          </ul>
        </nav>
        {
          !hideLanguageSwitcher && (
            <div class="flex items-center" id="lang-switcher-container">
              {/* Mobile: Globe icon only */}
              {!currentPath.startsWith("/es") && translationSlugEs && (
                <a
                  href={translationSlugEs}
                  class="lang-flag lg:hidden inline-flex items-center justify-center w-8 h-8 rounded-md text-slate-500 hover:text-slate-800 hover:bg-slate-100 transition-colors"
                  aria-label="Cambiar a Español"
                  data-lang="es"
                  data-astro-reload
                >
                  <Globe class="w-4.5 h-4.5" />
                </a>
              )}
              {!currentPath.startsWith("/en") && translationSlugEn && (
                <a
                  href={translationSlugEn}
                  class="lang-flag lg:hidden inline-flex items-center justify-center w-8 h-8 rounded-md text-slate-500 hover:text-slate-800 hover:bg-slate-100 transition-colors"
                  aria-label="Switch to English"
                  data-lang="en"
                  data-astro-reload
                >
                  <Globe class="w-4.5 h-4.5" />
                </a>
              )}
              {/* Desktop: Full label */}
              {!currentPath.startsWith("/es") && translationSlugEs && (
                <a
                  href={translationSlugEs}
                  class="lang-flag hidden lg:inline-flex items-center gap-1.5 px-2.5 py-1.5 rounded-md border border-slate-300 bg-slate-50 text-xs font-medium text-slate-600 hover:border-slate-400 hover:bg-slate-100 hover:text-slate-800 transition-colors"
                  aria-label="Cambiar a Español"
                  data-lang="es"
                  data-astro-reload
                >
                  <Globe class="w-3.5 h-3.5" />
                  <span class="font-semibold">English</span>
                  <span class="text-[0.6rem] text-slate-400">&rarr;Español</span>
                </a>
              )}
              {!currentPath.startsWith("/en") && translationSlugEn && (
                <a
                  href={translationSlugEn}
                  class="lang-flag hidden lg:inline-flex items-center gap-1.5 px-2.5 py-1.5 rounded-md border border-slate-300 bg-slate-50 text-xs font-medium text-slate-600 hover:border-slate-400 hover:bg-slate-100 hover:text-slate-800 transition-colors"
                  aria-label="Switch to English"
                  data-lang="en"
                  data-astro-reload
                >
                  <Globe class="w-3.5 h-3.5" />
                  <span class="font-semibold">Español</span>
                  <span class="text-[0.6rem] text-slate-400">&rarr;English</span>
                </a>
              )}
            </div>
          )
        }
        <div class="hidden lg:block">
          <Button href={content.cta.link} variant="primary" size="md">
            {content.cta.text}
          </Button>
        </div>
        <button
          id="mobile-menu-button"
          class="lg:hidden p-2 border-none cursor-pointer bg-transparent text-neutral-700 dark:text-neutral-300 mobile-menu-btn"
          aria-label="Toggle Menu"
          aria-expanded="false"
          aria-controls="mobile-menu-panel"
        >
          <span class="menu-icon block"><Menu size={24} /></span>
          <span class="close-icon hidden"><X size={24} /></span>
        </button>
      </div>
    </div>
  </div>

  <div
    id="mobile-menu-panel"
    class="fixed inset-x-0 top-0 z-40 bg-white dark:bg-neutral-950 shadow-xl lg:hidden hidden opacity-0 scale-95 transform transition-all duration-200 ease-out overflow-y-auto"
    aria-hidden="true"
  >
    <div class="site-container mx-auto px-4 sm:px-6 relative">
      <button
        id="mobile-panel-close-button"
        class="absolute top-4 left-4 p-2 text-neutral-700 dark:text-neutral-300 hover:text-primary dark:hover:text-primary-dark"
        aria-label="Close menu"
      >
        <X size={28} />
      </button>

      <ul class="flex flex-col gap-4 pt-20">
        {
          content.menu.map((item) => (
            <li>
              <a
                href={item.link}
                class:list={[
                  "block py-2 text-base font-medium rounded-md focus:outline-none focus:ring-2 focus:ring-primary-dark",
                  isCurrentPage(item.link)
                    ? "text-primary dark:text-primary-dark font-semibold"
                    : "text-neutral-700 hover:text-primary dark:text-neutral-300 dark:hover:text-primary-dark",
                ]}
                aria-current={isCurrentPage(item.link) ? "page" : undefined}
              >
                {item.name}
              </a>
            </li>
          ))
        }
      </ul>
      <!-- Language Switcher for Mobile Menu -->
      {
        !hideLanguageSwitcher && (
          <div class="mt-6 mb-4 flex justify-center">
            {translationSlugEs &&
              typeof translationSlugEs === "string" &&
              !currentPath.startsWith("/es") && (
                <a
                  href={translationSlugEs}
                  class="lang-flag inline-flex items-center gap-2 px-5 py-2.5 rounded-md border border-slate-300 bg-slate-50 text-sm font-medium text-slate-600 hover:border-slate-400 hover:bg-slate-100 hover:text-slate-800 focus:outline-none focus:ring-2 focus:ring-primary transition-colors"
                  aria-label="Cambiar a Español"
                  data-lang="es"
                  data-astro-reload
                >
                  <Globe class="w-4 h-4" />
                  <span class="font-semibold">English</span>
                  <span class="text-xs text-slate-400">&rarr;Español</span>
                </a>
              )}
            {translationSlugEn &&
              typeof translationSlugEn === "string" &&
              !currentPath.startsWith("/en") && (
                <a
                  href={translationSlugEn}
                  class="lang-flag inline-flex items-center gap-2 px-5 py-2.5 rounded-md border border-slate-300 bg-slate-50 text-sm font-medium text-slate-600 hover:border-slate-400 hover:bg-slate-100 hover:text-slate-800 focus:outline-none focus:ring-2 focus:ring-primary transition-colors"
                  aria-label="Switch to English"
                  data-lang="en"
                  data-astro-reload
                >
                  <Globe class="w-4 h-4" />
                  <span class="font-semibold">Español</span>
                  <span class="text-xs text-slate-400">&rarr;English</span>
                </a>
              )}
          </div>
        )
      }

      <div class="mt-4 pb-4 flex flex-col gap-3">
        <Button
          href={normalizePath(content.cta.link)}
          variant="primary"
          size="md"
          class="w-full text-center"
        >
          {content.cta.text}
        </Button>
      </div>
    </div>
  </div>
</header>

<script>
  const header = document.getElementById("site-header");
  const menuButton = document.getElementById("mobile-menu-button");
  const mobileMenuPanel = document.getElementById("mobile-menu-panel");
  const mobilePanelCloseButton = document.getElementById(
    "mobile-panel-close-button"
  );
  const menuIcon = menuButton?.querySelector(".menu-icon");
  const closeIcon = menuButton?.querySelector(".close-icon");

  function setMobileMenuPadding() {
    if (header && mobileMenuPanel) {
    }
  }

  function openMenu() {
    if (!menuButton || !mobileMenuPanel || !menuIcon || !closeIcon) return;
    menuButton.setAttribute("aria-expanded", "true");
    mobileMenuPanel.setAttribute("aria-hidden", "false");
    mobileMenuPanel.classList.remove("hidden", "opacity-0", "scale-95");
    mobileMenuPanel.classList.add("opacity-100", "scale-100");
    menuIcon.classList.add("hidden");
    closeIcon.classList.remove("hidden");
    document.body.style.overflow = "hidden";
  }

  function closeMenu() {
    if (!menuButton || !mobileMenuPanel || !menuIcon || !closeIcon) return;
    menuButton.setAttribute("aria-expanded", "false");
    mobileMenuPanel.setAttribute("aria-hidden", "true");
    mobileMenuPanel.classList.add("opacity-0", "scale-95");
    setTimeout(() => {
      mobileMenuPanel.classList.add("hidden");
    }, 200);
    menuIcon.classList.remove("hidden");
    closeIcon.classList.add("hidden");
    document.body.style.overflow = "";
  }

  if (menuButton) {
    menuButton.addEventListener("click", () => {
      const isExpanded = menuButton.getAttribute("aria-expanded") === "true";
      if (!isExpanded) {
        openMenu();
      } else {
        closeMenu();
      }
    });
  }

  if (mobilePanelCloseButton) {
    mobilePanelCloseButton.addEventListener("click", closeMenu);
  }

  window.addEventListener("resize", setMobileMenuPadding);
  setMobileMenuPadding();

  if (mobileMenuPanel) {
    mobileMenuPanel.querySelectorAll("a").forEach((link) => {
      link.addEventListener("click", () => {
        if (menuButton && menuButton.getAttribute("aria-expanded") === "true") {
          closeMenu();
        }
      });
    });
  }

  // Quiz language switcher warning
  function handleQuizLanguageSwitch(e: Event) {
    const currentPath = window.location.pathname;
    const isOnQuizPage = currentPath.includes("/quiz/");

    if (!isOnQuizPage) return; // Not on quiz page, allow normal navigation

    // Don't show warning on quiz landing pages - user hasn't started yet
    if (currentPath.match(/\/quiz\/[^/]+\/?$/) && !currentPath.includes("/question/")) return;

    const target = e.currentTarget as HTMLAnchorElement;
    const targetLang = target.getAttribute("data-lang");
    const targetUrl = target.getAttribute("href");

    if (!targetUrl) return;

    // Always show warning on quiz pages (question, results, report)
    // User is in the middle of quiz flow
    e.preventDefault();

    const message =
      targetLang === "es"
        ? `Switching to Spanish will restart your quiz and you'll lose your current progress.\n\nDo you want to continue?`
        : `Cambiar a inglés reiniciará tu quiz y perderás tu progreso actual.\n\n¿Deseas continuar?`;

    if (confirm(message)) {
      // Clear quiz data
      sessionStorage.removeItem("quizAnswers");
      sessionStorage.removeItem("quizScore");
      sessionStorage.removeItem("submissionId");
      sessionStorage.removeItem("leadData");

      // Redirect to quiz landing in new language
      const startUrl =
        targetLang === "es" ? "/es/quiz/it-services/" : "/en/quiz/it-services/";
      window.location.href = startUrl;
    }
  }

  // Initialize language switcher handlers after DOM is ready
  function initQuizLanguageSwitcher() {
    const langFlags = document.querySelectorAll(".lang-flag");
    if (langFlags.length === 0) {
      // Retry after a short delay if elements not found yet
      setTimeout(initQuizLanguageSwitcher, 100);
      return;
    }

    langFlags.forEach((link) => {
      link.addEventListener("click", handleQuizLanguageSwitch);
    });
  }

  // Start initialization
  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initQuizLanguageSwitcher);
  } else {
    initQuizLanguageSwitcher();
  }

  // Transparent header scroll detection
  function initTransparentHeader() {
    const header = document.getElementById("site-header");
    if (!header || !header.classList.contains("header-transparent")) {
      return; // Not a transparent header page
    }

    const headerInner = document.getElementById("header-inner");
    if (!headerInner) {
      return;
    }

    // Capture headerInner in closure to satisfy TypeScript
    const innerElement = headerInner;

    // Throttle with requestAnimationFrame for better performance
    let ticking = false;

    function updateElements() {
      const navLinks = document.querySelectorAll(".nav-link");
      const logoForDark = document.querySelector(".logo-light");
      const logoForWhite = document.querySelector(".logo-dark");
      const mobileMenuBtn = document.querySelector(".mobile-menu-btn");
      const langSwitcher = document.querySelector("#lang-switcher-container a.lg\\:hidden");
      const langSwitcherDesktop = document.querySelector("#lang-switcher-container a.lg\\:inline-flex");
      const langSwitcherDesktopSpans = langSwitcherDesktop?.querySelectorAll("span");
      const buildingsParallax = document.getElementById(
        "hero-buildings-parallax"
      );

      const scrollY = window.scrollY;
      const scrollThreshold = window.innerWidth < 768 ? 20 : 30;

      // Parallax effect for buildings (scale from 1.0 to 1.15 as user scrolls through hero)
      if (buildingsParallax) {
        const heroHeight = window.innerHeight;
        const scrollProgress = Math.min(scrollY / heroHeight, 1); // 0 to 1
        const scale = 1 + scrollProgress * 0.15; // 1.0 to 1.15 (increased from 0.1)
        buildingsParallax.style.transform = `scale(${scale})`;
      }

      if (scrollY > scrollThreshold) {
        // Scrolled - solid white background
        innerElement.style.backgroundColor = "#ffffff";
        innerElement.style.boxShadow =
          "0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06)";
        innerElement.style.borderColor = "#e5e7eb";

        if (logoForDark && logoForWhite) {
          logoForDark.classList.add("hidden");
          logoForWhite.classList.remove("hidden");
        }

        navLinks.forEach((link) => {
          if (link instanceof HTMLElement) {
            link.style.setProperty("color", "#374151", "important");
          }
        });

        if (mobileMenuBtn instanceof HTMLElement) {
          mobileMenuBtn.style.setProperty("color", "#374151", "important");
        }

        if (langSwitcher instanceof HTMLElement) {
          langSwitcher.style.setProperty("color", "#64748b", "important");
        }

        // Desktop lang switcher: restore solid style
        if (langSwitcherDesktop instanceof HTMLElement) {
          langSwitcherDesktop.style.setProperty("background-color", "rgb(248 250 252)", "important");
          langSwitcherDesktop.style.setProperty("border-color", "rgb(203 213 225)", "important");
          langSwitcherDesktop.style.setProperty("color", "rgb(71 85 105)", "important");
          langSwitcherDesktopSpans?.forEach((span) => {
            if (span instanceof HTMLElement) {
              span.style.removeProperty("color");
            }
          });
        }
      } else {
        // At top - transparent background
        innerElement.style.backgroundColor = "transparent";
        innerElement.style.boxShadow = "none";
        innerElement.style.borderColor = "transparent";

        if (logoForDark && logoForWhite) {
          logoForDark.classList.remove("hidden");
          logoForWhite.classList.add("hidden");
        }

        navLinks.forEach((link) => {
          if (link instanceof HTMLElement) {
            link.style.setProperty("color", "#ffffff", "important");
          }
        });

        if (mobileMenuBtn instanceof HTMLElement) {
          mobileMenuBtn.style.setProperty("color", "#ffffff", "important");
        }

        if (langSwitcher instanceof HTMLElement) {
          langSwitcher.style.setProperty("color", "#ffffff", "important");
        }

        // Desktop lang switcher: transparent style
        if (langSwitcherDesktop instanceof HTMLElement) {
          langSwitcherDesktop.style.setProperty("background-color", "rgba(255, 255, 255, 0.15)", "important");
          langSwitcherDesktop.style.setProperty("border-color", "rgba(255, 255, 255, 0.35)", "important");
          langSwitcherDesktop.style.setProperty("color", "#ffffff", "important");
          langSwitcherDesktopSpans?.forEach((span) => {
            if (span instanceof HTMLElement) {
              span.style.setProperty("color", "#ffffff", "important");
            }
          });
        }
      }

      ticking = false;
    }

    function handleScroll() {
      if (!ticking) {
        window.requestAnimationFrame(updateElements);
        ticking = true;
      }
    }

    // Add passive scroll listener for better performance
    window.addEventListener("scroll", handleScroll, { passive: true });

    // Run once on load
    handleScroll();
  }

  // Initialize transparent header after DOM is ready
  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initTransparentHeader);
  } else {
    initTransparentHeader();
  }
</script>

<style>
  /* Transparent header styles */
  .header-transparent #header-inner {
    background-color: transparent;
    box-shadow: none;
    border-color: transparent;
  }

  .header-transparent .nav-link {
    color: #ffffff !important;
  }

  .header-transparent .nav-link:hover {
    color: #ffc107 !important;
  }

  /* Mobile menu button and lang switcher on transparent header */
  .header-transparent .mobile-menu-btn,
  .header-transparent #lang-switcher-container a {
    color: #ffffff !important;
  }

  /* Desktop lang switcher: transparent style on hero */
  .header-transparent #lang-switcher-container a.lg\:inline-flex {
    background-color: rgba(255, 255, 255, 0.15) !important;
    border-color: rgba(255, 255, 255, 0.35) !important;
    color: #ffffff !important;
  }
  .header-transparent #lang-switcher-container a.lg\:inline-flex span {
    color: #ffffff !important;
  }
  .header-transparent #lang-switcher-container a.lg\:inline-flex:hover {
    background-color: rgba(255, 255, 255, 0.25) !important;
    border-color: rgba(255, 255, 255, 0.5) !important;
  }

  /* Smooth transitions */
  #header-inner,
  .nav-link,
  .mobile-menu-btn,
  .logo-light,
  .logo-dark,
  #lang-switcher-container a {
    transition: all 0.3s ease;
  }
</style>
