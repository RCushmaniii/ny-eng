---
import { twMerge } from 'tailwind-merge';

interface HeadlineProps {
  title?: string;
  subtitle?: string;
  tagline?: string;
  classes?:
    | string
    | {
        container?: string;
        title?: string;
        subtitle?: string;
        tagline?: string;
      };
}

const {
  title = '',
  subtitle = '',
  tagline = '',
  classes = {},
} = Astro.props as HeadlineProps;

const cx =
  typeof classes === 'string'
    ? { container: classes, title: '', subtitle: '', tagline: '' }
    : (classes as NonNullable<Exclude<HeadlineProps['classes'], string>>);
---

<div class:list={twMerge('text-center', cx.container)}>
  {title && <h2 class:list={twMerge('text-3xl font-bold', cx.title)}>{title}</h2>}
  {subtitle && (
    <p class:list={twMerge('mt-2 text-lg text-muted', cx.subtitle)}>{subtitle}</p>
  )}
  {tagline && (
    <p class:list={twMerge('mt-4 text-sm uppercase tracking-wide', cx.tagline)}>
      {tagline}
    </p>
  )}
</div>
