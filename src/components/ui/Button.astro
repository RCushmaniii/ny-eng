---
import { normalizePath, withSlash } from "@utils/url";
import { cn } from "@utils/cn";
export interface Props {
  href?: string;
  variant?:
    | "primary"
    | "secondary"
    | "accent"
    | "ghostLight"
    | "ghostDark"
    | "whatsapp";
  size?: "sm" | "md" | "lg";
  disabled?: boolean;
  class?: string;
  type?: "button" | "submit" | "reset";
  target?: string;
  rel?: string;
}

const {
  href,
  variant = "primary",
  size = "md",
  disabled = false,
  class: className = "",
  type = "button",
  target,
  rel,
  ...rest
} = Astro.props;

const baseStyles =
  "group relative inline-flex overflow-hidden items-center justify-center rounded-border-small font-semibold transition-all duration-300 ease-out focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-offset-2 disabled:pointer-events-none disabled:opacity-50 rounded-md gap-2";

const variants = {
  primary:
    "bg-amber-500 !text-white hover:bg-amber-400 focus-visible:ring-amber-500 hover:ring-2 hover:ring-amber-500 hover:ring-offset-2 shadow-lg",
  secondary:
    "bg-amber-500 !text-white hover:bg-amber-400 focus-visible:ring-amber-500 hover:ring-2 hover:ring-amber-500 hover:ring-offset-2 shadow-lg",
  accent:
    "bg-amber-500 !text-white hover:bg-amber-400 focus-visible:ring-amber-500 hover:ring-2 hover:ring-amber-500 hover:ring-offset-2 shadow-lg",
  ghostLight:
    "text-white ring-2 ring-white focus-visible:ring-white hover:ring-2 hover:ring-black hover:ring-offset-2 bg-transparent",
  ghostDark:
    "text-body-base ring-2 ring-text focus-visible:ring-text hover:ring-2 hover:ring-black hover:ring-offset-2",
  whatsapp:
    "bg-[#25D366] text-white hover:bg-[#1EBE5B] focus-visible:ring-[#25D366] hover:ring-2 hover:ring-[#25D366] hover:ring-offset-2",
};

const sizes = {
  sm: "h-9 px-3 text-xsmall",
  md: "h-10 px-4 text-small",
  lg: "h-11 px-8 text-base",
};

const classes = cn(baseStyles, variants[variant], sizes[size], className);

// Calculate the rel attribute value, respecting explicitly passed values
const computedRel =
  rel ?? (target === "_blank" ? "noopener noreferrer" : undefined);
---

<!-- Use conditional rendering for anchor vs button elements to ensure attributes are properly applied -->{
  href ? (
    <a
      class={classes}
      href={
        href
          ? /^https?:\/\//i.test(href)
            ? normalizePath(href)
            : withSlash(normalizePath(href))
          : undefined
      }
      target={target}
      rel={computedRel}
      {...rest}
    >
      <span class="absolute left-0 -mt-12 h-32 w-1/2 translate-x-[250%] rotate-12 bg-white opacity-20 transition-all duration-250 ease-out group-hover:translate-x-[2%]" />
      <span class="flex items-center justify-center">
        <slot />
      </span>
    </a>
  ) : (
    <button
      class={classes}
      type={type}
      disabled={disabled}
      aria-disabled={disabled}
      {...rest}
    >
      <span class="absolute left-0 -mt-12 h-32 w-1/2 translate-x-[250%] rotate-12 bg-white opacity-20 transition-all duration-250 ease-out group-hover:translate-x-[2%]" />
      <span class="flex items-center justify-center">
        <slot />
      </span>
    </button>
  )
}
