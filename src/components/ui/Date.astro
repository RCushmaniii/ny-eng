---
interface Props {
    date: string | number | Date;
    lang?: 'en' | 'es';
}

const { date, lang = 'en' } = Astro.props;

// Parse the date properly to avoid timezone issues
let dateObj: Date;

// Handle string dates in ISO format like "2025-05-08"
if (typeof date === 'string' && /^\d{4}-\d{2}-\d{2}$/.test(date)) {
    const [year, month, day] = date.split('-').map(Number);
    // Create a date at noon local time to avoid timezone issues shifting the day
    const jsDate = new globalThis.Date();
    jsDate.setFullYear(year, month - 1, day);
    jsDate.setHours(12, 0, 0, 0); // Set to noon to avoid day shifting
    dateObj = jsDate;
} else if (date instanceof Date) {
    dateObj = date;
} else {
    // For any other format, use the standard Date constructor
    dateObj = new globalThis.Date(date as string | number);
}

// Validate the date
if (isNaN(dateObj.getTime())) {
    throw new Error('Invalid date provided to Date component');
}

// Use the appropriate locale based on language
let formattedDate;

if (lang === 'es') {
    // Spanish date format without ordinal suffixes
    formattedDate = dateObj.toLocaleDateString('es-MX', {
        year: 'numeric',
        month: 'long',
        day: 'numeric'
    });
} else {
    // English date format with ordinal suffixes
    formattedDate = dateObj.toLocaleDateString('en-US', {
        year: 'numeric',
        month: 'long',
        day: 'numeric'
    }).replace(/(\d+)(?=(,))/, (match: string) => {
        const day = parseInt(match);
        const suffix = ['th', 'st', 'nd', 'rd'][(day % 10 > 3 || day > 20) ? 0 : day % 10];
        return day + suffix;
    });
}
---

<time datetime={dateObj.toISOString()} class="text-sm text-body-base">
    {formattedDate}
</time>
