---
import { Image } from "astro:assets";
import type { Testimonial } from "@data/testimonials/en";
import { cn } from "@utils/cn";

interface Props {
  testimonial: Testimonial;
  showHeadline?: boolean;
  showReadMore?: boolean;
  showCtaLink?: boolean;
}

const { testimonial, showHeadline = false, showReadMore = true, showCtaLink = true } = Astro.props;

// Set avatar size class based on testimonial.avatarSize
const avatarSizeClass = {
  sm: "w-10 h-10",
  md: "w-12 h-12",
  lg: "w-16 h-16"
}[testimonial.avatarSize || "md"];

// Generate stars based on rating
const stars = "★".repeat(testimonial.stars || 5);

// Determine if we should use the expandable content feature
const hasShortContent = !!testimonial.shortContent;
---

<div class="bg-white rounded-xl p-6 shadow-md hover:shadow-lg transition-shadow border border-gray-200 dark:bg-gray-900 dark:border-gray-800">
  {showHeadline && testimonial.headline && (
    <h3 class="text-lg font-bold mb-3 text-gray-900 dark:text-white">{testimonial.headline}</h3>
  )}
  
  <div class="mb-4 text-yellow-500 text-xl">{stars}</div>

  {hasShortContent ? (
    <div class="testimonial-content">
      <blockquote class="mb-6 italic text-gray-700 dark:text-gray-300 short-content">
        "{testimonial.shortContent}" 
        <span 
          class="text-primary-600 hover:text-primary-800 font-medium text-sm toggle-content-btn cursor-pointer"
          data-action="expand"
          data-lang={testimonial.link?.includes('/es/') ? 'es' : 'en'}
        >
          {testimonial.link?.includes('/es/') ? 'Mostrar más' : 'Show more'}
        </span>
      </blockquote>
      <blockquote class="mb-6 italic text-gray-700 dark:text-gray-300 full-content hidden">
        "{testimonial.content}" 
        <span 
          class="text-primary-600 hover:text-primary-800 font-medium text-sm toggle-content-btn cursor-pointer"
          data-action="collapse"
          data-lang={testimonial.link?.includes('/es/') ? 'es' : 'en'}
        >
          {testimonial.link?.includes('/es/') ? 'Mostrar menos' : 'Show less'}
        </span>
      </blockquote>
    </div>
  ) : (
    <blockquote class="mb-6 italic text-gray-700 dark:text-gray-300">
      "{testimonial.content}"
    </blockquote>
  )}

  <div class="flex items-center">
    {typeof testimonial.avatar === 'string' ? (
      <img
        src={testimonial.avatar}
        alt={`${testimonial.author} profile picture`}
        class:list={cn(avatarSizeClass, "rounded-full mr-4 object-cover")}
        width={testimonial.avatarSize === "lg" ? 64 : 48}
        height={testimonial.avatarSize === "lg" ? 64 : 48}
        loading="lazy"
      />
    ) : (
      <Image
        src={testimonial.avatar}
        alt={`${testimonial.author} profile picture`}
        class:list={cn(avatarSizeClass, "rounded-full mr-4 object-cover")}
        width={testimonial.avatarSize === "lg" ? 64 : 48}
        height={testimonial.avatarSize === "lg" ? 64 : 48}
        loading="lazy"
      />
    )}
    <div>
      <p class="font-semibold text-gray-900 dark:text-white">
        {testimonial.author}
      </p>
      <p class="text-sm text-gray-600 dark:text-gray-400">
        {testimonial.position}
        {testimonial.company && `, ${testimonial.company}`}
      </p>
    </div>
  </div>
  
  {showReadMore && showCtaLink && testimonial.link && (
    <div class="mt-4 text-right">
      <a 
        href={testimonial.link?.endsWith('/') ? testimonial.link : `${testimonial.link}/`} 
        class="text-primary-600 hover:text-primary-800 font-medium inline-flex items-center"
        {...(testimonial.link.startsWith('http') ? {
          target: "_blank",
          rel: "noopener noreferrer"
        } : {})}
      >
        {testimonial.linkText || (testimonial.link.includes('/es/') ? 'Leer más' : 'Read more')} <span class="ml-1">→</span>
      </a>
    </div>
  )}
</div>

<script>
  // Add client-side JavaScript to handle the toggle functionality
  document.addEventListener('DOMContentLoaded', () => {
    const toggleButtons = document.querySelectorAll('.toggle-content-btn');
    
    toggleButtons.forEach(button => {
      button.addEventListener('click', () => {
        const testimonialContent = button.closest('.testimonial-content');
        if (!testimonialContent) return;
        
        const shortContent = testimonialContent.querySelector('.short-content');
        const fullContent = testimonialContent.querySelector('.full-content');
        const action = button.getAttribute('data-action');
        
        if (action === 'expand') {
          shortContent?.classList.add('hidden');
          fullContent?.classList.remove('hidden');
        } else {
          shortContent?.classList.remove('hidden');
          fullContent?.classList.add('hidden');
        }
      });
    });
  });
</script>
