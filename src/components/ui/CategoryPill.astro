---
import routes from '@utils/paths';
import { normalizePath } from "@utils/url";
import { categories, getCategoryBySlug } from '../../data/categories';
import { serviceCategories } from '@data/service-categories';

interface Props {
  category: string;
  lang?: 'en' | 'es';
}

const { category, lang = 'en' } = Astro.props;

// Clean the category name to handle any format inconsistencies
const cleanCategoryName = category.trim();

// Normalize a string for matching (case and accent insensitive)
function normalize(str: string = ""): string {
  return str.trim().toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g, '');
}

const normalizedCategoryName = normalize(category);

// 0. Find by slug first — frontmatter always stores slugs, not display names
let categoryData = categories.find(cat => cat.slug === cleanCategoryName || cat.esSlug === cleanCategoryName);

// 1. Find by normalized English name
if (!categoryData) {
  categoryData = categories.find(cat => normalize(cat.name) === normalizedCategoryName);
}

// 2. If not found and using Spanish, try normalized Spanish name
if (!categoryData && lang === 'es') {
  categoryData = categories.find(cat => cat.name_es && normalize(cat.name_es) === normalizedCategoryName);
}

// 3. If still not found, try to match either name or name_es
if (!categoryData) {
  categoryData = categories.find(cat =>
    normalize(cat.name) === normalizedCategoryName ||
    (cat.name_es && normalize(cat.name_es) === normalizedCategoryName)
  );
}


// 4. If still not found, check if it matches a service category
let slug = '';
if (categoryData) {
  // Use Spanish slug if it exists and language is Spanish
  if (lang === 'es') {
    // First try to use the explicit esSlug if available
    if (categoryData.esSlug) {
      slug = categoryData.esSlug;
    } 
    // Otherwise, fall back to generating a slug from name_es
    else if (categoryData.name_es) {
      slug = categoryData.name_es
        .toLowerCase()
        .replace(/\s+/g, '-')
        .replace(/[&]/g, '')
        .normalize('NFD')
        .replace(/[\u0300-\u036f]/g, '');
    } else {
      slug = categoryData.slug; // Last resort: use English slug
    }
  } else {
    // For English, use the English slug
    slug = categoryData.slug;
  }
} else {
  // Try to map to service categories
  const serviceCategory = serviceCategories.find(cat => 
    cat.label === cleanCategoryName || 
    cat.esLabel === cleanCategoryName ||
    cat.slug === cleanCategoryName ||
    cat.esSlug === cleanCategoryName
  );
  
  if (serviceCategory) {
    // Use the appropriate slug based on language
    slug = lang === 'es' ? serviceCategory.esSlug : serviceCategory.slug;
  } else {
    // Last resort: create a slug from the name
    slug = cleanCategoryName.toLowerCase().replace(/\s+/g, '-');
  }
}

// Normalize slug to ensure it's URL-friendly
slug = slug
  .toLowerCase()
  .replace(/\s+/g, '-')
  .replace(/[&]/g, '')
  .normalize('NFD')
  .replace(/[\u0300-\u036f]/g, '');

// Build the category URL based on language with trailing slash
const categoryUrl = lang === 'es' ? routes.es.category(slug) : routes.en.category(slug);

// Get the display name based on language
let displayName = cleanCategoryName;
if (lang === 'es') {
  // Try to find Spanish name from category data
  if (categoryData?.name_es) {
    displayName = categoryData.name_es;
  } else {
    // Try to find in service categories
    const serviceCategory = serviceCategories.find(cat => 
      cat.label === cleanCategoryName || cat.slug === slug);
    if (serviceCategory) {
      displayName = serviceCategory.esLabel;
    }
  }
}
---

<a href={normalizePath(categoryUrl)} class="px-2 py-1 text-sm rounded-sm bg-blue-100 text-primary border-blue-200 border flex items-center justify-center leading-none font-medium hover:bg-blue-200 transition-colors duration-300 mr-2 no-underline">
  {displayName}
</a>