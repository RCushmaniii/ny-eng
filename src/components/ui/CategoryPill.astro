---
import { categories } from '../../data/categories';

interface Props {
  category: string;
  lang?: 'en' | 'es';
}

const { category, lang = 'en' } = Astro.props;

// Find the category slug from the categories data
const categoryData = categories.find(cat => cat.name === category);
const slug = categoryData?.slug || category.toLowerCase().replace(/\s+/g, '-');

// Build the category URL based on language
const categoryUrl = `/${lang}/category/${slug}`;

// Get the display name based on language
let displayName = category;
if (lang === 'es' && categoryData?.name_es) {
  displayName = categoryData.name_es;
}
---

<a href={categoryUrl} class="px-2 py-1 text-sm rounded-sm bg-blue-100 text-primary border-blue-200 border flex items-center justify-center leading-none font-medium hover:bg-blue-200 transition-colors duration-300 mr-2 no-underline">
  {displayName}
</a>