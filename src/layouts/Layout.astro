---
// Ensure this path is correct relative to Layout.astro's location
import { Font } from 'astro:assets';
import "../styles/global.css"; 
import Header from "../components/Header.astro"; // Ensure path is correct
import Footer from "../components/Footer.astro"; // Ensure path is correct
import type { FooterContent } from "../components/Footer.astro"; // Import the FooterContent type
import { headerContent as headerContentEn } from "@data/header/en.ts"; 
import { headerContent as headerContentEs } from "@data/header/es.ts";
import SEO from "../components/SEO.astro";
import OrgSchema from "../components/seo/OrgSchema.astro";
import WebsiteSchema from "../components/seo/WebsiteSchema.astro";
import { siteConfig } from "@data/config.ts";
import { footerContentEn } from '@data/footer/en.ts';
import { footerContentEs } from '@data/footer/es.ts';
import { getHreflangAlternates, getTranslationUrls, getPageLanguage, normalizeUrlPath } from '../utils/hreflang';
const { siteUrl } = siteConfig;
const SiteName = 'New York English Teacher';
const Separator = '|';
const defaultDescription = 'Professional Business English Coaching and Corporate Training';
const defaultLang = 'en';

interface Props {
  title?: string;
  description?: string;
  image?: string | { src: string; [key: string]: any }; 
  whatsappImage?: string | { src: string; [key: string]: any };
  linkedinImage?: string | { src: string; [key: string]: any };
  footerCta?: {
    title: string;
    description: string;
    hideCta: boolean;
    button: { text: string; link: string; target?: string };
  };
  canonicalUrl?: string;
  heroImage?: any; // Assuming ImageMetadata or string path
  heroImageMobile?: any; // Assuming ImageMetadata or string path
  ogType?: 'website' | 'article';
  lang?: string; // Added lang prop
  noIndex?: boolean; // Added for noindex, nofollow meta tag
  hideCta?: boolean; // Added to hide footer CTA section
  translationSlugEn?: string; // Translation slug for English version
  translationSlugEs?: string; // Translation slug for Spanish version
  // Pagination SEO metadata
  isPaginated?: boolean;
  paginationData?: {
    currentPage: number;
    totalPages: number;
    canonicalUrl: string;
    prevPageUrl?: string | null;
    nextPageUrl?: string | null;
  }
}

const {
  title,
  description,
  image,
  whatsappImage,
  linkedinImage,
  footerCta,
  canonicalUrl,
  heroImage,
  heroImageMobile,
  ogType = 'website',
  lang = 'en',
  noIndex = false,
  hideCta = false,
  isPaginated = false,
  paginationData
} = Astro.props;

const pageTitle = title ? `${title} ${Separator} ${SiteName}` : SiteName;
const pageDescription = description || defaultDescription || "";

// Determine page type for OG image selection
const isBlogOrArticlePage = Astro.url.pathname.includes('/blog/') || Astro.url.pathname.includes('/article/');
const isServicePage = Astro.url.pathname.includes('/services/') || Astro.url.pathname.includes('/servicios/');

// Normalize image for SEO: always a string
function normalizeImage(img: string | { src: string } | undefined, fallback: string): string {
  if (typeof img === 'string') return img;
  if (img && typeof (img as { src?: unknown }).src === 'string') return (img as { src: string }).src;
  return fallback;
}

const heroImageSrc = (heroImage && typeof (heroImage as { src?: unknown }).src === 'string') 
  ? (heroImage as { src: string }).src 
  : (typeof heroImage === 'string' ? heroImage : undefined);

// OG Image logic:
// 1. For blog/article pages: use the explicitly provided image, hero image, or default logo
// 2. For service pages: use the explicitly provided image or background image 
// 3. For main pages: use the explicitly provided image or default logo
const pageImageForSeo = "/images/logos/new-york-english-og.jpg";

// Use square version for WhatsApp
// No longer needed: handled by normalizeImage and prop fallback logic
// const whatsAppImagePath = ...

// Use appropriate image for LinkedIn
// No longer needed: handled by normalizeImage and prop fallback logic
// const linkedInImagePath = pageImageForSeo;

// Helper function to ensure trailing slashes on URLs
function ensureTrailingSlash(url: string | null | undefined): string {
  if (!url) return '';
  if (url.includes('.') || url.endsWith('/')) return url;
  return url + '/';
}

// Normalize the current path to fix trailing slash issues and build canonical
const normalizedCurrentPath = normalizeUrlPath(Astro.url.pathname);

// Build a clean site origin (single www., no trailing slash)
const rawSite = siteConfig.siteUrl.replace(/https?:\/\/www\.www\./i, 'https://www.');
const siteOrigin = (() => {
  try {
    const u = new URL(rawSite);
    return u.origin;
  } catch {
    return rawSite.endsWith('/') ? rawSite.slice(0, -1) : rawSite;
  }
})();

// Helper to absolutize a possibly relative URL against siteOrigin and enforce trailing slash for routes
function absolutizeCanonical(input: string | null | undefined): string {
  if (!input) return `${siteOrigin}${normalizedCurrentPath}`;
  const trimmed = input.replace(/https?:\/\/www\.www\./i, 'https://www.');
  try {
    const urlObj = new URL(trimmed, siteOrigin);
    // Enforce trailing slash on route-like paths
    if (!/\.[a-z0-9]+$/i.test(urlObj.pathname) && !urlObj.pathname.endsWith('/')) {
      urlObj.pathname = urlObj.pathname + '/';
    }
    // Final sanitize to prevent accidental double 'www.'
    return urlObj.toString().replace(/https?:\/\/www\.www\./i, 'https://www.');
  } catch {
    // Fallback to site origin + current path
    return `${siteOrigin}${normalizedCurrentPath}`.replace(/https?:\/\/www\.www\./i, 'https://www.');
  }
}

const fullCanonicalUrl = `${siteOrigin}${normalizedCurrentPath}`.replace(/https?:\/\/www\.www\./i, 'https://www.');

// Determine language from the URL path, falling back to the lang prop
const determinedLang = lang || (normalizedCurrentPath.startsWith('/es/') ? 'es' : 'en');

// Determine language based on URL path

const headerDataForCurrentLang = determinedLang === 'es' ? headerContentEs : headerContentEn;
const siteConfigForFooter = { companyName: siteConfig.companyName };
const baseFooterContentFromData = determinedLang === 'es' 
  ? footerContentEs(siteConfigForFooter) 
  : footerContentEn(siteConfigForFooter);

// Select appropriate header and footer content based on language

const { defaultFooterCta: baseDefaultCtaFromData, ...baseContentWithoutDefaultCta } = baseFooterContentFromData;
let finalFooterCta;
if (Astro.props.footerCta) {
  finalFooterCta = { ...baseDefaultCtaFromData, ...Astro.props.footerCta };
} else {
  finalFooterCta = { ...baseDefaultCtaFromData, hideCta: hideCta };
}
const actualFooterContentForComponent: FooterContent = {
  ...baseContentWithoutDefaultCta, 
  footerCta: finalFooterCta
};

let openGraphImagesFormatted;
if (pageImageForSeo) {
  const imagePath = normalizeImage(pageImageForSeo, "/images/logos/new-york-english-og.jpg");
  if (imagePath) {
    openGraphImagesFormatted = [{
      url: new URL(imagePath.startsWith('/') ? imagePath.substring(1) : imagePath, siteConfig.siteUrl).toString(),
    }];
  }
}

const twitterUsername = siteConfig.Socials.xSocial.includes('x.com/')
  ? `@${siteConfig.Socials.xSocial.split('x.com/')[1]}`
  : (siteConfig.Socials.xSocial.includes('twitter.com/') ? `@${siteConfig.Socials.xSocial.split('twitter.com/')[1]}` : undefined);

// Generate hreflang alternates using the centralized utility
// This ensures NO DUPLICATES and PERFECT RECIPROCITY
const hreflangAlternates = getHreflangAlternates(Astro.url.pathname, siteConfig.siteUrl);

// Get translation URLs for language switcher
const translationUrls = getTranslationUrls(Astro.url.pathname);
const translationSlugEn = translationUrls.en.replace('/en/', '').replace(/\/$/, '');
const translationSlugEs = translationUrls.es.replace('/es/', '').replace(/\/$/, '');

// Determine the current language from URL
const currentPageLang = getPageLanguage(Astro.url.pathname);

// Use the determined language for HTML lang attribute
const htmlLang = currentPageLang === 'es' ? 'es-MX' : 'en-US';

const fixedHeaderHeight = "0rem";

// --- Structured Data (JSON-LD) ---
// Website schema only - Organization schema is defined directly in the <head>

const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": siteConfig.companyName,
  "url": siteConfig.siteUrl
};
---

<!doctype html>
<html lang={htmlLang} data-theme="zeus">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    
    <!-- Safety redirect: fix /en/blog/en/... -> /en/blog/... -->
    <script is:inline>
      (function () {
        try {
          const path = location.pathname;
          const fixedPath = path.replace(/^\/(en|es)\/blog\/(en|es)\//i, '/$1/blog/');
          if (fixedPath !== path) {
            console.warn('[SafetyRedirect] Fixing duplicate language segment:', path, '->', fixedPath);
            location.replace(fixedPath + location.search + location.hash);
          }
        } catch (e) { console.error('[SafetyRedirect] Error:', e); }
      })();
    </script>
    
    <!-- SEO metadata is now handled by pages via the head slot -->
    
    <!-- Organization JSON-LD is now handled by pages via the head slot -->
    <!-- [Titan/Zeus] Google Fonts for theme headings and body -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Bruno+Ace+SC&family=Noto+Sans+KR:wght@100..900&display=swap" rel="stylesheet" />
    <!-- End Titan/Zeus Google Fonts -->
    <!-- [Titan/Zeus] Removed Astro Fonts API preload, using Google Fonts <link> only -->
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="sitemap" href="/sitemap-index.xml" />

    {/* Robots meta tag for noindex, nofollow */}
    {noIndex && <meta name="robots" content="noindex, nofollow" />}

    {/* Google Fonts links removed to rely on self-hosted versions */}

    {/* Hero Image Preload - Restored */}
    {heroImage && (
      <link
        rel="preload"
        as="image"
        href={typeof heroImage === 'string' ? heroImage : heroImage.src} 
        imagesrcset={
          heroImageMobile && typeof heroImage !== 'string' && typeof heroImageMobile !== 'string' && heroImage.src && heroImageMobile.src
            ? `${heroImageMobile.src} 800w, ${heroImage.src} 1920w`
            : undefined
        }
        imagesizes="(max-width: 768px) 100vw, 100vw"
        fetchpriority="high"
      />
    )}

    <!-- SEO metadata is now handled by pages via the head slot -->
    
    {/* Pagination navigation tags */}
    {isPaginated && paginationData && (
      <>
        {paginationData.prevPageUrl && (
          <link rel="prev" href={ensureTrailingSlash(paginationData.prevPageUrl)} />
        )}
        {paginationData.nextPageUrl && (
          <link rel="next" href={ensureTrailingSlash(paginationData.nextPageUrl)} />
        )}
      </>
    )}

    {/* <Fragment set:html={theme === "zeus" ? "<link rel='stylesheet' href='/themes/zeus.css'>" : ""} /> Removed */}
    {/* <ThemeSwitcher /> Removed */}

    <slot name="head" />
    <!-- WebsiteSchema is now handled by pages via the head slot -->
  </head>
  <body class={`antialiased font-sans bg-white dark:bg-neutral-950 text-neutral-900 dark:text-neutral-100 overflow-x-hidden ${heroImage ? 'has-hero-image' : ''}`} style="font-family: 'Noto Sans KR', sans-serif;">
    <div id="page-wrapper" class="flex flex-col min-h-screen">
      <!-- Pass translation slugs to Header component for language switching -->
      <Header content={headerDataForCurrentLang} translationSlugEn={translationSlugEn} translationSlugEs={translationSlugEs} />
      <main id="main-content" class="flex-grow" style={`padding-top: ${fixedHeaderHeight};`}>
        <slot />
      </main>
      <Footer content={actualFooterContentForComponent} />
    </div>
    {/* Adjusted aos.js to not use is:inline, assuming it's in public/js/ */}
    <script is:inline src="/js/aos.js"></script>
    <script is:inline>
      // This AOS init script should remain is:inline as it's small and page-specific config
      AOS.init({
        duration: 800, 
        easing: 'ease-in-out', 
        once: true, 
      });
    </script>
    {/* scroll.js - Restored */}
    <script src="/js/scroll.js" defer is:inline></script>
    <slot name="body-end" />
  </body>
</html>