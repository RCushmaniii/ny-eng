---
// Ensure this path is correct relative to Layout.astro's location
import "../styles/global.css"; 
import Header from "../components/Header.astro"; // Ensure path is correct
// Ensure these @data paths are correctly resolved by your tsconfig/jsconfig
import { headerContent as headerContentEn } from "@data/header/en"; 
import { headerContent as headerContentEs } from "@data/header/es";
import Footer from "../components/Footer.astro"; // Ensure path is correct
import type { FooterContent } from "../components/Footer.astro"; // Import the FooterContent type
// import ThemeSwitcher from "../components/ThemeSwitcher.astro"; // Removed as per user request
import { SEO, siteConfig, /* themeSetting */ } from "../data/config"; // themeSetting likely no longer needed here
import { footerContentEn } from '@data/footer/en';
import { footerContentEs } from '@data/footer/es';
import { AstroSeo } from '@astrolib/seo';

// const { theme } = themeSetting; // Removed as theme switcher is removed
const { SiteName, Separator, defaultDescription, defaultLang } = SEO;

interface Props {
  title?: string;
  description?: string;
  image?: string | { src: string; [key: string]: any }; 
  footerCta?: {
    title: string;
    description: string;
    hideCta: boolean;
    button: { text: string; link: string; target?: string };
  };
  canonicalUrl?: string;
  heroImage?: any; // Assuming ImageMetadata or string path
  heroImageMobile?: any; // Assuming ImageMetadata or string path
  translationSlugEs?: string; 
  translationSlugEn?: string; 
  ogType?: 'website' | 'article';
}

const {
  title,
  description,
  image,
  footerCta,
  canonicalUrl,
  heroImage,
  heroImageMobile,
  translationSlugEs,
  translationSlugEn,
  ogType = 'website'
} = Astro.props;

const pageTitle = title ? `${title} ${Separator} ${SiteName}` : SiteName;
const pageDescription = description || defaultDescription || "";
const pageImageForSeo = image;
const canonicalPath = canonicalUrl || Astro.url.pathname;
const fullCanonicalUrl = new URL(canonicalPath, siteConfig.siteUrl).toString();

const currentAstroPath = Astro.url.pathname;
let determinedLang = defaultLang || 'en';
if (currentAstroPath === '/es' || currentAstroPath.startsWith('/es/')) {
  determinedLang = 'es';
} else if (currentAstroPath === '/en' || currentAstroPath.startsWith('/en/')) {
  determinedLang = 'en';
}

console.log("[Layout] Astro.url.pathname:", currentAstroPath);
console.log("[Layout] Determined language:", determinedLang);

const headerDataForCurrentLang = determinedLang === 'es' ? headerContentEs : headerContentEn;
const siteConfigForFooter = { companyName: siteConfig.companyName };
const baseFooterContentFromData = determinedLang === 'es' 
  ? footerContentEs(siteConfigForFooter) 
  : footerContentEn(siteConfigForFooter);

console.log("[Layout] Header data selected (logoLink):", headerDataForCurrentLang.logoLink);
console.log("[Layout] Footer data selected (logoLink):", baseFooterContentFromData.logoLink);

const { defaultFooterCta: baseDefaultCtaFromData, ...baseContentWithoutDefaultCta } = baseFooterContentFromData;
let finalFooterCta;
if (Astro.props.footerCta) {
  finalFooterCta = { ...baseDefaultCtaFromData, ...Astro.props.footerCta };
} else {
  finalFooterCta = baseDefaultCtaFromData;
}
const actualFooterContentForComponent: FooterContent = {
  ...baseContentWithoutDefaultCta, 
  footerCta: finalFooterCta
};

let openGraphImagesFormatted;
if (pageImageForSeo) {
  const imagePath = typeof pageImageForSeo === 'string' ? pageImageForSeo : pageImageForSeo.src;
  if (imagePath) {
    openGraphImagesFormatted = [{
      url: new URL(imagePath.startsWith('/') ? imagePath.substring(1) : imagePath, siteConfig.siteUrl).toString(),
    }];
  }
}

const twitterUsername = siteConfig.Socials.xSocial.includes('x.com/')
  ? `@${siteConfig.Socials.xSocial.split('x.com/')[1]}`
  : (siteConfig.Socials.xSocial.includes('twitter.com/') ? `@${siteConfig.Socials.xSocial.split('twitter.com/')[1]}` : undefined);

const languageAlternatesList = [];
if (determinedLang === 'es' && translationSlugEn) {
  languageAlternatesList.push({ hreflang: 'es', href: fullCanonicalUrl });
  languageAlternatesList.push({ hreflang: 'en', href: new URL(translationSlugEn, siteConfig.siteUrl).toString() });
  languageAlternatesList.push({ hreflang: 'x-default', href: new URL(translationSlugEn, siteConfig.siteUrl).toString() });
} else if (determinedLang === 'en' && translationSlugEs) {
  languageAlternatesList.push({ hreflang: 'en', href: fullCanonicalUrl });
  languageAlternatesList.push({ hreflang: 'es', href: new URL(translationSlugEs, siteConfig.siteUrl).toString() });
  languageAlternatesList.push({ hreflang: 'x-default', href: fullCanonicalUrl }); 
} else {
  languageAlternatesList.push({ hreflang: determinedLang, href: fullCanonicalUrl });
  if (determinedLang === defaultLang) {
    languageAlternatesList.push({ hreflang: 'x-default', href: fullCanonicalUrl });
  }
  if (!languageAlternatesList.find(a => a.hreflang === 'x-default')) {
    languageAlternatesList.push({ hreflang: 'x-default', href: fullCanonicalUrl });
  }
}
const finalLanguageAlternates = languageAlternatesList.filter((obj, index, self) =>
  index === self.findIndex((o) => o.hreflang === obj.hreflang)
);

const fixedHeaderHeight = "0rem";
---

<!doctype html>
<html lang={determinedLang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="sitemap" href="/sitemap-index.xml" />

    {/* Google Fonts - Restored */}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Bruno+Ace+SC&family=Noto+Sans+KR:wght@100..900&display=swap"
      rel="stylesheet"
    />

    {/* Hero Image Preload - Restored */}
    {heroImage && (
      <link
        rel="preload"
        as="image"
        href={typeof heroImage === 'string' ? heroImage : heroImage.src} 
        imagesrcset={
          heroImageMobile && typeof heroImage !== 'string' && typeof heroImageMobile !== 'string' && heroImage.src && heroImageMobile.src
            ? `${heroImageMobile.src} 800w, ${heroImage.src} 1920w`
            : undefined
        }
        imagesizes="(max-width: 768px) 100vw, 100vw"
        fetchpriority="high"
      />
    )}

    <AstroSeo
      title={pageTitle}
      description={pageDescription}
      canonical={fullCanonicalUrl}
      openGraph={{
        url: fullCanonicalUrl,
        title: pageTitle,
        description: pageDescription,
        images: openGraphImagesFormatted,
        site_name: SiteName,
        type: ogType,
      }}
      twitter={{
        handle: twitterUsername,
        site: twitterUsername, 
        cardType: openGraphImagesFormatted ? 'summary_large_image' : 'summary',
      }}
      languageAlternates={finalLanguageAlternates.length > 0 ? finalLanguageAlternates : undefined}
    />

    {/* <Fragment set:html={theme === "zeus" ? "<link rel='stylesheet' href='/themes/zeus.css'>" : ""} /> Removed */}
    {/* <ThemeSwitcher /> Removed */}

    <slot name="head" />
  </head>
  <body class={`antialiased font-sans bg-white dark:bg-neutral-950 text-neutral-900 dark:text-neutral-100 overflow-x-hidden ${heroImage ? 'has-hero-image' : ''}`}>
    <div id="page-wrapper" class="flex flex-col min-h-screen">
      <Header content={headerDataForCurrentLang} translationSlugEs={translationSlugEs} translationSlugEn={translationSlugEn} />
      <main id="main-content" class="flex-grow" style={`padding-top: ${fixedHeaderHeight};`}>
        <slot />
      </main>
      <Footer content={actualFooterContentForComponent} />
    </div>
    {/* Adjusted aos.js to not use is:inline, assuming it's in public/js/ */}
    <script is:inline src="/js/aos.js"></script>
    <script is:inline>
      // This AOS init script should remain is:inline as it's small and page-specific config
      AOS.init({
        duration: 800, 
        easing: 'ease-in-out', 
        once: true, 
      });
    </script>
    {/* scroll.js - Restored */}
    <script src="/js/scroll.js" defer></script>
    <slot name="body-end" />
  </body>
</html>