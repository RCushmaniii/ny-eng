---
// Ensure this path is correct relative to Layout.astro's location
import { Font } from 'astro:assets';
import "../styles/global.css"; 
import Header from "../components/Header.astro"; // Ensure path is correct
import Footer from "../components/Footer.astro"; // Ensure path is correct
import type { FooterContent } from "../components/Footer.astro"; // Import the FooterContent type
import { headerContent as headerContentEn } from "@data/header/en"; 
import { headerContent as headerContentEs } from "@data/header/es";
import SEO from "../components/SEO.astro";
import { siteConfig } from "../data/config";
import { footerContentEn } from '@data/footer/en';
import { footerContentEs } from '@data/footer/es';
const { siteUrl } = siteConfig;
const SiteName = 'New York English Teacher – Your Career Performance Accelerator';
const Separator = '|';
const defaultDescription = 'Professional Business English Coaching and Corporate Training';
const defaultLang = 'en';

interface Props {
  title?: string;
  description?: string;
  image?: string | { src: string; [key: string]: any }; 
  whatsappImage?: string | { src: string; [key: string]: any };
  linkedinImage?: string | { src: string; [key: string]: any };
  footerCta?: {
    title: string;
    description: string;
    hideCta: boolean;
    button: { text: string; link: string; target?: string };
  };
  canonicalUrl?: string;
  heroImage?: any; // Assuming ImageMetadata or string path
  heroImageMobile?: any; // Assuming ImageMetadata or string path
  translationSlugEs?: string; 
  translationSlugEn?: string; 
  ogType?: 'website' | 'article';
  lang?: string; // Added lang prop
  noIndex?: boolean; // Added for noindex, nofollow meta tag
  hideCta?: boolean; // Added to hide footer CTA section
}

const {
  title,
  description,
  image,
  whatsappImage,
  linkedinImage,
  footerCta,
  canonicalUrl,
  heroImage,
  heroImageMobile,
  translationSlugEs,
  translationSlugEn,
  ogType = 'website',
  lang = 'en',
  noIndex = false,
  hideCta = false
} = Astro.props;

const pageTitle = title ? `${title} ${Separator} ${SiteName}` : SiteName;
const pageDescription = description || defaultDescription || "";

// Determine if this is a blog/article page or a homepage/main section page
const isBlogOrArticlePage = Astro.url.pathname.includes('/blog/') || Astro.url.pathname.includes('/article/');

// For blog/article pages: use the hero image if available
// For homepages and main section pages: always use the default logo image
// Normalize image for SEO: always a string
function normalizeImage(img: string | { src: string } | undefined, fallback: string): string {
  if (typeof img === 'string') return img;
  if (img && typeof (img as { src?: unknown }).src === 'string') return (img as { src: string }).src;
  return fallback;
}

const heroImageSrc = (heroImage && typeof (heroImage as { src?: unknown }).src === 'string') ? (heroImage as { src: string }).src : (typeof heroImage === 'string' ? heroImage : undefined);

const pageImageForSeo = isBlogOrArticlePage 
  ? normalizeImage(image, heroImageSrc || "/images/logos/new-york-english-og.jpg")
  : "/images/logos/new-york-english-og.jpg";

// Use square version for WhatsApp
// No longer needed: handled by normalizeImage and prop fallback logic
// const whatsAppImagePath = ...

// Use appropriate image for LinkedIn
// No longer needed: handled by normalizeImage and prop fallback logic
// const linkedInImagePath = pageImageForSeo;

// Ensure we always use the www version as canonical
const canonicalDomain = siteConfig.siteUrl.replace(/^(https?:\/\/)/, '$1www.');

// Build the canonical URL with the www domain
const canonicalPath = canonicalUrl || Astro.url.pathname;
let fullCanonicalUrl = new URL(canonicalPath, canonicalDomain).toString();
// Clean up any potential double slashes in the path
fullCanonicalUrl = fullCanonicalUrl.replace(/([^:]\/)\/+/g, '$1');

const currentAstroPath = Astro.url.pathname;
let determinedLang = defaultLang || 'en';
if (currentAstroPath === '/es' || currentAstroPath.startsWith('/es/')) {
  determinedLang = 'es';
} else if (currentAstroPath === '/en' || currentAstroPath.startsWith('/en/')) {
  determinedLang = 'en';
}

// Determine language based on URL path

const headerDataForCurrentLang = determinedLang === 'es' ? headerContentEs : headerContentEn;
const siteConfigForFooter = { companyName: siteConfig.companyName };
const baseFooterContentFromData = determinedLang === 'es' 
  ? footerContentEs(siteConfigForFooter) 
  : footerContentEn(siteConfigForFooter);

// Select appropriate header and footer content based on language

const { defaultFooterCta: baseDefaultCtaFromData, ...baseContentWithoutDefaultCta } = baseFooterContentFromData;
let finalFooterCta;
if (Astro.props.footerCta) {
  finalFooterCta = { ...baseDefaultCtaFromData, ...Astro.props.footerCta };
} else {
  finalFooterCta = { ...baseDefaultCtaFromData, hideCta: hideCta };
}
const actualFooterContentForComponent: FooterContent = {
  ...baseContentWithoutDefaultCta, 
  footerCta: finalFooterCta
};

let openGraphImagesFormatted;
if (pageImageForSeo) {
  const imagePath = normalizeImage(pageImageForSeo, "/images/logos/new-york-english-og.jpg");
  if (imagePath) {
    openGraphImagesFormatted = [{
      url: new URL(imagePath.startsWith('/') ? imagePath.substring(1) : imagePath, siteConfig.siteUrl).toString(),
    }];
  }
}

const twitterUsername = siteConfig.Socials.xSocial.includes('x.com/')
  ? `@${siteConfig.Socials.xSocial.split('x.com/')[1]}`
  : (siteConfig.Socials.xSocial.includes('twitter.com/') ? `@${siteConfig.Socials.xSocial.split('twitter.com/')[1]}` : undefined);

// Improved hreflang implementation to fix SEO issues
const languageAlternatesList = [];

// Always ensure we have a self-referencing hreflang tag
languageAlternatesList.push({ hreflang: determinedLang, href: fullCanonicalUrl });

// Add alternate language links when available
if (determinedLang === 'es' && translationSlugEn) {
  // Ensure translationSlugEn is valid and not undefined
  if (translationSlugEn && typeof translationSlugEn === 'string' && translationSlugEn !== 'undefined') {
    // Prevent double paths by removing any language prefix if it already exists
    let cleanEnPath = translationSlugEn.replace(/^\/?(en|es)\//, '');
    // Ensure the path starts with a single slash and doesn't have double slashes
    cleanEnPath = '/en/' + cleanEnPath.replace(/^\/+/, '').replace(/\/\/+/g, '/');
    const enUrl = new URL(cleanEnPath, canonicalDomain).toString().replace(/([^:]\/)\/+/g, '$1');
    languageAlternatesList.push({ hreflang: 'en', href: enUrl });
    languageAlternatesList.push({ hreflang: 'x-default', href: enUrl });
  }
} else if (determinedLang === 'en' && translationSlugEs) {
  // Ensure translationSlugEs is valid and not undefined
  if (translationSlugEs && typeof translationSlugEs === 'string' && translationSlugEs !== 'undefined') {
    // Prevent double paths by removing any language prefix if it already exists
    let cleanEsPath = translationSlugEs.replace(/^\/?(en|es)\//, '');
    // Ensure the path starts with a single slash and doesn't have double slashes
    cleanEsPath = '/es/' + cleanEsPath.replace(/^\/+/, '').replace(/\/\/+/g, '/');
    const esUrl = new URL(cleanEsPath, canonicalDomain).toString().replace(/([^:]\/)\/+/g, '$1');
    languageAlternatesList.push({ hreflang: 'es', href: esUrl });
    // For English pages, set x-default to the English version
    languageAlternatesList.push({ hreflang: 'x-default', href: fullCanonicalUrl });
  }
} else {
  // If no translation available, set x-default to current page
  if (determinedLang === defaultLang) {
    languageAlternatesList.push({ hreflang: 'x-default', href: fullCanonicalUrl });
  }
}

// Remove any duplicate hreflang entries
const finalLanguageAlternates = languageAlternatesList.filter((obj, index, self) =>
  index === self.findIndex((o) => o.hreflang === obj.hreflang)
);

const fixedHeaderHeight = "0rem";
---

<!doctype html>
<html lang={lang || determinedLang} data-theme="zeus">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <!-- [Titan/Zeus] Google Fonts for theme headings and body -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Bruno+Ace+SC&family=Noto+Sans+KR:wght@100..900&display=swap" rel="stylesheet" />
    <!-- End Titan/Zeus Google Fonts -->
    <!-- [Titan/Zeus] Removed Astro Fonts API preload, using Google Fonts <link> only -->
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="sitemap" href="/sitemap-index.xml" />

    {/* Robots meta tag for noindex, nofollow */}
    {noIndex && <meta name="robots" content="noindex, nofollow" />}

    {/* Google Fonts links removed to rely on self-hosted versions */}

    {/* Hero Image Preload - Restored */}
    {heroImage && (
      <link
        rel="preload"
        as="image"
        href={typeof heroImage === 'string' ? heroImage : heroImage.src} 
        imagesrcset={
          heroImageMobile && typeof heroImage !== 'string' && typeof heroImageMobile !== 'string' && heroImage.src && heroImageMobile.src
            ? `${heroImageMobile.src} 800w, ${heroImage.src} 1920w`
            : undefined
        }
        imagesizes="(max-width: 768px) 100vw, 100vw"
        fetchpriority="high"
      />
    )}

    <SEO
      title={pageTitle}
      description={pageDescription}
      image={pageImageForSeo}
      imageAlt={pageTitle}
      url={fullCanonicalUrl}
      locale={determinedLang === 'es' ? 'es_ES' : 'en_US'}
      alternateUrls={finalLanguageAlternates}
    />

    {/* <Fragment set:html={theme === "zeus" ? "<link rel='stylesheet' href='/themes/zeus.css'>" : ""} /> Removed */}
    {/* <ThemeSwitcher /> Removed */}

    <slot name="head" />
  </head>
  <body class={`antialiased font-sans bg-white dark:bg-neutral-950 text-neutral-900 dark:text-neutral-100 overflow-x-hidden ${heroImage ? 'has-hero-image' : ''}`} style="font-family: 'Noto Sans KR', sans-serif;">
    <div id="page-wrapper" class="flex flex-col min-h-screen">
      <!-- Pass translation slugs to Header component for language switching -->
      <Header content={headerDataForCurrentLang} translationSlugEs={translationSlugEs} translationSlugEn={translationSlugEn} />
      <main id="main-content" class="flex-grow" style={`padding-top: ${fixedHeaderHeight};`}>
        <slot />
      </main>
      <Footer content={actualFooterContentForComponent} />
    </div>
    {/* Adjusted aos.js to not use is:inline, assuming it's in public/js/ */}
    <script is:inline src="/js/aos.js"></script>
    <script is:inline>
      // This AOS init script should remain is:inline as it's small and page-specific config
      AOS.init({
        duration: 800, 
        easing: 'ease-in-out', 
        once: true, 
      });
    </script>
    {/* scroll.js - Restored */}
    <script src="/js/scroll.js" defer></script>
    <slot name="body-end" />
  </body>
</html>