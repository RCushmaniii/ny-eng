---
// Ensure this path is correct relative to Layout.astro's location
import "../styles/global.css"; 
import Header from "../components/Header.astro"; // Ensure path is correct
// Ensure these @data paths are correctly resolved by your tsconfig/jsconfig
import { headerContent as headerContentEn } from "@data/header/en"; 
import { headerContent as headerContentEs } from "@data/header/es";
import Footer from "../components/Footer.astro"; // Ensure path is correct
import type { FooterContent } from "../components/Footer.astro"; // Import the FooterContent type
import ThemeSwitcher from "../components/ThemeSwitcher.astro"; // Ensure path is correct
import { SEO, siteConfig, themeSetting } from "../data/config"; // Ensure path is correct
import { footerContentEn } from '@data/footer/en';
import { footerContentEs } from '@data/footer/es';

const { theme } = themeSetting;
const { SiteName, Separator, defaultDescription, defaultLang } = SEO; // Ensure defaultLang (e.g., 'en') is in your SEO config

interface Props {
  title?: string;
  description?: string;
  image?: string;
  footerCta?: {
    title: string;
    description: string;
    hideCta: boolean;
    button: { text: string; link: string; target?: string };
  };
  canonicalUrl?: string;
  heroImage?: any;
  heroImageMobile?: any;
  translationSlugEs?: string;
  translationSlugEn?: string;
}

const {
  title,
  description,
  image,
  footerCta,
  canonicalUrl,
  heroImage,
  heroImageMobile,
  translationSlugEs,
  translationSlugEn
} = Astro.props;

const pageTitle = title ? `${title} ${Separator} ${SiteName}` : SiteName;
const pageDescription = description || defaultDescription || "";
const pageImage = image || "";
const canonicalPath = canonicalUrl || Astro.url.pathname;
const fullCanonicalUrl = new URL(canonicalPath, siteConfig.siteUrl).toString();

// Determine current language for <html> tag and for selecting header content
const currentAstroPath = Astro.url.pathname;
let determinedLang = defaultLang || 'en'; // Default to English (or configured default)
if (currentAstroPath === '/es' || currentAstroPath.startsWith('/es/')) {
  determinedLang = 'es';
} else if (currentAstroPath === '/en' || currentAstroPath.startsWith('/en/')) {
  determinedLang = 'en';
}
// If currentAstroPath is just '/', it will use defaultLang.

console.log("[Layout] Astro.url.pathname:", currentAstroPath);
console.log("[Layout] Determined language:", determinedLang);

const headerDataForCurrentLang = determinedLang === 'es' ? headerContentEs : headerContentEn;

// Prepare data for the Footer component
const siteConfigForFooter = { companyName: siteConfig.companyName };
const baseFooterContentFromData = determinedLang === 'es' 
  ? footerContentEs(siteConfigForFooter) 
  : footerContentEn(siteConfigForFooter);

console.log("[Layout] Header data selected (logoLink):", headerDataForCurrentLang.logoLink);
console.log("[Layout] Footer data selected (logoLink):", baseFooterContentFromData.logoLink);

// Separate the default CTA and the rest of the base content
const { defaultFooterCta: baseDefaultCtaFromData, ...baseContentWithoutDefaultCta } = baseFooterContentFromData;

// Determine the final cta, merging if page provides one
let finalFooterCta;
if (Astro.props.footerCta) {
  finalFooterCta = { ...baseDefaultCtaFromData, ...Astro.props.footerCta };
} else {
  finalFooterCta = baseDefaultCtaFromData;
}

// Assemble the final content object for the Footer component, ensuring it matches FooterContent type
const actualFooterContentForComponent: FooterContent = {
  ...baseContentWithoutDefaultCta, // This has logoLink, tagline, sections, legalMenu, copyrightText
  footerCta: finalFooterCta        // This is the merged/final CTA
};

// --- CRITICAL FOR FIXED HEADER ---
// Calculate or set a fixed header height. 
// This value needs to match the actual height of your rendered <header> element 
// including its top margin (which is mt-4, typically 1rem or 16px).
// Example: If header inner content (py-4) is ~56px, plus rounded-lg, border,
// and the mt-4 (16px) on its container.
// A common height for such headers is between 4rem (64px) and 6.5rem (104px).
// Inspect your header's height in dev tools to get an accurate value.
const fixedHeaderHeight = "0rem"; // ADJUST THIS VALUE CAREFULLY!
// --- END CRITICAL ---
---

<!doctype html>
<html lang={determinedLang}> {/* DYNAMIC LANG ATTRIBUTE */}
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="canonical" href={fullCanonicalUrl} />
    <meta name="generator" content={Astro.generator} />

    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <meta name="robots" content="index, follow" />

    {heroImage && (
      <link
        rel="preload"
        as="image"
        href={heroImage.src}
        imagesrcset={
          heroImageMobile
            ? `${heroImageMobile.src} 800w, ${heroImage.src} 1920w`
            : undefined
        }
        imagesizes="(max-width: 768px) 100vw, 100vw"
        fetchpriority="high"
      />
    )}

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Bruno+Ace+SC&family=Noto+Sans+KR:wght@100..900&display=swap"
      rel="stylesheet"
    />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={fullCanonicalUrl} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    {pageImage && (
      <meta
        property="og:image"
        content={new URL(pageImage, siteConfig.siteUrl).toString()}
      />
    )}

    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={fullCanonicalUrl} />
    <meta property="twitter:title" content={pageTitle} />
    <meta property="twitter:description" content={pageDescription} />
    {pageImage && (
      <meta
        property="twitter:image"
        content={new URL(pageImage, siteConfig.siteUrl).toString()}
      />
    )}
  </head>

  <body data-theme={theme} style={`padding-top: ${fixedHeaderHeight};`}> {/* ADDED PADDING-TOP HERE */}
    <Header
      content={headerDataForCurrentLang}
      translationSlugEs={translationSlugEs}
      translationSlugEn={translationSlugEn}
    />
    <slot /> {/* This is where your page content (e.g., homepage) goes */}
    <Footer content={actualFooterContentForComponent} />
    <ThemeSwitcher />
    <script src="/js/scroll.js" defer></script> {/* Ensure path is correct */}
  </body>
</html>