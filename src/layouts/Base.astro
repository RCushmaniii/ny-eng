---
/**
 * Base.astro - Fixed to support both centralized i18n AND custom hreflang/canonical
 */

import "../styles/global.css";
import Header from "@components/Header.astro";
import Footer from "@components/Footer.astro";
import { headerContent as headerContentEn } from "@data/header/en.ts";
import { headerContent as headerContentEs } from "@data/header/es.ts";
import { footerContentEn } from "@data/footer/en.ts";
import { footerContentEs } from "@data/footer/es.ts";
import { siteConfig } from "@data/config.ts";
import OrgSchema from "@components/seo/OrgSchema.astro";
import WebsiteSchema from "@components/seo/WebsiteSchema.astro";
import ProfessionalServiceSchema from "@components/seo/ProfessionalServiceSchema.astro";
import ChatLauncher from "@components/chat/ChatLauncher.astro";
import * as i18n from "../lib/i18n";
import { type TKey, type Locale } from "../lib/i18n.ts";

export interface Props {
  title: string;
  description: string;
  lang: "en" | "es";
  tkey?: TKey;
  ogImage?: { src: string; alt?: string; width?: number; height?: number };
  ogType?: "website" | "article";
  articlePublishedTime?: string;
  articleModifiedTime?: string;
  articleAuthor?: string;
  heroImage?: string | { src: string; width?: number; height?: number };
  heroImageMobile?: string | { src: string; width?: number; height?: number };
  hideCta?: boolean;
  hideNav?: boolean;
  hideLanguageSwitcher?: boolean;
  customHreflangs?: Array<{ lang: string; href: string }>;
  customCanonical?: string;
  transparentHeader?: boolean;
  noindex?: boolean;
}

const {
  title,
  description,
  lang,
  tkey,
  ogImage,
  ogType = "website",
  articlePublishedTime,
  articleModifiedTime,
  articleAuthor,
  heroImage,
  heroImageMobile,
  hideCta,
  hideNav,
  hideLanguageSwitcher,
  customHreflangs,
  customCanonical,
  transparentHeader = false,
  noindex = false,
} = Astro.props;

// Fail fast if required props are missing
if (!lang) {
  throw new Error(`[Base.astro] Missing required prop: lang="${lang}"`);
}

// If no customHreflangs provided, tkey is required
if (!customHreflangs && !tkey) {
  throw new Error(
    `[Base.astro] Either tkey or customHreflangs must be provided`
  );
}

// Site from astro.config.mjs. Remove trailing slash to safely concatenate.
const SITE = (Astro.site?.href ?? "https://www.nyenglishteacher.com").replace(
  /\/+$/,
  ""
);

// Normalize to trailing slash (config uses trailingSlash: "always")
const ensureSlash = (u: string) => (u.endsWith("/") ? u : u + "/");

// FIXED: Use custom canonical if provided, otherwise use i18n system
let canonicalUrl: string;
let alternates: Array<{ lang: Locale; href: string }>;
let xDefault: string;

if (customCanonical && customHreflangs) {
  // Use custom canonical and hreflang (for blog posts, pagination, etc.)
  canonicalUrl = ensureSlash(customCanonical);
  alternates = customHreflangs.map((alt) => ({
    lang: alt.lang as any, // Keep the original format (en-US, es-MX)
    href: ensureSlash(alt.href),
  }));
  xDefault = ensureSlash(
    customHreflangs.find((alt) => alt.lang.startsWith("en"))?.href ||
      canonicalUrl
  );
} else {
  // Use centralized i18n system (for static pages)
  if (!tkey) {
    throw new Error(
      `[Base.astro] tkey is required when not using customHreflangs`
    );
  }

  const tkeyNonNull = tkey; // TypeScript type narrowing
  const relPath = i18n.routeFor[lang]?.[tkeyNonNull];
  if (!relPath) {
    throw new Error(
      `[Base.astro] routeFor missing for lang=${lang} tkey=${tkeyNonNull}`
    );
  }
  canonicalUrl = SITE + ensureSlash(relPath);

  // Build alternate links from route map
  alternates = Object.keys(i18n.routeFor)
    .map((l) => ({
      lang: l as Locale,
      href: SITE + ensureSlash(i18n.routeFor[l as Locale]?.[tkeyNonNull] ?? ""),
    }))
    .filter((a) => a.href.endsWith("/")); // drop undefined routes

  // x-default: point to your primary language
  xDefault =
    SITE +
    ensureSlash(i18n.routeFor[i18n.defaultLocale]?.[tkeyNonNull] ?? "/en/");
}

const ogTitle = title;
const ogDesc = description;

// Ensure OG image is absolute URL for proper social sharing
// Handle both string paths and Astro image objects
let ogImgPath: string;
if (ogImage?.src) {
  // If it's an Astro image object with .src property, extract the path
  const srcValue =
    typeof ogImage.src === "string" ? ogImage.src : (ogImage.src as any)?.src;
  ogImgPath = srcValue ?? "/images/logos/new-york-english-sq-og.jpg";
} else {
  ogImgPath = "/images/logos/new-york-english-sq-og.jpg";
}

// Convert relative paths to absolute URLs, but avoid processing Astro's @fs paths
const ogImg = ogImgPath.startsWith("http")
  ? ogImgPath
  : ogImgPath.startsWith("/@fs") ||
      ogImgPath.includes("C:/") ||
      ogImgPath.includes("C:\\")
    ? SITE + "/images/logos/new-york-english-sq-og.jpg" // Fallback for dev paths
    : SITE + (ogImgPath.startsWith("/") ? ogImgPath : "/" + ogImgPath);

const ogAlt =
  ogImage?.alt ??
  (lang === "es"
    ? "New York English Teacher (ES)"
    : "New York English Teacher (EN)");

// OG image dimensions — square (800×800) renders correctly in WhatsApp thumbnails
const ogImgWidth = ogImage?.width ?? 800;
const ogImgHeight = ogImage?.height ?? 800;

// Convert dates to ISO 8601 format with timezone (Mexico City: UTC-6)
// Using timezone-aware format prevents date confusion across regions
const formatToISO8601WithTimezone = (
  dateStr: string | undefined
): string | undefined => {
  if (!dateStr) return undefined;
  try {
    const date = new Date(dateStr);
    // Format as YYYY-MM-DDTHH:mm:ss-06:00 (Mexico City timezone)
    const year = date.getFullYear();
    const month = String(date.getMonth() + 1).padStart(2, "0");
    const day = String(date.getDate()).padStart(2, "0");
    const hours = String(date.getHours()).padStart(2, "0");
    const minutes = String(date.getMinutes()).padStart(2, "0");
    const seconds = String(date.getSeconds()).padStart(2, "0");
    return `${year}-${month}-${day}T${hours}:${minutes}:${seconds}-06:00`;
  } catch {
    return undefined;
  }
};

const publishedTimeISO = formatToISO8601WithTimezone(articlePublishedTime);
const modifiedTimeISO = formatToISO8601WithTimezone(articleModifiedTime);

// Additional variables for compatibility
const localeCode = i18n.getLocaleCode(lang);

// Header/Footer content
const headerData = lang === "en" ? headerContentEn : headerContentEs;
const rawFooterData =
  lang === "en" ? footerContentEn(siteConfig) : footerContentEs(siteConfig);

// Align prop name with Footer.astro expectation
const footerData = {
  ...rawFooterData,
  footerCta: {
    ...rawFooterData.defaultFooterCta,
    hideCta: hideCta ?? false,
  },
};

// Slugs for language switcher using i18n system (fallback for custom pages)
let translationSlugEn = customHreflangs
  ? ensureSlash(
      customHreflangs
        .find((alt) => alt.lang.startsWith("en"))
        ?.href?.replace(SITE, "") || (tkey ? i18n.routeFor["en"][tkey] : "/en/")
    )
  : ensureSlash(tkey ? i18n.routeFor["en"][tkey] : "/en/");

let translationSlugEs = customHreflangs
  ? ensureSlash(
      customHreflangs
        .find((alt) => alt.lang.startsWith("es"))
        ?.href?.replace(SITE, "") || (tkey ? i18n.routeFor["es"][tkey] : "/es/")
    )
  : ensureSlash(tkey ? i18n.routeFor["es"][tkey] : "/es/");

// Prevent double language prefixes in URLs
if (translationSlugEn.includes("/en/blog/en/")) {
  translationSlugEn = translationSlugEn.replace("/en/blog/en/", "/en/blog/");
}
if (translationSlugEs.includes("/es/blog/es/")) {
  translationSlugEs = translationSlugEs.replace("/es/blog/es/", "/es/blog/");
}
---

<!doctype html>
<html lang={lang === "es" ? "es-MX" : "en-US"} data-theme="zeus">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Preload critical fonts for better LCP -->
    <link
      rel="preload"
      href="/fonts/noto-sans-kr-v36-latin-regular.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href="/fonts/noto-sans-v42-latin-600.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />

    <!-- Canonical -->
    <link rel="canonical" href={canonicalUrl} />

    <!-- Hreflang alternates -->
    {
      alternates.map((a) => (
        <link
          rel="alternate"
          hreflang={customHreflangs ? a.lang : i18n.getHreflangCode(a.lang)}
          href={a.href}
        />
      ))
    }
    <link rel="alternate" hreflang="x-default" href={xDefault} />

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    {
      ogType === "article" && publishedTimeISO && (
        <meta property="article:published_time" content={publishedTimeISO} />
      )
    }
    {
      ogType === "article" && modifiedTimeISO && (
        <meta property="article:modified_time" content={modifiedTimeISO} />
      )
    }
    {
      ogType === "article" && articleAuthor && (
        <meta property="article:author" content={articleAuthor} />
      )
    }
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={ogTitle} />
    <meta property="og:description" content={ogDesc} />
    <meta property="og:image" content={ogImg} />
    <meta property="og:image:alt" content={ogAlt} />
    <meta property="og:image:width" content={ogImgWidth.toString()} />
    <meta property="og:image:height" content={ogImgHeight.toString()} />
    <meta property="og:locale" content={localeCode} />
    {lang === "en" && <meta property="og:locale:alternate" content="es_MX" />}
    {lang === "es" && <meta property="og:locale:alternate" content="en_US" />}
    <meta property="og:site_name" content="New York English Teacher" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={ogTitle} />
    <meta name="twitter:description" content={ogDesc} />
    <meta name="twitter:image" content={ogImg} />
    <meta name="twitter:image:alt" content={ogAlt} />

    <!-- Self-hosted fonts CSS - loaded FIRST to avoid any processing -->
    <link rel="stylesheet" href="/fonts.css" />

    <!-- Theme color for browser UI -->
    <meta name="theme-color" content="#3557c1" />

    <!-- Icons & Sitemap -->
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="sitemap" href="/sitemap-index.xml" />

    <!-- Preload hero image if provided -->
    {
      heroImage && (
        <link
          rel="preload"
          as="image"
          href={typeof heroImage === "string" ? heroImage : heroImage.src}
          imagesrcset={
            heroImageMobile &&
            typeof heroImage !== "string" &&
            typeof heroImageMobile !== "string" &&
            heroImage?.src &&
            heroImageMobile?.src
              ? `${heroImageMobile.src} 800w, ${heroImage.src} 1920w`
              : undefined
          }
          imagesizes="(max-width: 768px) 100vw, 100vw"
          fetchpriority="high"
        />
      )
    }

    <!-- Robots and caching -->
    <meta
      name="robots"
      content={noindex
        ? "noindex,follow"
        : "index,follow,max-image-preview:large"}
    />
    <meta
      http-equiv="Cache-Control"
      content="public, max-age=3600, s-maxage=86400"
    />

    <!-- Preconnect / DNS Prefetch -->
    <link rel="preconnect" href="https://wa.link" crossorigin />
    <link rel="dns-prefetch" href="https://wa.link" />
    <link rel="preconnect" href="https://api.whatsapp.com" crossorigin />
    <link rel="dns-prefetch" href="https://api.whatsapp.com" />
    <link rel="preconnect" href="https://formspree.io" crossorigin />
    <link rel="dns-prefetch" href="https://formspree.io" />

    <!-- JSON-LD Schemas -->
    <OrgSchema />
    <WebsiteSchema />
    <ProfessionalServiceSchema />

    <!-- Additional head content -->
    <slot name="head" />
  </head>
  <body
    class="antialiased font-sans bg-white dark:bg-neutral-950 text-neutral-900 dark:text-neutral-100"
  >
    <!-- Skip to main content link -->
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-50 focus:px-4 focus:py-2 focus:bg-primary focus:text-white focus:rounded focus:shadow-lg"
      >Skip to content</a
    >

    <div id="page-wrapper" class="flex flex-col min-h-screen">
      {
        !hideNav && (
          <Header
            content={headerData}
            translationSlugEn={translationSlugEn}
            translationSlugEs={translationSlugEs}
            hideLanguageSwitcher={hideLanguageSwitcher}
            transparentOnLoad={transparentHeader}
          />
        )
      }

      <main id="main-content" role="main" class="flex-grow">
        <slot />
      </main>

      <Footer content={footerData} />
    </div>

    {tkey !== "chat" && <ChatLauncher lang={lang} />}

    <!-- Scripts -->
    <script is:inline src="/js/aos.js"></script>
    <script is:inline>
      const prefersReduced = window.matchMedia(
        "(prefers-reduced-motion: reduce)"
      ).matches;
      if (!prefersReduced && window.AOS) {
        window.AOS.init({
          duration: 800,
          easing: "ease-in-out",
          once: true,
        });
      }
    </script>
    <script src="/js/scroll.js" defer></script>

    <!-- Delegated event listener for tag pills -->
    <script type="module">
      document.addEventListener("click", (e) => {
        if (e.target.closest(".stop-prop")) e.stopPropagation();
      });
    </script>
  </body>
</html>

<style is:global>
  /* ========================================
     GLOBAL LAYOUT FIX
     ======================================== */

  html,
  body {
    margin: 0;
    padding: 0;
    width: 100%;
  }

  /* Ensure all children use border-box */
  *,
  *::before,
  *::after {
    box-sizing: border-box;
  }
</style>
