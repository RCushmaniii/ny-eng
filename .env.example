# Example environment configuration for ny-eng / titan-core
# Copy this file to `.env` and fill in real, private values locally.
# Never commit your real `.env` file.

# Core runtime
NODE_ENV=production

# Site configuration
SITE_URL=https://example.com
ASTRO_SITE=https://example.com

# Email / Resend
RESEND_API_KEY=your-resend-api-key-here
RESEND_FROM_EMAIL=your-from-email@example.com

# Google / Calendar (if used)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REFRESH_TOKEN=your-google-refresh-token
GOOGLE_CALENDAR_ID=your-calendar-id

# Database (if applicable)
DB_HOST=localhost
DB_PORT=3306
DB_USER=db_user
DB_PASSWORD=change-me
DB_NAME=ny_eng

# Sentry error monitoring (org: cushlabsai, project: ny-eng)
SENTRY_DSN=your-sentry-dsn-here
SENTRY_AUTH_TOKEN=your-sentry-auth-token-here
SENTRY_ORG=cushlabsai
SENTRY_PROJECT=ny-eng

# IndexNow (SEO instant-indexing protocol)
INDEXNOW_KEY=your-indexnow-key-here

# Any additional keys used in scripts or server routes should be
# added here with safe placeholder values.
