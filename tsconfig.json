{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@assets/*": ["src/assets/*"],
      "@components/*": ["src/components/*"],
      "@data/*": ["src/data/*"],
      "@layouts/*": ["src/layouts/*"],
      "@styles/*": ["src/styles/*"],
      "@utils/*": ["src/utils/*"],
      "~/*": ["src/*"],
      "~/types": ["src/types/index.ts"],
      "~/utils/*": ["src/utils/*"],
      "~/components/*": ["src/components/*"]
    },
    "types": ["astro/client"]
  },
  "include": ["src/**/*", "astro.config.*", "env.d.ts"],
  "exclude": ["dist", "**/*.disabled", "**/__sandbox/**"]
}
