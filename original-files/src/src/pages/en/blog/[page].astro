---
import { blogSetting } from '@data/config';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  const enPosts = posts.filter(post => post.id.startsWith('en/') && post.data.publish !== false);
  const postsPerPage = blogSetting.postsPerPage || 10;
  const totalPages = Math.ceil(enPosts.length / postsPerPage);
  return Array.from({ length: totalPages }, (_, i) => ({
    params: { page: (i + 1).toString() },
    props: { page: i + 1, totalPages },
  }));
}

const { page, totalPages } = Astro.props;
---

<h1>Blog Page {page} of {totalPages}</h1>
<!-- Render paginated posts here -->
