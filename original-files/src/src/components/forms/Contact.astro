---
// src/pages/contact.astro (or wherever this form component lives)
import Button from "@components/ui/Button.astro";
import Input from "@components/ui/form/Input.astro";
import Textarea from "@components/ui/form/Textarea.astro";
import Checkbox from "@components/ui/form/Checkbox.astro";

const formBackground = "light"; // Or "dark" depending on your design
---

<form
    id="contact-form"
    action="https://formspree.io/f/xldjandr"
    method="POST"
    class="space-y-6
    bg-white p-6 rounded-lg"
>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <Input
            label="Name"
            id="name"
            name="name"
            required
            minlength="2"
            background={formBackground}
        />
        <Input
            label="Email"
            type="email"
            id="email"
            name="email"
            required
            background={formBackground}
        />
    </div>

    <Input
        label="Phone"
        type="tel"
        id="phone"
        name="phone"
        background={formBackground}
        placeholder="Optional, include country code for WhatsApp"
    />

    <Textarea
        label="Message"
        id="message"
        name="message"
        required
        minlength="10"
        background={formBackground}
        placeholder="Tell me about your communication goals and needs"
    />

    <!-- Honeypot field for spam prevention -->
    <input type="text" name="_gotcha" style="display: none" />

    <!-- This _next field is now technically redundant if JS works,
         but can serve as a fallback if JS fails entirely before preventing default.
         The JS redirect will override this. -->
    <input
        type="hidden"
        name="_next"
        value="https://newyorkenglish.com/thank-you"
    />

    <Checkbox
        label="I agree to the Terms of Use and Privacy Policy"
        id="terms"
        name="terms"
        required
        background={formBackground}
    />

    <div class="mt-6">
        <!-- Consider adding a loading state indicator here later -->
        <Button type="submit">Submit</Button>
    </div>

    <!-- Optional: Area to display submission status/errors -->
    <div id="form-status" class="mt-4 text-center"></div>
</form>

<script>
    const form = document.getElementById(
        "contact-form",
    ) as HTMLFormElement | null;
    const statusDiv = document.getElementById("form-status"); // Get status div

    if (form && statusDiv) {
        form.addEventListener("submit", async (e) => {
            e.preventDefault(); // Prevent the default browser submission ALWAYS

            // --- 1. Get Form Elements & Perform Validation ---
            const name = form.querySelector("#name") as HTMLInputElement;
            const email = form.querySelector("#email") as HTMLInputElement;
            const message = form.querySelector(
                "#message",
            ) as HTMLTextAreaElement;
            const terms = form.querySelector("#terms") as HTMLInputElement;
            const submitButton = form.querySelector(
                "button[type='submit']",
            ) as HTMLButtonElement | null;

            statusDiv.textContent = ""; // Clear previous status messages
            statusDiv.className = "mt-4 text-center"; // Reset classes

            if (!name.value || name.value.length < 2) {
                statusDiv.textContent =
                    "Please enter a valid name (minimum 2 characters)";
                statusDiv.classList.add("text-red-600");
                name.focus(); // Focus the invalid field
                return; // Stop processing
            }

            if (
                !email.value ||
                !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email.value)
            ) {
                // Basic email format check
                statusDiv.textContent = "Please enter a valid email address";
                statusDiv.classList.add("text-red-600");
                email.focus();
                return;
            }

            if (!message.value || message.value.length < 10) {
                statusDiv.textContent =
                    "Please enter a message (minimum 10 characters)";
                statusDiv.classList.add("text-red-600");
                message.focus();
                return;
            }

            if (!terms.checked) {
                statusDiv.textContent =
                    "Please agree to the terms of use and privacy policy";
                statusDiv.classList.add("text-red-600");
                terms.focus();
                return;
            }

            // --- 2. Validation Passed - Prepare for Submission ---
            const formData = new FormData(form);
            const formAction = form.action; // Get endpoint from form's action attribute

            // Disable button and show loading state
            if (submitButton) {
                submitButton.disabled = true;
                submitButton.textContent = "Submitting...";
            }
            statusDiv.textContent = "Sending your message...";
            statusDiv.classList.add("text-blue-600");

            // --- 3. Submit Data using Fetch ---
            try {
                const response = await fetch(formAction, {
                    method: "POST",
                    body: formData,
                    headers: {
                        Accept: "application/json", // Formspree prefers this for AJAX
                    },
                });

                // --- 4. Handle Response ---
                if (response.ok) {
                    // SUCCESS! Redirect to the local thank you page
                    console.log(
                        "Form submitted successfully via fetch, redirecting...",
                    );
                    statusDiv.textContent =
                        "Form sent successfully! Redirecting...";
                    statusDiv.className = "mt-4 text-center text-green-600"; // Success styling
                    window.location.href = "/thank-you"; // Redirect to your relative thank-you page URL
                } else {
                    // Server returned an error (e.g., 4xx, 5xx)
                    console.error(
                        "Sorry about this. Form submission failed:",
                        response.status,
                        response.statusText,
                    );
                    const errorData = await response.json().catch(() => ({})); // Try to get error details
                    statusDiv.textContent = `Submission failed: ${errorData.error || "Please try again."}`;
                    statusDiv.className = "mt-4 text-center text-red-600"; // Error styling
                    // Re-enable button
                    if (submitButton) {
                        submitButton.disabled = false;
                        submitButton.textContent = "Submit";
                    }
                }
            } catch (error) {
                // Network error or other fetch-related issue
                console.error("Network error during form submission:", error);
                statusDiv.textContent =
                    "Submission failed due to a network error. Please check connection.";
                statusDiv.className = "mt-4 text-center text-red-600"; // Error styling
                // Re-enable button
                if (submitButton) {
                    submitButton.disabled = false;
                    submitButton.textContent = "Submit";
                }
            }
        });
    } else {
        if (!form) console.error("Form with id='contact-form' not found.");
        if (!statusDiv)
            console.error("Element with id='form-status' not found.");
    }
</script>
