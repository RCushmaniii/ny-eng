---
import Button from '@components/ui/Button.astro';
import Eyebrow from '@components/ui/Eyebrow.astro';
import { getPaddingClass, getBackgroundColor, getTextColor } from '@utils/styleUtils';
import type { PaddingSize, ThemeColor } from '@utils/styleUtils';
import { Image } from 'astro:assets';

// --- CHANGE 1: Add descriptionPoints to Content interface ---
interface Content {
    eyebrow?: string;
    headline: string;
    subheadline?: string;
    description?: string;
    descriptionPoints?: string[]; // <-- ADD THIS LINE
    image: {
        src: string | any;
        alt: string;
    };
    buttons?: {
        text: string;
        link: string;
        variant?: 'primary' | 'secondary' | 'ghostLight' | 'ghostDark';
        target?: string;
    }[];
}

export interface Props {
    content: Content;
    // Layout props
    imagePosition?: 'left' | 'right';
    background?: ThemeColor;
    paddingTop?: PaddingSize;
    paddingBottom?: PaddingSize;
    padding?: PaddingSize;
}

const {
    content,
    // Layout props
    imagePosition = 'right',
    background = 'base',
    paddingTop,
    paddingBottom,
    padding,
} = Astro.props;

// --- CHANGE 2: Destructure descriptionPoints ---
const { eyebrow, headline, subheadline, description, descriptionPoints, image, buttons = [] } = content; // <-- ADD descriptionPoints HERE

const paddingClass = getPaddingClass({ padding, paddingTop, paddingBottom });
const bgColor = getBackgroundColor(background);
const textColor = getTextColor(background);
---
<section class:list={["relative", bgColor, paddingClass]}>
    <div class="site-container px-4">
        <div class:list={[
            "grid gap-16 items-center",
            "md:grid-cols-2",
            imagePosition === 'left' ? 'md:grid-cols-[1fr_1fr]' : ''
        ]}>
            {imagePosition === 'left' && (
                <div class="relative aspect-[4/3] overflow-hidden rounded-[var(--border-radius-base)] border border-black">
                    {/* ... Image component ... */}
                    <Image
                        src={image.src}
                        alt={image.alt}
                        width={800}
                        height={600}
                        class="w-full h-full object-cover"
                        quality={80}
                        format="webp"
                     />
                </div>
            )}

            <div class:list={[textColor]}>
                {eyebrow && (
                    <Eyebrow
                        text={eyebrow}
                        background={background}
                    />
                )}
                <h2 class={`fade-in-up ${textColor}`}>{headline}</h2>
                {subheadline && <h3 class={`fade-in-up delay-1 mt-4 text-h5 ${textColor}`}>{subheadline}</h3>}

                {/* --- CHANGE 3: Keep original description rendering --- */}
                {description && <p class={`fade-in-up delay-2 mt-6 text-base opacity-90 ${textColor}`}>{description}</p>}

                {/* --- CHANGE 4: Add block to render descriptionPoints --- */}
                {descriptionPoints && descriptionPoints.length > 0 && (
                    <div class={`fade-in-up delay-3 mt-4 space-y-2 ${textColor}`}> {/* Apply text color and animation */}
                        {/* You can make this intro text dynamic via another prop if needed */}
                        <strong>Here’s what you can expect:</strong>
                        <ul class="list-disc list-inside space-y-1"> {/* Add list styling classes */}
                            {descriptionPoints.map((point: string) => (
                                <li>{point}</li> // Render each point as plain text within <li>
                            ))}
                        </ul>
                    </div>
                )}

                {buttons.length > 0 && (
                    <div class="flex flex-wrap gap-4 mt-8" data-aos="fade-up">
                        {/* Render buttons (Code was commented out in original, uncomment if needed) 
                         {buttons.map((button) => (
                            <Button
                                href={button.link}
                                target={button.target || '_self'}
                                variant={button.variant || 'primary'}
                            >
                                {button.text}
                             </Button>
                         ))}*/}
                    </div>
                )}
            </div>

            {imagePosition === 'right' && (
                 <div class="relative aspect-[4/3] overflow-hidden rounded-[var(--border-radius-base)] border border-black" data-aos="fade-up" data-aos-delay="100">
                    {/* ... Image component ... */}
                     <Image
                        src={image.src}
                        alt={image.alt}
                        width={800}
                        height={600}
                        class="w-full h-full object-cover"
                        quality={80}
                        format="webp"
                     />
                </div>
            )}
        </div>
    </div>
</section>