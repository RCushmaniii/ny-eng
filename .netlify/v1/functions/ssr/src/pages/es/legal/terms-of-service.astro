---
import Base from "@layouts/Base.astro";
import InnerHero from '@components/sections/InnerHero.astro';
import { getCollection } from "astro:content";

// Define language and tkey for i18n
const lang = 'es';
const tkey = 'legal/terms-of-service';

// Get the legal content
const legalData = await getCollection('legal');
const entry = legalData.find(item => item.slug === 'es/terms-of-service');

if (!entry) {
  throw new Error('Terms of service content not found');
}

const { Content } = await entry.render();

const heroContent = {
  title: entry.data.title,
  description: entry.data.seo?.description || "",
  overlayOpacity: 0.8
} as const;

const footerCta = {
  eyebrow: "",
  title: "Transforma Tu Inglés Profesional Hoy",
  description: "Reserva tu consulta gratuita para obtener la claridad, confianza e impacto que tu rol exige.",
  hideCta: true, // Hide the CTA for legal pages
  button: {
    text: "Reservar Mi Consulta Gratuita",
    link: "/es/book/"
  }
} as const;
---

<Base 
  lang="es"
  tkey={tkey}
  title={entry.data.seo?.title || entry.data.title}
  description={entry.data.seo?.description || ''}
>
  <InnerHero content={heroContent} />
  <article class="site-container--small mx-auto px-8 prose pb-base pt-16">
    <Content />
  </article>
</Base>
