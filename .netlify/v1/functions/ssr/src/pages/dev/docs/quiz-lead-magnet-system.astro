---
/**
 * Quiz Lead Magnet System Documentation - Proper Astro page with markdown import
 */
import MarkdownLayout from '@layouts/MarkdownLayout.astro';
import { marked } from 'marked';

// Import the QUIZ-LEAD-MAGNET-SYSTEM.md content
const quizContent = await import('../../../../docs/QUIZ-LEAD-MAGNET-SYSTEM.md?raw');
const markdownText = quizContent.default;

// Convert markdown to HTML
const htmlContent = marked(markdownText);

const frontmatter = {
  title: 'Quiz Lead Magnet System',
  description: 'Complete documentation for Communication Confidence Quiz lead magnet system',
  category: 'Marketing',
  icon: '🎯'
};
---

<MarkdownLayout frontmatter={frontmatter}>
  <Fragment set:html={htmlContent} />
</MarkdownLayout>
